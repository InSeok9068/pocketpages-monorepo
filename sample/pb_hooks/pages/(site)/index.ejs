<header>
  <h1>HTMX Realtime Demo</h1>
  <p>Simple chat and counter example with PocketPages, HTMX and SSE.</p>
</header>

<section class="grid">
  <article>
    <header>
      <strong>Chat Connection #1</strong>
    </header>
    <div hx-ext="pocketbase-sse">
      <div sse-swap="chat" hx-swap="beforeend"></div>
    </div>
  </article>

  <article>
    <header>
      <strong>Chat Connection #2</strong>
    </header>
    <div hx-ext="pocketbase-sse">
      <div sse-swap="chat" hx-swap="beforeend"></div>
    </div>
  </article>
</section>

<article>
  <form hx-post="/api/chat" hx-swap="none" hx-on::after-request="if(event.detail.successful) { this.reset(); this.querySelector('input[name=message]').focus() }">
    <fieldset role="group">
      <input type="text" name="message" placeholder="Type a message..." required />
      <button type="submit">Send</button>
    </fieldset>
  </form>
</article>

<article>
  <fieldset role="group">
    <input type="text" value="Counter" readonly />
    <button hx-get="/api/count"><%- include('count.ejs') %></button>
  </fieldset>
</article>
