{
  "name": "vscode-pocketpages",
  "displayName": "VSCode PocketPages",
  "description": "VSCode extension for PocketPages <script server> completion, hover, and diagnostics in .ejs files.",
  "version": "0.0.1",
  "private": true,
  "publisher": "dlstj-local",
  "license": "UNLICENSED",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:ejs",
    "workspaceContains:**/pocketpages-globals.d.ts"
  ],
  "main": "./packages/vscode-pocketpages/index.js",
  "extensionDependencies": [
    "vscode.typescript-language-features"
  ],
  "contributes": {
    "commands": [
      {
        "command": "pocketpagesServerScript.probeCurrentFile",
        "title": "PocketPages: Probe Current EJS File"
      },
      {
        "command": "pocketpagesServerScript.refreshDiagnostics",
        "title": "PocketPages: Refresh Server Script Diagnostics"
      },
      {
        "command": "pocketpagesServerScript.reloadCaches",
        "title": "PocketPages: Reload Caches"
      },
      {
        "command": "pocketpagesServerScript.allFileReferences",
        "title": "PocketPages: All File References"
      },
      {
        "command": "pocketpagesServerScript.copyDebugBundle",
        "title": "PocketPages: Copy Debug Bundle"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "pocketpagesServerScript.allFileReferences",
          "when": "resourceScheme == file && (resourceExtname == .ejs || resourceExtname == .js || resourceExtname == .cjs || resourceExtname == .mjs)",
          "group": "navigation@20"
        }
      ]
    },
    "typescriptServerPlugins": [
      {
        "name": "@dlstj-local/pocketpages-typescript-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ]
  },
  "scripts": {
    "test": "npm run sanity-check",
    "sanity-check": "node ./scripts/sanity-check.js",
    "sync:ts-plugin": "node ./scripts/sync-ts-plugin-package.js",
    "package:vsix": "node -e \"require('fs').mkdirSync('dist', { recursive: true })\" && vsce package --follow-symlinks --allow-missing-repository --out ./dist/vscode-pocketpages.vsix",
    "install:vscode-pocketpages": "npm run package:vsix && node ./scripts/install-vscode-pocketpages.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1"
  },
  "dependencies": {
    "@dlstj-local/pocketpages-typescript-plugin": "file:./packages/typescript-plugin",
    "typescript": "^5.9.3",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  }
}
