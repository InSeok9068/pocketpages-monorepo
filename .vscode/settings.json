{
  "files.autoSave": "off",
  "files.associations": {
    "tailwind.css": "tailwindcss"
  },
  "html.validate.styles": false,
  "html.validate.scripts": false,
  "color-highlight.enable": false,
  "js/ts.preferGoToSourceDefinition": true,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ejs": "+load.js",
    "pocketbase.exe": "pbw.exe",
    "README.md": "MEMO.md, DBSCHEMA.md",
    "AGENTS.md": "AGENTS*.md",
    "package.json": "package-lock.json, .prettier*, eslint.config.js, unocss.config.js, tailwind.css, .dockerignore, .gitignore, .gitleaks.toml, knip.js, .node-version"
  },
  // prettier-ignore
  "files.exclude": {
    ".docs/**": true,
    ".cache/**": true,
    ".githooks/**": true,
    // "tools/**": true,
    // "scripts/**": true,
    // 개발중인 서비스만 주석
    // "apps/sample/**": true,
  },
  // prettier-ignore
  "search.exclude": {
    ".docs/**": true,
    ".cache/**": true,
    ".githooks/**": true,
    "**/*.bundle.js": true,
    "**/pb_schema.json": true,
    "**/package-lock.json": true,
    // "tools/**": true,
    // "scripts/**": true,
    // 개발중인 서비스만 주석
    // "apps/sample/**": true,
  },
  "tailwindCSS.lint.cssConflict": "ignore",
  "tailwindCSS.lint.suggestCanonicalClasses": "ignore",
  "tailwindCSS.includeLanguages": {
    "ejs": "html"
  },
  "tailwindCSS.experimental.configFile": {
    "tailwind.css": ["apps/*/pb_hooks/pages/**/*.ejs", "apps/*/pb_hooks/pages/**/*.js"]
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "keyword.operator.datastar.prefix",
        "settings": {
          "foreground": "#FFD866"
        }
      }
    ]
  },
  "dbcode.connections": [
    {
      "connectionId": "of_b7icMLkbbZ2JPToSRq",
      "name": "booklog",
      "driver": "sqlite",
      "connectionType": "socket",
      "socket": "pocketpages-monorepo/apps/booklog/pb_data/data.db",
      "readOnly": false,
      "postConnectionSqlType": "inline",
      "driverOptions": {
        "extensions": []
      },
      "idleTimeout": 0,
      "introspection": {
        "progressive": false
      }
    }
  ]
}
