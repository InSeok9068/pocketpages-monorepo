{
  "html.validate.scripts": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ejs": "+load.js",
    "pocketbase.exe": "pbw.exe",
    "README.md": "MEMO.md, DBSCHEMA.md",
    "AGENTS.md": "AGENTS*.md",
    "package.json": "package-lock.json, .prettier*, tailwind.config.js, .dockerignore, .gitignore"
  },
  // prettier-ignore
  "files.exclude": {
    ".docs/**": true,
    "tools/**": true,
    "scripts/**": true,
    // 개발중인 서비스만 주석
    "apps/sample/**": true,
    // "apps/kjca/**": true,
    // "apps/booklog/**": true,
    "apps/photofolio/**": true,
  },
  // prettier-ignore
  "search.exclude": {
    ".docs/**": true,
    "tools/**": true,
    "scripts/**": true,
    "**/pb_schema.json": true,
    "package-lock.json": true,
    // 개발중인 서비스만 주석
    "apps/sample/**": true,
    // "apps/kjca/**": true,
    // "apps/booklog/**": true,
    "apps/photofolio/**": true,
  },
  "tailwindCSS.includeLanguages": {
    "ejs": "html"
  },
  "dbcode.connections": [
    {
      "connectionId": "of_b7icMLkbbZ2JPToSRq",
      "name": "booklog",
      "driver": "sqlite",
      "connectionType": "socket",
      "socket": "pocketpages-monorepo/apps/booklog/pb_data/data.db",
      "readOnly": false,
      "postConnectionSqlType": "inline",
      "driverOptions": {
        "extensions": []
      },
      "idleTimeout": 0,
      "introspection": {
        "progressive": false
      }
    }
  ]
}
