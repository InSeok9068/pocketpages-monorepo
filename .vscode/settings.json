{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ejs": "+load.js",
    "pocketbase.exe": "pbw.exe",
    "README.md": "MEMO.md, DBSCHEMA.md",
    "package.json": "package-lock.json, .prettier*, tailwind.config.js"
  },
  "files.exclude": {
    // 개발중인 서비스만 주석
    "apps/sample/**": true
    // "apps/kjca/**": true
    // "apps/booklog/**": true
  },
  "search.exclude": {
    ".docs/**": true,
    "tools/**": true,
    "**/pb_schema.json": true,
    "package-lock.json": true,
    "lint-pocketpages.js": true,
    "diag-pocketpages.js": true
  },
  "tailwindCSS.includeLanguages": {
    "ejs": "html"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
