<script server>
  meta('title', 'Anchor')
  meta('description', '흔들릴 때 감정과 생각을 잠깐 정리하는 작은 도구')
</script>

<script>
  document.addEventListener('alpine:init', function () {
    Alpine.data('anchorFlow', function () {
      return {
        step: 0,
        mood: '',
        concern: '',
        support: '',
        thought: '',
        control: '',
        release: '',
        copied: false,
        audioWanted: true,
        audioPlaying: false,
        audioContext: null,
        audioNodes: [],
        moods: [
          { id: 'anxiety', label: '불안', text: '앞일이 너무 크게 느껴질 때' },
          { id: 'overheat', label: '과열됨', text: '생각이 멈추지 않을 때' },
          { id: 'comparison', label: '비교됨', text: '다른 기준에 흔들릴 때' },
          { id: 'lost', label: '막막함', text: '방향이 흐려졌을 때' },
          { id: 'tired', label: '지침', text: '계속 버티는 느낌일 때' },
          { id: 'unknown', label: '잘 모르겠음', text: '정확히 고르기 어려울 때' },
        ],
        concerns: [
          { id: 'future', label: '미래 걱정', text: '아직 오지 않은 일 때문에 흔들림' },
          { id: 'work', label: '일과 개발', text: '방향, 구조, 운영에 대한 생각' },
          { id: 'money', label: '돈과 생존', text: '수익, 비용, 지속 가능성' },
          { id: 'worth', label: '성과와 내 가치', text: '일의 결과가 나를 평가하는 느낌' },
          { id: 'relation', label: '관계', text: '사람 사이에서 생긴 마음' },
          { id: 'body', label: '몸과 생활', text: '수면, 피로, 루틴의 흔들림' },
        ],
        supports: [
          { id: 'organize', label: '차분한 정리', text: '지금 상황을 덜 엉킨 말로 보기' },
          { id: 'comfort', label: '과하지 않은 위로', text: '괜찮다는 말보다 정확한 이해 받기' },
          { id: 'action', label: '작은 다음 행동', text: '오늘 할 수 있는 하나만 고르기' },
          { id: 'separate', label: '내려놓을 것 구분', text: '내 몫과 아닌 것을 나누기' },
        ],
        steps: ['느낌', '고민', '도움', '기록', '정리'],
        findLabel(items, id) {
          for (let index = 0; index < items.length; index += 1) {
            if (items[index].id === id) {
              return items[index].label
            }
          }

          return ''
        },
        get moodLabel() {
          return this.findLabel(this.moods, this.mood)
        },
        get concernLabel() {
          return this.findLabel(this.concerns, this.concern)
        },
        get supportLabel() {
          return this.findLabel(this.supports, this.support)
        },
        get progressWidth() {
          return String(((this.step + 1) / this.steps.length) * 100) + '%'
        },
        get canMakePrompt() {
          return this.mood && this.concern && this.support
        },
        get audioLabel() {
          return this.audioWanted ? '소리 끄기' : '소리 켜기'
        },
        get promptText() {
          const lines = [
            '아래 내용을 바탕으로 내 상태를 차분하게 정리해줘.',
            '내 상태를 단정하지 말고, 가능한 해석을 2-3가지로 나눠줘.',
            '과장된 위로나 일반론은 줄이고, 내가 통제할 수 있는 것과 내려놓아도 되는 것을 구분해줘.',
            '마지막에는 오늘 실제로 할 수 있는 작은 행동 1-2개만 제안해줘.',
            '',
            '[지금 상태]',
            '- 가장 가까운 감정: ' + (this.moodLabel || '아직 고르지 않음'),
            '- 가까운 고민: ' + (this.concernLabel || '아직 고르지 않음'),
            '- 원하는 도움: ' + (this.supportLabel || '아직 고르지 않음'),
            '',
            '[내가 적은 내용]',
            '- 지금 머릿속에서 가장 큰 문장: ' + (this.thought || '아직 적지 않음'),
            '- 지금 내가 통제할 수 있는 것: ' + (this.control || '아직 적지 않음'),
            '- 지금은 잠시 내려놓아도 되는 것: ' + (this.release || '아직 적지 않음'),
          ]

          return lines.join('\n')
        },
        selectMood(id) {
          this.mood = id
          this.startCalmAudio()
          this.goNext()
        },
        selectConcern(id) {
          this.concern = id
          this.goNext()
        },
        selectSupport(id) {
          this.support = id
          this.goNext()
        },
        goNext() {
          if (this.step < this.steps.length - 1) {
            this.step += 1
          }
        },
        goBack() {
          if (this.step > 0) {
            this.step -= 1
          }
        },
        restart() {
          this.step = 0
          this.mood = ''
          this.concern = ''
          this.support = ''
          this.thought = ''
          this.control = ''
          this.release = ''
          this.copied = false
        },
        toggleAudio() {
          if (this.audioWanted) {
            this.stopCalmAudio()
            this.audioWanted = false
            return
          }

          this.audioWanted = true
          this.startCalmAudio()
        },
        startCalmAudio() {
          const AudioContextClass = window.AudioContext || window.webkitAudioContext

          if (!this.audioWanted || this.audioPlaying || !AudioContextClass) {
            return
          }

          const context = this.audioContext || new AudioContextClass()
          const masterGain = context.createGain()
          const firstTone = context.createOscillator()
          const secondTone = context.createOscillator()
          const filter = context.createBiquadFilter()

          firstTone.type = 'sine'
          firstTone.frequency.value = 174
          secondTone.type = 'sine'
          secondTone.frequency.value = 220
          filter.type = 'lowpass'
          filter.frequency.value = 540
          masterGain.gain.value = 0.0001

          firstTone.connect(filter)
          secondTone.connect(filter)
          filter.connect(masterGain)
          masterGain.connect(context.destination)

          firstTone.start()
          secondTone.start()
          masterGain.gain.setTargetAtTime(0.035, context.currentTime, 1.8)

          this.audioContext = context
          this.audioNodes = [firstTone, secondTone, filter, masterGain]
          this.audioPlaying = true
        },
        stopCalmAudio() {
          if (!this.audioPlaying || this.audioNodes.length === 0) {
            return
          }

          const context = this.audioContext
          const firstTone = this.audioNodes[0]
          const secondTone = this.audioNodes[1]
          const masterGain = this.audioNodes[3]

          if (context && masterGain) {
            masterGain.gain.setTargetAtTime(0.0001, context.currentTime, 0.6)
          }

          window.setTimeout(function () {
            try {
              firstTone.stop()
              secondTone.stop()
            } catch (exception) {
              console.warn('Calm audio already stopped', exception)
            }
          }, 900)

          this.audioNodes = []
          this.audioPlaying = false
        },
        copyPrompt() {
          const component = this

          if (!navigator.clipboard) {
            return
          }

          navigator.clipboard.writeText(this.promptText).then(function () {
            component.copied = true

            window.setTimeout(function () {
              component.copied = false
            }, 1600)
          })
        },
        openChatGpt() {
          window.location.href = 'https://chatgpt.com/?temporary-chat=true'
        },
      }
    })
  })
</script>

<section
  x-data="anchorFlow"
  class="mx-auto flex min-h-[calc(100dvh-2.5rem)] max-w-md flex-col">
  <header class="shrink-0 pb-4">
    <div class="flex items-center justify-between gap-4">
      <button
        type="button"
        x-show="step > 0"
        x-cloak
        x-on:click="goBack()"
        class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border-none bg-white/70 text-[#5f6d63] shadow-[inset_0_0_0_1px_rgba(96,122,101,0.10)]"
        aria-label="이전으로">
        <span
          class="i-lucide-arrow-left h-4 w-4"
          aria-hidden="true"></span>
      </button>
      <div
        x-show="step === 0"
        class="h-9 w-9"
        aria-hidden="true"></div>
      <button
        type="button"
        x-on:click="toggleAudio()"
        class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border-none bg-white/70 text-[#5f6d63] shadow-[inset_0_0_0_1px_rgba(96,122,101,0.10)]"
        x-bind:aria-label="audioLabel">
        <span
          class="h-4 w-4"
          x-bind:class="audioWanted ? 'i-lucide-volume-2' : 'i-lucide-volume-x'"
          aria-hidden="true"></span>
      </button>
    </div>

    <div class="mt-4">
      <div class="h-1 overflow-hidden rounded-full bg-[#dfe5dc]">
        <div
          class="h-full rounded-full bg-[#6d8772] transition-all duration-300"
          x-bind:style="'width: ' + progressWidth"></div>
      </div>
      <div class="mt-2.5 flex items-center justify-between text-xs font-medium text-[#718075]">
        <span x-text="steps[step]"></span>
        <span x-text="String(step + 1) + ' / ' + String(steps.length)"></span>
      </div>
    </div>
  </header>

  <div class="flex flex-1 flex-col justify-center">
    <section
      x-show="step === 0"
      x-transition.opacity
      class="space-y-4">
      <div class="space-y-1.5">
        <h1 class="text-[1.35rem] font-medium leading-[1.33] text-[#202720]">지금 어떤 감정이 가장 가까운가요?</h1>
        <p class="text-sm leading-5 text-[#667067]">정확히 맞히려 하지 말고, 지금 손이 가는 것 하나만 고릅니다.</p>
      </div>

      <div class="grid gap-2">
        <template
          x-for="item in moods"
          :key="item.id">
          <button
            type="button"
            x-on:click="selectMood(item.id)"
            class="min-h-[3.85rem] rounded-lg border-none bg-white/78 px-4 py-3 text-left shadow-[inset_0_0_0_1px_rgba(96,122,101,0.10)] transition active:scale-[0.995]"
            x-bind:class="mood === item.id ? 'bg-[#607a65] text-white shadow-none' : 'text-[#253028]'">
            <span
              class="block text-[15px] font-semibold"
              x-text="item.label"></span>
            <span
              class="mt-0.5 block text-[13px] leading-5"
            x-bind:class="mood === item.id ? 'text-[#edf4ee]' : 'text-[#68736b]'"
              x-text="item.text"></span>
          </button>
        </template>
      </div>
    </section>

    <section
      x-show="step === 1"
      x-transition.opacity
      class="space-y-4">
      <div class="space-y-1.5">
        <p class="text-[13px] font-medium text-[#718075]">선택한 느낌: <span x-text="moodLabel"></span></p>
        <h2 class="text-[1.35rem] font-medium leading-[1.33] text-[#202720]">어디에서 온 느낌에 가까운가요?</h2>
      </div>

      <div class="grid gap-2">
        <template
          x-for="item in concerns"
          :key="item.id">
          <button
            type="button"
            x-on:click="selectConcern(item.id)"
            class="min-h-[3.85rem] rounded-lg border-none bg-white/78 px-4 py-3 text-left shadow-[inset_0_0_0_1px_rgba(96,122,101,0.10)] transition active:scale-[0.995]"
            x-bind:class="concern === item.id ? 'bg-[#607a65] text-white shadow-none' : 'text-[#253028]'">
            <span
              class="block text-[15px] font-semibold"
              x-text="item.label"></span>
            <span
              class="mt-0.5 block text-[13px] leading-5"
              x-bind:class="concern === item.id ? 'text-[#edf4ee]' : 'text-[#68736b]'"
              x-text="item.text"></span>
          </button>
        </template>
      </div>
    </section>

    <section
      x-show="step === 2"
      x-transition.opacity
      class="space-y-4">
      <div class="space-y-1.5">
        <p class="text-[13px] font-medium text-[#718075]"><span x-text="moodLabel"></span> · <span x-text="concernLabel"></span></p>
        <h2 class="text-[1.35rem] font-medium leading-[1.33] text-[#202720]">지금 어떤 도움이 필요할까요?</h2>
      </div>

      <div class="grid gap-2">
        <template
          x-for="item in supports"
          :key="item.id">
          <button
            type="button"
            x-on:click="selectSupport(item.id)"
            class="min-h-[3.85rem] rounded-lg border-none bg-white/78 px-4 py-3 text-left shadow-[inset_0_0_0_1px_rgba(96,122,101,0.10)] transition active:scale-[0.995]"
            x-bind:class="support === item.id ? 'bg-[#607a65] text-white shadow-none' : 'text-[#253028]'">
            <span
              class="block text-[15px] font-semibold"
              x-text="item.label"></span>
            <span
              class="mt-0.5 block text-[13px] leading-5"
              x-bind:class="support === item.id ? 'text-[#edf4ee]' : 'text-[#68736b]'"
              x-text="item.text"></span>
          </button>
        </template>
      </div>
    </section>

    <section
      x-show="step === 3"
      x-transition.opacity
      class="space-y-4">
      <div class="space-y-1.5">
        <p class="text-[13px] font-medium text-[#718075]"><span x-text="moodLabel"></span> · <span x-text="concernLabel"></span> · <span x-text="supportLabel"></span></p>
        <h2 class="text-[1.35rem] font-medium leading-[1.33] text-[#202720]">짧게만 적어봅니다.</h2>
        <p class="text-sm leading-5 text-[#667067]">빈칸이 있어도 됩니다. 지금 잡히는 문장만 남깁니다.</p>
      </div>

      <div class="space-y-2.5">
        <label class="block">
          <span class="text-[13px] font-medium text-[#526157]">머릿속에서 가장 큰 문장</span>
          <textarea
            x-model="thought"
            rows="2"
            class="mt-1.5 box-border w-full resize-none rounded-lg border border-[#dfe5dc] bg-white/82 px-3.5 py-2.5 text-[15px] leading-6 text-[#253028] shadow-[0_1px_2px_rgba(37,48,40,0.05)] outline-none transition placeholder:text-[#9aa59d] focus:border-[#607a65]"
            placeholder="예: 지금 방향을 잘못 잡으면 나중에 크게 후회할 것 같다."></textarea>
        </label>

        <label class="block">
          <span class="text-[13px] font-medium text-[#526157]">내가 통제할 수 있는 것</span>
          <textarea
            x-model="control"
            rows="2"
            class="mt-1.5 box-border w-full resize-none rounded-lg border border-[#dfe5dc] bg-white/82 px-3.5 py-2.5 text-[15px] leading-6 text-[#253028] shadow-[0_1px_2px_rgba(37,48,40,0.05)] outline-none transition placeholder:text-[#9aa59d] focus:border-[#607a65]"
            placeholder="예: 오늘 할 일 하나를 정하고 비교되는 입력을 줄이는 것."></textarea>
        </label>

        <label class="block">
          <span class="text-[13px] font-medium text-[#526157]">잠시 내려놓아도 되는 것</span>
          <textarea
            x-model="release"
            rows="2"
            class="mt-1.5 box-border w-full resize-none rounded-lg border border-[#dfe5dc] bg-white/82 px-3.5 py-2.5 text-[15px] leading-6 text-[#253028] shadow-[0_1px_2px_rgba(37,48,40,0.05)] outline-none transition placeholder:text-[#9aa59d] focus:border-[#607a65]"
            placeholder="예: 오늘 모든 방향을 확정해야 한다는 압박."></textarea>
        </label>
      </div>

      <button
        type="button"
        x-on:click="goNext()"
        class="inline-flex min-h-12 w-full items-center justify-center rounded-full border border-[#607a65] bg-[#607a65] px-5 py-2.5 text-[15px] font-medium text-white shadow-[0_8px_20px_rgba(72,96,77,0.16)]">
        정리된 문장 보기
      </button>
    </section>

    <section
      x-show="step === 4"
      x-transition.opacity
      class="space-y-4">
      <div class="space-y-1.5">
        <h2 class="text-[1.35rem] font-medium leading-[1.33] text-[#202720]">이대로 AI에게 넘길 수 있습니다.</h2>
        <p class="text-sm leading-5 text-[#667067]">복사한 뒤 ChatGPT에 붙여넣으면 지금 상태를 처음부터 설명하지 않아도 됩니다.</p>
      </div>

      <pre
        class="max-h-[42dvh] overflow-auto whitespace-pre-wrap rounded-lg border border-[#dfe5dc] bg-white/82 p-3.5 text-[13px] leading-5 text-[#526157] shadow-[0_1px_2px_rgba(37,48,40,0.05)]"
        x-text="promptText"></pre>

      <div class="grid gap-2">
        <button
          type="button"
          x-on:click="copyPrompt()"
          x-bind:disabled="!canMakePrompt"
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-[#607a65] bg-[#607a65] px-5 py-2.5 text-[15px] font-medium text-white shadow-[0_8px_20px_rgba(72,96,77,0.16)] disabled:border-[#dfe5dc] disabled:bg-[#dfe5dc] disabled:text-[#8a968e]">
          <span
            class="i-lucide-copy h-5 w-5"
            aria-hidden="true"></span>
          <span x-text="copied ? '복사됨' : '복사하기'"></span>
        </button>

        <button
          type="button"
          x-on:click="openChatGpt()"
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-[#dfe5dc] bg-white/82 px-5 py-2.5 text-[15px] font-medium text-[#526157] shadow-[0_1px_2px_rgba(37,48,40,0.05)]">
          <span
            class="i-lucide-message-circle h-5 w-5"
            aria-hidden="true"></span>
          <span>ChatGPT 열기</span>
        </button>
      </div>

      <div class="grid grid-cols-3 gap-2 pt-2">
        <button
          type="button"
          class="rounded-lg border border-[#dfe5dc] bg-white/82 px-3 py-2.5 text-[13px] font-medium text-[#526157] shadow-[0_1px_2px_rgba(37,48,40,0.05)]">
          일기
        </button>
        <button
          type="button"
          class="rounded-lg border border-[#dfe5dc] bg-white/82 px-3 py-2.5 text-[13px] font-medium text-[#526157] shadow-[0_1px_2px_rgba(37,48,40,0.05)]">
          문장
        </button>
        <button
          type="button"
          x-on:click="restart()"
          class="rounded-lg border border-[#dfe5dc] bg-white/82 px-3 py-2.5 text-[13px] font-medium text-[#526157] shadow-[0_1px_2px_rgba(37,48,40,0.05)]">
          처음으로
        </button>
      </div>
    </section>
  </div>
</section>
