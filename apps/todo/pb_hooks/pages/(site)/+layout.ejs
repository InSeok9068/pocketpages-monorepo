<% const isProduction = String(env('APP_ENV') || 'development').trim() === 'production' %>
<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1" />
    <title><%= meta('title') %></title>
    <meta
      name="description"
      content="<%= meta('description') %>" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="<%= asset('/assets/favicon.svg') %>" />
    <link
      rel="apple-touch-icon"
      href="<%= asset('/assets/icon-192.png') %>" />
    <link
      rel="manifest"
      href="<%= asset('/assets/manifest.webmanifest') %>" />
    <meta
      name="theme-color"
      content="#f8fafc" />
    <meta
      name="mobile-web-app-capable"
      content="yes" />
    <meta
      name="apple-mobile-web-app-capable"
      content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="default" />
    <meta
      name="apple-mobile-web-app-title"
      content="TODO" />
    <link
      rel="stylesheet"
      href="<%= asset('/assets/style.css') %>" />
    <%- include('unocss-head.ejs', { isProduction }) %>
    <script src="<%= asset('/assets/vendor/htmx-2.0.10.min.js') %>"></script>
    <script src="<%= asset('/assets/vendor/pocketbase-htmx-ext-sse-0.0.3.js') %>"></script>
    <script
      defer
      src="<%= asset('/assets/vendor/alpine-3.15.12-cdn.min.js') %>"></script>
    <%- slots.head %>
  </head>

  <body
    un-cloak
    class="min-h-screen bg-slate-50 text-slate-950 antialiased">
    <% if (request.auth) { %><%- include('app-nav.ejs') %><% } %>
    <main class="mx-auto w-full max-w-6xl px-4 py-6 pb-24 md:pb-8"><%- slots.body || slot %></main>
    <% if (request.auth) { %>
    <div
      id="notification-realtime"
      class="hidden"
      hx-ext="pocketbase-sse"
      sse-swap="notifications/*"
      hx-swap="none"
      aria-hidden="true"></div>
    <div
      id="notification-realtime-toast"
      class="pointer-events-none fixed right-4 bottom-20 z-50 hidden max-w-sm rounded-xl bg-slate-950 px-4 py-3 text-sm font-bold text-white shadow-xl md:bottom-6"
      role="status"
      aria-live="polite"></div>
    <script src="<%= asset('/assets/notification-realtime.js') %>"></script>
    <% } %>
  </body>
</html>
