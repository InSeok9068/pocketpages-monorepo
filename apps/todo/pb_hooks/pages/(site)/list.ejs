<script server>
  const { dateutil } = require('@pocketpages/utils')
  const todoData = resolve('todo-data')
  meta('title', '업무 검색 · TODO')
  meta('description', '조건별 업무 검색')
  if (!request.auth) {
    dbg('todo/list:redirect', { status: 303, redirectTo: '/sign-in' })
    redirect('/sign-in', { status: 303 })
    return
  }
  const userId = String(request.auth.get('id') || '')
  const query = {
    keyword: String(request.url.query.keyword || '').trim(),
    developer: String(request.url.query.developer || '').trim(),
    state: String(request.url.query.state || '').trim(),
    done: String(request.url.query.done || '').trim(),
    from: String(request.url.query.from || '').trim(),
    to: String(request.url.query.to || '').trim(),
  }
  const developers = todoData.listDevelopers(userId)
  const stateOptions = todoData.listWorkStates()
  /** @type {{keyword: string, developerId: string, state: string, sort: string, limit: number, done?: boolean, from?: string, to?: string}} */
  const filters = { keyword: query.keyword, developerId: query.developer, state: query.state, sort: '-updated', limit: 500 }
  if (query.done === 'true') filters.done = true
  if (query.done === 'false') filters.done = false
  if (query.from) filters.from = dateutil.startOfDay(query.from).toISOString()
  if (query.to) filters.to = dateutil.endOfDay(query.to).toISOString()
  const workCards = todoData.listWorkCards(userId, filters)
  dbg('todo/list:response', { userId, workCount: workCards.length })
</script>
<header class="mb-6">
  <p class="text-sm font-bold text-blue-600">SEARCH</p>
  <h1 class="mt-1 text-3xl font-black tracking-tight">업무 검색</h1>
</header>
<form
  method="get"
  action="/list"
  class="mb-6 grid gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm md:grid-cols-3">
  <input
    name="keyword"
    value="<%= query.keyword %>"
    placeholder="제목 또는 내용 검색"
    class="h-10 rounded-lg px-3 md:col-span-2" />
  <select
    name="developer"
    class="h-10 rounded-lg px-3">
    <option value="">담당자 전체</option>
    <option
      value="__unassigned__"
      <%= query.developer === '__unassigned__' ? 'selected' : '' %>>
      미배정
    </option>
    <% for (let index = 0; index < developers.length; index += 1) { %>
    <option
      value="<%= developers[index].id %>"
      <%= query.developer === developers[index].id ? 'selected' : '' %>>
      <%= developers[index].name %>
    </option>
    <% } %>
  </select>
  <select
    name="state"
    class="h-10 rounded-lg px-3">
    <option value="">상태 전체</option>
    <% for (let index = 0; index < stateOptions.length; index += 1) { %>
    <option
      value="<%= stateOptions[index].value %>"
      <%= query.state === stateOptions[index].value ? 'selected' : '' %>>
      <%= stateOptions[index].label %>
    </option>
    <% } %>
  </select>
  <select
    name="done"
    class="h-10 rounded-lg px-3">
    <option value="">완료 여부 전체</option>
    <option
      value="false"
      <%= query.done === 'false' ? 'selected' : '' %>>
      미완료
    </option>
    <option
      value="true"
      <%= query.done === 'true' ? 'selected' : '' %>>
      완료
    </option>
  </select>
  <div class="grid grid-cols-2 gap-2">
    <input
      type="date"
      name="from"
      value="<%= query.from %>"
      class="h-10 min-w-0 rounded-lg px-2" /><input
      type="date"
      name="to"
      value="<%= query.to %>"
      class="h-10 min-w-0 rounded-lg px-2" />
  </div>
  <div class="flex gap-2 md:col-span-3">
    <button class="inline-flex h-10 items-center gap-2 rounded-lg border-0 bg-slate-900 px-4 text-sm font-bold text-white"><span class="i-lucide-search h-4 w-4"></span>검색</button
    ><a
      href="/list"
      class="ui-button-secondary inline-flex h-10 items-center rounded-lg px-4 text-sm font-bold text-slate-600 no-underline"
      >초기화</a
    >
  </div>
</form>
<p class="mb-3 text-sm font-bold text-slate-600">검색 결과 <%= workCards.length %>개</p>
<div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
  <div class="overflow-x-auto">
    <table class="min-w-full text-left text-sm">
      <thead class="bg-slate-50 text-xs text-slate-500">
        <tr>
          <th class="px-4 py-3">제목</th>
          <th class="px-4 py-3">상태</th>
          <th class="px-4 py-3">담당자</th>
          <th class="px-4 py-3">마감일</th>
          <th class="px-4 py-3">수정</th>
        </tr>
      </thead>
      <tbody>
        <% for (let index = 0; index < workCards.length; index += 1) { const work = workCards[index] %>
        <tr class="border-t border-slate-100">
          <td class="px-4 py-3">
            <a
              href="/works/<%= encodeURIComponent(work.id) %>"
              class="font-bold text-slate-900 no-underline hover:text-blue-700"
              ><%= work.title %></a
            >
          </td>
          <td class="px-4 py-3"><span class="<%= work.stateBadgeClass %> rounded-full px-2 py-1 text-xs font-bold"><%= work.stateLabel %></span></td>
          <td class="px-4 py-3 text-slate-600"><%= work.developerName %></td>
          <td class="px-4 py-3 text-slate-600"><%= work.dueDateLabel || '-' %></td>
          <td class="px-4 py-3 text-slate-500"><%= work.createdLabel %></td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
