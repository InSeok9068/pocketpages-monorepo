<script server>
  const { dateutil } = require('@pocketpages/utils')
  const todoData = resolve('todo-data')

  meta('title', '업무 상세 · TODO')
  meta('description', '업무 내용을 확인하고 수정합니다.')

  if (!request.auth) {
    dbg('todo/works/detail:redirect', { status: 303, redirectTo: '/sign-in' })
    redirect('/sign-in', { status: 303 })
    return
  }

  const userId = String(request.auth.get('id') || '')
  const workId = String(params.workId || '')
  let work = null

  try {
    work = $app.findFirstRecordByFilter('works', 'id = {:workId} && user = {:userId}', { workId, userId })
  } catch (exception) {
    warn('todo/works/detail:not-found', { userId, workId, error: String(exception.message || exception) })
    dbg('todo/works/detail:redirect', { status: 303, redirectTo: '/', message: '업무를 찾지 못했습니다.' })
    redirect('/', { status: 303, message: '업무를 찾지 못했습니다.' })
    return
  }

  const developers = todoData.listDevelopers(userId)
  const stateOptions = todoData.listWorkStates()
  const redmineHost = String(env('REDMINE_HOST') || 'https://pms.kpcard.co.kr').replace(/\/$/, '')
  const redmineProjectId = String(env('REDMINE_PROJECT_ID') || 'palrago').trim()
  const redmineNewIssueUrl = redmineHost + '/projects/' + encodeURIComponent(redmineProjectId) + '/issues/new'
  const dueDate = String(work.get('dueDate') || '')
  const view = {
    id: String(work.get('id') || ''),
    title: String(work.get('title') || ''),
    content: String(work.get('content') || ''),
    done: !!work.get('done'),
    dueDate: dueDate ? dateutil.formatDate(dueDate, dateutil.FORMATS.DATE) : '',
    state: String(work.get('state') || 'wait'),
    developerId: String(work.get('developer') || ''),
    redmine: String(work.get('redmine') || ''),
    joplin: String(work.get('joplin') || ''),
    file: String(work.get('file') || ''),
    originalFileName: String(work.get('originalFileName') || ''),
  }
  const fileUrl = view.file
    ? '/api/files/works/' + encodeURIComponent(view.id) + '/' + encodeURIComponent(view.file)
    : ''
  /** @type {types.WorkStateOption} */
  let currentState = {
    value: view.state,
    label: view.state,
    iconClass: 'i-lucide-circle',
    badgeClass: 'bg-slate-100 text-slate-700',
  }
  for (let index = 0; index < stateOptions.length; index += 1) {
    if (stateOptions[index].value === view.state) currentState = stateOptions[index]
  }
  const scheduledIds = Array.isArray(work.get('scheduledNotifications')) ? work.get('scheduledNotifications') : []
  const scheduledNotifications = []
  for (let index = 0; index < scheduledIds.length; index += 1) {
    try {
      const scheduled = $app.findFirstRecordByFilter(
        'scheduledNotifications',
        'id = {:scheduledId} && user = {:userId}',
        { scheduledId: String(scheduledIds[index]), userId }
      )
      const scheduledTime = String(scheduled.get('time') || '')
      scheduledNotifications.push({
        id: String(scheduled.get('id') || ''),
        timeLabel: scheduledTime ? dateutil.formatDate(scheduledTime, dateutil.FORMATS.DATE_TIME_MINUTES) : '',
      })
    } catch (_exception) {
      continue
    }
  }

  dbg('todo/works/detail:response', { userId, workId })
</script>

