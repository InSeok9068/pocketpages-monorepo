<script src="<%= asset('/assets/vendor/tiptap.vendor.min.js') %>"></script>
<script src="<%= asset('/assets/work-detail-editor.js') %>"></script>
<script src="<%= asset('/assets/vendor/filepond-4.32.12.min.js') %>"></script>
<script>
  ;(function () {
    var input = document.getElementById('work-file')
    if (!input || !window.FilePond || window.FilePond.find(input)) return

    var maxFileSize = 50 * 1024 * 1024
    var pond = window.FilePond.create(input, {
      storeAsFile: true,
      allowMultiple: false,
      allowProcess: false,
      credits: false,
      labelIdle:
        '<span class="work-filepond-label"><span class="i-lucide-file-up work-filepond-label-icon"></span><strong>파일 선택</strong><small>누르거나 이곳에 놓아주세요</small></span>',
      labelFileWaitingForSize: '파일 확인 중',
      labelFileLoading: '파일 불러오는 중',
      labelFileLoadError: '파일을 불러오지 못했습니다',
      labelFileRemoveError: '파일을 제거하지 못했습니다',
      labelButtonRemoveItem: '선택한 파일 제거',
      labelTapToCancel: '눌러서 취소',
      labelTapToRetry: '눌러서 다시 시도',
      labelTapToUndo: '눌러서 되돌리기',
    })

    pond.on('addfile', function (error, item) {
      if (error || !item || !item.file) return
      if (item.file.size > maxFileSize) {
        pond.removeFile(item.id)
        window.alert('첨부파일은 최대 50MB까지 업로드할 수 있습니다.')
        return
      }
    })
  })()

  document.addEventListener('keydown', function (event) {
    if (!event.altKey || event.ctrlKey || event.metaKey || event.shiftKey || event.repeat || event.code !== 'KeyS') {
      return
    }

    const form = document.querySelector('#work-detail-form')
    if (!form) {
      return
    }

    event.preventDefault()
    form.requestSubmit()
  })
</script>
