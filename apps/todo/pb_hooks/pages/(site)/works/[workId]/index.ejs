<script server>
  const { dateutil } = require('@pocketpages/utils')
  const todoData = resolve('todo-data')

  meta('title', '업무 상세 · TODO')
  meta('description', '업무 내용을 확인하고 수정합니다.')

  if (!request.auth) {
    dbg('todo/works/detail:redirect', { status: 303, redirectTo: '/sign-in' })
    redirect('/sign-in', { status: 303 })
    return
  }

  const userId = String(request.auth.get('id') || '')
  const workId = String(params.workId || '')
  let work = null

  try {
    work = $app.findFirstRecordByFilter('works', 'id = {:workId} && user = {:userId}', { workId, userId })
  } catch (exception) {
    warn('todo/works/detail:not-found', { userId, workId, error: String(exception.message || exception) })
    dbg('todo/works/detail:redirect', { status: 303, redirectTo: '/', message: '업무를 찾지 못했습니다.' })
    redirect('/', { status: 303, message: '업무를 찾지 못했습니다.' })
    return
  }

  const developers = todoData.listDevelopers(userId)
  const stateOptions = todoData.listWorkStates()
  const redmineHost = String(env('REDMINE_HOST') || 'https://pms.kpcard.co.kr').replace(/\/$/, '')
  const redmineProjectId = String(env('REDMINE_PROJECT_ID') || 'palrago').trim()
  const redmineNewIssueUrl = redmineHost + '/projects/' + encodeURIComponent(redmineProjectId) + '/issues/new'
  const dueDate = String(work.get('dueDate') || '')
  const view = {
    id: String(work.get('id') || ''),
    title: String(work.get('title') || ''),
    content: String(work.get('content') || ''),
    done: !!work.get('done'),
    dueDate: dueDate ? dateutil.formatDate(dueDate, dateutil.FORMATS.DATE) : '',
    state: String(work.get('state') || 'wait'),
    developerId: String(work.get('developer') || ''),
    redmine: String(work.get('redmine') || ''),
    joplin: String(work.get('joplin') || ''),
    file: String(work.get('file') || ''),
    originalFileName: String(work.get('originalFileName') || ''),
  }
  /** @type {types.WorkStateOption} */
  let currentState = { value: view.state, label: view.state, iconClass: 'i-lucide-circle', badgeClass: 'bg-slate-100 text-slate-700' }
  for (let index = 0; index < stateOptions.length; index += 1) {
    if (stateOptions[index].value === view.state) currentState = stateOptions[index]
  }
  const scheduledIds = Array.isArray(work.get('scheduledNotifications')) ? work.get('scheduledNotifications') : []
  const scheduledNotifications = []
  for (let index = 0; index < scheduledIds.length; index += 1) {
    try {
      const scheduled = $app.findFirstRecordByFilter('scheduledNotifications', 'id = {:scheduledId} && user = {:userId}', { scheduledId: String(scheduledIds[index]), userId })
      const scheduledTime = String(scheduled.get('time') || '')
      scheduledNotifications.push({
        id: String(scheduled.get('id') || ''),
        title: String(scheduled.get('title') || ''),
        message: String(scheduled.get('message') || ''),
        timeLabel: scheduledTime ? dateutil.formatDate(scheduledTime, dateutil.FORMATS.DATE_TIME_MINUTES) : '',
      })
    } catch (_exception) {
      continue
    }
  }

  dbg('todo/works/detail:response', { userId, workId })
</script>

<header class="mb-5 flex flex-wrap items-center justify-between gap-4">
  <div class="flex min-w-0 items-center gap-3">
    <a
      href="/"
      class="ui-button-secondary inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-slate-600 no-underline"
      aria-label="오늘 화면으로 돌아가기"
      ><span class="i-lucide-arrow-left h-4 w-4"></span
    ></a>
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-2">
        <p class="text-xs font-black tracking-[0.16em] text-blue-600">WORK DETAIL</p>
        <span class="<%= currentState.badgeClass %> inline-flex items-center gap-1 rounded-full px-2 py-1 text-[11px] font-bold"
          ><span class="<%= currentState.iconClass %> h-3.5 w-3.5"></span><%= currentState.label %></span
        >
      </div>
      <h1 class="mt-1 truncate text-2xl font-black text-slate-950"><%= view.title %></h1>
    </div>
  </div>
  <button
    type="submit"
    form="work-detail-form"
    aria-keyshortcuts="Alt+S"
    title="저장 (Alt+S)"
    class="inline-flex h-11 items-center justify-center gap-2 rounded-xl border-0 bg-blue-600 px-5 text-sm font-black text-white shadow-sm hover:bg-blue-700">
    <span class="i-lucide-save h-4 w-4"></span>변경사항 저장<span class="ml-1 rounded-md bg-white/15 px-1.5 py-0.5 text-[10px] font-bold">Alt+S</span>
  </button>
</header>

<%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

<form
  id="work-detail-form"
  method="post"
  action="/xapi/works/update"
  enctype="multipart/form-data"
  class="grid items-start gap-5 lg:grid-cols-[minmax(0,1fr)_20rem]">
  <input
    type="hidden"
    name="work_id"
    value="<%= view.id %>" />
  <section class="min-w-0 space-y-5">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <label class="block text-sm font-bold text-slate-700"
        ><span class="mb-2 flex items-center gap-2"><span class="i-lucide-heading h-4 w-4 text-slate-400"></span>업무 제목</span>
        <input
          name="title"
          value="<%= view.title %>"
          required
          maxlength="100"
          class="h-12 w-full rounded-xl px-4 text-lg font-bold" />
      </label>
    </article>
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <label class="block text-sm font-bold text-slate-700"
        ><span class="mb-2 flex items-center justify-between gap-3"
          ><span class="inline-flex items-center gap-2"><span class="i-lucide-align-left h-4 w-4 text-slate-400"></span>업무 내용</span
          ><span class="text-[11px] font-normal text-slate-400">HTML 또는 일반 텍스트</span></span
        >
        <textarea
          name="content"
          rows="22"
          class="min-h-140 w-full resize-y rounded-xl p-4 font-mono text-sm leading-6"
          placeholder="업무 내용을 HTML 또는 텍스트로 작성하세요">
<%= view.content %></textarea>
      </label>
    </article>
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-start gap-3">
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-violet-50 text-violet-600"><span class="i-lucide-link-2 h-4 w-4"></span></span>
        <div>
          <h2 class="font-black">외부 연결</h2>
          <p class="mt-1 text-xs text-slate-500">관련 이슈나 문서 주소를 함께 보관합니다.</p>
        </div>
      </div>
      <div class="mt-4 grid gap-4 xl:grid-cols-2">
        <label class="block text-sm font-bold text-slate-700"
          >Redmine URL<input
            type="url"
            name="redmine"
            value="<%= view.redmine %>"
            class="mt-2 h-11 w-full rounded-xl px-3"
            placeholder="https://pms.kpcard.co.kr/issues/123"
        /></label>
        <label class="block text-sm font-bold text-slate-700"
          >Joplin 링크<input
            type="text"
            name="joplin"
            value="<%= view.joplin %>"
            class="mt-2 h-11 w-full rounded-xl px-3"
        /></label>
      </div>
      <div class="mt-4 flex flex-wrap items-center gap-2 border-t border-slate-100 pt-4">
        <% if (view.redmine) { %>
        <button
          type="button"
          hx-get="/xapi/redmine/<%= encodeURIComponent(view.id) %>"
          hx-target="#redmine-panel"
          hx-swap="outerHTML"
          onclick="document.getElementById('redmine-dialog').showModal()"
          class="inline-flex h-10 items-center gap-2 rounded-xl border-0 bg-blue-600 px-4 text-sm font-black text-white hover:bg-blue-700">
          <span class="i-lucide-git-pull-request-arrow h-4 w-4"></span>Redmine 상태 관리
        </button>
        <a
          href="<%= view.redmine %>"
          target="_blank"
          rel="noopener noreferrer"
          class="ui-button-secondary inline-flex h-10 items-center gap-2 rounded-xl px-4 text-sm font-bold text-slate-600 no-underline"
          ><span class="i-lucide-external-link h-4 w-4"></span>이슈 열기</a
        >
        <% } else { %>
        <button
          type="submit"
          form="redmine-create-form"
          onclick="return confirm('현재 저장된 업무 내용으로 Redmine 이슈를 생성할까요?')"
          class="inline-flex h-10 items-center gap-2 rounded-xl border-0 bg-blue-600 px-4 text-sm font-black text-white hover:bg-blue-700">
          <span class="i-lucide-square-plus h-4 w-4"></span>저장된 업무로 이슈 생성
        </button>
        <span class="text-xs text-slate-500">제목·내용·마감일을 가져와 생성하고 URL을 자동 연결합니다.</span>
        <% } %>
        <a
          href="<%= redmineNewIssueUrl %>"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-auto inline-flex h-9 items-center gap-1.5 px-2 text-xs font-bold text-slate-500 no-underline hover:text-blue-700"
          ><span class="i-lucide-square-arrow-out-up-right h-3.5 w-3.5"></span>Redmine에서 직접 생성</a
        >
      </div>
    </article>
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-start gap-3">
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-blue-50 text-blue-600"><span class="i-lucide-alarm-clock h-4 w-4"></span></span>
        <div>
          <h2 class="font-black">예약 알림</h2>
          <p class="mt-1 text-xs text-slate-500">업무를 다시 확인할 시간을 예약합니다.</p>
        </div>
      </div>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <label class="block">
          <span class="mb-1.5 block text-xs font-bold text-slate-500">알림 제목</span>
          <input
            form="scheduled-notification-create-form"
            name="title"
            value="<%= view.title %>"
            required
            maxlength="100"
            class="h-11 w-full rounded-xl px-3"
            placeholder="알림 제목" />
        </label>
        <label class="block">
          <span class="mb-1.5 block text-xs font-bold text-slate-500">알림 시각</span>
          <input
            form="scheduled-notification-create-form"
            type="datetime-local"
            name="time"
            required
            class="h-11 w-full rounded-xl px-3" />
        </label>
        <label class="block sm:col-span-2">
          <span class="mb-1.5 block text-xs font-bold text-slate-500">메시지</span>
          <input
            form="scheduled-notification-create-form"
            name="message"
            maxlength="500"
            class="h-11 w-full rounded-xl px-3"
            placeholder="알림에서 확인할 간단한 메모" />
        </label>
        <button
          type="submit"
          form="scheduled-notification-create-form"
          class="inline-flex h-10 items-center justify-center gap-2 rounded-xl border-0 bg-slate-900 px-4 text-sm font-bold text-white sm:w-fit">
          <span class="i-lucide-alarm-clock-plus h-4 w-4"></span>알림 추가
        </button>
      </div>
      <div class="mt-4 divide-y divide-slate-100">
        <% if (!scheduledNotifications.length) { %>
        <p class="rounded-xl bg-slate-50 px-4 py-5 text-center text-xs text-slate-400">등록된 예약 알림이 없습니다.</p>
        <% } %>
        <% for (let index = 0; index < scheduledNotifications.length; index += 1) { const item = scheduledNotifications[index] %>
        <div class="flex items-start gap-3 py-3">
          <span class="i-lucide-alarm-clock mt-0.5 h-4 w-4 text-blue-600"></span>
          <div class="min-w-0 flex-1">
            <p class="font-bold"><%= item.title %></p>
            <p class="mt-1 text-xs text-slate-500"><%= item.timeLabel %><%= item.message ? ' · ' + item.message : '' %></p>
          </div>
          <button
            type="submit"
            form="scheduled-notification-delete-form"
            name="scheduled_id"
            value="<%= item.id %>"
            class="inline-flex h-8 w-8 items-center justify-center rounded-lg border-0 bg-transparent text-slate-400 hover:bg-rose-50 hover:text-rose-600"
            aria-label="예약 알림 삭제">
            <span class="i-lucide-trash-2 h-4 w-4"></span>
          </button>
        </div>
        <% } %>
      </div>
    </article>
  </section>
  <aside class="space-y-4 lg:sticky lg:top-24">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="font-black">업무 속성</h2>
      <p class="mt-1 text-xs text-slate-500">진행 상태와 담당 일정을 관리합니다.</p>
      <div class="mt-4 grid gap-4">
        <label class="block text-sm font-bold text-slate-700"
          >상태<select
            name="state"
            class="mt-2 h-11 w-full rounded-xl px-3">
            <% for (let index = 0; index < stateOptions.length; index += 1) { %>
            <option
              value="<%= stateOptions[index].value %>"
              <%= view.state === stateOptions[index].value ? 'selected' : '' %>>
              <%= stateOptions[index].label %>
            </option>
            <% } %>
          </select></label
        >
        <label class="block text-sm font-bold text-slate-700"
          >담당자<select
            name="developer"
            class="mt-2 h-11 w-full rounded-xl px-3">
            <option value="">미배정</option>
            <% for (let index = 0; index < developers.length; index += 1) { %>
            <option
              value="<%= developers[index].id %>"
              <%= view.developerId === developers[index].id ? 'selected' : '' %>>
              <%= developers[index].name %>
            </option>
            <% } %>
          </select></label
        >
        <label class="block text-sm font-bold text-slate-700">
          마감일
          <input
            type="date"
            name="due_date"
            value="<%= view.dueDate %>"
            class="mt-2 h-11 w-full rounded-xl px-3" />
        </label>
        <label class="flex items-center gap-2 rounded-xl bg-slate-50 px-3 py-3 text-sm font-bold text-slate-700"
          ><input
            type="checkbox"
            name="done"
            value="true"
            <%= view.done ? 'checked' : '' %>
            class="h-4 w-4" />완료 처리</label
        >
      </div>
    </article>
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="font-black">첨부파일</h2>
      <% if (view.file) { %>
      <p class="mt-2 text-sm break-all text-slate-600"><%= view.originalFileName || view.file %></p>
      <label class="mt-3 flex items-center gap-2 text-sm font-bold text-rose-600"
        ><input
          type="checkbox"
          name="remove_file"
          value="true" />기존 파일 삭제</label
      ><% } %><label class="mt-3 block text-sm font-bold text-slate-700"
        >새 파일<input
          type="file"
          name="file"
          class="mt-2 block w-full text-sm text-slate-500"
      /></label>
    </article>
    <button
      type="submit"
      aria-keyshortcuts="Alt+S"
      title="저장 (Alt+S)"
      class="inline-flex h-12 w-full items-center justify-center gap-2 rounded-xl border-0 bg-blue-600 text-sm font-black text-white shadow-sm hover:bg-blue-700">
      <span class="i-lucide-save h-4 w-4"></span>변경사항 저장<span class="ml-1 rounded-md bg-white/15 px-1.5 py-0.5 text-[10px]">Alt+S</span>
    </button>
    <button
      type="submit"
      form="work-delete-form"
      class="inline-flex h-10 w-full items-center justify-center gap-2 rounded-xl border border-rose-200 bg-white text-sm font-bold text-rose-600 hover:bg-rose-50">
      <span class="i-lucide-trash-2 h-4 w-4"></span>업무 삭제
    </button>
  </aside>
</form>

<dialog
  id="redmine-dialog"
  class="m-auto max-h-[90vh] w-[min(44rem,calc(100vw-2rem))] overflow-y-auto rounded-2xl border-0 bg-white p-0 text-slate-900 shadow-2xl backdrop:bg-slate-950/40">
  <header class="sticky top-0 z-10 flex items-center justify-between border-b border-slate-200 bg-white px-5 py-4">
    <div>
      <p class="text-xs font-black tracking-[0.12em] text-blue-600">REDMINE</p>
      <h2 class="mt-0.5 font-black">연결된 이슈 관리</h2>
    </div>
    <button
      type="button"
      onclick="document.getElementById('redmine-dialog').close()"
      class="inline-flex h-9 w-9 items-center justify-center rounded-lg border-0 bg-slate-100 text-slate-500 hover:bg-slate-200"
      aria-label="Redmine 관리 닫기">
      <span class="i-lucide-x h-4 w-4"></span>
    </button>
  </header>
  <div class="p-5">
    <div
      id="redmine-panel"
      class="py-12 text-center text-sm text-slate-500">
      <span class="i-lucide-loader-circle mx-auto mb-3 h-6 w-6 animate-spin text-blue-600"></span>Redmine 이슈를 불러오는 중입니다.
    </div>
  </div>
</dialog>

<form
  id="redmine-create-form"
  method="post"
  action="/xapi/redmine/create">
  <input
    type="hidden"
    name="work_id"
    value="<%= view.id %>" />
</form>

<form
  id="scheduled-notification-create-form"
  method="post"
  action="/xapi/scheduled-notifications/create">
  <input
    type="hidden"
    name="work_id"
    value="<%= view.id %>" />
</form>

<form
  id="scheduled-notification-delete-form"
  method="post"
  action="/xapi/scheduled-notifications/delete">
  <input
    type="hidden"
    name="work_id"
    value="<%= view.id %>" />
</form>

<form
  id="work-delete-form"
  method="post"
  action="/xapi/works/delete"
  onsubmit="return confirm('이 업무를 삭제할까요?')">
  <input
    type="hidden"
    name="work_id"
    value="<%= view.id %>" />
</form>

<script>
  document.addEventListener('keydown', function (event) {
    if (!event.altKey || event.ctrlKey || event.metaKey || event.shiftKey || event.repeat || event.code !== 'KeyS') {
      return
    }

    const form = document.querySelector('#work-detail-form')
    if (!form) {
      return
    }

    event.preventDefault()
    form.requestSubmit()
  })
</script>
