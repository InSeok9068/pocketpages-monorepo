<script server>
  const todoData = resolve('todo-data')
  const workView = resolve('work-view')
  meta('title', '설정 · TODO')
  meta('description', '담당자와 업무 설정')
  if (!request.auth) {
    dbg('todo/setting:redirect', { status: 303, redirectTo: '/sign-in' })
    redirect('/sign-in', { status: 303 })
    return
  }
  const userId = String(request.auth.get('id') || '')
  const developers = todoData.listDevelopers(userId)
  const setting = todoData.findSetting(userId)
  const daysBefore = workView.getUrgentDays(setting)
  dbg('todo/setting:response', { userId, developerCount: developers.length })
</script>
<header class="mb-6">
  <p class="text-sm font-bold text-blue-600">SETTINGS</p>
  <h1 class="mt-1 text-3xl font-black tracking-tight">설정</h1>
</header>
<div class="grid gap-5 lg:grid-cols-2">
  <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-lg font-black">브라우저 알림</h2>
    <p
      class="mt-2 text-sm text-slate-500"
      data-browser-notification-description>
      알림 권한은 이 버튼을 누를 때만 요청합니다.
    </p>
    <button
      type="button"
      data-enable-browser-notifications
      class="mt-4 inline-flex h-10 items-center gap-2 rounded-lg border-0 bg-blue-600 px-4 text-sm font-bold text-white disabled:cursor-not-allowed disabled:bg-slate-200 disabled:text-slate-500">
      브라우저 알림 켜기
    </button>
  </section>
  <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-lg font-black">업무 표시</h2>
    <form
      method="post"
      action="/xapi/settings/save"
      class="mt-4 space-y-4">
      <label class="block text-sm font-bold text-slate-700">
        마감 임박 기준
        <div class="mt-2 flex items-center gap-2">
          <input
            type="number"
            min="0"
            max="365"
            name="days_before"
            value="<%= daysBefore %>"
            class="h-11 w-28 rounded-lg border border-slate-200 px-3" />
          <span class="text-sm text-slate-500">일 전부터 강조</span>
        </div>
      </label>
      <button class="inline-flex h-10 items-center gap-2 rounded-lg border-0 bg-slate-900 px-4 text-sm font-bold text-white">
        <span class="i-lucide-save h-4 w-4"></span>
        설정 저장
      </button>
    </form>
  </section>
  <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-lg font-black">담당자</h2>
    <form
      method="post"
      action="/xapi/developers/create"
      class="mt-4 flex gap-2">
      <input
        name="name"
        required
        maxlength="60"
        placeholder="담당자 이름"
        class="h-10 min-w-0 flex-1 rounded-lg border border-slate-200 px-3" />
      <button class="inline-flex h-10 items-center gap-1 rounded-lg border-0 bg-blue-600 px-3 text-sm font-bold text-white">
        <span class="i-lucide-plus h-4 w-4"></span>
        추가
      </button>
    </form>
    <ul class="mt-4 divide-y divide-slate-100">
      <% for (let index = 0; index < developers.length; index += 1) { %>
      <li class="flex items-center gap-3 py-3">
        <span class="i-lucide-user-round h-4 w-4 text-slate-400"></span>
        <span class="font-bold"><%= developers[index].name %></span>
        <form
          method="post"
          action="/xapi/developers/delete"
          class="ml-auto"
          onsubmit="return confirm('이 담당자를 숨길까요?')">
          <input
            type="hidden"
            name="developer_id"
            value="<%= developers[index].id %>" />
          <button class="inline-flex h-8 w-8 items-center justify-center rounded-lg border-0 bg-transparent text-slate-400 hover:bg-rose-50 hover:text-rose-600">
            <span class="i-lucide-trash-2 h-4 w-4"></span>
          </button>
        </form>
      </li>
      <% } %>
    </ul>
  </section>
</div>
