<%
  const currentPath = String(request.url.pathname || '')
  const navItems = [
    { href: '/', label: '오늘', icon: 'i-lucide-list-checks' },
    { href: '/kanban', label: '칸반', icon: 'i-lucide-columns-3' },
    { href: '/list', label: '검색', icon: 'i-lucide-search' },
    { href: '/calendar', label: '캘린더', icon: 'i-lucide-calendar-days' },
    { href: '/dashboard', label: '현황', icon: 'i-lucide-chart-no-axes-column' },
  ]
%>
<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/92 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center gap-3 px-4 py-3">
    <a
      href="/"
      class="flex shrink-0 items-center gap-2 font-black tracking-tight text-slate-950 no-underline">
      <span
        class="i-lucide-square-check-big h-5 w-5 text-blue-600"
        aria-hidden="true"></span>
      TODO
    </a>
    <nav
      class="ml-2 hidden min-w-0 items-center gap-1 md:flex"
      aria-label="주요 메뉴">
      <% for (let index = 0; index < navItems.length; index += 1) { %>
      <% const item = navItems[index] %>
      <a
        href="<%= item.href %>"
        data-nav-shortcut="<%= index + 1 %>"
        aria-keyshortcuts="Alt+<%= index + 1 %>"
        title="<%= item.label %> (Alt+<%= index + 1 %>)"
        class="<%= currentPath === item.href ? 'bg-slate-900 text-white' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-950' %> inline-flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-bold no-underline">
        <span
          class="<%= item.icon %> h-4 w-4"
          aria-hidden="true"></span
        ><%= item.label %>
      </a>
      <% } %>
    </nav>
    <div class="ml-auto flex items-center gap-1">
      <a
        href="/notification"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-slate-600 no-underline hover:bg-slate-100"
        aria-label="알림"
        ><span class="i-lucide-bell h-4.5 w-4.5"></span
      ></a>
      <a
        href="/setting"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-slate-600 no-underline hover:bg-slate-100"
        aria-label="설정"
        ><span class="i-lucide-settings h-4.5 w-4.5"></span
      ></a>
      <form
        method="post"
        action="/xapi/auth/sign-out">
        <button
          type="submit"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg border-0 bg-transparent text-slate-600 hover:bg-slate-100"
          aria-label="로그아웃">
          <span class="i-lucide-log-out h-4.5 w-4.5"></span>
        </button>
      </form>
    </div>
  </div>
</header>
<nav
  class="fixed inset-x-0 bottom-0 z-40 border-t border-slate-200 bg-white md:hidden"
  aria-label="모바일 메뉴">
  <div class="mx-auto grid max-w-lg grid-cols-5">
    <% for (let index = 0; index < navItems.length; index += 1) { %>
    <% const item = navItems[index] %>
    <a
      href="<%= item.href %>"
      data-nav-shortcut="<%= index + 1 %>"
      aria-keyshortcuts="Alt+<%= index + 1 %>"
      class="<%= currentPath === item.href ? 'text-blue-600' : 'text-slate-500' %> flex flex-col items-center gap-1 py-2 text-[11px] font-bold no-underline">
      <span
        class="<%= item.icon %> h-5 w-5"
        aria-hidden="true"></span
      ><%= item.label %>
    </a>
    <% } %>
  </div>
</nav>
<script>
  document.addEventListener('keydown', function (event) {
    if (!event.altKey || event.ctrlKey || event.metaKey || event.shiftKey || event.repeat) {
      return
    }

    const shortcut = event.code.match(/^Digit([1-5])$/)
    if (!shortcut) {
      return
    }

    const link = document.querySelector(`[data-nav-shortcut="${shortcut[1]}"]`)
    if (!link) {
      return
    }

    event.preventDefault()
    link.click()
  })
</script>
