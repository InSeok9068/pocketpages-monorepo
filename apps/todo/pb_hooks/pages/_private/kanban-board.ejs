<section
  id="kanban-board"
  class="grid gap-4 lg:grid-cols-3">
  <% for (let stateIndex = 0; stateIndex < stateOptions.length; stateIndex += 1) { %>
  <%
    const state = stateOptions[stateIndex]
    const stateWorks = workCards.filter(function (work) {
      return work.state === state.value
    })
  %>
  <article class="rounded-xl bg-slate-100 p-3">
    <header class="mb-3 flex items-center gap-2 px-1">
      <span class="<%= state.iconClass %> h-4 w-4 text-slate-600"></span>
      <h2 class="font-black"><%= state.label %></h2>
      <span class="ml-auto rounded-full bg-white px-2 py-0.5 text-xs font-bold text-slate-500"><%= stateWorks.length %></span>
    </header>
    <div
      class="min-h-20 space-y-2"
      data-kanban-list
      data-state="<%= state.value %>">
      <% for (let workIndex = 0; workIndex < stateWorks.length; workIndex += 1) { %>
      <% const work = stateWorks[workIndex] %>
      <article
        class="rounded-lg border border-slate-200 bg-white p-3 shadow-sm"
        data-kanban-card
        data-work-id="<%= work.id %>">
        <div class="flex items-start gap-2">
          <a
            href="/works/<%= encodeURIComponent(work.id) %>"
            class="block min-w-0 flex-1 leading-5 font-bold text-slate-900 no-underline hover:text-blue-700"
            ><%= work.title %></a
          ><span
            class="i-lucide-grip-vertical h-4 w-4 shrink-0 cursor-grab text-slate-300"
            data-kanban-handle></span>
        </div>
        <div class="mt-2 flex items-center gap-2 text-xs text-slate-500">
          <span class="i-lucide-user-round h-3.5 w-3.5"></span><span class="truncate"><%= work.developerName %></span><span class="ml-auto"><%= work.dueDateLabel || '-' %></span>
        </div>
        <form
          hx-post="/xapi/works/state"
          hx-target="#kanban-board"
          hx-swap="outerHTML"
          class="mt-3">
          <input
            type="hidden"
            name="work_id"
            value="<%= work.id %>" />
          <select
            name="state"
            onchange="this.form.requestSubmit()"
            class="h-8 w-full rounded-md border border-slate-200 bg-slate-50 px-2 text-xs font-bold">
            <% for (let optionIndex = 0; optionIndex < stateOptions.length; optionIndex += 1) { %>
            <option
              value="<%= stateOptions[optionIndex].value %>"
              <%= work.state === stateOptions[optionIndex].value ? 'selected' : '' %>>
              <%= stateOptions[optionIndex].label %>
            </option>
            <% } %>
          </select>
        </form>
      </article>
      <% } %>
    </div>
  </article>
  <% } %>
</section>
