<section id="kanban-board">
  <div
    class="mb-3 flex flex-wrap items-center gap-1.5"
    aria-label="상태별 업무 수">
    <% for (let summaryIndex = 0; summaryIndex < stateOptions.length; summaryIndex += 1) { %>
    <%
      const summaryState = stateOptions[summaryIndex]
      const summaryCount = workCards.filter(function (work) {
        return work.state === summaryState.value
      }).length
    %>
    <span class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-xs text-slate-600 shadow-sm">
      <span class="<%= summaryState.iconClass %> h-3.5 w-3.5 text-slate-400"></span>
      <span class="font-bold"><%= summaryState.label %></span>
      <strong class="text-slate-900"><%= summaryCount %></strong>
    </span>
    <% } %>
  </div>
  <div class="overflow-x-auto pb-2">
    <div class="min-w-220">
      <div class="flex items-start gap-3">
        <% for (let stateIndex = 0; stateIndex < stateOptions.length; stateIndex += 1) { %>
        <%
          const state = stateOptions[stateIndex]
          const stateWorks = workCards.filter(function (work) {
            return work.state === state.value
          })
        %>
        <article class="min-w-70 flex-1 overflow-hidden rounded-xl border border-slate-200 bg-slate-100/80 shadow-sm">
          <header class="flex items-center gap-2 border-b border-slate-200 bg-white px-3 py-2.5">
            <span class="<%= state.badgeClass %> inline-flex h-7 w-7 items-center justify-center rounded-md"><span class="<%= state.iconClass %> h-3.5 w-3.5"></span></span>
            <h2 class="text-sm font-black text-slate-900"><%= state.label %></h2>
            <span class="ml-auto inline-flex h-6 min-w-6 items-center justify-center rounded-full bg-slate-100 px-2 text-[11px] font-black text-slate-600"><%= stateWorks.length %></span>
          </header>
          <div
            class="min-h-28 space-y-2 p-2.5 lg:max-h-[calc(100vh-15rem)] lg:overflow-y-auto"
            data-kanban-list
            data-state="<%= state.value %>">
            <% if (!stateWorks.length) { %>
            <div class="flex min-h-20 flex-col items-center justify-center rounded-lg border border-dashed border-slate-300 bg-white/60 px-3 text-center">
              <span class="i-lucide-inbox h-4 w-4 text-slate-300"></span>
              <p class="mt-1.5 text-[11px] font-bold text-slate-400">업무가 없습니다</p>
            </div>
            <% } %>
            <% for (let workIndex = 0; workIndex < stateWorks.length; workIndex += 1) { %>
            <% const work = stateWorks[workIndex] %>
            <article
              class="<%= work.isUrgent ? 'ui-work-card-urgent' : '' %> <%= work.done ? 'opacity-75' : '' %> ui-work-card group rounded-lg p-2.5 shadow-sm transition hover:shadow-md"
              data-kanban-card
              data-work-id="<%= work.id %>">
              <div class="flex items-start gap-1.5">
                <a
                  href="/works/<%= encodeURIComponent(work.id) %>"
                  class="<%= work.done ? 'line-through' : '' %> block min-w-0 flex-1 text-sm leading-5 font-bold text-slate-900 no-underline hover:text-blue-700">
                  <%= work.title %>
                </a>
                <button
                  type="button"
                  class="inline-flex h-6 w-6 shrink-0 cursor-grab items-center justify-center rounded-md border-0 bg-transparent text-slate-300 hover:bg-slate-100 hover:text-slate-600 active:cursor-grabbing"
                  data-kanban-handle
                  aria-label="<%= work.title %> 이동">
                  <span class="i-lucide-grip-vertical h-3.5 w-3.5"></span>
                </button>
              </div>
              <div class="mt-1.5 grid grid-cols-[minmax(0,1fr)_auto] items-center gap-2 text-[11px] text-slate-500">
                <span class="inline-flex min-w-0 items-center gap-1">
                  <span class="i-lucide-user-round h-3 w-3"></span>
                  <span class="truncate"><%= work.developerName %></span>
                </span>
                <span class="<%= work.isUrgent ? 'font-bold text-rose-600' : '' %> inline-flex items-center gap-1">
                  <span class="i-lucide-calendar-clock h-3 w-3"></span>
                  <%= work.dueDateLabel || '없음' %>
                </span>
              </div>
              <div class="mt-2 flex min-h-7 items-center gap-1.5 border-t border-slate-100 pt-2 text-slate-400">
                <% if (work.redmine || work.joplin || work.file) { %>
                <% if (work.redmine) { %>
                <span
                  class="i-lucide-square-kanban h-3 w-3"
                  title="Redmine 연결"></span>
                <% } %> <% if (work.joplin) { %>
                <span
                  class="i-lucide-notebook-tabs h-3 w-3"
                  title="Joplin 연결"></span>
                <% } %> <% if (work.file) { %>
                <span
                  class="i-lucide-paperclip h-3 w-3"
                  title="첨부파일 있음"></span>
                <% } %>
                <% } %>
                <form
                  hx-post="/xapi/works/state"
                  hx-target="#kanban-board"
                  hx-swap="outerHTML"
                  class="ml-auto">
                  <input
                    type="hidden"
                    name="work_id"
                    value="<%= work.id %>" />
                  <input
                    type="hidden"
                    name="developer"
                    value="<%= selectedDeveloper %>" />
                  <select
                    name="state"
                    onchange="this.form.requestSubmit()"
                    aria-label="<%= work.title %> 상태 변경"
                    class="h-7 max-w-28 rounded-md px-2 text-[11px] font-bold text-slate-600">
                    <% for (let optionIndex = 0; optionIndex < stateOptions.length; optionIndex += 1) { %>
                    <option
                      value="<%= stateOptions[optionIndex].value %>"
                      <%= work.state === stateOptions[optionIndex].value ? 'selected' : '' %>>
                      <%= stateOptions[optionIndex].label %>
                    </option>
                    <% } %>
                  </select>
                </form>
              </div>
            </article>
            <% } %>
          </div>
        </article>
        <% } %>
      </div>
    </div>
  </div>
</section>
