<div id="redmine-panel">
  <% if (errorMessage) { %>
  <div class="rounded-xl bg-rose-50 px-4 py-3 text-sm font-bold text-rose-700"><%= errorMessage %></div>
  <% } else { %>
  <div class="mb-5 flex flex-wrap items-start justify-between gap-3">
    <div>
      <div class="flex flex-wrap items-center gap-2">
        <span class="rounded-full bg-blue-50 px-2.5 py-1 text-xs font-black text-blue-700">#<%= issue.id %></span>
        <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-600"><%= issue.statusName %></span>
      </div>
      <h3 class="mt-2 text-lg font-black text-slate-950"><%= issue.subject %></h3>
      <p class="mt-1 text-xs text-slate-500"><%= issue.projectName %><%= issue.trackerName ? ' · ' + issue.trackerName : '' %></p>
    </div>
    <a
      href="<%= issue.url %>"
      target="_blank"
      rel="noopener noreferrer"
      class="ui-button-secondary inline-flex h-9 items-center gap-2 rounded-lg px-3 text-xs font-bold text-slate-600 no-underline">
      <span class="i-lucide-external-link h-3.5 w-3.5"></span>
      Redmine 열기
    </a>
  </div>
  <form
    hx-post="/xapi/redmine/update"
    hx-target="#redmine-panel"
    hx-swap="outerHTML"
    x-data="{ doneRatio: <%= issue.doneRatio %> }"
    class="space-y-5">
    <input
      type="hidden"
      name="work_id"
      value="<%= workId %>" />
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block text-sm font-bold text-slate-700">
        상태
        <select
          name="status_id"
          class="mt-2 h-11 w-full rounded-xl px-3">
          <% for (let index = 0; index < issue.allowedStatuses.length; index += 1) { %>
          <option
            value="<%= issue.allowedStatuses[index].id %>"
            <%= issue.statusId === issue.allowedStatuses[index].id ? 'selected' : '' %>>
            <%= issue.allowedStatuses[index].name %>
          </option>
          <% } %>
        </select>
      </label>
      <label class="block text-sm font-bold text-slate-700">
        담당자
        <select
          name="assigned_to_id"
          class="mt-2 h-11 w-full rounded-xl px-3">
          <option value="">미지정</option>
          <% for (let index = 0; index < issue.allowedAssignees.length; index += 1) { %>
          <option
            value="<%= issue.allowedAssignees[index].id %>"
            <%= issue.assignedToId === issue.allowedAssignees[index].id ? 'selected' : '' %>>
            <%= issue.allowedAssignees[index].name %>
          </option>
          <% } %>
        </select>
      </label>
      <label class="block text-sm font-bold text-slate-700 sm:col-span-2">
        진척도
        <div class="mt-2 flex h-11 items-center gap-3 rounded-xl bg-slate-50 px-3">
          <input
            type="range"
            name="done_ratio"
            min="0"
            max="100"
            step="10"
            x-model.number="doneRatio"
            class="min-w-0 flex-1" />
          <output
            class="w-10 text-right text-xs font-black text-blue-700"
            x-text="doneRatio + '%'">
            <%= issue.doneRatio %>%
          </output>
        </div>
      </label>
      <label class="block text-sm font-bold text-slate-700">
        시작일
        <input
          type="date"
          name="start_date"
          value="<%= issue.startDate %>"
          class="mt-2 h-11 w-full rounded-xl px-3" />
      </label>
      <label class="block text-sm font-bold text-slate-700">
        종료일
        <input
          type="date"
          name="due_date"
          value="<%= issue.dueDate %>"
          class="mt-2 h-11 w-full rounded-xl px-3" />
      </label>
    </div>
    <fieldset class="rounded-xl bg-slate-50 p-4">
      <legend class="px-1 text-xs font-black text-slate-600">일감 관리자 추가</legend>
      <div class="mt-2 flex flex-wrap gap-x-5 gap-y-3 text-sm text-slate-700">
        <label class="inline-flex items-center gap-2">
          <input
            type="checkbox"
            name="watchers"
            value="cx" />
          CX팀
        </label>
        <label class="inline-flex items-center gap-2">
          <input
            type="checkbox"
            name="watchers"
            value="server" />
          개발팀(서버)
        </label>
        <label class="inline-flex items-center gap-2">
          <input
            type="checkbox"
            name="watchers"
            value="client" />
          개발팀(클라이언트)
        </label>
        <label class="inline-flex items-center gap-2">
          <input
            type="checkbox"
            name="watchers"
            value="biz" />
          사업팀
        </label>
        <label class="inline-flex items-center gap-2">
          <input
            type="checkbox"
            name="watchers"
            value="manager" />
          관리자
        </label>
      </div>
    </fieldset>
    <label class="block text-sm font-bold text-slate-700">
      댓글
      <textarea
        name="notes"
        rows="4"
        class="mt-2 w-full resize-y rounded-xl p-3 text-sm leading-6"
        placeholder="Redmine 변경 이력에 남길 댓글"></textarea>
    </label>
    <div class="flex justify-end">
      <button class="inline-flex h-10 items-center gap-2 rounded-xl border-0 bg-blue-600 px-4 text-sm font-black text-white hover:bg-blue-700">
        <span class="i-lucide-refresh-cw h-4 w-4"></span>
        Redmine 업데이트
      </button>
    </div>
  </form>
  <% } %>
</div>
