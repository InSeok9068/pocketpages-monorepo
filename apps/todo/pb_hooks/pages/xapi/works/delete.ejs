<script server>
  const htmxResponse = resolve('htmx-response')
  const todoData = resolve('todo-data')
  const isHtmx = String(request.header('HX-Request') || '').toLowerCase() === 'true'
  const form = body()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const workId = String(form.work_id || '').trim()
  const selectedDeveloper = String(form.developer || '').trim()
  let listMessage = ''
  let workCards = []

  dbg('todo/xapi/works/delete:start', { userId, workId })

  try {
    if (request.method !== 'POST') throw new Error('잘못된 요청입니다.')
    if (!userId) throw new Error('로그인이 필요합니다.')
    const work = $app.findFirstRecordByFilter('works', 'id = {:workId} && user = {:userId}', { workId, userId })

    $app.delete(work)
    info('todo/xapi/works/delete:success', { userId, workId })
  } catch (exception) {
    listMessage = String(exception.message || exception)
    error('todo/xapi/works/delete:failed', { userId, workId, error: listMessage })
  }

  if (!isHtmx) {
    const redirectTo = selectedDeveloper ? '/?developer=' + encodeURIComponent(selectedDeveloper) : '/'
    const redirectMessage = listMessage || '업무를 삭제했습니다.'
    dbg('todo/xapi/works/delete:redirect', { status: 303, redirectTo, message: redirectMessage })
    redirect(redirectTo, { status: 303, message: redirectMessage })
    return
  }

  if (!listMessage) {
    htmxResponse.setToastTrigger(response, {
      message: '업무를 삭제했습니다.',
      tone: 'success',
    })
  }

  if (userId) workCards = todoData.listWorkCards(userId, { done: false, developerId: selectedDeveloper })
</script>
<%- include('work-list.ejs', { workCards, selectedDeveloper, listMessage }) %>
