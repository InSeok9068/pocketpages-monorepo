<script server>
  const htmxResponse = resolve('htmx-response')
  const todoData = resolve('todo-data')
  const form = body()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const selectedDeveloper = String(form.developer || '').trim()
  let order = null
  let listMessage = ''
  let workCards = []
  try {
    order = JSON.parse(String(form.order || ''))
  } catch (_exception) {
    order = null
  }
  const orderCount = Array.isArray(order) ? order.length : 0
  dbg('todo/xapi/works/reorder:start', { userId, orderCount })
  try {
    if (request.method !== 'POST') throw new Error('잘못된 요청입니다.')
    if (!userId) throw new Error('로그인이 필요합니다.')
    if (!Array.isArray(order)) throw new Error('정렬 값이 올바르지 않습니다.')
    const bindings = { userId }
    const sortCases = []
    const idPlaceholders = []
    const seenIds = {}
    for (let index = 0; index < order.length; index += 1) {
      const workId = String(order[index] || '').trim()
      if (!workId || seenIds[workId]) throw new Error('정렬 값이 올바르지 않습니다.')
      const idKey = 'id' + index
      const sortKey = 'sort' + index
      seenIds[workId] = true
      bindings[idKey] = workId
      bindings[sortKey] = index
      sortCases.push('WHEN {:' + idKey + '} THEN {:' + sortKey + '}')
      idPlaceholders.push('{:' + idKey + '}')
    }
    if (order.length) {
      $app.runInTransaction(function (txApp) {
        const updateResult = txApp
          .db()
          .newQuery(
            'UPDATE works SET sort = CASE id '
              + sortCases.join(' ')
              + ' ELSE sort END WHERE user = {:userId} AND done = FALSE AND id IN ('
              + idPlaceholders.join(', ')
              + ')'
          )
          .bind(bindings)
          .execute()
        if (updateResult.rowsAffected() !== order.length) throw new Error('정렬할 업무를 찾을 수 없습니다.')
      })
    }
    info('todo/xapi/works/reorder:success', { userId, orderCount })
  } catch (exception) {
    listMessage = String(exception.message || exception)
    error('todo/xapi/works/reorder:failed', { userId, error: listMessage })
  }
  if (listMessage) {
    htmxResponse.setToastTrigger(response, {
      message: listMessage,
      tone: 'error',
    })
  }
  if (userId) workCards = todoData.listWorkCards(userId, { done: false, developerId: selectedDeveloper })
</script>
<%- include('work-list.ejs', { workCards, selectedDeveloper, listMessage }) %>
