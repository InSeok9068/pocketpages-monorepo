<script server>
  const htmxResponse = resolve('htmx-response')
  const todoData = resolve('todo-data')
  const form = body()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const selectedDeveloper = String(form.developer || '')
  const stateOptions = todoData.listOpenWorkStates()
  let order = null
  let workCards = []
  let errorMessage = ''
  try {
    order = JSON.parse(String(form.order || ''))
  } catch (_exception) {
    order = null
  }
  const orderCount = Array.isArray(order) ? order.length : 0
  dbg('todo/xapi/works/move:start', { userId, orderCount })
  try {
    if (request.method !== 'POST') throw new Error('잘못된 요청입니다.')
    if (!userId) throw new Error('로그인이 필요합니다.')
    if (!Array.isArray(order)) throw new Error('이동 값이 올바르지 않습니다.')
    const validStates = {}
    for (let index = 0; index < stateOptions.length; index += 1) validStates[stateOptions[index].value] = true
    const bindings = { userId, updated: new Date().toISOString() }
    const stateCases = []
    const sortCases = []
    const idPlaceholders = []
    const seenIds = {}
    for (let index = 0; index < order.length; index += 1) {
      const item = order[index] || {}
      const workId = String(item.id || '').trim()
      const state = String(item.state || '').trim()
      const sort = Number(item.sort)
      if (!workId || seenIds[workId] || !validStates[state] || !isFinite(sort)) throw new Error('이동 값이 올바르지 않습니다.')
      const idKey = 'id' + index
      const stateKey = 'state' + index
      const sortKey = 'sort' + index
      seenIds[workId] = true
      bindings[idKey] = workId
      bindings[stateKey] = state
      bindings[sortKey] = sort
      stateCases.push('WHEN {:' + idKey + '} THEN {:' + stateKey + '}')
      sortCases.push('WHEN {:' + idKey + '} THEN {:' + sortKey + '}')
      idPlaceholders.push('{:' + idKey + '}')
    }
    if (order.length) {
      $app.runInTransaction(function (txApp) {
        const updateResult = txApp
          .db()
          .newQuery(
            'UPDATE works SET state = CASE id ' +
              stateCases.join(' ') +
              ' ELSE state END, sort = CASE id ' +
              sortCases.join(' ') +
              ' ELSE sort END, updated = {:updated} WHERE user = {:userId} AND done = FALSE AND id IN (' +
              idPlaceholders.join(', ') +
              ')'
          )
          .bind(bindings)
          .execute()
        if (updateResult.rowsAffected() !== order.length) throw new Error('이동할 업무를 찾을 수 없습니다.')
      })
    }
    info('todo/xapi/works/move:success', { userId, orderCount })
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('todo/xapi/works/move:failed', { userId, error: errorMessage })
  }
  if (errorMessage) {
    htmxResponse.setToastTrigger(response, {
      message: errorMessage,
      tone: 'error',
    })
  }
  if (userId) workCards = todoData.listWorkCards(userId, { done: false, developerId: selectedDeveloper, limit: 500 })
</script>
<%- include('kanban-board.ejs', { stateOptions, workCards, selectedDeveloper }) %>
