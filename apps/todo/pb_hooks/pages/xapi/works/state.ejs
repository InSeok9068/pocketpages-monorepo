<script server>
  const htmxResponse = resolve('htmx-response')
  const todoData = resolve('todo-data')
  const form = body()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const selectedDeveloper = String(form.developer || '')
  const workId = String(form.work_id || '').trim()
  const state = String(form.state || '').trim()
  const stateOptions = todoData.listOpenWorkStates()
  let workCards = []
  let errorMessage = ''

  dbg('todo/xapi/works/state:start', { userId, workId, state })
  try {
    if (request.method !== 'POST') throw new Error('잘못된 요청입니다.')
    if (!userId) throw new Error('로그인이 필요합니다.')
    let isValidState = false
    for (let index = 0; index < stateOptions.length; index += 1)
      if (stateOptions[index].value === state) isValidState = true
    if (!isValidState) throw new Error('상태 값이 올바르지 않습니다.')
    const work = $app.findFirstRecordByFilter('works', 'id = {:workId} && user = {:userId} && done = false', {
      workId,
      userId,
    })
    work.set('state', state)
    $app.save(work)
    info('todo/xapi/works/state:success', { userId, workId, state })
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('todo/xapi/works/state:failed', { userId, workId, state, error: errorMessage })
  }
  htmxResponse.setToastTrigger(response, {
    message: errorMessage || '업무 상태를 변경했습니다.',
    tone: errorMessage ? 'error' : 'success',
  })
  if (userId) workCards = todoData.listWorkCards(userId, { done: false, developerId: selectedDeveloper, limit: 500 })
</script>
<%- include('kanban-board.ejs', { stateOptions, workCards, selectedDeveloper }) %>
