<script server>
  const todoData = resolve('todo-data')
  const form = body()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const workId = String(form.work_id || '').trim()
  const state = String(form.state || '').trim()
  const stateOptions = todoData.listWorkStates()
  let workCards = []

  dbg('todo/xapi/works/state:start', { userId, workId, state })
  try {
    if (request.method !== 'POST' || !userId) throw new Error('로그인이 필요합니다.')
    let isValidState = false
    for (let index = 0; index < stateOptions.length; index += 1) if (stateOptions[index].value === state) isValidState = true
    if (!isValidState) throw new Error('상태 값이 올바르지 않습니다.')
    const work = $app.findFirstRecordByFilter('works', 'id = {:workId} && user = {:userId}', { workId, userId })
    const isDone = state === 'done'
    work.set('state', state)
    work.set('done', isDone)
    work.set('doneDate', isDone ? new Date().toISOString() : '')
    $app.save(work)
    info('todo/xapi/works/state:success', { userId, workId, state })
  } catch (exception) {
    error('todo/xapi/works/state:failed', { userId, workId, state, error: String(exception.message || exception) })
  }
  if (userId) workCards = todoData.listWorkCards(userId, { limit: 500 })
</script>
<%- include('kanban-board.ejs', { stateOptions, workCards }) %>
