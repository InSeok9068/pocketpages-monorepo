<script server>
  const form = body()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const notificationId = String(form.notification_id || '').trim()
  let errorMessage = ''
  dbg('todo/xapi/notifications/read:start', { userId, notificationId })
  try {
    if (request.method !== 'POST' || !userId) throw new Error('로그인이 필요합니다.')
    const notification = $app.findFirstRecordByFilter('notifications', 'id = {:notificationId} && user = {:userId}', { notificationId, userId })
    notification.set('read', true)
    $app.save(notification)
    info('todo/xapi/notifications/read:success', { userId, notificationId })
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('todo/xapi/notifications/read:failed', { userId, notificationId, error: errorMessage })
  }
  dbg('todo/xapi/notifications/read:redirect', { status: 303, redirectTo: '/notification', message: errorMessage })
  redirect('/notification', { status: 303, message: errorMessage })
  return
</script>
