<script server>
  const redmineService = resolve('redmine-service')
  const config = {
    host: String(env('REDMINE_HOST') || 'https://pms.kpcard.co.kr').replace(/\/$/, ''),
    apiKey: String(env('REDMINE_API_KEY') || '').trim(),
  }

  dbg('todo/api/redmine:update:start', { isSignedIn: !!request.auth })

  if (request.method !== 'POST') {
    warn('todo/api/redmine:update:invalid-method', { method: request.method })
    response.json(405, { ok: false, message: 'POST 요청만 허용됩니다.' })
    return
  }
  if (!request.auth) {
    warn('todo/api/redmine:update:unauthorized', {})
    response.json(401, { ok: false, message: '로그인이 필요합니다.' })
    return
  }
  if (!config.apiKey) {
    error('todo/api/redmine:update:missing-api-key', {})
    response.json(503, { ok: false, message: 'Redmine 연동 설정이 필요합니다.' })
    return
  }

  /** @type {types.RedmineUpdateInput} */
  const input = body()
  const issueId = String(input.id || '').trim()
  const watcherGroups = Array.isArray(input.watchers) ? input.watchers : []

  if (!/^\d+$/.test(issueId)) {
    warn('todo/api/redmine:update:invalid-issue-id', { issueId })
    response.json(400, { ok: false, message: '이슈 번호가 올바르지 않습니다.' })
    return
  }

  try {
    redmineService.updateIssue(config, input)
    const watcherResult = redmineService.addWatcherGroups(config, issueId, watcherGroups)
    if (watcherResult.failedIds.length) {
      warn('todo/api/redmine:update:watcher-failed', { issueId, failedIds: watcherResult.failedIds })
    }

    info('todo/api/redmine:update:success', { issueId, watcherCount: watcherResult.addedCount })
    response.json(200, {
      ok: true,
      watcherCount: watcherResult.addedCount,
      failedWatcherIds: watcherResult.failedIds,
    })
    return
  } catch (exception) {
    error('todo/api/redmine:update:failed', { issueId, error: String(exception.message || exception) })
    response.json(502, { ok: false, message: String(exception.message || 'Redmine 요청 중 문제가 발생했습니다.') })
    return
  }
</script>
