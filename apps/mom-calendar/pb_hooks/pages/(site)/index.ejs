<script server>
  meta('title', '맘캘린더')
  meta('description', '로컬에 저장하는 근무 달력')
</script>

<div class="app-shell">
  <section
    class="summary-strip"
    aria-label="이번 달 요약">
    <article class="summary-item">
      <span class="summary-label">근무일</span>
      <strong id="summary-days">0일</strong>
    </article>
    <article class="summary-item">
      <span class="summary-label">야근</span>
      <strong id="summary-overtime">0시간</strong>
    </article>
    <article class="summary-item">
      <span class="summary-label">예상 금액</span>
      <strong id="summary-pay">0원</strong>
    </article>
  </section>

  <section
    class="calendar-panel"
    aria-label="근무 달력">
    <div id="calendar"></div>
  </section>
</div>

<div
  id="sheet-backdrop"
  class="sheet-backdrop"
  hidden></div>

<aside
  id="salary-sheet"
  class="bottom-sheet"
  aria-label="월급 계산"
  hidden>
  <div
    class="sheet-handle"
    aria-hidden="true"></div>
  <div class="panel-heading">
    <h2>월급 계산</h2>
    <button
      class="icon-button"
      type="button"
      id="close-salary-sheet-button"
      aria-label="닫기">
      ×
    </button>
  </div>

  <div class="stacked-form">
    <div class="field-grid">
      <label>
        <span>시작일</span>
        <input
          id="salary-start-date"
          type="date" />
      </label>
      <label>
        <span>종료일</span>
        <input
          id="salary-end-date"
          type="date" />
      </label>
    </div>

    <label class="check-card">
      <input
        id="salary-tax-enabled"
        type="checkbox"
        checked />
      <span>프리랜서 3.3% 원천세 적용</span>
    </label>
  </div>

  <div class="salary-result-grid">
    <article>
      <span class="summary-label">근무일</span>
      <strong id="salary-work-days">0일</strong>
    </article>
    <article>
      <span class="summary-label">세전 금액</span>
      <strong id="salary-gross-pay">0원</strong>
    </article>
    <article>
      <span class="summary-label">원천세</span>
      <strong id="salary-tax-amount">0원</strong>
    </article>
    <article class="salary-net-card">
      <span class="summary-label">실수령</span>
      <strong id="salary-net-pay">0원</strong>
    </article>
  </div>

  <p
    id="salary-formula"
    class="salary-formula">
    세전 0원 - 원천세 0원 = 0원
  </p>
</aside>

<aside
  id="month-sheet"
  class="bottom-sheet"
  aria-label="월 선택"
  hidden>
  <div
    class="sheet-handle"
    aria-hidden="true"></div>
  <div class="panel-heading">
    <h2>월 선택</h2>
    <button
      class="icon-button"
      type="button"
      id="close-month-sheet-button"
      aria-label="닫기">
      ×
    </button>
  </div>

  <div class="month-year-control">
    <button
      class="ghost-button"
      type="button"
      id="prev-month-year-button">
      이전
    </button>
    <strong id="month-picker-year">2026년</strong>
    <button
      class="ghost-button"
      type="button"
      id="next-month-year-button">
      다음
    </button>
  </div>

  <div
    id="month-option-list"
    class="month-option-list">
    <button
      type="button"
      data-month="1">
      1월
    </button>
    <button
      type="button"
      data-month="2">
      2월
    </button>
    <button
      type="button"
      data-month="3">
      3월
    </button>
    <button
      type="button"
      data-month="4">
      4월
    </button>
    <button
      type="button"
      data-month="5">
      5월
    </button>
    <button
      type="button"
      data-month="6">
      6월
    </button>
    <button
      type="button"
      data-month="7">
      7월
    </button>
    <button
      type="button"
      data-month="8">
      8월
    </button>
    <button
      type="button"
      data-month="9">
      9월
    </button>
    <button
      type="button"
      data-month="10">
      10월
    </button>
    <button
      type="button"
      data-month="11">
      11월
    </button>
    <button
      type="button"
      data-month="12">
      12월
    </button>
  </div>
</aside>

<aside
  id="workplace-sheet"
  class="bottom-sheet"
  aria-label="근무지 관리"
  hidden>
  <div
    class="sheet-handle"
    aria-hidden="true"></div>
  <div class="panel-heading">
    <h2>근무지</h2>
    <div class="panel-actions">
      <button
        class="ghost-button"
        type="button"
        id="reset-workplace-button">
        새로 입력
      </button>
      <button
        class="icon-button"
        type="button"
        id="close-workplace-sheet-button"
        aria-label="닫기">
        ×
      </button>
    </div>
  </div>

  <form
    id="workplace-form"
    class="stacked-form">
    <input
      type="hidden"
      id="workplace-id" />

    <label>
      <span>근무한 곳</span>
      <input
        id="workplace-name"
        autocomplete="off"
        placeholder="예: 서울요양센터"
        required />
    </label>

    <div class="field-grid workplace-pay-grid">
      <label>
        <span>일당</span>
        <input
          id="daily-pay"
          type="number"
          min="0"
          step="1000"
          inputmode="numeric"
          value="0" />
      </label>
      <label>
        <span>야간시급</span>
        <input
          id="overtime-hourly-pay"
          type="number"
          min="0"
          step="1000"
          inputmode="numeric"
          value="0" />
      </label>
      <label>
        <span>식대</span>
        <input
          id="meal-allowance"
          type="number"
          min="0"
          step="500"
          inputmode="numeric"
          value="0" />
      </label>
    </div>

    <button
      class="primary-button"
      type="submit">
      근무지 저장
    </button>
  </form>

  <div
    id="workplace-list"
    class="workplace-list"></div>
</aside>

<nav
  class="bottom-nav"
  aria-label="하단 메뉴">
  <button
    class="bottom-nav-button is-active"
    type="button"
    id="show-calendar-button">
    <svg
      class="bottom-nav-icon"
      viewBox="0 0 24 24"
      aria-hidden="true"
      focusable="false">
      <path d="M8 2v4" />
      <path d="M16 2v4" />
      <rect
        x="3"
        y="5"
        width="18"
        height="16"
        rx="2" />
      <path d="M3 10h18" />
      <path d="M8 14h.01" />
      <path d="M12 14h.01" />
      <path d="M16 14h.01" />
      <path d="M8 18h.01" />
      <path d="M12 18h.01" />
    </svg>
    달력
  </button>
  <button
    class="bottom-nav-button"
    type="button"
    id="open-salary-sheet-button">
    <svg
      class="bottom-nav-icon"
      viewBox="0 0 24 24"
      aria-hidden="true"
      focusable="false">
      <rect
        x="4"
        y="2"
        width="16"
        height="20"
        rx="2" />
      <path d="M8 6h8" />
      <path d="M8 10h8" />
      <path d="M8 14h.01" />
      <path d="M12 14h.01" />
      <path d="M16 14h.01" />
      <path d="M8 18h.01" />
      <path d="M12 18h.01" />
      <path d="M16 18h.01" />
    </svg>
    계산
  </button>
  <button
    class="bottom-nav-button"
    type="button"
    id="open-workplace-sheet-button">
    <svg
      class="bottom-nav-icon"
      viewBox="0 0 24 24"
      aria-hidden="true"
      focusable="false">
      <path d="M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 0 1 16 0Z" />
      <circle
        cx="12"
        cy="10"
        r="3" />
    </svg>
    근무지
  </button>
</nav>

<dialog
  id="worklog-dialog"
  class="worklog-dialog">
  <form
    id="worklog-form"
    method="dialog"
    class="dialog-card">
    <div class="dialog-heading">
      <div>
        <span class="summary-label">근무 기록</span>
        <h2 id="worklog-date-label">날짜</h2>
      </div>
      <button
        class="icon-button"
        type="button"
        id="close-worklog-button"
        aria-label="닫기">
        ×
      </button>
    </div>

    <input
      type="hidden"
      id="worklog-date" />

    <label>
      <span>근무지</span>
      <select
        id="worklog-workplace"
        required></select>
    </label>

    <div class="worklog-detail-grid">
      <label>
        <span>야근 시간</span>
        <input
          id="worklog-overtime-hours"
          type="number"
          min="0"
          step="0.5"
          inputmode="decimal"
          value="0" />
      </label>

      <label class="check-card worklog-meal-card">
        <input
          id="worklog-meal-allowance-paid"
          type="checkbox" />
        <span>식대 받음</span>
      </label>
    </div>

    <div class="dialog-actions">
      <button
        class="danger-button"
        type="button"
        id="delete-worklog-button">
        삭제
      </button>
      <button
        class="primary-button"
        type="submit">
        저장
      </button>
    </div>
  </form>
</dialog>

<script src="<%= asset('/assets/vendor/fullcalendar-6.1.21.global.min.js') %>"></script>
<script src="<%= asset('/assets/js/mom-calendar-db.js') %>"></script>
<script src="<%= asset('/assets/js/mom-calendar-app.js') %>?v=mobile-12"></script>
