<script server>
  const BACKUP_COLLECTION = 'mom_calendar_backups'

  function isValidBackupId(value) {
    return /^[A-Za-z0-9_-]{20,80}$/.test(value)
  }

  if (request.method !== 'POST') {
    response.json(405, {
      ok: false,
      message: '잘못된 요청입니다.',
    })
    return
  }

  const form = body()
  const backupId = String(form.backupId || '').trim()

  try {
    if (!isValidBackupId(backupId)) throw new Error('백업 코드가 올바르지 않습니다.')

    const backupRecord = $app.findFirstRecordByFilter(BACKUP_COLLECTION, 'backup_id = {:backupId}', {
      backupId: backupId,
    })

    response.json(200, {
      ok: true,
      backupId: backupId,
      payload: backupRecord.get('payload'),
      updated: String(backupRecord.get('updated') || ''),
    })
  } catch (exception) {
    response.json(404, {
      ok: false,
      message: '해당 백업을 찾을 수 없습니다.',
    })
  }
</script>
