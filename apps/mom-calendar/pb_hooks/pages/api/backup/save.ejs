<script server>
  const BACKUP_COLLECTION = 'mom_calendar_backups'
  const STALE_BACKUP_DAYS = 30

  function isValidBackupId(value) {
    return /^[A-Za-z0-9_-]{20,80}$/.test(value)
  }

  function isValidBackupPayload(payload) {
    if (!payload || typeof payload !== 'object' || Array.isArray(payload)) return false
    if (String(payload.app || '') !== 'mom-calendar') return false
    if (!payload.data || typeof payload.data !== 'object' || Array.isArray(payload.data)) return false

    return Array.isArray(payload.data.workplaces) && Array.isArray(payload.data.workLogs)
  }

  function cleanupStaleBackups(currentBackupId) {
    const expiresBefore = new Date(Date.now() - STALE_BACKUP_DAYS * 24 * 60 * 60 * 1000).toISOString()
    const staleRecords = $app.findRecordsByFilter(BACKUP_COLLECTION, 'backup_id != {:backupId} && updated < {:expiresBefore}', 'updated', 20, 0, {
      backupId: currentBackupId,
      expiresBefore: expiresBefore,
    })

    staleRecords.forEach(function (record) {
      $app.delete(record)
    })
  }

  if (request.method !== 'POST') {
    response.json(405, {
      ok: false,
      message: '잘못된 요청입니다.',
    })
    return
  }

  const form = body()
  const backupId = String(form.backupId || '').trim()
  const payload = form.payload
  const nowIso = new Date().toISOString()

  try {
    if (!isValidBackupId(backupId)) throw new Error('백업 코드가 올바르지 않습니다.')
    if (!isValidBackupPayload(payload)) throw new Error('백업 데이터가 올바르지 않습니다.')

    let backupRecord = null

    try {
      backupRecord = $app.findFirstRecordByFilter(BACKUP_COLLECTION, 'backup_id = {:backupId}', {
        backupId: backupId,
      })
    } catch (exception) {
      backupRecord = null
    }

    if (!backupRecord) {
      backupRecord = new Record($app.findCollectionByNameOrId(BACKUP_COLLECTION))
      backupRecord.set('backup_id', backupId)
    }

    backupRecord.set('payload', payload)
    $app.save(backupRecord)

    try {
      cleanupStaleBackups(backupId)
    } catch (exception) {
      console.warn('mom-calendar backup cleanup failed', String(exception.message || exception))
    }

    response.json(200, {
      ok: true,
      backupId: backupId,
      savedAt: nowIso,
    })
  } catch (exception) {
    response.json(400, {
      ok: false,
      message: String(exception.message || exception) || '백업에 실패했습니다.',
    })
  }
</script>
