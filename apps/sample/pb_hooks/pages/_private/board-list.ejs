<%
  const safeBoards = Array.isArray(typeof boardItems === 'undefined' ? undefined : boardItems) ? boardItems : []
  const safeError = typeof error === 'undefined' ? '' : String(error || '')
  const currentBoardSlug = typeof selectedBoardSlug === 'undefined' ? '' : String(selectedBoardSlug || '')
  const boardCards = safeBoards.map((boardItem) => {
    const boardName = boardItem.name || ''
    const boardSlug = boardItem.slug || ''
    const description = String(boardItem.description || '').trim()

    return {
      name: boardName,
      slug: boardSlug,
      path: boardItem.path || '',
      description: description.length > 96 ? description.slice(0, 93) + '...' : description,
      searchExpr: JSON.stringify(`${boardName} ${boardSlug}`.toLowerCase()),
    }
  })
%>
<% if (safeError) { %>
<p class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= safeError %></p>
<% } else if (!boardCards.length) { %>
<p class="text-sm text-stone-500">No boards found.</p>
<% } else { %>
<div class="space-y-3">
  <% boardCards.forEach((boardCard) => { %>
  <article
    x-show="<%= `${boardCard.searchExpr}.includes(q.toLowerCase())` %>"
    class="<%= currentBoardSlug === boardCard.slug ? 'border-stone-900 bg-white shadow-sm' : 'border-stone-200 bg-stone-50' %> rounded-2xl border px-4 py-4 transition">
    <header class="flex items-start justify-between gap-3">
      <div class="min-w-0 space-y-1">
        <h3 class="truncate text-base font-semibold text-stone-950"><%= boardCard.name || '(untitled board)' %></h3>
        <p class="truncate text-[11px] uppercase tracking-[0.14em] text-stone-500">/boards/<%= boardCard.slug %></p>
      </div>
      <% if (currentBoardSlug === boardCard.slug) { %>
      <span class="shrink-0 rounded-full bg-stone-900 px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] text-white">Selected</span>
      <% } %>
    </header>
    <p class="mt-3 text-sm leading-6 text-stone-600"><%= boardCard.description || 'No description' %></p>
    <div class="mt-4 flex flex-wrap items-center gap-2">
      <form
        hx-get="/xapi/posts/panel"
        hx-target="#post-panel"
        hx-swap="outerHTML"
        hx-push-url="/patterns?board=<%= encodeURIComponent(boardCard.slug) %>">
        <input
          type="hidden"
          name="board"
          value="<%= boardCard.slug %>" />
        <button
          type="submit"
          class="<%= currentBoardSlug === boardCard.slug ? 'bg-stone-900 text-white hover:bg-stone-700' : 'border border-stone-300 text-stone-700 hover:border-stone-900 hover:text-stone-900' %> inline-flex items-center rounded-full px-3 py-1.5 text-xs font-medium transition">
          <%= currentBoardSlug === boardCard.slug ? 'Refresh panel' : 'Load panel' %>
        </button>
      </form>
      <a
        href="<%= boardCard.path %>"
        class="inline-flex items-center rounded-full border border-stone-300 px-3 py-1.5 text-xs font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900">
        Full page
      </a>
    </div>
  </article>
  <% }) %>
</div>
<% } %>
