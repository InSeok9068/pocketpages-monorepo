<%
  const boardItems = (boards || []).map((board) => {
    const boardName = board.get("name") || "";
    const boardSlug = board.get("slug") || "";

    return {
      name: boardName,
      slug: boardSlug,
      description: board.get("description") || "",
      searchExpr: JSON.stringify(`${boardName} ${boardSlug}`.toLowerCase()),
    };
  });
%>
<% if (error) { %>
<p>
  <strong><%= error %></strong>
</p>
<% } else if (!boardItems.length) { %>
<p><em>No boards found.</em></p>
<% } else { %>
<% boardItems.forEach((boardItem) => { %>
<article x-show="<%= `${boardItem.searchExpr}.includes(q.toLowerCase())` %>">
  <header>
    <h3><%= boardItem.name || '(untitled board)' %></h3>
    <p>
      <small>/boards/<%= boardItem.slug %></small>
    </p>
  </header>
  <p><%= boardItem.description || 'No description' %></p>
  <form hx-get="/xapi/posts/panel" hx-target="#post-panel" hx-swap="outerHTML">
    <input type="hidden" name="board" value="<%= boardItem.slug %>" />
    <button type="submit"><%= selectedBoardSlug === boardItem.slug ? 'Refresh posts' : 'View posts' %></button>
  </form>
  <nav>
    <a href="/boards/<%= boardItem.slug %>">Open board page</a>
  </nav>
</article>
<% }) %>
<% } %>
