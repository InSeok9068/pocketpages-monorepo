<% const flashMessage = params && params.__flash ? String(params.__flash).trim() : '' const isErrorFlash = /failed|error|not found|required|cannot|invalid/i.test(flashMessage) %> <% if (flashMessage)
{ %>
<p class="<%= `mb-6 ${isErrorFlash ? 'border-rose-200 text-rose-700' : 'border-emerald-200 text-emerald-700'}` %> rounded-2xl border bg-emerald-50 bg-rose-50 px-4 py-3 text-sm font-medium">
  <%= flashMessage %>
</p>
<% } %>
