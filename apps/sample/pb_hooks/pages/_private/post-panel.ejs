<%
  const panelBoard = selectedBoard || null;
  const panelBoardName = panelBoard ? panelBoard.name || selectedBoardSlug : '';
  const panelBoardPath = panelBoard ? panelBoard.path || '' : '';
  const panelError = typeof error === 'undefined' ? '' : String(error || '');
  const safePostItems = Array.isArray(typeof postItems === 'undefined' ? undefined : postItems) ? postItems : [];
%>
<article id="post-panel" class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
  <% if (!selectedBoardSlug) { %>
  <header class="space-y-3">
    <h2 class="text-2xl font-semibold text-stone-950">HTMX Post Panel</h2>
    <p class="max-w-2xl text-sm leading-6 text-stone-600">왼쪽 목록에서 게시판을 고르면 `xapi/posts/panel`이 이 영역만 다시 렌더링합니다.</p>
  </header>
  <% } else if (panelError) { %>
  <p class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= panelError %></p>
  <% } else if (!panelBoard) { %>
  <p class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700">Board not found.</p>
  <% } else { %>
  <header class="mb-5 flex flex-wrap items-start justify-between gap-4">
    <div class="min-w-0 space-y-2">
      <p class="text-xs uppercase tracking-[0.16em] text-stone-500">HTMX Fragment</p>
      <h2 class="text-2xl font-semibold text-stone-950"><%= panelBoardName %></h2>
      <p class="truncate text-sm text-stone-500"><%= panelBoardPath %></p>
      <p class="max-w-2xl text-sm leading-6 text-stone-600">HTMX 응답은 raw HTML만 반환하고, 전체 작성/수정은 full page route로 넘깁니다.</p>
      <p class="text-sm text-stone-500">
        JSON example:
        <a href="/api/boards/<%= encodeURIComponent(selectedBoardSlug) %>?limit=3" class="font-medium text-stone-700 no-underline hover:text-stone-900">
          /api/boards/<%= selectedBoardSlug %>?limit=3
        </a>
      </p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <a href="<%= panelBoardPath %>/posts/new" class="inline-flex items-center rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-white no-underline transition hover:bg-stone-700">
        Write post
      </a>
      <a
        href="<%= panelBoardPath %>"
        class="inline-flex items-center rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900"
      >
        Open board
      </a>
    </div>
  </header>

  <% if (!safePostItems.length) { %>
  <p class="text-sm text-stone-500">No published posts yet.</p>
  <% } else { %>
  <div class="space-y-3">
    <% safePostItems.forEach((postItem) => { %>
    <section class="rounded-2xl border border-stone-200 bg-stone-50 px-4 py-4">
      <h3 class="text-base font-semibold text-stone-900">
        <a href="<%= postItem.path %>" class="text-stone-900 no-underline hover:text-stone-700"><%= postItem.title %></a>
      </h3>
      <p class="mt-2 text-xs uppercase tracking-[0.14em] text-stone-500"><%= postItem.isNotice ? 'Notice' : 'Post' %> · <%= postItem.authorName %> · <%= postItem.publishedAt %></p>
    </section>
    <% }) %>
  </div>
  <% } %>
  <% } %>
</article>
