<script server>
  const boardService = resolve('board-service')
  const form = body()
  const boardSlug = String(form.board || '').trim()
  const title = String(form.title || '').trim()
  const slug = boardService.slugify(form.slug || form.title)
  const authorName = String(form.authorName || '').trim()
  const content = String(form.content || '').trim()
  const isNotice = String(form.isNotice || '') === 'true'
  const status = String(form.status || 'published').trim() || 'published'

  dbg('api/posts/create:start', { boardSlug, title, status, isNotice })

  const selectedBoard = boardService.findActiveBoardBySlug(boardSlug)
  let errorMessage = ''

  if (!selectedBoard) {
    warn('api/posts/create:board-not-found', { boardSlug })
    errorMessage = 'Board not found.'
  } else if (!title || !slug || !authorName || !content) {
    warn('api/posts/create:validation-failed', { boardSlug, title, slug, authorName })
    errorMessage = 'All fields are required.'
  }

  if (!errorMessage) {
    try {
      const collection = $app.findCollectionByNameOrId('posts')
      const record = new Record(collection)
      record.set('board', selectedBoard.id)
      record.set('title', title)
      record.set('slug', slug)
      record.set('content', content)
      record.set('author_name', authorName)
      record.set('status', status)
      record.set('is_notice', isNotice)
      record.set('view_count', 0)
      if (status === 'published') {
        record.set('published_at', new Date().toISOString())
      }
      $app.save(record)
      info('api/posts/create:success', { boardSlug, slug: record.get('slug') })
      response.redirect('/boards/' + encodeURIComponent(boardSlug) + '?__flash=' + encodeURIComponent('Post created.'), 303)
      return
    } catch (exception) {
      error('api/posts/create:save-failed', exception)
      errorMessage = String(exception.message || exception)
    }
  }
</script>
<% response.redirect('/boards/' + encodeURIComponent(boardSlug) + '?__flash=' + encodeURIComponent(errorMessage || 'Failed to create post.'), 303) %>
