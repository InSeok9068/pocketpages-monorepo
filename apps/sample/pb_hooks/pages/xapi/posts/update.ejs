<script server>
  const boardService = resolve('board-service')
  const form = body()
  const boardSlug = String(form.board || '').trim()
  const postSlug = String(form.post || '').trim()
  const title = String(form.title || '').trim()
  const nextSlug = boardService.slugify(form.slug || form.title)
  const authorName = String(form.authorName || '').trim()
  const content = String(form.content || '').trim()
  const status = String(form.status || 'draft').trim() || 'draft'
  const isNotice = String(form.isNotice || '') === 'true'

  dbg('api/posts/update:start', { boardSlug, postSlug, nextSlug, status, isNotice })

  const board = boardService.findActiveBoardBySlug(boardSlug)
  let post = null
  let errorMessage = ''

  if (!board) {
    warn('api/posts/update:board-not-found', { boardSlug })
    errorMessage = 'Board not found.'
  }

  if (!errorMessage) {
    post = boardService.findPostByBoardAndSlug(board.id, postSlug)

    if (!post) {
      warn('api/posts/update:post-not-found', { boardSlug, postSlug })
      errorMessage = 'Post not found.'
    }
  }

  if (!errorMessage && (!title || !nextSlug || !authorName || !content)) {
    warn('api/posts/update:validation-failed', { boardSlug, postSlug, nextSlug })
    errorMessage = 'All fields are required.'
  }

  if (!errorMessage) {
    try {
      post.set('title', title)
      post.set('slug', nextSlug)
      post.set('content', content)
      post.set('author_name', authorName)
      post.set('status', status)
      post.set('is_notice', isNotice)
      if (status === 'published' && !post.get('published_at')) {
        post.set('published_at', new Date().toISOString())
      }
      $app.save(post)
      info('api/posts/update:success', { boardSlug, previousSlug: postSlug, nextSlug })
      response.redirect(
        '/boards/' + encodeURIComponent(boardSlug) + '/posts/' + encodeURIComponent(nextSlug) + '?__flash=' + encodeURIComponent('Post updated.'),
        303
      )
      return
    } catch (exception) {
      error('api/posts/update:save-failed', exception)
      errorMessage = String(exception.message || exception)
    }
  }
</script>
<%
  const fallbackBoard = '/boards/' + encodeURIComponent(boardSlug)
  const fallbackPost = postSlug
    ? fallbackBoard + '/posts/' + encodeURIComponent(postSlug)
    : fallbackBoard
  response.redirect(fallbackPost + '?__flash=' + encodeURIComponent(errorMessage || 'Failed to update post.'), 303)
%>
