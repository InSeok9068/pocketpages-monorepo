<script server>
  const boardService = resolve('board-service');
  const boardSlug = String(request.url.query.board || '').trim();
  const selectedBoard = boardService.findActiveBoardBySlug(boardSlug);
  let posts = [];

  if (selectedBoard) {
    try {
      posts = $app.findRecordsByFilter('posts', 'board = {:boardId} && status = "published"', '-is_notice,-published_at,-created', 50, 0, { boardId: selectedBoard.id });
    } catch (error) {
      posts = [];
    }
  }
</script>
<%- include('post-panel.ejs', {
  selectedBoard,
  selectedBoardSlug: boardSlug,
  posts,
}) %>
