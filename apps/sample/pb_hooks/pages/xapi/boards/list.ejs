<script server>
  const selectedBoardSlug = String(request.url.query.board || '').trim();
  let boards = [];
  let errorMessage = '';

  dbg('xapi/boards/list:start', { selectedBoardSlug });

  try {
    boards = $app.findRecordsByFilter('boards', '', '+sort_order,+name', 50, 0);
  } catch (error) {
    warn('xapi/boards/list:load-failed', { message: String(error.message || error) });
    errorMessage = String(error.message || error);
  }

  dbg('xapi/boards/list:response', {
    boardCount: boards.length,
    selectedBoardSlug,
    error: errorMessage || '',
  });
</script>
<%- include('board-list.ejs', { boards, error: errorMessage, selectedBoardSlug }) %>
