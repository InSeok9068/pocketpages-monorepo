<% if (data.error) { %>
  <article class="rounded-3xl border border-rose-200 bg-white p-6 shadow-sm">
    <header class="space-y-4">
      <h1 class="text-3xl font-semibold text-stone-950"><%= data.error %></h1>
    </header>
    <p class="mt-4">
      <a href="/boards/<%= params.boardSlug %>" class="text-sm font-medium text-stone-600 no-underline hover:text-stone-900">
        Back to board
      </a>
    </p>
  </article>
<% } else { %>
  <% const boardName = data.board.get('name') || params.boardSlug %>
  <% const title = data.post.get('title') || params.postSlug %>
  <% const status = data.post.get('status') || 'draft' %>
  <% const authorName = data.post.get('author_name') || 'unknown' %>
  <% const publishedAt = data.post.get('published_at') || data.post.created || '' %>
  <% const content = data.post.get('content') || '' %>

  <header class="mb-8 space-y-4">
    <p>
      <a href="/boards/<%= params.boardSlug %>" class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900">
        <%= boardName %>
      </a>
    </p>
    <h1 class="text-4xl font-semibold tracking-tight text-stone-950"><%= title %></h1>
    <p class="text-sm uppercase tracking-[0.14em] text-stone-500"><%= status %> · <%= authorName %> · <%= publishedAt %></p>
  </header>

  <% if (params.__flash) { %>
    <p class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
      <%= params.__flash %>
    </p>
  <% } %>

  <article class="mb-6 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
    <header class="mb-4">
      <h2 class="text-2xl font-semibold text-stone-950">Content</h2>
    </header>
    <div class="max-w-none leading-7 text-stone-700"><%- content %></div>
  </article>

  <article class="mb-6 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
    <header class="mb-5">
      <h2 class="text-2xl font-semibold text-stone-950">Edit Post</h2>
    </header>

    <form action="/api/posts/update" method="post" class="max-w-2xl space-y-4">
      <input type="hidden" name="board" value="<%= params.boardSlug %>" />
      <input type="hidden" name="post" value="<%= params.postSlug %>" />

      <label class="block">
        Title
        <input
          type="text"
          name="title"
          maxlength="200"
          value="<%= title %>"
          required
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        />
      </label>

      <label class="block">
        Slug
        <input
          type="text"
          name="slug"
          value="<%= data.post.get('slug') || params.postSlug %>"
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        />
      </label>

      <label class="block">
        Author
        <input
          type="text"
          name="authorName"
          value="<%= authorName %>"
          required
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        />
      </label>

      <label class="block">
        Content
        <textarea
          name="content"
          rows="10"
          required
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        ><%= content %></textarea>
      </label>

      <label class="block">
        Status
        <select
          name="status"
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        >
          <option value="published" <%= status === 'published' ? 'selected' : '' %>>Published</option>
          <option value="draft" <%= status === 'draft' ? 'selected' : '' %>>Draft</option>
          <option value="archived" <%= status === 'archived' ? 'selected' : '' %>>Archived</option>
        </select>
      </label>

      <label class="flex items-center gap-3 text-sm text-stone-700">
        <input type="checkbox" name="isNotice" value="true" <%= data.post.get('is_notice') ? 'checked' : '' %> />
        Notice
      </label>

      <button
        type="submit"
        class="inline-flex items-center rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-stone-700"
      >
        Save changes
      </button>
    </form>
  </article>

  <article class="rounded-3xl border border-rose-200 bg-rose-50 p-6 shadow-sm">
    <header class="mb-5">
      <h2 class="text-2xl font-semibold text-rose-900">Delete Post</h2>
    </header>

    <form action="/api/posts/delete" method="post">
      <input type="hidden" name="board" value="<%= params.boardSlug %>" />
      <input type="hidden" name="post" value="<%= params.postSlug %>" />
      <button
        type="submit"
        class="inline-flex items-center rounded-full bg-rose-700 px-4 py-2 text-sm font-medium text-white transition hover:bg-rose-600"
      >
        Delete post
      </button>
    </form>
  </article>
<% } %>
