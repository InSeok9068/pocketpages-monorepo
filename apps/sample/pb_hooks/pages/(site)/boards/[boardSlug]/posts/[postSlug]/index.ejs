<script server>
  const boardSlug = String(params.boardSlug || '').trim()
  const postSlug = String(params.postSlug || '').trim()
  let board = null
  let post = null

  try {
    board = $app.findFirstRecordByFilter(
      'boards',
      'slug = {:slug} && is_active = true',
      { slug: boardSlug }
    )
  } catch (error) {
    board = null
  }

  if (!board) {
    response.status(404)
    meta('title', 'Board Not Found')
  } else {
    try {
      post = $app.findFirstRecordByFilter(
        'posts',
        'board = {:boardId} && slug = {:slug}',
        { boardId: board.id, slug: postSlug }
      )
    } catch (error) {
      post = null
    }

    if (!post) {
      response.status(404)
      meta('title', 'Post Not Found')
    } else {
      meta('title', `${post.get('title') || postSlug} | ${board.get('name') || boardSlug}`)
      meta('description', board.get('description') || `Post ${postSlug}`)
    }
  }

  const data = !board
    ? {
        board: null,
        post: null,
        error: 'Board not found',
      }
    : !post
      ? {
          board,
          post: null,
          error: 'Post not found',
        }
      : {
          board,
          post,
          error: '',
        }
</script>

<% if (data.error) { %>
  <article rounded-3xl border="~ rose-200" bg-white p-6 shadow="sm">
    <header space-y-4>
      <h1 text="3xl stone-950" font-semibold><%= data.error %></h1>
    </header>
    <p mt-4>
      <a href="/boards/<%= params.boardSlug %>" text="sm stone-600 hover:stone-900" font-medium no-underline>
        Back to board
      </a>
    </p>
  </article>
<% } else { %>
  <% const boardName = data.board.get('name') || params.boardSlug %>
  <% const title = data.post.get('title') || params.postSlug %>
  <% const status = data.post.get('status') || 'draft' %>
  <% const authorName = data.post.get('author_name') || 'unknown' %>
  <% const publishedAt = data.post.get('published_at') || data.post.created || '' %>
  <% const content = data.post.get('content') || '' %>

  <header mb-8 space-y-4>
    <p>
      <a href="/boards/<%= params.boardSlug %>" text="sm stone-500 hover:stone-900" font-medium no-underline>
        <%= boardName %>
      </a>
    </p>
    <h1 text="4xl stone-950" font-semibold tracking-tight><%= title %></h1>
    <p text="sm stone-500" uppercase tracking="[0.14em]"><%= status %> · <%= authorName %> · <%= publishedAt %></p>
  </header>

  <% if (params.__flash) { %>
    <p mb-6 rounded-2xl border="~ emerald-200" bg="emerald-50" px-4 py-3 text="sm emerald-700" font-medium>
      <%= params.__flash %>
    </p>
  <% } %>

  <article mb-6 rounded-3xl border="~ stone-200" bg-white p-6 shadow="sm">
    <header mb-4>
      <h2 text="2xl stone-950" font-semibold>Content</h2>
    </header>
    <div max-w-none leading-7 text="stone-700"><%- content %></div>
  </article>

  <article mb-6 rounded-3xl border="~ stone-200" bg-white p-6 shadow="sm">
    <header mb-5>
      <h2 text="2xl stone-950" font-semibold>Edit Post</h2>
    </header>

    <form action="/api/posts/update" method="post" max-w-2xl space-y-4>
      <input type="hidden" name="board" value="<%= params.boardSlug %>" />
      <input type="hidden" name="post" value="<%= params.postSlug %>" />

      <label block>
        Title
        <input
          type="text"
          name="title"
          maxlength="200"
          value="<%= title %>"
          required
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        />
      </label>

      <label block>
        Slug
        <input
          type="text"
          name="slug"
          value="<%= data.post.get('slug') || params.postSlug %>"
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        />
      </label>

      <label block>
        Author
        <input
          type="text"
          name="authorName"
          value="<%= authorName %>"
          required
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        />
      </label>

      <label block>
        Content
        <textarea
          name="content"
          rows="10"
          required
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        ><%= content %></textarea>
      </label>

      <label block>
        Status
        <select
          name="status"
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        >
          <option value="published" <%= status === 'published' ? 'selected' : '' %>>Published</option>
          <option value="draft" <%= status === 'draft' ? 'selected' : '' %>>Draft</option>
          <option value="archived" <%= status === 'archived' ? 'selected' : '' %>>Archived</option>
        </select>
      </label>

      <label flex items-center gap-3 text="sm stone-700">
        <input type="checkbox" name="isNotice" value="true" <%= data.post.get('is_notice') ? 'checked' : '' %> />
        Notice
      </label>

      <button
        type="submit"
        inline-flex items-center rounded-full bg="stone-900 hover:stone-700" px-4 py-2 text="sm white" font-medium transition
      >
        Save changes
      </button>
    </form>
  </article>

  <article rounded-3xl border="~ rose-200" bg="rose-50" p-6 shadow="sm">
    <header mb-5>
      <h2 text="2xl rose-900" font-semibold>Delete Post</h2>
    </header>

    <form action="/api/posts/delete" method="post">
      <input type="hidden" name="board" value="<%= params.boardSlug %>" />
      <input type="hidden" name="post" value="<%= params.postSlug %>" />
      <button
        type="submit"
        inline-flex items-center rounded-full bg="rose-700 hover:rose-600" px-4 py-2 text="sm white" font-medium transition
      >
        Delete post
      </button>
    </form>
  </article>
<% } %>
