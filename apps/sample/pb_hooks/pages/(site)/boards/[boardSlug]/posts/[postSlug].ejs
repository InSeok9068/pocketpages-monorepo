<script server>
  const boardService = resolve('board-service')
  const postService = resolve('post-service')
  const postRole = resolve('roles/post')
  const sharedData = data || {}
  const board = sharedData.board || null
  const post = sharedData.post || null
  const boardSummary = boardService.toBoardSummary(board)
  let postDetail = null

  if (!boardSummary) {
    response.status(404)
    meta('title', 'Board Not Found')
  } else {
    if (!post) {
      response.status(404)
      meta('title', 'Post Not Found')
    } else {
      if (postRole.canIncrementViewCount(post)) {
        try {
          post.set('view_count', Number(post.get('view_count') || 0) + 1)
          $app.save(post)
          info('page/posts/show:view-incremented', {
            boardSlug: boardSummary.slug,
            postSlug: String(params.postSlug || '').trim(),
            viewCount: post.get('view_count'),
          })
        } catch (error) {
          warn('page/posts/show:view-increment-failed', {
            boardSlug: boardSummary.slug,
            postSlug: String(params.postSlug || '').trim(),
            message: String(error.message || error),
          })
        }
      }

      postDetail = postService.toPostDetail(post, boardSummary.slug)
      meta('title', `${postDetail.title} | ${boardSummary.name || boardSummary.slug}`)
      meta('description', boardSummary.description || `Post ${postDetail.slug}`)
    }
  }

  const pageData = !boardSummary
    ? {
        board: null,
        post: null,
        error: 'Board not found',
      }
    : !postDetail
      ? {
          board: boardSummary,
          post: null,
          error: 'Post not found',
        }
      : {
          board: boardSummary,
          post: postDetail,
          error: '',
        }

  dbg('page/posts/show:response', {
    boardSlug: pageData.board ? pageData.board.slug : String(params.boardSlug || '').trim(),
    postSlug: pageData.post ? pageData.post.slug : String(params.postSlug || '').trim(),
    error: pageData.error || '',
    status: pageData.post ? pageData.post.status : '',
    viewCount: pageData.post ? pageData.post.viewCount : 0,
  })
</script>

<% if (pageData.error) { %>
<article class="rounded-3xl border border-rose-200 bg-white p-6 shadow-sm">
  <header class="space-y-4">
    <h1 class="text-3xl font-semibold text-stone-950"><%= pageData.error %></h1>
  </header>
  <p class="mt-4">
    <a
      href="/boards/<%= params.boardSlug %>"
      class="text-sm font-medium text-stone-600 no-underline hover:text-stone-900">
      Back to board
    </a>
  </p>
</article>
<% } else { %>

<header class="mb-8 space-y-4">
  <p>
    <a
      href="<%= pageData.board.path %>"
      class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900">
      <%= pageData.board.name %>
    </a>
  </p>
  <h1 class="text-4xl font-semibold tracking-tight text-stone-950"><%= pageData.post.title %></h1>
  <p class="text-sm uppercase tracking-[0.14em] text-stone-500">
    <%= pageData.post.isNotice ? 'Notice' : 'Post' %> · <%= pageData.post.status %> · <%= pageData.post.authorName %> · <%= pageData.post.publishedAt %> · views
    <%= pageData.post.viewCount %>
  </p>
</header>

<%- include('flash-alert.ejs') %>

<article class="mb-6 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
  <header class="mb-5 flex items-center justify-between gap-4">
    <div>
      <h2 class="text-2xl font-semibold text-stone-950">Content</h2>
    </div>
    <nav class="flex items-center gap-3">
      <a
        href="<%= pageData.post.editPath %>"
        class="inline-flex items-center rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900">
        Edit post
      </a>
    </nav>
  </header>
  <div class="max-w-none leading-7 text-stone-700"><%= pageData.post.content %></div>
</article>
<% } %>
