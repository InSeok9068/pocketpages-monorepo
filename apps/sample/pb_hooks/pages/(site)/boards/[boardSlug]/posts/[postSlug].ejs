<script server>
  const boardService = resolve("board-service");
  const postRole = resolve("roles/post");
  const sharedData = data || {};
  const board = sharedData.board || null;
  const boardSlug = String(params.boardSlug || "").trim();
  const postSlug = String(params.postSlug || "").trim();
  let post = null;

  if (!board) {
    response.status(404);
    meta("title", "Board Not Found");
  } else {
    post = boardService.findPostByBoardAndSlug(board.id, postSlug);

    if (!post) {
      response.status(404);
      meta("title", "Post Not Found");
    } else {
      if (postRole.canIncrementViewCount(post)) {
        try {
          post.set("view_count", Number(post.get("view_count") || 0) + 1);
          $app.save(post);
          info("page/posts/show:view-incremented", {
            boardSlug,
            postSlug,
            viewCount: post.get("view_count"),
          });
        } catch (error) {
          warn("page/posts/show:view-increment-failed", {
            boardSlug,
            postSlug,
            message: String(error.message || error),
          });
        }
      }

      meta("title", `${post.get("title") || postSlug} | ${board.get("name") || boardSlug}`);
      meta("description", board.get("description") || `Post ${postSlug}`);
    }
  }

  const pageData = !board
    ? {
        board: null,
        post: null,
        error: "Board not found",
      }
    : !post
      ? {
          board,
          post: null,
          error: "Post not found",
        }
      : {
          board,
          post,
          boardName: board.get("name") || boardSlug,
          title: post.get("title") || postSlug,
          status: post.get("status") || "draft",
          authorName: post.get("author_name") || "unknown",
          publishedAt: post.get("published_at") || post.created || "",
          content: post.get("content") || "",
          viewCount: post.get("view_count") || 0,
          error: "",
        };

  dbg("page/posts/show:response", {
    boardSlug,
    postSlug,
    error: pageData.error || "",
    status: pageData.post ? pageData.post.get("status") || "" : "",
    viewCount: pageData.post ? pageData.post.get("view_count") || 0 : 0,
  });
</script>

<% if (pageData.error) { %>
<article class="rounded-3xl border border-rose-200 bg-white p-6 shadow-sm">
  <header class="space-y-4">
    <h1 class="text-3xl font-semibold text-stone-950"><%= pageData.error %></h1>
  </header>
  <p class="mt-4">
    <a href="/boards/<%= params.boardSlug %>" class="text-sm font-medium text-stone-600 no-underline hover:text-stone-900"> Back to board </a>
  </p>
</article>
<% } else { %>

<header class="mb-8 space-y-4">
  <p>
    <a href="/boards/<%= params.boardSlug %>" class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900"> <%= pageData.boardName %> </a>
  </p>
  <h1 class="text-4xl font-semibold tracking-tight text-stone-950"><%= pageData.title %></h1>
  <p class="text-sm uppercase tracking-[0.14em] text-stone-500"><%= pageData.status %> · <%= pageData.authorName %> · <%= pageData.publishedAt %> · views <%= pageData.viewCount %></p>
</header>

<%- include('flash-alert.ejs') %>

<article class="mb-6 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
  <header class="mb-5 flex items-center justify-between gap-4">
    <div>
      <h2 class="text-2xl font-semibold text-stone-950">Content</h2>
    </div>
    <nav class="flex items-center gap-3">
      <a
        href="/boards/<%= params.boardSlug %>/posts/<%= params.postSlug %>/edit"
        class="inline-flex items-center rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900"
      >
        Edit post
      </a>
    </nav>
  </header>
  <div class="max-w-none leading-7 text-stone-700"><%= pageData.content %></div>
</article>
<% } %>
