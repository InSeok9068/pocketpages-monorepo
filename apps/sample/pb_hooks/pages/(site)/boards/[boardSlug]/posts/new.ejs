<script server>
  const boardService = resolve('board-service')
  const sharedData = data || {}
  const board = sharedData.board || null
  const boardSummary = boardService.toBoardSummary(board)

  if (!boardSummary) {
    response.status(404)
    meta('title', 'Board Not Found')
  } else {
    meta('title', `Write Post | ${boardSummary.name || boardSummary.slug}`)
    meta('description', boardSummary.description || `Write post in ${boardSummary.slug}`)
  }

  const pageData = boardSummary
    ? {
        board: boardSummary,
        error: '',
      }
    : {
        board: null,
        error: 'Board not found',
      }

  dbg('page/posts/new:response', {
    boardSlug: pageData.board ? pageData.board.slug : String(params.boardSlug || '').trim(),
    error: pageData.error || '',
    boardId: pageData.board ? pageData.board.id : '',
  })
</script>

<% if (pageData.error) { %>
<article class="rounded-3xl border border-rose-200 bg-white p-6 shadow-sm">
  <header class="space-y-4">
    <h1 class="text-3xl font-semibold text-stone-950"><%= pageData.error %></h1>
  </header>
  <p class="mt-4">
    <a
      href="/boards/<%= params.boardSlug %>"
      class="text-sm font-medium text-stone-600 no-underline hover:text-stone-900">
      Back to board
    </a>
  </p>
</article>
<% } else { %>

<header class="mb-8 space-y-4">
  <p>
    <a
      href="<%= pageData.board.path %>"
      class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900">
      <%= pageData.board.name %>
    </a>
  </p>
  <h1 class="text-4xl font-semibold tracking-tight text-stone-950">Write Post</h1>
  <p class="max-w-2xl text-base leading-7 text-stone-600">새 글 작성만 분리한 화면입니다.</p>
</header>

<%- include('flash-alert.ejs') %>

<article class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
  <%- include('post-form.ejs', {
  formAction: '/xapi/posts/create',
  boardSlug: pageData.board.slug,
  postSlug: '',
  submitLabel: 'Create post',
  textareaRows: 8,
  values: {
    title: '',
    slug: '',
    authorName: '',
    content: '',
    status: 'published',
    isNotice: false,
  },
}) %>
</article>
<% } %>
