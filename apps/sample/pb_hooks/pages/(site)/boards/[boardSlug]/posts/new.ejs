<script server>
  const sharedData = data || {}
  const board = sharedData.board || null
  const boardSlug = String(params.boardSlug || '').trim()

  if (!board) {
    response.status(404)
    meta('title', 'Board Not Found')
  } else {
    meta('title', `Write Post | ${board.get('name') || boardSlug}`)
    meta('description', board.get('description') || `Write post in ${boardSlug}`)
  }

  const pageData = board
    ? {
        board,
        error: '',
      }
    : {
        board: null,
        error: 'Board not found',
      }
</script>

<% if (pageData.error) { %>
  <article rounded-3xl border="~ rose-200" bg-white p-6 shadow="sm">
    <header space-y-4>
      <h1 text="3xl stone-950" font-semibold><%= pageData.error %></h1>
    </header>
    <p mt-4>
      <a href="/boards/<%= params.boardSlug %>" text="sm stone-600 hover:stone-900" font-medium no-underline>
        Back to board
      </a>
    </p>
  </article>
<% } else { %>
  <% const boardName = pageData.board.get('name') || params.boardSlug %>

  <header mb-8 space-y-4>
    <p>
      <a href="/boards/<%= params.boardSlug %>" text="sm stone-500 hover:stone-900" font-medium no-underline>
        <%= boardName %>
      </a>
    </p>
    <h1 text="4xl stone-950" font-semibold tracking-tight>Write Post</h1>
    <p max-w-2xl text="base stone-600" leading-7>새 글 작성만 분리한 화면입니다.</p>
  </header>

  <% if (params.__flash) { %>
    <p mb-6 rounded-2xl border="~ emerald-200" bg="emerald-50" px-4 py-3 text="sm emerald-700" font-medium>
      <%= params.__flash %>
    </p>
  <% } %>

  <article rounded-3xl border="~ stone-200" bg-white p-6 shadow="sm">
    <form action="/api/posts/create" method="post" max-w-2xl space-y-4>
      <input type="hidden" name="board" value="<%= params.boardSlug %>" />

      <label block>
        Title
        <input
          type="text"
          name="title"
          maxlength="200"
          required
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        />
      </label>

      <label block>
        Slug
        <input
          type="text"
          name="slug"
          placeholder="welcome-post"
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        />
      </label>

      <label block>
        Author
        <input
          type="text"
          name="authorName"
          placeholder="Admin"
          required
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        />
      </label>

      <label block>
        Content
        <textarea
          name="content"
          rows="8"
          required
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        ></textarea>
      </label>

      <label block>
        Status
        <select
          name="status"
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        >
          <option value="published">Published</option>
          <option value="draft">Draft</option>
          <option value="archived">Archived</option>
        </select>
      </label>

      <label flex items-center gap-3 text="sm stone-700">
        <input type="checkbox" name="isNotice" value="true" />
        Notice
      </label>

      <button
        type="submit"
        inline-flex items-center rounded-full bg="stone-900 hover:stone-700" px-4 py-2 text="sm white" font-medium transition
      >
        Create post
      </button>
    </form>
  </article>
<% } %>
