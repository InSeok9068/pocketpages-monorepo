<script server>
  const boardService = resolve('board-service')
  const postService = resolve('post-service')
  const sharedData = data || {}
  const board = sharedData.board || null
  const post = sharedData.post || null
  const boardSummary = boardService.toBoardSummary(board)
  const postDetail = postService.toPostDetail(post, String(params.boardSlug || '').trim())

  if (!boardSummary) {
    response.status(404)
    meta('title', 'Board Not Found')
  } else if (!postDetail) {
    response.status(404)
    meta('title', 'Post Not Found')
  } else {
    meta('title', `Edit ${postDetail.title} | ${boardSummary.name || boardSummary.slug}`)
    meta('description', boardSummary.description || `Edit post ${postDetail.slug}`)
  }

  const pageData = !boardSummary
    ? {
        board: null,
        post: null,
        error: 'Board not found',
      }
    : !postDetail
      ? {
          board: boardSummary,
          post: null,
          error: 'Post not found',
        }
      : {
          board: boardSummary,
          post: postDetail,
          formValues: postService.toPostFormValues(post),
          error: '',
        }

  dbg('page/posts/edit:response', {
    boardSlug: pageData.board ? pageData.board.slug : String(params.boardSlug || '').trim(),
    postSlug: pageData.post ? pageData.post.slug : String(params.postSlug || '').trim(),
    error: pageData.error || '',
    status: pageData.post ? pageData.post.status : '',
  })
</script>

<% if (pageData.error) { %>
<article class="rounded-3xl border border-rose-200 bg-white p-6 shadow-sm">
  <header class="space-y-4">
    <h1 class="text-3xl font-semibold text-stone-950"><%= pageData.error %></h1>
  </header>
  <p class="mt-4">
    <a
      href="/boards/<%= params.boardSlug %>"
      class="text-sm font-medium text-stone-600 no-underline hover:text-stone-900"
    >
      Back to board
    </a>
  </p>
</article>
<% } else { %>
<header class="mb-8 space-y-4">
  <p>
    <a
      href="<%= pageData.post.path %>"
      class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900"
    >
      <%= pageData.post.title %>
    </a>
  </p>
  <h1 class="text-4xl font-semibold tracking-tight text-stone-950">Edit Post</h1>
  <p class="max-w-2xl text-base leading-7 text-stone-600"><%= pageData.board.name %> 게시판의 게시글을 수정합니다.</p>
</header>

<%- include('flash-alert.ejs') %>

<article class="mb-6 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
  <header class="mb-5 flex items-center justify-between gap-4">
    <div>
      <h2 class="text-2xl font-semibold text-stone-950">Edit Fields</h2>
    </div>
    <a
      href="<%= pageData.post.path %>"
      class="inline-flex items-center rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900"
    >
      View post
    </a>
  </header>

  <%- include('post-form.ejs', {
  formAction: '/xapi/posts/update',
  boardSlug: params.boardSlug,
  postSlug: params.postSlug,
  submitLabel: 'Save changes',
  textareaRows: 10,
  values: pageData.formValues,
}) %>
</article>

<article class="rounded-3xl border border-rose-200 bg-rose-50 p-6 shadow-sm">
  <header class="mb-5">
    <h2 class="text-2xl font-semibold text-rose-900">Delete Post</h2>
  </header>

  <form
    action="/xapi/posts/delete"
    method="post"
  >
    <input
      type="hidden"
      name="board"
      value="<%= pageData.board.slug %>"
    />
    <input
      type="hidden"
      name="post"
      value="<%= pageData.post.slug %>"
    />
    <button
      type="submit"
      class="inline-flex items-center rounded-full bg-rose-700 px-4 py-2 text-sm font-medium text-white transition hover:bg-rose-600"
    >
      Delete post
    </button>
  </form>
</article>
<% } %>
