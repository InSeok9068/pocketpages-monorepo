<script server>
  const boardService = resolve('board-service');
  const sharedData = data || {};
  const board = sharedData.board || null;
  const boardSlug = String(params.boardSlug || '').trim();
  const postSlug = String(params.postSlug || '').trim();
  let post = null;

  if (!board) {
    response.status(404);
    meta('title', 'Board Not Found');
  } else {
    post = boardService.findPostByBoardAndSlug(board.id, postSlug);

    if (!post) {
      response.status(404);
      meta('title', 'Post Not Found');
    } else {
      meta('title', `Edit ${post.get('title') || postSlug} | ${board.get('name') || boardSlug}`);
      meta('description', board.get('description') || `Edit post ${postSlug}`);
    }
  }

  const pageData = !board
    ? {
        board: null,
        post: null,
        error: 'Board not found',
      }
    : !post
      ? {
          board,
          post: null,
          error: 'Post not found',
        }
      : {
          board,
          post,
          boardName: board.get('name') || boardSlug,
          postTitle: post.get('title') || postSlug,
          formValues: {
            title: post.get('title') || '',
            slug: post.get('slug') || postSlug,
            authorName: post.get('author_name') || '',
            content: post.get('content') || '',
            status: post.get('status') || 'draft',
            isNotice: !!post.get('is_notice'),
          },
          error: '',
        };

  dbg('page/posts/edit:response', {
    boardSlug,
    postSlug,
    error: pageData.error || '',
    status: pageData.post ? pageData.post.get('status') || '' : '',
  });
</script>

<% if (pageData.error) { %>
<article class="rounded-3xl border border-rose-200 bg-white p-6 shadow-sm">
  <header class="space-y-4">
    <h1 class="text-3xl font-semibold text-stone-950"><%= pageData.error %></h1>
  </header>
  <p class="mt-4">
    <a href="/boards/<%= params.boardSlug %>" class="text-sm font-medium text-stone-600 no-underline hover:text-stone-900"> Back to board </a>
  </p>
</article>
<% } else { %>
<header class="mb-8 space-y-4">
  <p>
    <a href="/boards/<%= params.boardSlug %>/posts/<%= params.postSlug %>" class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900"> <%= pageData.postTitle %> </a>
  </p>
  <h1 class="text-4xl font-semibold tracking-tight text-stone-950">Edit Post</h1>
  <p class="max-w-2xl text-base leading-7 text-stone-600"><%= pageData.boardName %> 게시판의 게시글을 수정합니다.</p>
</header>

<%- include('flash-alert.ejs') %>

<article class="mb-6 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
  <header class="mb-5 flex items-center justify-between gap-4">
    <div>
      <h2 class="text-2xl font-semibold text-stone-950">Edit Fields</h2>
    </div>
    <a
      href="/boards/<%= params.boardSlug %>/posts/<%= params.postSlug %>"
      class="inline-flex items-center rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900"
    >
      View post
    </a>
  </header>

  <%- include('post-form.ejs', {
  formAction: '/xapi/posts/update',
  boardSlug: params.boardSlug,
  postSlug: params.postSlug,
  submitLabel: 'Save changes',
  textareaRows: 10,
  values: pageData.formValues,
}) %>
</article>

<article class="rounded-3xl border border-rose-200 bg-rose-50 p-6 shadow-sm">
  <header class="mb-5">
    <h2 class="text-2xl font-semibold text-rose-900">Delete Post</h2>
  </header>

  <form action="/xapi/posts/delete" method="post">
    <input type="hidden" name="board" value="<%= params.boardSlug %>" />
    <input type="hidden" name="post" value="<%= params.postSlug %>" />
    <button type="submit" class="inline-flex items-center rounded-full bg-rose-700 px-4 py-2 text-sm font-medium text-white transition hover:bg-rose-600">Delete post</button>
  </form>
</article>
<% } %>
