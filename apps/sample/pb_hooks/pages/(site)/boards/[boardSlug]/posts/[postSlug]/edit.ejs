<script server>
  const boardService = resolve('board-service')
  const sharedData = data || {}
  const board = sharedData.board || null
  const boardSlug = String(params.boardSlug || '').trim()
  const postSlug = String(params.postSlug || '').trim()
  let post = null

  if (!board) {
    response.status(404)
    meta('title', 'Board Not Found')
  } else {
    post = boardService.findPostByBoardAndSlug(board.id, postSlug)

    if (!post) {
      response.status(404)
      meta('title', 'Post Not Found')
    } else {
      meta('title', `Edit ${post.get('title') || postSlug} | ${board.get('name') || boardSlug}`)
      meta('description', board.get('description') || `Edit post ${postSlug}`)
    }
  }

  const pageData = !board
    ? {
        board: null,
        post: null,
        error: 'Board not found',
      }
    : !post
      ? {
          board,
          post: null,
          error: 'Post not found',
        }
      : {
          board,
          post,
          error: '',
        }
</script>

<% if (pageData.error) { %>
  <article rounded-3xl border="~ rose-200" bg-white p-6 shadow="sm">
    <header space-y-4>
      <h1 text="3xl stone-950" font-semibold><%= pageData.error %></h1>
    </header>
    <p mt-4>
      <a href="/boards/<%= params.boardSlug %>" text="sm stone-600 hover:stone-900" font-medium no-underline>
        Back to board
      </a>
    </p>
  </article>
<% } else { %>
  <% const boardName = pageData.board.get('name') || params.boardSlug %>
  <% const postTitle = pageData.post.get('title') || params.postSlug %>
  <header mb-8 space-y-4>
    <p>
      <a href="/boards/<%= params.boardSlug %>/posts/<%= params.postSlug %>" text="sm stone-500 hover:stone-900" font-medium no-underline>
        <%= postTitle %>
      </a>
    </p>
    <h1 text="4xl stone-950" font-semibold tracking-tight>Edit Post</h1>
    <p max-w-2xl text="base stone-600" leading-7><%= boardName %> 게시판의 게시글을 수정합니다.</p>
  </header>

  <% if (params.__flash) { %>
    <p mb-6 rounded-2xl border="~ emerald-200" bg="emerald-50" px-4 py-3 text="sm emerald-700" font-medium>
      <%= params.__flash %>
    </p>
  <% } %>

  <article mb-6 rounded-3xl border="~ stone-200" bg-white p-6 shadow="sm">
    <header mb-5 flex items-center justify-between gap-4>
      <div>
        <h2 text="2xl stone-950" font-semibold>Edit Fields</h2>
      </div>
      <a
        href="/boards/<%= params.boardSlug %>/posts/<%= params.postSlug %>"
        inline-flex items-center rounded-full border="~ stone-300 hover:stone-900" px-4 py-2 text="sm stone-700 hover:stone-900" font-medium no-underline transition
      >
        View post
      </a>
    </header>

    <%- include('post-form.ejs', {
      formAction: '/xapi/posts/update',
      boardSlug: params.boardSlug,
      postSlug: params.postSlug,
      submitLabel: 'Save changes',
      textareaRows: 10,
      values: {
        title: pageData.post.get('title') || '',
        slug: pageData.post.get('slug') || params.postSlug,
        authorName: pageData.post.get('author_name') || '',
        content: pageData.post.get('content') || '',
        status: pageData.post.get('status') || 'draft',
        isNotice: !!pageData.post.get('is_notice'),
      },
    }) %>
  </article>

  <article rounded-3xl border="~ rose-200" bg="rose-50" p-6 shadow="sm">
    <header mb-5>
      <h2 text="2xl rose-900" font-semibold>Delete Post</h2>
    </header>

    <form action="/xapi/posts/delete" method="post">
      <input type="hidden" name="board" value="<%= params.boardSlug %>" />
      <input type="hidden" name="post" value="<%= params.postSlug %>" />
      <button
        type="submit"
        inline-flex items-center rounded-full bg="rose-700 hover:rose-600" px-4 py-2 text="sm white" font-medium transition
      >
        Delete post
      </button>
    </form>
  </article>
<% } %>
