<% if (data.error) { %>
  <article>
    <header>
      <h1><%= data.error %></h1>
    </header>
    <p><a href="/">Back to home</a></p>
  </article>
<% } else { %>
  <% const boardName = data.board.get('name') || params.boardSlug %>
  <% const boardDescription = data.board.get('description') || 'No description' %>

  <header>
    <p><a href="/">Home</a></p>
    <h1><%= boardName %></h1>
    <p><%= boardDescription %></p>
  </header>

  <article>
    <header>
      <h2>Published Posts</h2>
      <p><small>/boards/<%= params.boardSlug %></small></p>
    </header>

    <% if (!data.posts.length) { %>
      <p><em>No published posts yet.</em></p>
    <% } else { %>
      <% data.posts.forEach((post) => { %>
        <% const title = post.get('title') || '(untitled post)' %>
        <% const authorName = post.get('author_name') || 'unknown' %>
        <% const isNotice = !!post.get('is_notice') %>
        <% const publishedAt = post.get('published_at') || post.created %>
        <section>
          <h3><%= title %></h3>
          <p>
            <small><%= isNotice ? 'Notice' : 'Post' %> · <%= authorName %> · <%= publishedAt %></small>
          </p>
        </section>
      <% }) %>
    <% } %>
  </article>
<% } %>
