<script server>
  const sharedData = data || {}
  const boardSlug = String(params.boardSlug || '').trim()
  const board = sharedData.board || null
  let posts = []

  if (!board) {
    response.status(404)
    meta('title', 'Board Not Found')
  } else {
    meta('title', `${board.get('name') || boardSlug} | PocketPages Board`)
    meta('description', board.get('description') || `Board ${boardSlug}`)

    try {
      posts = $app.findRecordsByFilter(
        'posts',
        'board = {:boardId}',
        '-is_notice,-published_at,-created',
        50,
        0,
        { boardId: board.id }
      )
    } catch (error) {
      posts = []
    }
  }

  const pageData = board
    ? {
        board,
        posts,
        error: '',
      }
    : {
        board: null,
        posts: [],
        error: 'Board not found',
      }

  dbg('page/boards/show:response', {
    boardSlug,
    error: pageData.error || '',
    postCount: pageData.posts.length,
  })
</script>

<% if (pageData.error) { %>
  <article rounded-3xl border="~ rose-200" bg-white p-6 shadow="sm">
    <header space-y-4>
      <h1 text="3xl stone-950" font-semibold><%= pageData.error %></h1>
    </header>
    <p mt-4>
      <a href="/boards" text="sm stone-600 hover:stone-900" font-medium no-underline>Back to boards</a>
    </p>
  </article>
<% } else { %>
  <% const boardName = pageData.board.get('name') || params.boardSlug %>
  <% const boardDescription = pageData.board.get('description') || 'No description' %>

  <header mb-8 space-y-4>
    <p>
      <a href="/boards" text="sm stone-500 hover:stone-900" font-medium no-underline>Boards</a>
    </p>
    <h1 text="4xl stone-950" font-semibold tracking-tight><%= boardName %></h1>
    <p max-w-3xl text="base stone-600" leading-7><%= boardDescription %></p>
  </header>

  <% if (params.__flash) { %>
    <p mb-6 rounded-2xl border="~ emerald-200" bg="emerald-50" px-4 py-3 text="sm emerald-700" font-medium>
      <%= params.__flash %>
    </p>
  <% } %>

  <article mb-6 rounded-3xl border="~ stone-200" bg-white p-6 shadow="sm">
    <header mb-4>
      <h2 text="2xl stone-950" font-semibold>Actions</h2>
    </header>
    <nav>
      <a
        href="/boards/<%= params.boardSlug %>/posts/new"
        inline-flex items-center rounded-full bg="stone-900 hover:stone-700" px-4 py-2 text="sm white" font-medium no-underline transition
      >
        Write new post
      </a>
    </nav>
  </article>

  <article rounded-3xl border="~ stone-200" bg-white p-6 shadow="sm">
    <header mb-5 space-y-2>
      <h2 text="2xl stone-950" font-semibold>Posts</h2>
      <p text="sm stone-500">/boards/<%= params.boardSlug %></p>
    </header>

    <% if (!pageData.posts.length) { %>
      <p text="sm stone-500">No posts yet.</p>
    <% } else { %>
      <div space-y-4>
        <% pageData.posts.forEach((post) => { %>
          <% const title = post.get('title') || '(untitled post)' %>
          <% const authorName = post.get('author_name') || 'unknown' %>
          <% const isNotice = !!post.get('is_notice') %>
          <% const status = post.get('status') || 'draft' %>
          <% const publishedAt = post.get('published_at') || post.created || '' %>
          <% const viewCount = post.get('view_count') || 0 %>
          <% const preview = String(post.get('content') || '').replace(/<[^>]*>/g, '').slice(0, 180) %>
          <section rounded-2xl border="~ stone-200" bg="stone-50" px-5 py-4>
            <h3 text="lg stone-900" font-semibold>
              <a
                href="/boards/<%= params.boardSlug %>/posts/<%= post.get('slug') %>"
                text="stone-900 hover:stone-700" no-underline
              >
                <%= title %>
              </a>
            </h3>
            <p mt-2 text="xs stone-500" uppercase tracking="[0.14em]">
              <%= isNotice ? 'Notice' : 'Post' %> · <%= status %> · <%= authorName %> · <%= publishedAt %> · views <%= viewCount %>
            </p>
            <% if (preview) { %>
              <p mt-3 text="sm stone-600" leading-6><%= preview %></p>
            <% } %>
            <p mt-4>
              <a
                href="/boards/<%= params.boardSlug %>/posts/<%= post.get('slug') %>"
                inline-flex items-center rounded-full border="~ stone-300 hover:stone-900" px-3 py-1.5 text="xs stone-700 hover:stone-900" font-medium no-underline transition
              >
                Read post
              </a>
            </p>
          </section>
        <% }) %>
      </div>
    <% } %>
  </article>
<% } %>
