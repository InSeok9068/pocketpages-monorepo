<script server>
  const boardService = resolve('board-service');
  const postService = resolve('post-service');
  const sharedData = data || {};
  const board = sharedData.board || null;
  const boardSummary = boardService.toBoardSummary(board);
  let postCards = [];
  let postError = '';

  if (!boardSummary) {
    response.status(404);
    meta('title', 'Board Not Found');
  } else {
    meta('title', `${boardSummary.name || boardSummary.slug} | PocketPages Board`);
    meta('description', boardSummary.description || `Board ${boardSummary.slug}`);

    try {
      postCards = postService.toPostCards(postService.listPostsByBoard(board.id), boardSummary.slug);
    } catch (error) {
      warn('page/boards/show:posts-load-failed', {
        boardSlug: boardSummary.slug,
        message: String(error.message || error),
      });
      postError = String(error.message || error);
    }
  }

  const pageData = boardSummary
    ? {
        board: boardSummary,
        postCards: postCards,
        postError: postError,
        error: '',
      }
    : {
        board: null,
        postCards: [],
        postError: '',
        error: 'Board not found',
      };

  dbg('page/boards/show:response', {
    boardSlug: pageData.board ? pageData.board.slug : String(params.boardSlug || '').trim(),
    error: pageData.error || '',
    postError: pageData.postError || '',
    postCount: pageData.postCards.length,
  });
</script>

<% if (pageData.error) { %>
<article class="rounded-3xl border border-rose-200 bg-white p-6 shadow-sm">
  <header class="space-y-4">
    <h1 class="text-3xl font-semibold text-stone-950"><%= pageData.error %></h1>
  </header>
  <p class="mt-4">
    <a href="/boards" class="text-sm font-medium text-stone-600 no-underline hover:text-stone-900">Back to boards</a>
  </p>
</article>
<% } else { %>

<header class="mb-8 space-y-4">
  <p>
    <a href="/boards" class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900">Boards</a>
  </p>
  <h1 class="text-4xl font-semibold tracking-tight text-stone-950"><%= pageData.board.name %></h1>
  <p class="max-w-3xl text-base leading-7 text-stone-600"><%= pageData.board.description || 'No description' %></p>
</header>

<%- include('flash-alert.ejs') %>

<article class="mb-6 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
  <header class="mb-4">
    <h2 class="text-2xl font-semibold text-stone-950">Actions</h2>
  </header>
  <nav>
    <a
      href="/boards/<%= pageData.board.slug %>/posts/new"
      class="inline-flex items-center rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-white no-underline transition hover:bg-stone-700"
    >
      Write new post
    </a>
  </nav>
</article>

<article class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
  <header class="mb-5 space-y-2">
    <h2 class="text-2xl font-semibold text-stone-950">Posts</h2>
    <p class="text-sm text-stone-500"><%= pageData.board.path %></p>
  </header>

  <% if (pageData.postError) { %>
  <p class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= pageData.postError %></p>
  <% } else if (!pageData.postCards.length) { %>
  <p class="text-sm text-stone-500">No posts yet.</p>
  <% } else { %>
  <div class="space-y-4">
    <% pageData.postCards.forEach((postCard) => { %>
    <section class="rounded-2xl border border-stone-200 bg-stone-50 px-5 py-4">
      <h3 class="text-lg font-semibold text-stone-900">
        <a href="<%= postCard.path %>" class="text-stone-900 no-underline hover:text-stone-700"> <%= postCard.title %> </a>
      </h3>
      <p class="mt-2 text-xs uppercase tracking-[0.14em] text-stone-500">
        <%= postCard.isNotice ? 'Notice' : 'Post' %> · <%= postCard.status %> · <%= postCard.authorName %> · <%= postCard.publishedAt %> · views <%= postCard.viewCount %>
      </p>
      <% if (postCard.preview) { %>
      <p class="mt-3 text-sm leading-6 text-stone-600"><%= postCard.preview %></p>
      <% } %>
      <p class="mt-4">
        <a
          href="<%= postCard.path %>"
          class="inline-flex items-center rounded-full border border-stone-300 px-3 py-1.5 text-xs font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900"
        >
          Read post
        </a>
      </p>
    </section>
    <% }) %>
  </div>
  <% } %>
</article>
<% } %>
