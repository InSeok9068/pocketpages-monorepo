<script server>
  const sharedData = data || {};
  const boardSlug = String(params.boardSlug || "").trim();
  const board = sharedData.board || null;
  let posts = [];

  if (!board) {
    response.status(404);
    meta("title", "Board Not Found");
  } else {
    meta("title", `${board.get("name") || boardSlug} | PocketPages Board`);
    meta("description", board.get("description") || `Board ${boardSlug}`);

    try {
      posts = $app.findRecordsByFilter("posts", "board = {:boardId}", "-is_notice,-published_at,-created", 50, 0, { boardId: board.id });
    } catch (error) {
      posts = [];
    }
  }

  const pageData = board
    ? {
        board,
        posts,
        error: "",
      }
    : {
        board: null,
        posts: [],
        error: "Board not found",
      };

  dbg("page/boards/show:response", {
    boardSlug,
    error: pageData.error || "",
    postCount: pageData.posts.length,
  });
</script>

<% if (pageData.error) { %>
<article class="rounded-3xl border border-rose-200 bg-white p-6 shadow-sm">
  <header class="space-y-4">
    <h1 class="text-3xl font-semibold text-stone-950"><%= pageData.error %></h1>
  </header>
  <p class="mt-4">
    <a href="/boards" class="text-sm font-medium text-stone-600 no-underline hover:text-stone-900">Back to boards</a>
  </p>
</article>
<% } else { %> <% const boardName = pageData.board.get('name') || params.boardSlug %> <% const boardDescription = pageData.board.get('description') || 'No description' %>

<header class="mb-8 space-y-4">
  <p>
    <a href="/boards" class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900">Boards</a>
  </p>
  <h1 class="text-4xl font-semibold tracking-tight text-stone-950"><%= boardName %></h1>
  <p class="max-w-3xl text-base leading-7 text-stone-600"><%= boardDescription %></p>
</header>

<%- include('flash-alert.ejs') %>

<article class="mb-6 rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
  <header class="mb-4">
    <h2 class="text-2xl font-semibold text-stone-950">Actions</h2>
  </header>
  <nav>
    <a href="/boards/<%= params.boardSlug %>/posts/new" class="inline-flex items-center rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-white no-underline transition hover:bg-stone-700">
      Write new post
    </a>
  </nav>
</article>

<article class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
  <header class="mb-5 space-y-2">
    <h2 class="text-2xl font-semibold text-stone-950">Posts</h2>
    <p class="text-sm text-stone-500">/boards/<%= params.boardSlug %></p>
  </header>

  <% if (!pageData.posts.length) { %>
  <p class="text-sm text-stone-500">No posts yet.</p>
  <% } else { %>
  <div class="space-y-4">
    <% pageData.posts.forEach((post) => { %> <% const title = post.get('title') || '(untitled post)' %> <% const authorName = post.get('author_name') || 'unknown' %> <% const isNotice =
    !!post.get('is_notice') %> <% const status = post.get('status') || 'draft' %> <% const publishedAt = post.get('published_at') || post.created || '' %> <% const viewCount = post.get('view_count')
    || 0 %> <% const preview = String(post.get('content') || '').replace(/<[^>]*>/g, '').slice(0, 180) %>
    <section class="rounded-2xl border border-stone-200 bg-stone-50 px-5 py-4">
      <h3 class="text-lg font-semibold text-stone-900">
        <a href="/boards/<%= params.boardSlug %>/posts/<%= post.get('slug') %>" class="text-stone-900 no-underline hover:text-stone-700"> <%= title %> </a>
      </h3>
      <p class="mt-2 text-xs uppercase tracking-[0.14em] text-stone-500"><%= isNotice ? 'Notice' : 'Post' %> · <%= status %> · <%= authorName %> · <%= publishedAt %> · views <%= viewCount %></p>
      <% if (preview) { %>
      <p class="mt-3 text-sm leading-6 text-stone-600"><%= preview %></p>
      <% } %>
      <p class="mt-4">
        <a
          href="/boards/<%= params.boardSlug %>/posts/<%= post.get('slug') %>"
          class="inline-flex items-center rounded-full border border-stone-300 px-3 py-1.5 text-xs font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900"
        >
          Read post
        </a>
      </p>
    </section>
    <% }) %>
  </div>
  <% } %>
</article>
<% } %>
