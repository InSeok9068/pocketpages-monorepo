<script server>
  meta('title', 'Boards')
  meta('description', 'Simple boards list page')

  let pageData = {
    boards: [],
    error: '',
  }

  try {
    pageData.boards = $app.findRecordsByFilter('boards', '', '+sort_order,+name', 50, 0)
  } catch (error) {
    pageData.error = String(error.message || error)
  }

  dbg('page/boards:index:response', {
    error: pageData.error || '',
    boardCount: pageData.boards.length,
  })
</script>

<header mb-8 space-y-4>
  <p>
    <a href="/" text="sm stone-500 hover:stone-900" font-medium no-underline>Home</a>
  </p>
  <h1 text="4xl stone-950" font-semibold tracking-tight>Boards</h1>
  <p max-w-2xl text="base stone-600" leading-7>여기서는 게시판 목록을 보고 새 게시판을 만듭니다.</p>
</header>

<% if (params.__flash) { %>
  <p mb-6 rounded-2xl border="~ emerald-200" bg="emerald-50" px-4 py-3 text="sm emerald-700" font-medium>
    <%= params.__flash %>
  </p>
<% } %>

<section grid gap-6>
  <article rounded-3xl border="~ stone-200" bg-white p-6 shadow="sm">
    <header mb-5>
      <h2 text="2xl stone-950" font-semibold>Create Board</h2>
    </header>

    <form action="/xapi/boards/create" method="post" max-w-2xl space-y-4>
      <label block>
        Name
        <input
          type="text"
          name="name"
          placeholder="General Discussion"
          required
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        />
      </label>

      <label block>
        Slug
        <input
          type="text"
          name="slug"
          placeholder="general-discussion"
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        />
      </label>

      <label block>
        Description
        <textarea
          name="description"
          rows="4"
          placeholder="Board description"
          mt-2 block w-full rounded-2xl border="~ stone-300 focus:stone-500" bg="stone-50 focus:white" px-4 py-3 text="sm stone-900" outline-none transition
        ></textarea>
      </label>

      <button
        type="submit"
        inline-flex items-center rounded-full bg="stone-900 hover:stone-700" px-4 py-2 text="sm white" font-medium transition
      >
        Create board
      </button>
    </form>
  </article>

  <article rounded-3xl border="~ stone-200" bg-white p-6 shadow="sm">
    <header mb-5>
      <h2 text="2xl stone-950" font-semibold>Board List</h2>
    </header>

    <% if (pageData.error) { %>
      <p rounded-2xl border="~ rose-200" bg="rose-50" px-4 py-3 text="sm rose-700" font-medium><%= pageData.error %></p>
    <% } else if (!pageData.boards.length) { %>
      <p text="sm stone-500">No boards found.</p>
    <% } else { %>
      <div overflow-x-auto>
        <table min-w-full border-separate border-spacing-0 text="left sm">
          <thead>
            <tr>
              <th scope="col" border-b="~ stone-200" px-4 py-3 text="stone-500" font-semibold>Name</th>
              <th scope="col" border-b="~ stone-200" px-4 py-3 text="stone-500" font-semibold>Slug</th>
              <th scope="col" border-b="~ stone-200" px-4 py-3 text="stone-500" font-semibold>Description</th>
              <th scope="col" border-b="~ stone-200" px-4 py-3 text="stone-500" font-semibold>Open</th>
            </tr>
          </thead>
          <tbody>
            <% pageData.boards.forEach((board) => { %>
              <% const boardName = board.get('name') || '' %>
              <% const boardSlug = board.get('slug') || '' %>
              <% const boardDescription = board.get('description') || '' %>
              <tr align-top>
                <td border-b="~ stone-100" px-4 py-4 text="stone-900" font-semibold>
                  <%= boardName || '(untitled board)' %>
                </td>
                <td border-b="~ stone-100" px-4 py-4 text="stone-500" whitespace-nowrap>
                  /boards/<%= boardSlug %>
                </td>
                <td border-b="~ stone-100" px-4 py-4 text="stone-600" leading-6>
                  <%= boardDescription || 'No description' %>
                </td>
                <td border-b="~ stone-100" px-4 py-4>
                  <a
                    href="/boards/<%= boardSlug %>"
                    inline-flex items-center rounded-full border="~ stone-300 hover:stone-900" px-3 py-1.5 text="xs stone-700 hover:stone-900" font-medium no-underline transition
                  >
                    Open
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </article>
</section>
