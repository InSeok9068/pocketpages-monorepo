<header class="mb-8 space-y-4">
  <p>
    <a href="/" class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900">Home</a>
  </p>
  <h1 class="text-4xl font-semibold tracking-tight text-stone-950">Boards</h1>
  <p class="max-w-2xl text-base leading-7 text-stone-600">여기서는 게시판 목록을 보고 새 게시판을 만듭니다.</p>
</header>

<% if (params.__flash) { %>
  <p class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
    <%= params.__flash %>
  </p>
<% } %>

<section class="grid gap-6">
  <article class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
    <header class="mb-5">
      <h2 class="text-2xl font-semibold text-stone-950">Create Board</h2>
    </header>

    <form action="/api/boards/create" method="post" class="max-w-2xl space-y-4">
      <label class="block">
        Name
        <input
          type="text"
          name="name"
          placeholder="General Discussion"
          required
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        />
      </label>

      <label class="block">
        Slug
        <input
          type="text"
          name="slug"
          placeholder="general-discussion"
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        />
      </label>

      <label class="block">
        Description
        <textarea
          name="description"
          rows="4"
          placeholder="Board description"
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        ></textarea>
      </label>

      <button
        type="submit"
        class="inline-flex items-center rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-stone-700"
      >
        Create board
      </button>
    </form>
  </article>

  <article class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
    <header class="mb-5">
      <h2 class="text-2xl font-semibold text-stone-950">Board List</h2>
    </header>

    <% if (data.error) { %>
      <p class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= data.error %></p>
    <% } else if (!data.boards.length) { %>
      <p class="text-sm text-stone-500">No boards found.</p>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full border-separate border-spacing-0 text-left text-sm">
          <thead>
            <tr>
              <th scope="col" class="border-b border-stone-200 px-4 py-3 font-semibold text-stone-500">Name</th>
              <th scope="col" class="border-b border-stone-200 px-4 py-3 font-semibold text-stone-500">Slug</th>
              <th scope="col" class="border-b border-stone-200 px-4 py-3 font-semibold text-stone-500">Description</th>
              <th scope="col" class="border-b border-stone-200 px-4 py-3 font-semibold text-stone-500">Open</th>
            </tr>
          </thead>
          <tbody>
            <% data.boards.forEach((board) => { %>
              <% const boardName = board.get('name') || '' %>
              <% const boardSlug = board.get('slug') || '' %>
              <% const boardDescription = board.get('description') || '' %>
              <tr class="align-top">
                <td class="border-b border-stone-100 px-4 py-4 font-semibold text-stone-900">
                  <%= boardName || '(untitled board)' %>
                </td>
                <td class="border-b border-stone-100 px-4 py-4 text-stone-500 whitespace-nowrap">
                  /boards/<%= boardSlug %>
                </td>
                <td class="border-b border-stone-100 px-4 py-4 leading-6 text-stone-600">
                  <%= boardDescription || 'No description' %>
                </td>
                <td class="border-b border-stone-100 px-4 py-4">
                  <a
                    href="/boards/<%= boardSlug %>"
                    class="inline-flex items-center rounded-full border border-stone-300 px-3 py-1.5 text-xs font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900"
                  >
                    Open
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </article>
</section>
