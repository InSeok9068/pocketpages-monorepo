<script server>
  const boardService = resolve('board-service');
  meta('title', 'Boards');
  meta('description', 'Simple boards list page');

  let pageData = {
    boardItems: [],
    error: '',
  };

  try {
    pageData.boardItems = boardService.toBoardSummaries(boardService.listBoards());
  } catch (error) {
    warn('page/boards:index:load-failed', { message: String(error.message || error) });
    pageData.error = String(error.message || error);
  }

  dbg('page/boards:index:response', {
    error: pageData.error || '',
    boardCount: pageData.boardItems.length,
  });
</script>

<header class="mb-8 space-y-4">
  <p>
    <a href="/" class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900">Home</a>
  </p>
  <h1 class="text-4xl font-semibold tracking-tight text-stone-950">Boards</h1>
  <p class="max-w-2xl text-base leading-7 text-stone-600">여기서는 게시판 목록을 보고 새 게시판을 만듭니다.</p>
</header>

<%- include('flash-alert.ejs') %>

<section class="grid gap-6">
  <article class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
    <header class="mb-5">
      <h2 class="text-2xl font-semibold text-stone-950">Create Board</h2>
    </header>

    <form action="/xapi/boards/create" method="post" class="max-w-2xl space-y-4">
      <label class="block">
        Name
        <input
          type="text"
          name="name"
          placeholder="General Discussion"
          required
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        />
      </label>

      <label class="block">
        Slug
        <input
          type="text"
          name="slug"
          placeholder="general-discussion"
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        />
      </label>

      <label class="block">
        Description
        <textarea
          name="description"
          rows="4"
          placeholder="Board description"
          class="mt-2 block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
        ></textarea>
      </label>

      <button type="submit" class="inline-flex items-center rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-stone-700">Create board</button>
    </form>
  </article>

  <article class="rounded-3xl border border-stone-200 bg-white p-6 shadow-sm">
    <header class="mb-5">
      <h2 class="text-2xl font-semibold text-stone-950">Board List</h2>
    </header>

    <% if (pageData.error) { %>
    <p class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700"><%= pageData.error %></p>
    <% } else if (!pageData.boardItems.length) { %>
    <p class="text-sm text-stone-500">No boards found.</p>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="min-w-full border-separate border-spacing-0 text-left text-sm">
        <thead>
          <tr>
            <th scope="col" class="border-b border-stone-200 px-4 py-3 font-semibold text-stone-500">Name</th>
            <th scope="col" class="border-b border-stone-200 px-4 py-3 font-semibold text-stone-500">Slug</th>
            <th scope="col" class="border-b border-stone-200 px-4 py-3 font-semibold text-stone-500">Description</th>
            <th scope="col" class="border-b border-stone-200 px-4 py-3 font-semibold text-stone-500">Open</th>
          </tr>
        </thead>
        <tbody>
          <% pageData.boardItems.forEach((boardItem) => { %>
          <tr align-top>
            <td class="border-b border-stone-100 px-4 py-4 font-semibold text-stone-900"><%= boardItem.name || '(untitled board)' %></td>
            <td class="whitespace-nowrap border-b border-stone-100 px-4 py-4 text-stone-500">/boards/<%= boardItem.slug %></td>
            <td class="border-b border-stone-100 px-4 py-4 leading-6 text-stone-600"><%= boardItem.description || 'No description' %></td>
            <td class="border-b border-stone-100 px-4 py-4">
              <a
                href="<%= boardItem.path %>"
                class="inline-flex items-center rounded-full border border-stone-300 px-3 py-1.5 text-xs font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900"
              >
                Open
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </article>
</section>
