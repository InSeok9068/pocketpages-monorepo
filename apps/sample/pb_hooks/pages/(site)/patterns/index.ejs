<script server>
  const boardService = resolve('board-service');
  const postService = resolve('post-service');
  const requestedBoardSlug = String(request.url.query.board || '').trim();
  let boardItems = [];
  let boardListError = '';
  let selectedBoard = null;
  let selectedBoardSlug = requestedBoardSlug;
  let postItems = [];
  let postError = '';

  meta('title', 'PocketPages Sample Workspace');
  meta('description', 'PocketPages sample workspace for page, xapi, api flows');

  try {
    boardItems = boardService.toBoardSummaries(boardService.listBoards());
  } catch (error) {
    warn('page/patterns:index:board-list-failed', {
      message: String(error.message || error),
    });
    boardListError = String(error.message || error);
  }

  if (!selectedBoardSlug && boardItems.length) {
    const defaultBoard = boardItems.find(function (boardItem) {
      return boardItem.isActive;
    }) || boardItems[0];

    selectedBoardSlug = defaultBoard ? defaultBoard.slug : '';
  }

  if (selectedBoardSlug) {
    const selectedBoardRecord = boardService.findActiveBoardBySlug(selectedBoardSlug);

    if (selectedBoardRecord) {
      selectedBoard = boardService.toBoardSummary(selectedBoardRecord);

      try {
        postItems = postService.toPostPanelItems(postService.listPublishedPostsByBoard(selectedBoardRecord.id), selectedBoardSlug);
      } catch (error) {
        warn('page/patterns:index:post-list-failed', {
          boardSlug: selectedBoardSlug,
          message: String(error.message || error),
        });
        postError = String(error.message || error);
      }
    }
  }

  const boardCount = boardItems.length;
  const apiListUrl = '/api/boards/list?limit=10';
  const selectedBoardApiUrl = selectedBoard ? '/api/boards/' + encodeURIComponent(selectedBoard.slug) + '?limit=3' : '';
  const apiPreviewPayload = selectedBoard
    ? {
        meta: {
          requestedAt: '2026-03-17T09:00:00.000Z',
          recentLimit: 3,
        },
        board: {
          id: selectedBoard.id,
          name: selectedBoard.name,
          slug: selectedBoard.slug,
          description: selectedBoard.description,
          path: selectedBoard.path,
          isActive: selectedBoard.isActive,
        },
        stats: {
          totalPosts: postItems.length,
          publishedPosts: postItems.length,
          draftPosts: 0,
          archivedPosts: 0,
          noticePosts: postItems.filter(function (postItem) {
            return postItem.isNotice;
          }).length,
        },
        recentPosts: postItems.slice(0, 3).map(function (postItem) {
          return {
            title: postItem.title,
            slug: String(postItem.path || '').split('/').pop() || '',
            isNotice: postItem.isNotice,
            publishedAt: postItem.publishedAt,
            path: postItem.path,
          };
        }),
      }
    : {
        meta: {
          requestedAt: '2026-03-17T09:00:00.000Z',
          recentLimit: 3,
        },
        board: null,
        stats: {
          totalPosts: 0,
          publishedPosts: 0,
          draftPosts: 0,
          archivedPosts: 0,
          noticePosts: 0,
        },
        recentPosts: [],
      };
  const apiPreviewJson = JSON.stringify(apiPreviewPayload, null, 2);

  dbg('page/patterns:index:response', {
    requestedBoardSlug: requestedBoardSlug,
    selectedBoardSlug: selectedBoardSlug,
    boardCount: boardCount,
    boardListError: boardListError || '',
    postCount: postItems.length,
    postError: postError || '',
  });
</script>

<header class="mb-8 overflow-hidden rounded-[2rem] border border-stone-200 bg-[linear-gradient(135deg,#f8f5ef,white_50%,#ece7de)] px-6 py-8 shadow-sm md:px-8 md:py-10">
  <div class="flex flex-wrap items-start justify-between gap-6">
    <div class="max-w-3xl space-y-4">
      <p>
        <a href="/" class="text-sm font-medium text-stone-500 no-underline hover:text-stone-900">Home</a>
      </p>
      <p class="inline-flex items-center rounded-full border border-stone-300 bg-white/80 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Sample Workspace</p>
      <h1 class="text-4xl font-semibold tracking-tight text-stone-950 md:text-5xl">PocketPages Sample Workspace</h1>
      <p class="max-w-3xl text-base leading-7 text-stone-600">설명문을 길게 읽는 페이지가 아니라, 페이지 렌더링, HTMX fragment, JSON endpoint가 같이 동작하는 샘플 작업 화면입니다. 이 화면에서 바로 눌러보고 파일 구조를 따라가면 됩니다.</p>
    </div>

    <div class="grid min-w-[18rem] gap-3 rounded-3xl border border-stone-200 bg-white/85 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">Quick Links</p>
      <a href="/boards" class="inline-flex items-center justify-center rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-white no-underline transition hover:bg-stone-700">Open board CRUD</a>
      <a href="<%= apiListUrl %>" class="inline-flex items-center justify-center rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900">
        Open board API list
      </a>
    </div>
  </div>
</header>

<section class="mb-6 grid gap-4 md:grid-cols-3">
  <article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">Pages</p>
    <h2 class="mt-3 text-2xl font-semibold text-stone-950"><%= boardCount %></h2>
    <p class="mt-2 text-sm leading-6 text-stone-600">게시판 수입니다. 전체 페이지는 `(site)` 아래 route에서 렌더링합니다.</p>
  </article>

  <article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">Selected Board</p>
    <h2 class="mt-3 text-2xl font-semibold text-stone-950"><%= selectedBoard ? selectedBoard.name : 'No active board' %></h2>
    <p class="mt-2 text-sm leading-6 text-stone-600"><%= selectedBoard ? selectedBoard.path : '게시판을 하나 고르면 HTMX panel과 JSON snapshot이 같이 바뀝니다.' %></p>
  </article>

  <article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">Endpoints</p>
    <h2 class="mt-3 text-2xl font-semibold text-stone-950">xapi + api</h2>
    <p class="mt-2 text-sm leading-6 text-stone-600">HTML 조각은 `xapi`, JSON은 `api`에서 따로 확인할 수 있습니다.</p>
  </article>
</section>

<section class="grid gap-6 xl:grid-cols-[22rem_minmax(0,1fr)]">
  <article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
    <header class="mb-4 space-y-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">Board Selector</p>
        <h2 class="text-2xl font-semibold text-stone-950">Boards</h2>
        <p class="mt-2 text-sm leading-6 text-stone-600">게시판을 고르면 오른쪽 패널과 JSON 예시가 같이 바뀝니다.</p>
      </div>
    </header>

    <div x-data="{ q: '' }" class="space-y-4">
      <div class="flex items-center gap-2">
        <label class="block min-w-0 flex-1">
          <span class="sr-only">Search boards</span>
          <input
            x-model="q"
            type="text"
            placeholder="Search boards"
            class="block w-full rounded-2xl border border-stone-300 bg-stone-50 px-4 py-3 text-sm text-stone-900 outline-none transition focus:border-stone-500 focus:bg-white"
          />
        </label>
        <form hx-get="/xapi/boards/list" hx-target="#board-list" hx-swap="innerHTML" class="shrink-0">
          <input type="hidden" name="board" value="<%= selectedBoardSlug %>" />
          <button type="submit" class="inline-flex items-center rounded-full border border-stone-300 px-4 py-3 text-sm font-medium text-stone-700 transition hover:border-stone-900 hover:text-stone-900">
            Refresh
          </button>
        </form>
      </div>

      <div class="rounded-3xl bg-stone-100/70 p-2">
        <div id="board-list" class="max-h-[32rem] overflow-y-auto pr-1">
        <%- include('board-list.ejs', {
        boardItems: boardItems,
        error: boardListError,
        selectedBoardSlug: selectedBoardSlug,
      }) %>
        </div>
      </div>
    </div>
  </article>

  <div class="space-y-6">
    <%- include('post-panel.ejs', {
    selectedBoard: selectedBoard,
    selectedBoardSlug: selectedBoardSlug,
    postItems: postItems,
    error: postError,
  }) %>

    <article class="rounded-3xl border border-stone-200 bg-white p-5 shadow-sm">
      <header class="mb-5 flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">JSON Snapshot</p>
          <h2 class="text-2xl font-semibold text-stone-950">Board API</h2>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-stone-600">board 하나를 고르면 실제 JSON endpoint 주소와 응답 모양을 바로 확인할 수 있습니다. 목록 endpoint는 `/api/boards/list`, 상세 snapshot은 `/api/boards/{boardSlug}`입니다.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <a href="<%= apiListUrl %>" class="inline-flex items-center rounded-full border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 no-underline transition hover:border-stone-900 hover:text-stone-900">
            Open list API
          </a>
          <% if (selectedBoardApiUrl) { %>
          <a href="<%= selectedBoardApiUrl %>" class="inline-flex items-center rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-white no-underline transition hover:bg-stone-700">
            Open snapshot API
          </a>
          <% } %>
        </div>
      </header>

      <div class="grid gap-4">
        <div class="rounded-2xl border border-stone-200 bg-stone-50 px-4 py-4">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">List Endpoint</p>
          <p class="mt-2 font-mono text-sm text-stone-700"><%= apiListUrl %></p>
        </div>

        <% if (selectedBoardApiUrl) { %>
        <div class="rounded-2xl border border-stone-200 bg-stone-50 px-4 py-4">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Snapshot Endpoint</p>
          <p class="mt-2 font-mono text-sm text-stone-700"><%= selectedBoardApiUrl %></p>
        </div>
        <% } else { %>
        <div class="rounded-2xl border border-dashed border-stone-300 bg-stone-50 px-4 py-4">
          <p class="text-sm text-stone-500">활성 게시판이 있으면 실제 snapshot endpoint 주소가 여기 표시됩니다.</p>
        </div>
        <% } %>

        <div class="rounded-2xl border border-stone-200 bg-stone-50 px-4 py-4">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-stone-500">Response Preview</p>
          <pre class="mt-3 max-h-[20rem] overflow-auto rounded-2xl bg-stone-950 px-4 py-4 text-xs leading-6 text-stone-100"><code><%= apiPreviewJson %></code></pre>
        </div>
      </div>
    </article>
  </div>
</section>
