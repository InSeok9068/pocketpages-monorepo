<script server>
  function slugify(value) {
    return String(value || '')
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 200)
  }

  const form = body()
  const boardSlug = String(form.board || '').trim()
  const title = String(form.title || '').trim()
  const slug = slugify(form.slug || form.title)
  const authorName = String(form.authorName || '').trim()
  const content = String(form.content || '').trim()
  const isNotice = String(form.isNotice || '') === 'true'
  const status = String(form.status || 'published').trim() || 'published'

  let selectedBoard = null
  let error = ''

  if (boardSlug) {
    try {
      selectedBoard = $app.findFirstRecordByFilter(
        'boards',
        'slug = {:slug} && is_active = true',
        { slug: boardSlug }
      )
    } catch (error) {
      selectedBoard = null
    }
  }

  if (!selectedBoard) {
    error = 'Board not found.'
  } else if (!title || !slug || !authorName || !content) {
    error = 'All fields are required.'
  }

  if (!error) {
    try {
      const collection = $app.findCollectionByNameOrId('posts')
      const record = new Record(collection)
      record.set('board', selectedBoard.id)
      record.set('title', title)
      record.set('slug', slug)
      record.set('content', content)
      record.set('author_name', authorName)
      record.set('status', status)
      record.set('is_notice', isNotice)
      record.set('view_count', 0)
      if (status === 'published') {
        record.set('published_at', new Date().toISOString())
      }
      $app.save(record)
      response.redirect('/boards/' + encodeURIComponent(boardSlug) + '?__flash=' + encodeURIComponent('Post created.'), 303)
      return
    } catch (error) {
      error = String(error.message || error)
    }
  }
</script>
<% response.redirect('/boards/' + encodeURIComponent(boardSlug) + '?__flash=' + encodeURIComponent(error || 'Failed to create post.'), 303) %>
