<script server>
  const boardService = resolve('/_private/board-service')
  const form = body()
  const boardSlug = String(form.board || '').trim()
  const postSlug = String(form.post || '').trim()

  dbg('api/posts/delete:start', { boardSlug, postSlug })

  const board = boardService.findActiveBoardBySlug(boardSlug)
  let post = null
  let errorMessage = ''

  if (!board) {
    warn('api/posts/delete:board-not-found', { boardSlug })
    errorMessage = 'Board not found.'
  }

  if (!errorMessage) {
    post = boardService.findPostByBoardAndSlug(board.id, postSlug)

    if (!post) {
      warn('api/posts/delete:post-not-found', { boardSlug, postSlug })
      errorMessage = 'Post not found.'
    }
  }

  if (!errorMessage) {
    try {
      $app.delete(post)
      info('api/posts/delete:success', { boardSlug, postSlug })
      response.redirect('/boards/' + encodeURIComponent(boardSlug) + '?__flash=' + encodeURIComponent('Post deleted.'), 303)
      return
    } catch (exception) {
      error('api/posts/delete:delete-failed', exception)
      errorMessage = String(exception.message || exception)
    }
  }
</script>
<%
  const fallbackBoard = '/boards/' + encodeURIComponent(boardSlug)
  const fallbackPost = postSlug
    ? fallbackBoard + '/posts/' + encodeURIComponent(postSlug)
    : fallbackBoard
  response.redirect(fallbackPost + '?__flash=' + encodeURIComponent(errorMessage || 'Failed to delete post.'), 303)
%>
