<script server>
  const roomStore = resolve('room-store')
  const roomCode = roomStore.normalizeCode(params.roomCode)

  dbg('xapi/rooms/answer:start', {
    method: request.method,
    roomCode: roomCode,
  })

  if (request.method === 'GET') {
    const room = roomStore.findRoom(store, roomCode)

    if (!room) {
      warn('xapi/rooms/answer:not-found', {
        roomCode: roomCode,
      })
      response.json(404, {
        ok: false,
        error: 'Room not found.',
      })
      return
    }

    response.json(200, {
      ok: true,
      answer: room.answer,
    })
    return
  }

  if (request.method !== 'POST') {
    warn('xapi/rooms/answer:method-not-allowed', {
      method: request.method,
      roomCode: roomCode,
    })
    response.json(405, {
      ok: false,
      error: 'Method not allowed.',
    })
    return
  }

  const payload = body()
  const room = roomStore.updateRoom(store, roomCode, function (nextRoom) {
    nextRoom.answer = payload.answer || null
  })

  if (!room) {
    warn('xapi/rooms/answer:not-found', {
      roomCode: roomCode,
    })
    response.json(404, {
      ok: false,
      error: 'Room not found.',
    })
    return
  }

  info('xapi/rooms/answer:saved', {
    roomCode: roomCode,
  })

  response.json(200, {
    ok: true,
  })
</script>
