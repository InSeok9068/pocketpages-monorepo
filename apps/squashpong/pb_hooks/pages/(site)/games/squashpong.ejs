<script server>
  const roomCode = String(request.url.query.room || '').trim()
  const redirectTo = roomCode ? '/?room=' + encodeURIComponent(roomCode) : '/'

  dbg('pages/games/squashpong:redirect', {
    status: 303,
    redirectTo: redirectTo,
  })

  response.redirect(redirectTo, 303)
  return
</script>
