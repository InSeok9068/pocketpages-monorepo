<script server>
  meta('title', 'Squash Pong')
  meta('description', '친구와 방 코드로 연결해서 즐기는 WebRTC 스쿼시퐁 초안')
</script>

<!-- slot:head -->
<script>
  window.SQUASHPONG_ROOM_CODE = '<%= String(request.url.query.room || '') %>'
</script>
<script
  defer
  src="<%= asset('/assets/squashpong/game-rules.js') %>"></script>
<script
  defer
  src="<%= asset('/assets/squashpong/game.js') %>"></script>

<!-- slot:body -->
<main class="shell">
  <div
    id="connection-banner"
    class="connection-banner">
    방을 만들거나 친구 방에 참가하세요.
  </div>

  <section
    id="lobby-screen"
    class="screen lobby-screen">
    <header class="lobby-header">
      <p class="eyebrow">친구 대전</p>
      <h1>Squash Pong</h1>
    </header>

    <div class="panel-section primary-actions">
      <button
        id="solo-play"
        class="solo-button"
        type="button">
        솔로 플레이
      </button>
      <button
        id="create-room"
        type="button">
        방 만들기
      </button>
    </div>

    <div class="panel-section">
      <h2>공속도</h2>
      <div
        id="speed-mode-list"
        class="speed-mode-list"
        role="radiogroup"
        aria-label="공속도 선택">
        <label class="speed-mode-option is-selected">
          <input
            type="radio"
            name="speedMode"
            value="normal"
            checked />
          <span>기본</span>
        </label>
        <label class="speed-mode-option">
          <input
            type="radio"
            name="speedMode"
            value="fast" />
          <span>빠름</span>
        </label>
        <label class="speed-mode-option">
          <input
            type="radio"
            name="speedMode"
            value="turbo" />
          <span>매우 빠름</span>
        </label>
      </div>
    </div>

    <div class="panel-section">
      <h2>참가</h2>
      <label for="room-code">방 코드</label>
      <div class="join-row">
        <input
          id="room-code"
          autocomplete="off"
          maxlength="8"
          placeholder="예: A7KQ2M" />
        <button
          id="join-room"
          type="button">
          참가
        </button>
      </div>
    </div>

    <div class="panel-section">
      <h2>캐릭터</h2>
      <div
        id="character-list"
        class="character-list"
        role="radiogroup"
        aria-label="캐릭터 선택">
        <label class="character-option is-selected">
          <input
            type="radio"
            name="character"
            value="lime"
            checked />
          <span
            class="character-swatch"
            style="--character-color: #b7f25a"></span>
          <span>라임</span>
        </label>
        <label class="character-option">
          <input
            type="radio"
            name="character"
            value="sky" />
          <span
            class="character-swatch"
            style="--character-color: #62c8ff"></span>
          <span>스카이</span>
        </label>
        <label class="character-option">
          <input
            type="radio"
            name="character"
            value="coral" />
          <span
            class="character-swatch"
            style="--character-color: #ff7d6e"></span>
          <span>코랄</span>
        </label>
        <label class="character-option">
          <input
            type="radio"
            name="character"
            value="violet" />
          <span
            class="character-swatch"
            style="--character-color: #c7a4ff"></span>
          <span>바이올렛</span>
        </label>
      </div>
    </div>
  </section>

  <section
    id="room-screen"
    class="screen room-screen"
    hidden>
    <header class="room-header">
      <p class="eyebrow">방 대기</p>
      <h1 id="room-code-display">------</h1>
    </header>

    <div class="panel-section">
      <button
        id="copy-link"
        class="secondary"
        type="button">
        초대 링크 복사
      </button>
      <a
        class="ghost-link"
        href="/"
        >로비로</a
      >
    </div>

    <div class="panel-section">
      <h2>상태</h2>
      <dl class="status-list">
        <div>
          <dt>역할</dt>
          <dd id="role-label">대기</dd>
        </div>
        <div>
          <dt>연결</dt>
          <dd id="peer-label">끊김</dd>
        </div>
        <div>
          <dt>랠리</dt>
          <dd id="rally-label">0</dd>
        </div>
        <div>
          <dt>공속도</dt>
          <dd id="speed-label">기본</dd>
        </div>
      </dl>
    </div>
  </section>

  <section
    id="game-screen"
    class="screen game-screen"
    hidden>
    <div class="game-hud">
      <div>
        <span id="score-label">0 : 0</span>
        <span id="turn-label">대기</span>
      </div>
      <button
        id="leave-game"
        class="icon-text-button"
        type="button"
        aria-label="게임 나가기">
        나가기
      </button>
    </div>

    <div class="play-surface">
      <canvas
        id="game-canvas"
        width="540"
        height="960"
        tabindex="-1"
        aria-label="Squash Pong game canvas"></canvas>
    </div>
  </section>
</main>
