<%
  /** @type {types.KjcaFormState} */
  const safeFormState = formState || {
    reportDate: '',
    testOneOnly: false,
  }
  /** @type {types.KjcaDashboardState} */
  const safeDashboardState = dashboardState || {
    reportDate: '',
    testOneOnly: false,
    noticeMessage: '',
    errorMessage: '',
    warnings: [],
    stoppedReason: '',
    isDiaryAccessible: null,
    teamLeadRows: [],
    analysisResults: [],
    deptWeekTables: [],
    deptSnapshots: [],
  }
  const reportDate = String(safeFormState.reportDate || safeDashboardState.reportDate || '').trim()
  const testOneOnly = !!(safeFormState.testOneOnly || safeDashboardState.testOneOnly)
  const encodedState = kjcaCore.serializeDashboardState(safeDashboardState)
  const deptWeekTables = (safeDashboardState.deptWeekTables || []).map((table) => ({
    ...table,
    summaryText: kjcaCore.buildDeptSummaryText({
      dept: table.dept,
      reportDate,
      analysisResults: safeDashboardState.analysisResults || [],
    }),
    weekdayRows: kjcaCore.WEEKDAY_ORDER.map((weekday) => {
      const row = kjcaCore.getWeekdayMergedRow(table.rows || [], weekday)
      const isToday = kjcaCore.isFocusWeekday(weekday, table.todayWeekday)

      return {
        weekday,
        row,
        isToday,
      }
    }),
  }))
  const hasDeptWeekTables = deptWeekTables.length > 0
  const hasAnalysisResults = !!(safeDashboardState.analysisResults && safeDashboardState.analysisResults.length > 0)
  const deptJobStatusTables = []
  const seenJobStatusDept = {}
  const deptMiscSections = []
  const seenMiscDept = {}

  ;(safeDashboardState.analysisResults || []).forEach((item) => {
    const dept = String((item && item.dept) || '').trim()
    const jobStatusTable = item && item.recruiting ? item.recruiting.jobStatusTable : null
    const hasStaffNames = !!(jobStatusTable && Array.isArray(jobStatusTable.staffNames) && jobStatusTable.staffNames.length > 0)
    const hasRows = !!(jobStatusTable && Array.isArray(jobStatusTable.rows) && jobStatusTable.rows.length > 0)

    if (!dept || !hasStaffNames || !hasRows || seenJobStatusDept[dept]) return

    seenJobStatusDept[dept] = true
    deptJobStatusTables.push({
      dept,
      position: String((item && item.position) || '').trim(),
      staffName: String((item && item.staffName) || '').trim(),
      ok: !(item && item.ok === false),
      error: String((item && item.error) || '').trim(),
      table: jobStatusTable,
    })
  })

  ;(safeDashboardState.analysisResults || []).forEach((item) => {
    const dept = String((item && item.dept) || '').trim()
    const miscSection = item && item.miscSection ? item.miscSection : null
    const hasMiscItems = !!(miscSection && Array.isArray(miscSection.items) && miscSection.items.length > 0)

    if (!dept || !hasMiscItems || seenMiscDept[dept]) return

    seenMiscDept[dept] = true
    deptMiscSections.push({
      dept,
      position: String((item && item.position) || '').trim(),
      staffName: String((item && item.staffName) || '').trim(),
      ok: !(item && item.ok === false),
      error: String((item && item.error) || '').trim(),
      section: miscSection,
    })
  })

  const hasJobStatusTables = deptJobStatusTables.length > 0
  const hasMiscSections = deptMiscSections.length > 0
  const defaultResultTab = hasDeptWeekTables ? 'weekly-plan' : hasJobStatusTables ? 'job-status' : hasMiscSections ? 'misc-section' : 'weekly-plan'
  const showEmptyState = !hasDeptWeekTables && !hasAnalysisResults && !safeDashboardState.noticeMessage && !safeDashboardState.errorMessage
%>

<div
  class="grid gap-5 xl:grid-cols-[320px_minmax(0,1fr)]"
  :style="leftOpen ? '' : 'grid-template-columns: minmax(0, 1fr)'">
  <div
    id="kjca-collect-indicator"
    class="htmx-indicator fixed inset-0 z-[120] items-center justify-center bg-slate-950/35 px-6 backdrop-blur-[2px]"
    role="status"
    aria-live="polite"
    aria-atomic="true">
    <div class="w-full max-w-md rounded-[28px] border border-slate-200 bg-white/95 p-6 shadow-2xl shadow-slate-900/20">
      <div class="min-w-0">
        <div class="flex items-center gap-3">
          <span class="inline-block h-4 w-4 animate-spin rounded-full border-2 border-slate-400 border-t-slate-900"></span>
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Processing</p>
        </div>
        <div class="min-w-0">
          <h2 class="mt-2 text-lg font-semibold text-slate-950">자동 취합/비교 실행 중</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">팀장 일지 스크랩, 부서별 주간표 분석, 결과 저장을 순서대로 처리하고 있습니다.</p>
          <p class="mt-3 text-xs leading-5 text-slate-500">작업이 끝나면 현재 화면이 자동으로 새 결과로 갱신됩니다.</p>
        </div>
      </div>
    </div>
  </div>
  <aside
    x-show="leftOpen"
    x-transition.opacity.duration.150ms
    x-transition.scale.origin.top.left.duration.150ms
    class="flex min-w-0 flex-col gap-5 xl:self-start">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/60">
      <form
        id="kjca-dashboard-form"
        hx-post="/xapi/kjca/collect-weekly"
        hx-target="#kjca-dashboard-shell"
        hx-swap="innerHTML"
        hx-indicator="#kjca-collect-indicator"
        class="space-y-4">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Filters</p>
            <h2 class="mt-1 text-lg font-semibold text-slate-950">조회 조건</h2>
          </div>
          <% if (!authState.isSuperuser) { %>
          <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">로그인 필요</span>
          <% } %>
        </div>

        <label class="block text-sm font-medium text-slate-700">
          조회일
          <input
            type="date"
            name="reportDate"
            value="<%= reportDate %>"
            class="kjca-control mt-2 block px-4 py-3 text-sm text-slate-900" />
        </label>

        <label class="flex items-center gap-3 rounded-xl bg-slate-50 px-4 py-3 text-sm text-slate-700">
          <% if (testOneOnly) { %>
          <input
            type="checkbox"
            name="testOneOnly"
            value="true"
            checked />
          <% } else { %>
          <input
            type="checkbox"
            name="testOneOnly"
            value="true" />
          <% } %>
          <span>테스트 모드 (1건만 처리)</span>
        </label>

        <% if (authState.isSuperuser) { %>
        <button
          type="submit"
          class="kjca-btn kjca-btn-primary w-full">
          금일 자동 취합/비교 실행
        </button>
        <% } else { %>
        <button
          type="submit"
          class="kjca-btn kjca-btn-primary w-full"
          disabled>
          금일 자동 취합/비교 실행
        </button>
        <% } %>
      </form>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/60">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Team Leads</p>
          <h2 class="mt-1 text-lg font-semibold text-slate-950">팀장 목록</h2>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"> 총 <%= (safeDashboardState.teamLeadRows || []).length %>건 </span>
      </div>

      <div class="mt-4 text-sm text-slate-600">
        접근 상태: <% if (safeDashboardState.isDiaryAccessible === true) { %>
        <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-800">성공</span>
        <% } else if (safeDashboardState.isDiaryAccessible === false) { %>
        <span class="rounded-full bg-rose-100 px-2.5 py-1 text-xs font-semibold text-rose-800">실패</span>
        <% } else { %>
        <span>-</span>
        <% } %>
      </div>

      <% if (!safeDashboardState.teamLeadRows || safeDashboardState.teamLeadRows.length === 0) { %>
      <p class="mt-4 text-sm text-slate-500">조회 결과가 없습니다.</p>
      <% } else { %>
      <div class="mt-4 max-h-[calc(100vh-360px)] overflow-y-auto rounded-xl border border-slate-200 bg-slate-50/70 p-4">
        <div class="grid grid-cols-[minmax(0,1fr)_56px_72px] gap-x-2 gap-y-2 text-sm text-slate-700">
          <div class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">부서</div>
          <div class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">직책</div>
          <div class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">성명</div>
          <% safeDashboardState.teamLeadRows.forEach((row) => { %>
          <div class="break-words"><%= row.dept %></div>
          <div class="break-words"><%= row.position %></div>
          <div class="break-words"><%= row.staffName %></div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </article>
  </aside>

  <section class="min-w-0 space-y-6">
    <div class="flex items-center justify-between gap-3">
      <div class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Results</div>
      <div class="flex flex-wrap items-center justify-end gap-2">
        <div class="inline-flex flex-wrap items-center justify-end gap-2 rounded-2xl border border-slate-200 bg-white/92 px-3 py-2 shadow-sm shadow-slate-200/40">
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">관리자 로그인</p>
          <% if (authState.isSuperuser) { %>
          <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">로그인됨</span>
          <% } else if (authState.isSignedIn) { %>
          <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">권한 확인 필요</span>
          <% } else { %>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">미로그인</span>
          <% } %>
          <%- include('flash-alert.ejs', { flashDisplay: 'inline' }) %>

          <% if (!authState.isSuperuser) { %>
          <a
            href="/sign-in"
            class="kjca-btn kjca-btn-primary kjca-btn-sm">
            로그인
          </a>
          <% } else { %>
          <form
            action="/xapi/auth/sign-out"
            method="post">
            <button
              type="submit"
              class="kjca-btn kjca-btn-secondary kjca-btn-sm">
              로그아웃
            </button>
          </form>
          <% } %>
        </div>

        <button
          type="button"
          @click="leftOpen = !leftOpen"
          class="kjca-btn kjca-btn-secondary kjca-btn-sm">
          <span x-text="leftOpen ? '조회 영역 접기' : '조회 영역 펼치기'"></span>
        </button>
      </div>
    </div>

    <input
      type="hidden"
      id="kjca-dashboard-state"
      name="dashboardStateJson"
      value="<%= encodedState %>" />

    <% if (safeDashboardState.noticeMessage) { %>
    <div class="rounded-2xl border border-emerald-200 bg-emerald-50/95 px-5 py-4 text-sm font-medium text-emerald-700 shadow-sm shadow-emerald-100/40"><%= safeDashboardState.noticeMessage %></div>
    <% } %>
    <% if (safeDashboardState.errorMessage) { %>
    <div class="rounded-2xl border border-rose-200 bg-rose-50/95 px-5 py-4 text-sm font-medium text-rose-700 shadow-sm shadow-rose-100/40"><%= safeDashboardState.errorMessage %></div>
    <% } %>
    <% if (hasDeptWeekTables || hasJobStatusTables || hasMiscSections) { %>
    <article
      x-data="{ weeklyResultTab: '<%= defaultResultTab %>' }"
      class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/60 md:p-6">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Daily Report Summary</p>
          <h2 class="mt-1 text-lg font-semibold text-slate-950">일일 업무 일지 취합</h2>
        </div>
        <div class="flex flex-wrap items-center justify-end gap-2">
          <span
            x-show="weeklyResultTab === 'weekly-plan'"
            class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
            총 <%= deptWeekTables.length %>개 부서
          </span>
          <span
            x-show="weeklyResultTab === 'job-status'"
            class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
            총 <%= deptJobStatusTables.length %>개 부서
          </span>
          <span
            x-show="weeklyResultTab === 'misc-section'"
            class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
            총 <%= deptMiscSections.length %>개 부서
          </span>
        </div>
      </div>

      <div class="mt-5 rounded-2xl border border-slate-200 bg-slate-50/70 p-2">
        <div class="flex flex-wrap gap-2">
          <button
            type="button"
            @click="weeklyResultTab = 'weekly-plan'"
            :class="weeklyResultTab === 'weekly-plan' ? 'kjca-tab-btn kjca-tab-btn-active' : 'kjca-tab-btn kjca-tab-btn-idle'">
            <span>금주 모집 계획</span>
            <span class="rounded-full bg-white/80 px-2 py-0.5 text-[11px] font-semibold text-slate-600">
              <%= deptWeekTables.length %>개 부서
            </span>
          </button>
          <button
            type="button"
            @click="weeklyResultTab = 'job-status'"
            :class="weeklyResultTab === 'job-status' ? 'kjca-tab-btn kjca-tab-btn-active' : 'kjca-tab-btn kjca-tab-btn-idle'">
            <span>알선취업자 현황</span>
            <span class="rounded-full bg-white/80 px-2 py-0.5 text-[11px] font-semibold text-slate-600">
              <%= deptJobStatusTables.length %>개 부서
            </span>
          </button>
          <button
            type="button"
            @click="weeklyResultTab = 'misc-section'"
            :class="weeklyResultTab === 'misc-section' ? 'kjca-tab-btn kjca-tab-btn-active' : 'kjca-tab-btn kjca-tab-btn-idle'">
            <span>기타 사항</span>
            <span class="rounded-full bg-white/80 px-2 py-0.5 text-[11px] font-semibold text-slate-600">
              <%= deptMiscSections.length %>개 부서
            </span>
          </button>
        </div>
      </div>

      <div
        x-show="weeklyResultTab === 'weekly-plan'"
        x-transition.opacity.duration.150ms
        class="mt-5 flex flex-col gap-4">
        <% if (!hasDeptWeekTables) { %>
        <section class="rounded-[28px] border border-dashed border-slate-300 bg-gradient-to-br from-slate-50 via-white to-slate-50/80 p-6 text-center shadow-sm shadow-slate-200/40">
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Weekly Plan</p>
          <h3 class="mt-2 text-xl font-semibold text-slate-950">금주 모집 계획 데이터가 없습니다</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600">업무일지에서 주간 모집/홍보 표가 확인되면 이 탭에 부서별 주간표를 렌더링합니다.</p>
        </section>
        <% } %>
        <% deptWeekTables.forEach((table) => { %>
        <details
          open
          class="rounded-2xl border border-slate-200 bg-slate-50/60 p-4">
          <summary class="cursor-pointer text-base font-semibold text-slate-950">
            <div class="inline-flex items-center gap-3">
              <span><%= table.dept %></span>
              <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">주간표</span>
            </div>
          </summary>

          <div class="mt-4 flex items-center justify-end">
            <button
              type="button"
              hx-post="/xapi/kjca/clear-cache"
              hx-vals="<%= JSON.stringify({ dept: table.dept }) %>"
              hx-include="#kjca-dashboard-form, #kjca-dashboard-state"
              hx-target="#kjca-dashboard-shell"
              hx-swap="innerHTML"
              class="kjca-btn kjca-btn-secondary kjca-btn-sm">
              해당 부서 캐시 지우기
            </button>
          </div>

          <div class="mt-4 overflow-x-auto rounded-2xl border border-slate-200 bg-white">
            <table class="w-full min-w-[980px] border-separate border-spacing-0 text-left text-sm text-slate-700">
              <thead class="bg-slate-50">
                <tr>
                  <th
                    colspan="7"
                    class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">
                    <%= table.summaryText %>
                  </th>
                </tr>
                <tr>
                  <th
                    rowspan="2"
                    class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">
                    요일
                  </th>
                  <th
                    colspan="3"
                    class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">
                    주간 홍보계획
                  </th>
                  <th class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">결과</th>
                  <th
                    rowspan="2"
                    class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">
                    담당자(홍보)
                  </th>
                  <th
                    rowspan="2"
                    class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">
                    비고
                  </th>
                </tr>
                <tr>
                  <th class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">모집홍보처</th>
                  <th class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">모집 홍보내용</th>
                  <th class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">모집목표</th>
                  <th class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">모집 건수</th>
                </tr>
              </thead>
              <tbody>
                <% table.weekdayRows.forEach((weekdayRow) => { %>
                <tr class="<%= weekdayRow.isToday ? 'bg-blue-50/70 text-slate-900' : 'bg-white text-slate-700' %>">
                  <td class="<%= `border-b ${weekdayRow.isToday ? 'font-semibold' : 'font-medium'}` %> break-words border-slate-100 px-4 py-3 align-top">
                    <%= kjcaCore.weekdayLabelMap[weekdayRow.weekday] %>
                    <% if (weekdayRow.isToday) { %>
                    <span class="ml-2 rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-semibold text-blue-700">오늘</span>
                    <% } %>
                  </td>
                  <td class="break-words border-b border-slate-100 px-4 py-3 align-top"><%= weekdayRow.row.channelName || '' %></td>
                  <td class="break-words border-b border-slate-100 px-4 py-3 align-top"><%= weekdayRow.row.promotionContent || '' %></td>
                  <td class="break-words border-b border-slate-100 px-4 py-3 align-top"><%= weekdayRow.row.targetText || '' %></td>
                  <td class="break-words border-b border-slate-100 px-4 py-3 align-top"><%= weekdayRow.row.recruitCountText || '' %></td>
                  <td class="break-words border-b border-slate-100 px-4 py-3 align-top"><%= weekdayRow.row.ownerName || '' %></td>
                  <td class="break-words border-b border-slate-100 px-4 py-3 align-top"><%= weekdayRow.row.note || '' %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </details>
        <% }) %>
      </div>

      <div
        x-show="weeklyResultTab === 'job-status'"
        x-transition.opacity.duration.150ms
        class="mt-5">
        <% if (!hasJobStatusTables) { %>
        <section class="rounded-[28px] border border-dashed border-slate-300 bg-gradient-to-br from-slate-50 via-white to-blue-50/60 p-6 text-center shadow-sm shadow-slate-200/40">
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Job Status</p>
          <h3 class="mt-2 text-xl font-semibold text-slate-950">알선취업자 현황 데이터가 없습니다</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600">업무일지 본문에서 `알선취업자 현황` 표가 확인되면 이 탭에 부서별 표를 그대로 렌더링합니다.</p>
        </section>
        <% } else { %>
        <div class="flex flex-col gap-4">
          <% deptJobStatusTables.forEach((item) => { %>
          <details
            open
            class="rounded-2xl border border-slate-200 bg-slate-50/60 p-4">
            <summary class="cursor-pointer text-base font-semibold text-slate-950">
              <div class="inline-flex flex-wrap items-center gap-3">
                <span><%= item.dept %></span>
                <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700"><%= item.table.staffNames.length %>명</span>
                <% if (item.table.title && item.table.title !== '알선취업자 현황') { %>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600"><%= item.table.title %></span>
                <% } %>
              </div>
            </summary>

            <% if (!item.ok && item.error) { %>
            <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50/95 px-4 py-3 text-sm font-medium text-amber-700">
              AI 상세 분석은 실패했지만, 알선취업자 현황 표는 원본 HTML에서 직접 추출했습니다. (<%= item.error %>)
            </div>
            <% } %>

            <div class="mt-4 overflow-x-auto rounded-2xl border border-slate-200 bg-white">
              <table class="w-full min-w-[760px] border-separate border-spacing-0 text-left text-sm text-slate-700">
                <thead class="bg-slate-50">
                  <tr>
                    <th class="border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800">구분</th>
                    <% item.table.staffNames.forEach((staffName) => { %>
                    <th class="border-b border-slate-200 px-4 py-3 text-center text-sm font-semibold text-slate-800"><%= staffName %></th>
                    <% }) %>
                  </tr>
                </thead>
                <tbody>
                  <% item.table.rows.forEach((row) => { %>
                  <tr class="bg-white">
                    <td class="border-b border-slate-100 bg-slate-50/60 px-4 py-3 font-semibold text-slate-800"><%= row.label %></td>
                    <% row.values.forEach((value) => { %>
                    <td class="border-b border-slate-100 px-4 py-3 text-center align-middle"><%= value.text || '' %></td>
                    <% }) %>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </details>
          <% }) %>
        </div>
        <% } %>
      </div>

      <div
        x-show="weeklyResultTab === 'misc-section'"
        x-transition.opacity.duration.150ms
        class="mt-5">
        <% if (!hasMiscSections) { %>
        <section class="rounded-[28px] border border-dashed border-slate-300 bg-gradient-to-br from-slate-50 via-white to-slate-50/80 p-6 text-center shadow-sm shadow-slate-200/40">
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Misc Notes</p>
          <h3 class="mt-2 text-xl font-semibold text-slate-950">기타 사항 데이터가 없습니다</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600">업무일지 마지막 `기타 사항 / 기타보고` 영역이 확인되면 이 탭에 부서별로 취합해서 표시합니다.</p>
        </section>
        <% } else { %>
        <div class="flex flex-col gap-4">
          <% deptMiscSections.forEach((item) => { %>
          <details
            open
            class="rounded-2xl border border-slate-200 bg-slate-50/60 p-4">
            <summary class="cursor-pointer text-base font-semibold text-slate-950">
              <div class="inline-flex flex-wrap items-center gap-3">
                <span><%= item.dept %></span>
                <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700"><%= item.section.items.length %>개 항목</span>
                <% if (item.section.title && item.section.title !== '기타 사항') { %>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600"><%= item.section.title %></span>
                <% } %>
              </div>
            </summary>

            <% if (!item.ok && item.error) { %>
            <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50/95 px-4 py-3 text-sm font-medium text-amber-700">
              AI 상세 분석은 실패했지만, 기타 사항은 원본 HTML에서 직접 추출했습니다. (<%= item.error %>)
            </div>
            <% } %>

            <div class="mt-4 grid gap-3">
              <% item.section.items.forEach((miscItem) => { %>
              <section class="rounded-2xl border border-slate-200 bg-white p-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= miscItem.label %></p>
                <div class="mt-2 whitespace-pre-line break-words text-sm leading-6 text-slate-700"><%= miscItem.content %></div>
              </section>
              <% }) %>
            </div>
          </details>
          <% }) %>
        </div>
        <% } %>
      </div>
    </article>
    <% } %>
    <% if (hasAnalysisResults) { %>
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/60 md:p-6">
      <div class="flex items-center justify-between gap-3">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">AI Results</p>
          <h2 class="mt-1 text-lg font-semibold text-slate-950">AI 분석 상세</h2>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"> 총 <%= safeDashboardState.analysisResults.length %>건 </span>
      </div>

      <div class="mt-5 flex flex-col gap-4">
        <% safeDashboardState.analysisResults.forEach((item) => { %>
        <details
          open
          class="rounded-2xl border border-slate-200 bg-slate-50/60 p-4">
          <summary class="cursor-pointer text-base font-semibold text-slate-950"><%= item.dept %> / <%= item.staffName %><%= item.ok ? '' : ' (실패)' %></summary>

          <div class="mt-4 space-y-4 text-sm text-slate-700">
            <div>
              <a
                href="<%= item.printUrl %>"
                target="_blank"
                rel="noreferrer"
                class="kjca-btn kjca-btn-secondary kjca-btn-sm">
                원본링크
              </a>
            </div>

            <% if (!item.ok) { %>
            <div class="rounded-2xl border border-rose-200 bg-rose-50/95 px-4 py-3 text-sm font-medium text-rose-700"><%= item.error || '분석에 실패했습니다.' %></div>
            <% } %>

            <div class="grid gap-4 md:grid-cols-2">
              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Promotion</p>
                <div class="mt-2 space-y-1">
                  <% if (!item.promotion || item.promotion.length === 0) { %>
                  <p class="text-sm text-slate-500">-</p>
                  <% } else { %>
                  <% item.promotion.forEach((promotionText) => { %>
                  <div class="break-words">- <%= promotionText %></div>
                  <% }) %>
                  <% } %>
                </div>
              </div>

              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Daily Actual</p>
                <p class="mt-2 text-sm font-medium text-slate-700"><%= item.recruiting && item.recruiting.dailyActualCount !== null ? `${item.recruiting.dailyActualCount}명` : '-' %></p>
              </div>
            </div>
          </div>
        </details>
        <% }) %>
      </div>
    </article>
    <% } %>
    <% if (showEmptyState) { %>
    <article class="rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm shadow-slate-200/60 md:p-7">
      <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-500">Ready</p>
      <h2 class="mt-2 text-2xl font-semibold text-slate-950">자동 취합 대기 중</h2>
      <p class="mt-3 text-sm leading-7 text-slate-600">좌측 조회 조건을 설정하고 자동 취합을 실행하면 팀장 목록, 부서별 주간표, AI 분석 상세가 이 영역에 렌더링됩니다.</p>
    </article>
    <% } %>
  </section>
</div>
