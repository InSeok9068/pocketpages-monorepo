<% if (isProduction) { %>
<link
  rel="stylesheet"
  href="<%= asset('/assets/uno.min.css') %>" />
<% } else { %>
<style>
  [un-cloak] {
    display: none !important;
  }
</style>
<script
  src="<%= asset('/assets/vendor/preset-wind3-66.5.12.global.js') %>"></script>
<script
  src="<%= asset('/assets/vendor/preset-icons-66.5.12.global.js') %>"></script>
<script>
  let lucideIcons

  window.__unocss = {
    presets: [
      () => window.__unocss_runtime.presets.presetWind3(),
      () =>
        window.__unocss_runtime.presets.presetIcons({
          collections: {
            lucide: () => {
              lucideIcons =
                lucideIcons ||
                fetch(
                  '<%= asset('/assets/vendor/iconify-lucide-1.2.107.icons.json') %>',
                ).then((response) => response.json())

              return lucideIcons
            },
          },
        }),
    ],
    ready: () => {
      document.body.removeAttribute('un-cloak')
    },
  }
</script>
<script
  src="<%= asset('/assets/vendor/unocss-core-66.5.12.global.js') %>"></script>
<% } %>
