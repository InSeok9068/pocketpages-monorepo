<%
  const safeTable = table || {
    title: '',
    headers: [],
    rows: [],
  }
  const hasRows = Array.isArray(safeTable.rows) && safeTable.rows.length > 0
%>
<section class="rounded-2xl border border-slate-200 bg-white p-4">
  <div class="flex items-center justify-between gap-3">
    <h4 class="text-sm font-semibold text-slate-950"><%= safeTable.title %></h4>
    <% if (hasRows) { %>
    <span class="rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-semibold text-slate-600"><%= safeTable.rows.length %>행</span>
    <% } %>
  </div>

  <div class="mt-3 overflow-x-auto rounded-2xl border border-slate-200 bg-slate-50/40">
    <table class="w-full min-w-[720px] border-separate border-spacing-0 text-left text-sm text-slate-700">
      <thead class="bg-slate-50">
        <tr>
          <% safeTable.headers.forEach((header) => { %>
          <th class="whitespace-pre-line border-b border-slate-200 px-4 py-3 text-sm font-semibold text-slate-800"><%= header %></th>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <% if (!hasRows) { %>
        <tr>
          <td
            colspan="<%= safeTable.headers.length || 1 %>"
            class="border-b border-slate-100 px-4 py-6 text-center text-sm text-slate-500">
            표시할 데이터가 없습니다.
          </td>
        </tr>
        <% } else { %>
        <% safeTable.rows.forEach((row) => { %>
        <tr class="bg-white">
          <% row.forEach((cell) => { %>
          <td class="whitespace-pre-line break-words border-b border-slate-100 px-4 py-3 align-top"><%= cell %></td>
          <% }) %>
        </tr>
        <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
