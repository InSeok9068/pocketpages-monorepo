<script server>
  const kjcaService = resolve('kjca-service')

  if (request.method !== 'POST') {
    response.status(405)
    response.json(405, {
      ok: false,
      message: 'Method not allowed.',
    })
    return
  }

  const authState = kjcaService.readAuthState({ request })
  if (!authState.isSuperuser) {
    response.status(401)
    response.json(401, {
      ok: false,
      message: 'PocketBase 슈퍼유저 로그인이 필요합니다.',
    })
    return
  }

  const payload = body()

  try {
    const result = kjcaService.probeStaffAuth(
      {
        request,
        dbg,
        info,
        warn,
        error,
      },
      payload,
    )

    response.json(200, result)
  } catch (exception) {
    const errorMessage = String(exception.message || exception)
    error('api/staff-auth-probe:failed', {
      error: errorMessage,
    })
    response.status(500)
    response.json(500, {
      ok: false,
      message: errorMessage,
    })
  }
</script>
