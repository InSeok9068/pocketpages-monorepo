<script server>
  const kjcaService = resolve('kjca-service')
  const routeContext = resolve('kjca-route-context')

  const payload = body()

  try {
    const result = kjcaService.analyzeStaffDiary(
      routeContext.buildAnalyzeContext({ request, dbg, info, warn, error, resolve }),
      payload,
    )

    response.json(200, result)
  } catch (exception) {
    const errorMessage = String(exception.message || exception)
    error('api/staff-diary/analyze:failed', {
      error: errorMessage,
    })
    response.json(500, {
      ok: false,
      message: errorMessage,
    })
  }
</script>
