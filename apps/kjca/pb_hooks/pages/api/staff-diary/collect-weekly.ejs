<script server>
  const kjcaService = resolve("kjca-service");
  const staffDiaryAnalysisCacheRole = resolve("roles/staff-diary-analysis-cache");
  const recruitingWeekPlanRole = resolve("roles/recruiting-week-plan");
  const recruitingWeekPlanItemRole = resolve("roles/recruiting-week-plan-item");
  const recruitingDailyResultRole = resolve("roles/recruiting-daily-result");
  const recruitingWeekTextPlanRole = resolve("roles/recruiting-week-text-plan");
  const recruitingWeekTextRowRole = resolve("roles/recruiting-week-text-row");

  const payload = body();

  try {
    const result = kjcaService.collectWeekly(
      request,
      {
        staffDiaryAnalysisCacheRole,
        recruitingWeekPlanRole,
        recruitingWeekPlanItemRole,
        recruitingDailyResultRole,
        recruitingWeekTextPlanRole,
        recruitingWeekTextRowRole,
      },
      payload,
    );

    response.json(200, result);
  } catch (exception) {
    const errorMessage = String(exception.message || exception);
    error("api/staff-diary/collect-weekly:failed", {
      error: errorMessage,
    });
    response.json(500, {
      ok: false,
      message: errorMessage,
    });
  }
</script>
