<% const isProduction = String(env('APP_ENV') || 'development').trim() === 'production' %>
<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1" />
    <title><%= meta('title') %></title>
    <meta
      name="description"
      content="<%= meta('description') %>" />
    <meta
      property="og:title"
      content="<%= meta('title') %>" />
    <meta
      property="og:description"
      content="<%= meta('description') %>" />
    <meta
      property="og:url"
      content="<%= meta('path') ? meta('path') : meta('url') || request.url %>" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="<%= asset('/assets/favicon.svg') %>" />
    <link
      rel="stylesheet"
      href="<%= asset('/assets/style.css') %>" />
    <% if (isProduction) { %>
    <link
      rel="stylesheet"
      href="<%= asset('/assets/uno.min.css') %>" />
    <% } else { %>
    <style>
      [un-cloak] {
        display: none !important;
      }
    </style>
    <% } %>
    <script>
      window.__assetFallback = function (element) {
        element.onerror = null
        element.src = element.dataset.fallbackSrc
      }
    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.10/dist/htmx.min.js"
      data-fallback-src="<%= asset('/assets/vendor/htmx-2.0.10.min.js') %>"
      onerror="window.__assetFallback(this)"></script>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.15.11/dist/cdn.min.js"
      data-fallback-src="<%= asset('/assets/vendor/alpine-3.15.11-cdn.min.js') %>"
      onerror="window.__assetFallback(this)"></script>
    <script
      src="https://cdn.jsdelivr.net/npm/pocketbase-htmx-ext-sse@0.0.3/src/htmx-ext-sse.js"
      data-fallback-src="<%= asset('/assets/vendor/pocketbase-htmx-ext-sse-0.0.3.js') %>"
      onerror="window.__assetFallback(this)"></script>
    <% if (!isProduction) { %>
    <script
      src="https://cdn.jsdelivr.net/npm/@unocss/runtime@66.5.12/preset-wind3.global.js"
      data-fallback-src="<%= asset('/assets/vendor/preset-wind3-66.5.12.global.js') %>"
      onerror="window.__assetFallback(this)"></script>
    <script
      src="https://cdn.jsdelivr.net/npm/@unocss/runtime@66.5.12/preset-icons.global.js"
      data-fallback-src="<%= asset('/assets/vendor/preset-icons-66.5.12.global.js') %>"
      onerror="window.__assetFallback(this)"></script>
    <script>
      window.__unocss = {
        presets: [
          () => window.__unocss_runtime.presets.presetWind3(),
          () =>
            window.__unocss_runtime.presets.presetIcons({
              cdn: 'https://esm.sh/',
            }),
        ],
        ready: () => {
          document.body.removeAttribute('un-cloak')
        },
      }
    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/@unocss/runtime@66.5.12/core.global.js"
      data-fallback-src="<%= asset('/assets/vendor/unocss-core-66.5.12.global.js') %>"
      onerror="window.__assetFallback(this)"></script>
    <% } %>
    <%- slots.head %>
  </head>

  <body
    un-cloak
    class="min-h-screen text-slate-900 antialiased">
    <div class="min-h-screen">
      <main class="mx-auto max-w-[1480px] px-4 py-5 md:px-8 md:py-7 xl:px-10 xl:py-8"><%- slots.body || slot %></main>
    </div>
  </body>
</html>
