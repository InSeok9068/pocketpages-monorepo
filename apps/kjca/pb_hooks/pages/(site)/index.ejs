<script server>
  const kjcaService = resolve("kjca-service");

  meta("title", "KJCA 업무일지 자동 취합");
  meta("description", "KJCA 업무일지 자동 취합 및 확인 화면");

  const authState = kjcaService.readAuthState(request);
  const formState = kjcaService.buildFormState({
    reportDate: params.reportDate,
    testOneOnly: params.testOneOnly,
  });
  const dashboardState = kjcaService.buildDashboardState({
    reportDate: formState.reportDate,
    testOneOnly: formState.testOneOnly,
  });

  dbg("page/kjca:index:response", {
    isSignedIn: authState.isSignedIn,
    isSuperuser: authState.isSuperuser,
    reportDate: formState.reportDate,
    testOneOnly: formState.testOneOnly,
  });
</script>

<section mb-5 grid gap-4 xl:grid-cols="[minmax(0,1fr)_300px]">
  <div rounded-2xl border="~ slate-200" bg="white/92" p="6 md:8" shadow="sm slate-200/70">
    <p text="11px slate-500" font-semibold uppercase tracking="[0.24em]">KJCA 업무일지</p>
    <h1 mt-3 text="3xl slate-950 md:4xl" font="semibold" tracking-tight>KJCA 업무일지 자동 취합</h1>
    <p mt-3 max-w-3xl text="sm slate-600 md:base" leading-7>업무일지 취합 현황을 확인하고 자동 취합을 실행할 수 있는 화면입니다.</p>
  </div>

  <div rounded-2xl border="~ slate-200" bg="white/92" p-6 shadow="sm slate-200/70">
    <p text="11px slate-500" font-semibold uppercase tracking="[0.24em]">관리자 로그인</p>
    <div mt-4 space-y-3 text="sm slate-700">
      <div flex items-center justify-between gap-3>
        <span text="slate-500">상태</span>
        <% if (authState.isSuperuser) { %>
        <span rounded-full bg="blue-50" px-3 py-1 text="xs blue-700" font-semibold>관리자 로그인됨</span>
        <% } else if (authState.isSignedIn) { %>
        <span rounded-full bg="amber-50" px-3 py-1 text="xs amber-700" font-semibold>권한 확인 필요</span>
        <% } else { %>
        <span rounded-full bg="slate-100" px-3 py-1 text="xs slate-600" font-semibold>미로그인</span>
        <% } %>
      </div>
      <div flex items-center justify-between gap-3 border-t="~ slate-100" pt-3>
        <span text="slate-500">계정</span>
        <span text-right font-medium><%= authState.email || '-' %></span>
      </div>
    </div>

    <div mt-5 flex gap-2>
      <% if (!authState.isSuperuser) { %>
      <a href="/sign-in" class="kjca-btn kjca-btn-primary"> 로그인 </a>
      <% } else { %>
      <form action="/xapi/auth/sign-out" method="post">
        <button type="submit" class="kjca-btn kjca-btn-secondary">로그아웃</button>
      </form>
      <% } %>
    </div>
  </div>
</section>

<%- include('flash-alert.ejs') %>

<section x-data="{ leftOpen: true }" rounded-2xl border="~ slate-200" bg="white/72" p="4 md:5" shadow="sm slate-200/60">
  <div id="kjca-dashboard-shell"><%- include('dashboard-shell.ejs', { authState, formState, dashboardState, kjcaService, }) %></div>
</section>
