<script server>
  const kjcaAuth = resolve('kjca-auth')
  const kjcaCore = resolve('kjca-core')

  meta('title', 'KJCA 업무일지 자동 취합')
  meta('description', 'KJCA 업무일지 자동 취합 및 확인 화면')

  const authState = kjcaAuth.readAuthState(request)
  const formState = kjcaCore.buildFormState({
    reportDate: request.url.query.reportDate,
    testOneOnly: request.url.query.testOneOnly,
  })
  const dashboardState = kjcaCore.buildDashboardState({
    reportDate: formState.reportDate,
    testOneOnly: formState.testOneOnly,
  })

  dbg('page/kjca:index:response', {
    isSignedIn: authState.isSignedIn,
    isSuperuser: authState.isSuperuser,
    reportDate: formState.reportDate,
    testOneOnly: formState.testOneOnly,
  })
</script>

<header class="sr-only">
  <h1>KJCA 업무일지 자동 취합</h1>
</header>

<section
  x-data="{ leftOpen: true, collectionMode: 'daily' }"
  class="bg-white/72 rounded-2xl border border-slate-200 p-4 shadow-sm shadow-slate-200/60 md:p-5">
  <div id="kjca-dashboard-shell">
    <%- include('dashboard-shell.ejs', { authState, formState, dashboardState, kjcaCore }) %>
  </div>
</section>
