<script server>
  const kjcaAuth = resolve('kjca-auth')
  const kjcaCore = resolve('kjca-core')

  meta('title', 'KJCA 업무일지 자동 취합')
  meta('description', 'KJCA 업무일지 자동 취합 및 확인 화면')

  const authState = kjcaAuth.readAuthState(request)
  const formState = kjcaCore.buildFormState({
    reportDate: request.url.query.reportDate,
    testOneOnly: request.url.query.testOneOnly,
  })
  const dashboardState = kjcaCore.buildDashboardState({
    reportDate: formState.reportDate,
    testOneOnly: formState.testOneOnly,
  })

  dbg('page/kjca:index:response', {
    isSignedIn: authState.isSignedIn,
    isSuperuser: authState.isSuperuser,
    reportDate: formState.reportDate,
    testOneOnly: formState.testOneOnly,
  })
</script>

<section class="mb-5 grid gap-4 xl:grid-cols-[minmax(0,1fr)_300px]">
  <div class="bg-white/92 rounded-2xl border border-slate-200 p-6 shadow-sm shadow-slate-200/70 md:p-8">
    <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-500">KJCA 업무일지</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl">KJCA 업무일지 자동 취합</h1>
    <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-600 md:text-base">업무일지 취합 현황을 확인하고 자동 취합을 실행할 수 있는 화면입니다.</p>
  </div>

  <div class="bg-white/92 rounded-2xl border border-slate-200 p-6 shadow-sm shadow-slate-200/70">
    <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-500">관리자 로그인</p>
    <div class="mt-4 space-y-3 text-sm text-slate-700">
      <div class="flex items-center justify-between gap-3">
        <span class="text-slate-500">상태</span>
        <% if (authState.isSuperuser) { %>
        <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">관리자 로그인됨</span>
        <% } else if (authState.isSignedIn) { %>
        <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">권한 확인 필요</span>
        <% } else { %>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">미로그인</span>
        <% } %>
      </div>
      <div class="flex items-center justify-between gap-3 border-t border-slate-100 pt-3">
        <span class="text-slate-500">계정</span>
        <span class="text-right font-medium"><%= authState.email || '-' %></span>
      </div>
    </div>

    <div class="mt-5 flex gap-2">
      <% if (!authState.isSuperuser) { %>
      <a
        href="/sign-in"
        class="kjca-btn kjca-btn-primary">
        로그인
      </a>
      <% } else { %>
      <form
        action="/xapi/auth/sign-out"
        method="post">
        <button
          type="submit"
          class="kjca-btn kjca-btn-secondary">
          로그아웃
        </button>
      </form>
      <% } %>
    </div>
  </div>
</section>

<%- include('flash-alert.ejs') %>

<section
  x-data="{ leftOpen: true }"
  class="bg-white/72 rounded-2xl border border-slate-200 p-4 shadow-sm shadow-slate-200/60 md:p-5">
  <div id="kjca-dashboard-shell">
    <%- include('dashboard-shell.ejs', { authState, formState, dashboardState, kjcaCore }) %>
  </div>
</section>
