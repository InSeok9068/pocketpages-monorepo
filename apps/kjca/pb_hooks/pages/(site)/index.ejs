<script server>
  const kjcaService = resolve('kjca-service')

  meta('title', 'KJCA 업무일지 자동 취합')
  meta('description', 'KJCA 팀장 업무일지를 PocketPages SSR로 취합하고 분석하는 대시보드')

  const authState = kjcaService.readAuthState({ request })
  const formState = kjcaService.buildFormState({
    reportDate: params.reportDate,
    testOneOnly: params.testOneOnly,
  })
  const dashboardState = kjcaService.buildDashboardState({
    reportDate: formState.reportDate,
    testOneOnly: formState.testOneOnly,
  })

  dbg('page/kjca:index:response', {
    isSignedIn: authState.isSignedIn,
    isSuperuser: authState.isSuperuser,
    reportDate: formState.reportDate,
    testOneOnly: formState.testOneOnly,
  })
</script>

<section mb-6 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between>
  <div min-w-0 space-y-2>
    <p text="xs amber-700" font="semibold" tracking="[0.28em]" uppercase>kjca pocketpages</p>
    <h1 text="3xl slate-950 md:4xl" font="semibold" tracking-tight>KJCA 업무일지 자동 취합</h1>
    <p max-w-3xl text="sm slate-600 md:base" leading-7>
      기존 SPA 흐름을 SSR + HTMX 액션으로 옮겼습니다. 팀장 일지 수집, Gemini 분석, 주간표 업서트가 모두 PocketPages 내부 서비스에서 실행됩니다.
    </p>
  </div>

  <div shrink-0 rounded-3xl border="~ amber-200/70" bg="white/80" px-5 py-4 shadow="sm amber-100/60" backdrop-blur>
    <p text="xs slate-500" font-semibold uppercase tracking="[0.2em]">PocketBase Login</p>
    <p mt-2 text="sm slate-700">
      <% if (authState.isSignedIn && authState.email) { %>
        <span font-semibold><%= authState.email %></span>
      <% } else { %>
        <span>미로그인</span>
      <% } %>
    </p>
    <div mt-4 flex gap-2>
      <% if (!authState.isSuperuser) { %>
        <a
          href="/sign-in"
          inline-flex items-center rounded-full bg="slate-900 hover:slate-700" px-4 py-2 text="sm white" font-medium no-underline transition
        >
          로그인
        </a>
      <% } else { %>
        <form action="/xapi/auth/sign-out" method="post">
          <button
            type="submit"
            inline-flex items-center rounded-full border="~ slate-300 hover:slate-900" bg="white/90" px-4 py-2 text="sm slate-700" font-medium transition
          >
            로그아웃
          </button>
        </form>
      <% } %>
    </div>
  </div>
</section>

<%- include('flash-alert.ejs') %>

<section
  x-data="{ leftOpen: true }"
  rounded-4xl border="~ white/60" bg="white/55" p="4 md:6"
  shadow="xl amber-100/30"
  backdrop-blur
>
  <div id="kjca-dashboard-shell">
    <%- include('dashboard-shell.ejs', {
      authState,
      formState,
      dashboardState,
      kjcaService,
    }) %>
  </div>
</section>
