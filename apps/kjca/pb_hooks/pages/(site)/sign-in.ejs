<script server>
  const kjcaService = resolve('kjca-service')

  meta('title', 'KJCA 관리자 로그인')
  meta('description', '관리자 로그인 페이지')

  const authState = kjcaService.readAuthState(request)

  if (authState.isSuperuser) {
    dbg('page/kjca:sign-in:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '이미 로그인되어 있습니다.',
    })
    redirect('/', {
      status: 303,
      message: '이미 로그인되어 있습니다.',
    })
    return
  }
</script>

<section mx-auto max-w="[560px]" py="10 md:16">
  <div rounded-2xl border="~ slate-200" bg="white/94" p="6 md:8" shadow="sm slate-200/80">
    <p text="11px slate-500" font-semibold uppercase tracking="[0.24em]">관리자 로그인</p>
    <h1 mt-3 text="3xl slate-950" font-semibold tracking-tight>관리자 로그인</h1>
    <p mt-3 text="sm slate-600" leading-7>
      아이디에 `@`가 없으면 자동으로 `@kjca.local`이 붙습니다. 로그인 후 `/` 대시보드로 이동합니다.
    </p>

    <div mt-5 rounded-2xl bg="slate-50" px-4 py-3 text="sm slate-600">
      로그인 후 자동 취합 실행과 캐시 삭제 기능을 사용할 수 있습니다.
    </div>

    <div mt-6>
      <%- include('flash-alert.ejs') %>
    </div>

    <form action="/xapi/auth/sign-in" method="post" mt-6 space-y-4>
      <label block text="sm slate-700" font-medium>
        아이디
        <input
          type="text"
          name="loginId"
          placeholder="admin"
          required
          class="kjca-control"
          mt-2 block px-4 py-3 text="sm slate-900"
        />
      </label>

      <label block text="sm slate-700" font-medium>
        비밀번호
        <input
          type="password"
          name="password"
          placeholder="비밀번호 입력"
          required
          class="kjca-control"
          mt-2 block px-4 py-3 text="sm slate-900"
        />
      </label>

      <div flex gap-3 pt-2>
        <button
          type="submit"
          class="kjca-btn kjca-btn-primary"
        >
          로그인
        </button>
        <a
          href="/"
          class="kjca-btn kjca-btn-secondary"
        >
          홈으로
        </a>
      </div>
    </form>
  </div>
</section>
