<script server>
  const projectBoard = resolve('project-board')

  function patchMoveSignals(message) {
    datastar.patchSignals({
      projectMessage: message,
      projectMoveId: '',
      projectMoveStatus: '',
      projectMoveOrder: [],
    })
  }

  function patchBoard(userId, message) {
    const state = projectBoard.getProjectBoardState($app, userId)

    datastar.patchElements(
      include('project-board.ejs', {
        statusColumns: state.statusColumns,
        projectsByStatus: state.projectsByStatus,
      }),
      {
        selector: '#project-board',
        mode: 'outer',
        useViewTransition: true,
      }
    )
    patchMoveSignals(message)
    datastar.executeScript('window.launchboardSetProjectMobileSignal && window.launchboardSetProjectMobileSignal(); window.launchboardInitSortable && window.launchboardInitSortable();')
  }

  if (request.method !== 'POST') {
    warn('xapi/projects/move:invalid-method', {
      method: request.method,
    })

    if (datastar.isRequest(request)) {
      datastar.patchSignals({
        projectMessage: '잘못된 요청입니다.',
      })
      return
    }

    dbg('xapi/projects/move:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '잘못된 요청입니다.',
    })
    redirect('/', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    warn('xapi/projects/move:unauthorized', {})

    if (datastar.isRequest(request)) {
      datastar.patchSignals({
        projectMessage: '로그인이 필요합니다.',
      })
      return
    }

    dbg('xapi/projects/move:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      flash: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const signals = datastar.requestSignals({
    projectMoveId: '',
    projectMoveStatus: '',
    projectMoveOrder: [],
  })
  const userId = String(request.auth.get('id') || '')
  const projectId = String(signals.projectMoveId || '').trim()
  const status = String(signals.projectMoveStatus || '').trim()
  const moveOrder = Array.isArray(signals.projectMoveOrder) ? signals.projectMoveOrder : []
  let errorMessage = ''

  function setStatusDates(project, nextStatus) {
    if (nextStatus === 'building' && !project.get('started_at')) project.set('started_at', new Date().toISOString())
    if (nextStatus === 'launched' && !project.get('launched_at')) project.set('launched_at', new Date().toISOString())
    if (nextStatus === 'discarded' && !project.get('discarded_at')) project.set('discarded_at', new Date().toISOString())
  }

  function getProjectOrderUpdates(orderItems) {
    const updates = []
    const seen = {}

    for (let index = 0; index < orderItems.length; index += 1) {
      const item = orderItems[index] || {}
      const orderedProjectId = String(item.id || '').trim()
      const orderedStatus = String(item.status || '').trim()
      const sortOrder = Number(item.sortOrder || index + 1)

      if (!orderedProjectId || seen[orderedProjectId]) continue
      if (projectBoard.PROJECT_STATUS_VALUES.indexOf(orderedStatus) < 0) throw new Error('상태 값이 올바르지 않습니다.')
      if (isNaN(sortOrder) || sortOrder < 0) throw new Error('정렬 값이 올바르지 않습니다.')

      const project = $app.findFirstRecordByFilter('projects', 'id = {:projectId} && user = {:userId}', {
        projectId: orderedProjectId,
        userId,
      })

      seen[orderedProjectId] = true
      updates.push({
        project,
        status: orderedStatus,
        sortOrder,
      })
    }

    return updates
  }

  dbg('xapi/projects/move:start', {
    userId,
    projectId,
    status,
  })

  try {
    if (!userId) throw new Error('로그인이 필요합니다.')
    if (!projectId) throw new Error('프로젝트를 찾지 못했습니다.')
    if (projectBoard.PROJECT_STATUS_VALUES.indexOf(status) < 0) throw new Error('상태 값이 올바르지 않습니다.')

    const project = $app.findFirstRecordByFilter('projects', 'id = {:projectId} && user = {:userId}', {
      projectId,
      userId,
    })
    const previousStatus = String(project.get('status') || '')
    const orderUpdates = getProjectOrderUpdates(moveOrder)

    if (orderUpdates.length > 0) {
      let movedProjectUpdated = false

      for (let index = 0; index < orderUpdates.length; index += 1) {
        const update = orderUpdates[index]

        update.project.set('status', update.status)
        update.project.set('sort_order', update.sortOrder)
        setStatusDates(update.project, update.status)
        $app.save(update.project)
        if (String(update.project.get('id') || '') === projectId) movedProjectUpdated = true
      }

      if (!movedProjectUpdated) {
        project.set('status', status)
        setStatusDates(project, status)
        $app.save(project)
      }
    } else {
      project.set('status', status)
      setStatusDates(project, status)
      $app.save(project)
    }

    info('xapi/projects/move:success', {
      projectId,
      previousStatus,
      status,
      orderedCount: orderUpdates.length,
    })
    if (datastar.isRequest(request)) {
      patchMoveSignals('')
      return
    }

    dbg('xapi/projects/move:redirect', {
      status: 303,
      redirectTo: '/',
    })
    redirect('/', {
      status: 303,
    })
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('xapi/projects/move:failed', {
      userId,
      projectId,
      status,
      error: errorMessage,
    })
  }

  if (datastar.isRequest(request)) {
    patchBoard(userId, errorMessage || '변경에 실패했습니다.')
    return
  }

  dbg('xapi/projects/move:redirect', {
    status: 303,
    redirectTo: '/',
    error: errorMessage || '변경에 실패했습니다.',
  })
  redirect('/', {
    status: 303,
    message: errorMessage || '변경에 실패했습니다.',
  })
  return
</script>
