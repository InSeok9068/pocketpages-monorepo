<script server>
  const projectBoard = resolve('project-board')

  function patchStatusSignals(message) {
    datastar.patchSignals({
      projectMessage: message,
      projectActionOpen: false,
      projectActionId: '',
      projectActionName: '',
      projectActionStatus: '',
      projectActionHref: '',
      projectActionTasksHref: '',
      projectStatusId: '',
      projectStatus: '',
    })
  }

  function patchBoard(userId, message) {
    const state = projectBoard.getProjectBoardState($app, userId)

    datastar.patchElements(
      include('project-board.ejs', {
        statusColumns: state.statusColumns,
        projectsByStatus: state.projectsByStatus,
      }),
      {
        selector: '#project-board',
        mode: 'outer',
        useViewTransition: true,
      }
    )
    patchStatusSignals(message)
    datastar.executeScript('window.launchboardInitSortable && window.launchboardInitSortable();')
  }

  if (request.method !== 'POST') {
    if (datastar.isRequest(request)) {
      datastar.patchSignals({
        projectMessage: '잘못된 요청입니다.',
      })
      return
    }

    dbg('xapi/projects/status:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '잘못된 요청입니다.',
    })
    redirect('/', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    if (datastar.isRequest(request)) {
      datastar.patchSignals({
        projectMessage: '로그인이 필요합니다.',
      })
      return
    }

    dbg('xapi/projects/status:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      flash: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const statusValues = ['idea', 'building', 'launched', 'paused', 'discarded']
  const form = datastar.isRequest(request)
    ? datastar.requestSignals({
        projectStatusId: '',
        projectStatus: '',
      })
    : body()
  const userId = String(request.auth.get('id') || '')
  const projectId = String(form.project_id || form.projectStatusId || '').trim()
  const status = String(form.status || form.projectStatus || '').trim()
  let errorMessage = ''

  dbg('xapi/projects/status:start', {
    userId,
    projectId,
    status,
  })

  try {
    if (!userId) throw new Error('로그인이 필요합니다.')
    if (!projectId) throw new Error('프로젝트를 찾지 못했습니다.')
    if (statusValues.indexOf(status) < 0) throw new Error('상태 값이 올바르지 않습니다.')

    const project = $app.findFirstRecordByFilter('projects', 'id = {:projectId} && user = {:userId}', {
      projectId,
      userId,
    })
    const previousStatus = String(project.get('status') || '')

    project.set('status', status)

    if (status === 'building' && !project.get('started_at')) project.set('started_at', new Date().toISOString())
    if (status === 'launched' && !project.get('launched_at')) project.set('launched_at', new Date().toISOString())
    if (status === 'discarded' && !project.get('discarded_at')) project.set('discarded_at', new Date().toISOString())

    $app.save(project)

    info('xapi/projects/status:success', {
      projectId,
      previousStatus,
      status,
    })

    if (datastar.isRequest(request)) {
      patchBoard(userId, '')
      return
    }

    dbg('xapi/projects/status:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '',
    })
    redirect('/', {
      status: 303,
    })
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('xapi/projects/status:failed', {
      userId,
      projectId,
      status,
      error: errorMessage,
    })
  }

  if (datastar.isRequest(request)) {
    patchBoard(userId, errorMessage || '변경에 실패했습니다.')
    return
  }

  dbg('xapi/projects/status:redirect', {
    status: 303,
    redirectTo: '/',
    error: errorMessage || '변경에 실패했습니다.',
  })
  redirect('/', {
    status: 303,
    message: errorMessage || '변경에 실패했습니다.',
  })
  return
</script>
