<script server>
  if (request.method !== 'POST') {
    dbg('xapi/projects/update:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '잘못된 요청입니다.',
    })
    redirect('/', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    dbg('xapi/projects/update:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      flash: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const statusValues = ['idea', 'ready', 'building', 'launched', 'paused', 'discarded']
  const priorityValues = ['low', 'normal', 'high']
  const form = body()
  const userId = String(request.auth.get('id') || '')
  const projectId = String(form.project_id || '').trim()
  const nameKo = String(form.name_ko || '').trim()
  const nameEn = String(form.name_en || '').trim()
  const slug = String(form.slug || '').trim().toLowerCase()
  const status = String(form.status || '').trim()
  const priority = String(form.priority || '').trim()
  const sortOrder = Number(form.sort_order || 0)
  let redirectTo = '/'
  let project = null
  let previousSlug = ''
  let errorMessage = ''

  function optionalText(value) {
    return String(value || '').trim()
  }

  function parseTags(value) {
    const raw = String(value || '').trim()

    if (!raw) return []

    return raw
      .split(',')
      .map((tag) => tag.trim())
      .filter((tag) => !!tag)
  }

  function dateOrEmpty(value) {
    const raw = String(value || '').trim()

    if (!raw) return ''

    return new Date(raw + 'T00:00:00.000Z').toISOString()
  }

  dbg('xapi/projects/update:start', {
    userId,
    projectId,
    slug,
    status,
    priority,
  })

  try {
    if (!userId) throw new Error('로그인이 필요합니다.')
    if (!projectId) throw new Error('프로젝트를 찾지 못했습니다.')

    project = $app.findFirstRecordByFilter('projects', 'id = {:projectId} && user = {:userId}', {
      projectId,
      userId,
    })
    previousSlug = String(project.get('slug') || '')
    redirectTo = previousSlug ? '/projects/' + encodeURIComponent(previousSlug) : '/'

    if (!nameKo) throw new Error('프로젝트명이 필요합니다.')
    if (!/^[a-z0-9]+(?:-[a-z0-9]+)*$/.test(slug)) throw new Error('슬러그는 영문 소문자, 숫자, 하이픈만 사용할 수 있습니다.')
    if (statusValues.indexOf(status) < 0) throw new Error('상태 값이 올바르지 않습니다.')
    if (priorityValues.indexOf(priority) < 0) throw new Error('우선순위 값이 올바르지 않습니다.')
    if (isNaN(sortOrder) || sortOrder < 0) throw new Error('정렬 값이 올바르지 않습니다.')

    if (slug !== previousSlug) {
      try {
        $app.findFirstRecordByFilter('projects', 'slug = {:slug} && user = {:userId} && id != {:projectId}', {
          slug,
          userId,
          projectId,
        })
        throw new Error('이미 같은 슬러그가 있습니다.')
      } catch (exception) {
        if (String(exception.message || exception) === '이미 같은 슬러그가 있습니다.') {
          throw exception
        }
      }
    }

    project.set('name_ko', nameKo)
    project.set('name_en', nameEn)
    project.set('slug', slug)
    project.set('status', status)
    project.set('priority', priority)
    project.set('domain_url', optionalText(form.domain_url))
    project.set('repo_url', optionalText(form.repo_url))
    project.set('description', optionalText(form.description))
    project.set('problem', optionalText(form.problem))
    project.set('target_user', optionalText(form.target_user))
    project.set('status_reason', optionalText(form.status_reason))
    project.set('tags', parseTags(form.tags))
    project.set('sort_order', sortOrder)
    project.set('is_pinned', String(form.is_pinned || '') === 'true')
    project.set('started_at', dateOrEmpty(form.started_at))
    project.set('launched_at', dateOrEmpty(form.launched_at))
    project.set('discarded_at', dateOrEmpty(form.discarded_at))

    if (status === 'building' && !project.get('started_at')) project.set('started_at', new Date().toISOString())
    if (status === 'launched' && !project.get('launched_at')) project.set('launched_at', new Date().toISOString())
    if (status === 'discarded' && !project.get('discarded_at')) project.set('discarded_at', new Date().toISOString())

    $app.save(project)

    redirectTo = '/projects/' + encodeURIComponent(slug)

    info('xapi/projects/update:success', {
      projectId,
      previousSlug,
      slug,
    })
    dbg('xapi/projects/update:redirect', {
      status: 303,
      redirectTo,
      flash: '저장했습니다.',
    })
    redirect(redirectTo, {
      status: 303,
      message: '저장했습니다.',
    })
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('xapi/projects/update:failed', {
      userId,
      projectId,
      slug,
      error: errorMessage,
    })
  }

  dbg('xapi/projects/update:redirect', {
    status: 303,
    redirectTo,
    error: errorMessage || '저장에 실패했습니다.',
  })
  redirect(redirectTo, {
    status: 303,
    message: errorMessage || '저장에 실패했습니다.',
  })
  return
</script>
