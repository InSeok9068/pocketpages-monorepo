<script server>
  const taskBoard = resolve('task-board')

  function patchMoveSignals(message) {
    datastar.patchSignals({
      moveTaskId: '',
      moveStatus: '',
      moveOrder: [],
      taskMessage: message,
      taskActionOpen: false,
      taskActionId: '',
      taskActionTitle: '',
      taskActionStatus: '',
      taskActionHref: '',
      taskActionProjectId: '',
      taskActionBoardScope: 'project',
      taskActionView: 'all',
    })
  }

  function patchInbox(view, userId, message) {
    const inboxView = view === 'today' ? 'today' : 'all'
    const state = taskBoard.getTaskInboxState($app, userId, inboxView)

    datastar.patchElements(
      include('task-board.ejs', {
        projectId: '',
        projectSlug: '',
        statusColumns: state.statusColumns,
        tasksByStatus: state.tasksByStatus,
        canSortTasks: true,
        canDeleteTasks: true,
        canFilterTasks: true,
        boardScope: 'inbox',
        taskView: inboxView,
      }),
      {
        selector: '#task-board',
        mode: 'outer',
      }
    )
    datastar.patchSignals({
      moveTaskId: '',
      moveStatus: '',
      moveOrder: [],
      taskMessage: message,
      taskActionOpen: false,
      taskActionId: '',
      taskActionTitle: '',
      taskActionStatus: '',
      taskActionHref: '',
      taskActionProjectId: '',
      taskActionBoardScope: 'inbox',
      taskActionView: inboxView,
    })
    datastar.executeScript('window.launchboardInitTaskSortable && window.launchboardInitTaskSortable(); window.launchboardApplyTaskFilter && window.launchboardApplyTaskFilter();')
  }

  function patchBoard(projectId, userId, message) {
    const project = $app.findFirstRecordByFilter('projects', 'id = {:projectId} && user = {:userId}', {
      projectId,
      userId,
    })
    const projectSlug = String(project.get('slug') || '').trim()
    const state = taskBoard.getTaskBoardState($app, userId, projectId)

    datastar.patchElements(
      include('task-board.ejs', {
        projectId,
        projectSlug,
        statusColumns: state.statusColumns,
        tasksByStatus: state.tasksByStatus,
        canFilterTasks: false,
      }),
      {
        selector: '#task-board',
        mode: 'outer',
      }
    )
    patchMoveSignals(message)
    datastar.executeScript('window.launchboardInitTaskSortable && window.launchboardInitTaskSortable();')
  }

  if (request.method !== 'POST') {
    warn('xapi/tasks/move:invalid-method', {
      method: request.method,
    })
    datastar.patchSignals({
      taskMessage: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    warn('xapi/tasks/move:unauthorized', {})
    datastar.patchSignals({
      taskMessage: '로그인이 필요합니다.',
    })
    return
  }

  const signals = datastar.requestSignals({
    moveTaskId: '',
    moveStatus: '',
    moveOrder: [],
    taskBoardScope: 'project',
    taskView: 'all',
  })
  const userId = String(request.auth.get('id') || '')
  const taskId = String(signals.moveTaskId || '').trim()
  const status = String(signals.moveStatus || '').trim()
  const moveOrder = Array.isArray(signals.moveOrder) ? signals.moveOrder : []
  const boardScope = String(signals.taskBoardScope || 'project').trim()
  const taskView = String(signals.taskView || 'all').trim()
  let projectId = ''
  let errorMessage = ''

  function setStatusDates(task, nextStatus) {
    if (nextStatus === 'doing' && !task.get('started_at')) task.set('started_at', new Date().toISOString())
    if (nextStatus === 'done' && !task.get('completed_at')) task.set('completed_at', new Date().toISOString())
    if (nextStatus === 'canceled' && !task.get('canceled_at')) task.set('canceled_at', new Date().toISOString())
  }

  function getTaskOrderUpdates(orderItems, targetProjectId) {
    const updates = []
    const seen = {}

    for (let index = 0; index < orderItems.length; index += 1) {
      const item = orderItems[index] || {}
      const orderedTaskId = String(item.id || '').trim()
      const orderedStatus = String(item.status || '').trim()
      const sortOrder = Number(item.sortOrder || index + 1)

      if (!orderedTaskId || seen[orderedTaskId]) continue
      if (taskBoard.TASK_STATUS_VALUES.indexOf(orderedStatus) < 0) throw new Error('상태 값이 올바르지 않습니다.')
      if (isNaN(sortOrder) || sortOrder < 0) throw new Error('정렬 값이 올바르지 않습니다.')

      const task = $app.findFirstRecordByFilter('project_tasks', 'id = {:taskId} && user = {:userId} && project = {:projectId}', {
        taskId: orderedTaskId,
        userId,
        projectId: targetProjectId,
      })

      seen[orderedTaskId] = true
      updates.push({
        task,
        status: orderedStatus,
        sortOrder,
      })
    }

    return updates
  }

  dbg('xapi/tasks/move:start', {
    userId,
    taskId,
    status,
  })

  try {
    if (!userId) throw new Error('로그인이 필요합니다.')
    if (!taskId) throw new Error('업무를 찾지 못했습니다.')
    if (taskBoard.TASK_STATUS_VALUES.indexOf(status) < 0) throw new Error('상태 값이 올바르지 않습니다.')

    const task = $app.findFirstRecordByFilter('project_tasks', 'id = {:taskId} && user = {:userId}', {
      taskId,
      userId,
    })
    const previousStatus = String(task.get('status') || '')
    projectId = String(task.get('project') || '')
    const orderUpdates = boardScope === 'inbox' ? [] : getTaskOrderUpdates(moveOrder, projectId)

    if (orderUpdates.length > 0) {
      let movedTaskUpdated = false

      for (let index = 0; index < orderUpdates.length; index += 1) {
        const update = orderUpdates[index]

        update.task.set('status', update.status)
        update.task.set('sort_order', update.sortOrder)
        setStatusDates(update.task, update.status)
        $app.save(update.task)
        if (String(update.task.get('id') || '') === taskId) movedTaskUpdated = true
      }

      if (!movedTaskUpdated) {
        task.set('status', status)
        setStatusDates(task, status)
        $app.save(task)
      }
    } else {
      task.set('status', status)
      setStatusDates(task, status)
      $app.save(task)
    }

    info('xapi/tasks/move:success', {
      taskId,
      projectId,
      previousStatus,
      status,
      orderedCount: orderUpdates.length,
    })
    if (boardScope === 'inbox') {
      patchInbox(taskView, userId, '')
      return
    }

    if (orderUpdates.length === 0) {
      patchBoard(projectId, userId, '')
      return
    }

    patchMoveSignals('')
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('xapi/tasks/move:failed', {
      userId,
      taskId,
      status,
      error: errorMessage,
    })
  }

  if (boardScope === 'inbox') {
    patchInbox(taskView, userId, errorMessage || '변경에 실패했습니다.')
    return
  }

  if (projectId) {
    patchBoard(projectId, userId, errorMessage || '변경에 실패했습니다.')
    return
  }

  datastar.patchSignals({
    moveTaskId: '',
    moveStatus: '',
    taskMessage: errorMessage || '변경에 실패했습니다.',
  })
  return
</script>
