<%
  const navActive = typeof activeNav === 'undefined' ? '' : String(activeNav || '')
  const navCanCreateTask = typeof canCreateTask === 'undefined' ? false : canCreateTask === true

  const navItems = [
    { key: 'tasks', href: '/tasks', label: '업무', icon: 'i-lucide-list-todo' },
    { key: 'today', href: '/tasks?view=today', label: '오늘', icon: 'i-lucide-calendar-check' },
    { key: 'projects', href: '/', label: '프로젝트', icon: 'i-lucide-panels-top-left' },
  ]
  const mobileGridClass = navCanCreateTask ? 'grid-cols-4' : 'grid-cols-3'
%>

<aside class="fixed right-0 bottom-0 left-0 z-40 border-t border-[#e5e8eb] bg-white/95 px-3 pt-2 pb-3 shadow-[0_-10px_30px_rgba(25,31,40,0.08)] backdrop-blur">
  <nav
    class="<%= mobileGridClass %> mx-auto grid max-w-[520px] gap-1"
    aria-label="업무 네비게이션">
    <% for (let index = 0; index < navItems.length; index += 1) { %>
    <% const item = navItems[index] %>
    <a
      href="<%= item.href %>"
      class="<%= navActive === item.key ? 'text-[#1b64da]' : 'text-[#6b7684]' %> flex min-w-0 flex-col items-center justify-center gap-1 rounded-lg px-1 py-1.5 text-[11px] font-bold no-underline hover:bg-[#f7f8fa]"
      aria-current="<%= navActive === item.key ? 'page' : 'false' %>">
      <span
        class="<%= item.icon %> h-5 w-5"
        aria-hidden="true"></span>
      <span class="truncate"><%= item.label %></span>
    </a>
    <% } %>

    <% if (navCanCreateTask) { %>
    <button
      type="button"
      class="flex min-w-0 flex-col items-center justify-center gap-1 rounded-lg border-0 bg-transparent px-1 py-1.5 text-[11px] font-bold text-[#6b7684] hover:bg-[#f7f8fa] hover:text-[#191f28]"
      data-on:click="$taskModalOpen = true">
      <span
        class="i-lucide-plus h-5 w-5"
        aria-hidden="true"></span>
      <span class="truncate">추가</span>
    </button>
    <% } %>
  </nav>
</aside>
