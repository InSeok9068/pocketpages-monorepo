<div
  id="task-board"
  class="grid gap-3"
  data-task-board
  data-project-id="<%= projectId %>"
  data-project-slug="<%= projectSlug %>">
  <%
    const taskBoardCanSort = typeof canSortTasks === 'undefined' ? true : canSortTasks === true
    const taskBoardCanDelete = typeof canDeleteTasks === 'undefined' ? true : canDeleteTasks === true
    const taskBoardCanFilter = canFilterTasks === true
    const taskBoardScope = typeof boardScope === 'undefined' ? (projectId ? 'project' : 'inbox') : String(boardScope || 'project')
    const taskBoardView = typeof taskView === 'undefined' ? 'all' : String(taskView || 'all')
  %>
  <nav
    class="grid grid-cols-5 gap-1 rounded-lg bg-white p-1 shadow-[0_8px_24px_rgba(25,31,40,0.05)]"
    aria-label="업무 상태"
    data-task-mobile-tabs>
    <% for (let tabIndex = 0; tabIndex < statusColumns.length; tabIndex += 1) { %>
    <% const tabColumn = statusColumns[tabIndex] %>
    <% const tabTasks = tasksByStatus[tabColumn.value] || [] %>
    <button
      type="button"
      class="flex h-11 min-w-0 flex-col items-center justify-center gap-0.5 rounded-md border-0 bg-[#f2f4f6] px-1 text-[10px] leading-none font-bold text-[#4e5968] hover:bg-[#eaf3ff]"
      data-task-status-tab
      data-status="<%= tabColumn.value %>"
      data-attr="{'aria-pressed': $activeTaskStatus === '<%= tabColumn.value %>' ? 'true' : 'false'}"
      data-class="{'bg-[#eaf3ff] text-[#1b64da] shadow-[inset_0_0_0_1px_rgba(49,130,246,0.28)]': $activeTaskStatus === '<%= tabColumn.value %>', 'bg-[#f2f4f6] text-[#4e5968]': $activeTaskStatus !== '<%= tabColumn.value %>'}"
      data-on:click="window.launchboardActivateTaskStatus && window.launchboardActivateTaskStatus('<%= tabColumn.value %>')">
      <span
        class="<%= tabColumn.icon %> h-3.5 w-3.5"
        aria-hidden="true"></span>
      <span class="flex max-w-full min-w-0 items-center gap-0.5">
        <span class="truncate"><%= tabColumn.label %></span>
        <span
          class="shrink-0 text-[10px] text-[#6b7684]"
          data-task-status-count
          data-status="<%= tabColumn.value %>"
          data-class="{'text-[#1b64da]': $activeTaskStatus === '<%= tabColumn.value %>', 'text-[#6b7684]': $activeTaskStatus !== '<%= tabColumn.value %>'}">
          <%= tabTasks.length %>
        </span>
      </span>
    </button>
    <% } %>
  </nav>

  <div
    class="launchboard-task-swiper swiper"
    data-task-status-swiper>
    <div class="swiper-wrapper">
      <% for (let columnIndex = 0; columnIndex < statusColumns.length; columnIndex += 1) { %>
      <% const column = statusColumns[columnIndex] %>
      <% const columnTasks = tasksByStatus[column.value] || [] %>
      <section
        id="task-status-<%= column.value %>"
        class="<%= column.surface %> swiper-slide min-h-[240px] rounded-lg p-3"
        data-task-column
        data-status="<%= column.value %>">
        <header class="flex items-center justify-between gap-3 px-1 py-1">
          <div class="flex min-w-0 items-center gap-2">
            <span class="<%= column.iconTone %> inline-flex h-7 w-7 items-center justify-center rounded-lg">
              <span
                class="<%= column.icon %> h-4 w-4"
                aria-hidden="true"></span>
            </span>
            <h2 class="truncate text-sm font-bold text-[#191f28]"><%= column.label %></h2>
            <span
              class="text-xs font-bold text-[#8b95a1]"
              data-task-status-count
              data-status="<%= column.value %>">
              <%= columnTasks.length %>
            </span>
          </div>

          <div class="flex shrink-0 items-center gap-1">
            <% if (taskBoardCanFilter) { %>
            <div class="relative">
              <button
                type="button"
                class="inline-flex h-8 w-8 items-center justify-center rounded-lg border-0 bg-white/70 text-[#6b7684] hover:bg-white"
                aria-label="업무 검색 필터"
                data-attr="{'aria-expanded': $taskFilterOpen ? 'true' : 'false'}"
                data-on:click="$taskFilterOpen = !$taskFilterOpen">
                <span
                  class="i-lucide-search h-4 w-4"
                  aria-hidden="true"></span>
              </button>
            </div>
            <% } %>
          </div>
        </header>

        <% if (taskBoardCanFilter) { %>
        <div
          class="mt-2 grid gap-2"
          data-task-filter-panel
          data-show="$taskFilterOpen"
          style="display: none">
          <label class="relative block">
            <span
              class="i-lucide-search pointer-events-none absolute top-1/2 left-3 h-4 w-4 -translate-y-1/2 text-[#8b95a1]"
              aria-hidden="true"></span>
            <input
              type="search"
              class="h-9 w-full rounded-lg border-0 bg-white/80 pr-3 pl-9 text-sm font-semibold text-[#191f28] outline-none placeholder:text-[#b0b8c1] focus:bg-white focus:shadow-[inset_0_0_0_1px_#3182f6]"
              placeholder="검색"
              data-task-filter-query
              data-on:input="window.launchboardApplyTaskFilter && window.launchboardApplyTaskFilter(el)" />
          </label>

          <div class="launchboard-scrollbar-none flex gap-2 overflow-x-auto pb-1">
            <label class="flex h-8 shrink-0 cursor-pointer items-center justify-center gap-1 rounded-lg bg-white/80 px-3 text-xs font-bold text-[#4e5968] hover:bg-white">
              <input
                type="checkbox"
                class="h-4 w-4 accent-[#3182f6]"
                data-task-filter-high
                data-on:input="window.launchboardApplyTaskFilter && window.launchboardApplyTaskFilter(el)" />
              높음
            </label>
            <label class="flex h-8 shrink-0 cursor-pointer items-center justify-center gap-1 rounded-lg bg-white/80 px-3 text-xs font-bold text-[#4e5968] hover:bg-white">
              <input
                type="checkbox"
                class="h-4 w-4 accent-[#3182f6]"
                data-task-filter-due
                data-on:input="window.launchboardApplyTaskFilter && window.launchboardApplyTaskFilter(el)" />
              마감
            </label>
          </div>
        </div>
        <% } %>

        <div
          class="mt-2.5 grid gap-2.5"
          data-task-sortable-list
          data-status="<%= column.value %>">
          <div
            class="rounded-lg bg-white/70 px-3 py-2.5 text-center text-xs font-medium text-[#8b95a1]"
            <% if (columnTasks.length > 0) { %>hidden<% } %>
            data-task-empty-state>
            비어 있음
          </div>

          <% for (let taskIndex = 0; taskIndex < columnTasks.length; taskIndex += 1) { %>
          <% const task = columnTasks[taskIndex] %>
          <%
            const baseTaskHref = task.href || (projectSlug ? '/projects/' + encodeURIComponent(projectSlug) + '/tasks/' + encodeURIComponent(task.id) : '#')
            const returnTo = taskBoardView === 'today' ? '/tasks?view=today' : '/tasks'
            const taskHref = taskBoardScope === 'inbox' && baseTaskHref !== '#' ? baseTaskHref + '?return_to=' + encodeURIComponent(returnTo) : baseTaskHref
          %>
          <article
            class="max-w-full min-w-0 cursor-pointer overflow-hidden rounded-lg bg-white p-3.5 shadow-[0_8px_22px_rgba(25,31,40,0.07),0_0_0_1px_rgba(227,231,237,0.72)] transition hover:-translate-y-0.5 hover:shadow-[0_12px_28px_rgba(25,31,40,0.1),0_0_0_1px_rgba(49,130,246,0.16)]"
            data-task-card
            data-task-id="<%= task.id %>"
            data-project-id="<%= task.projectId %>"
            data-status="<%= task.status %>"
            data-task-search="<%= task.title %> <%= task.description %> <%= task.projectName %> <%= task.typeLabel %>"
            data-priority="<%= task.priority %>"
            data-has-due="<%= task.dueAt ? 'true' : 'false' %>"
            role="link"
            tabindex="0"
            data-on:click="if (document.body.dataset.launchboardTaskDragging !== 'true') window.location.href = '<%= taskHref %>'"
            data-on:keydown="if (evt.key === 'Enter') window.location.href = '<%= taskHref %>'">
            <div class="flex min-w-0 items-start justify-between gap-3">
              <div class="min-w-0 flex-1">
                <div class="flex min-w-0 items-center gap-1.5">
                  <% if (task.isPinned) { %>
                  <span
                    class="i-lucide-pin h-3.5 w-3.5 shrink-0 text-[#f59f00]"
                    aria-hidden="true"></span>
                  <% } %>
                  <h3 class="min-w-0 flex-1 truncate text-sm leading-5 font-bold text-[#191f28]"><%= task.title %></h3>
                </div>
                <% if (task.projectName) { %>
                <p class="mt-0.5 truncate text-[11px] font-bold text-[#8b95a1]"><%= task.projectName %></p>
                <% } %>
                <% if (task.description) { %>
                <p class="mt-1 line-clamp-2 text-xs leading-5 text-[#6b7684]"><%= task.description %></p>
                <% } %>
              </div>

              <div class="flex shrink-0 items-center gap-1">
                <button
                  type="button"
                  class="inline-flex h-8 w-8 items-center justify-center rounded-md border-0 bg-[#f2f4f6] text-[#4e5968] hover:bg-[#e5e8eb]"
                  aria-label="업무 작업"
                  title="업무 작업"
                  data-task-action-button
                  data-task-id="<%= task.id %>"
                  data-task-title="<%= task.title %>"
                  data-task-status="<%= task.status %>"
                  data-task-href="<%= taskHref %>"
                  data-task-project-id="<%= task.projectId %>"
                  data-task-board-scope="<%= taskBoardScope %>"
                  data-task-view="<%= taskBoardView %>"
                  data-on:click__stop="$taskActionId = el.dataset.taskId; $taskActionTitle = el.dataset.taskTitle; $taskActionStatus = el.dataset.taskStatus; $taskActionHref = el.dataset.taskHref; $taskActionProjectId = el.dataset.taskProjectId; $taskActionBoardScope = el.dataset.taskBoardScope; $taskActionView = el.dataset.taskView; $taskActionOpen = true">
                  <span
                    class="i-lucide-more-horizontal h-4 w-4"
                    aria-hidden="true"></span>
                </button>
                <% if (taskBoardCanSort) { %>
                <span
                  role="button"
                  tabindex="-1"
                  class="inline-flex h-8 w-8 cursor-grab items-center justify-center rounded-md border-0 bg-[#f2f4f6] text-[#8b95a1] active:cursor-grabbing"
                  data-task-drag-handle
                  aria-label="드래그">
                  <span
                    class="i-lucide-grip-vertical h-4 w-4"
                    aria-hidden="true"></span>
                </span>
                <% } %>
              </div>
            </div>

            <div class="mt-2.5 flex items-center justify-between gap-2">
              <div class="flex min-w-0 flex-wrap items-center gap-1.5">
                <span class="rounded-md bg-[#f2f4f6] px-2 py-1 text-[11px] font-bold text-[#6b7684]"><%= task.typeLabel %></span>
                <% if (task.dueBadge) { %>
                <span class="<%= task.dueBadge.tone %> inline-flex items-center gap-1 rounded-md px-2 py-1 text-[11px] font-bold">
                  <span
                    class="<%= task.dueBadge.icon %> h-3 w-3"
                    aria-hidden="true"></span>
                  <%= task.dueBadge.label %>
                </span>
                <% } %>
                <% for (let badgeIndex = 0; badgeIndex < task.signalBadges.length; badgeIndex += 1) { %>
                <% const badge = task.signalBadges[badgeIndex] %>
                <span class="<%= badge.tone %> inline-flex items-center gap-1 rounded-md px-2 py-1 text-[11px] font-bold">
                  <span
                    class="<%= badge.icon %> h-3 w-3"
                    aria-hidden="true"></span>
                  <%= badge.label %>
                </span>
                <% } %>
                <% if (task.dueAt) { %>
                <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[#8b95a1]">
                  <span
                    class="i-lucide-calendar h-3.5 w-3.5"
                    aria-hidden="true"></span>
                  <%= task.dueAt %>
                </span>
                <% } %>
              </div>

              <% if (taskBoardCanDelete) { %>
              <form
                method="post"
                action="/xapi/tasks/delete"
                data-on:submit="@post('/xapi/tasks/delete', {contentType: 'form'})"
                data-on:click__stop="true">
                <input
                  type="hidden"
                  name="task_id"
                  value="<%= task.id %>" />
                <input
                  type="hidden"
                  name="project_id"
                  value="<%= projectId %>" />
                <input
                  type="hidden"
                  name="task_board_scope"
                  value="<%= taskBoardScope %>" />
                <input
                  type="hidden"
                  name="task_view"
                  value="<%= taskBoardView %>" />
                <button
                  type="submit"
                  class="inline-flex h-7 w-7 items-center justify-center rounded-md border-0 bg-[#f7f8fa] text-[#8b95a1] hover:bg-[#fff0f0] hover:text-[#e03131]"
                  aria-label="삭제"
                  data-on:click__stop="if (!confirm('이 업무를 완전히 삭제할까요?')) evt.preventDefault()">
                  <span
                    class="i-lucide-trash-2 h-3.5 w-3.5"
                    aria-hidden="true"></span>
                </button>
              </form>
              <% } %>
            </div>
          </article>
          <% } %>
        </div>
      </section>
      <% } %>
    </div>
  </div>
</div>
