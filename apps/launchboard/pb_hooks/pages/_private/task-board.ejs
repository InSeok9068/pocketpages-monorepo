<div
  id="task-board"
  class="grid gap-3 md:gap-4"
  data-task-board
  data-project-id="<%= projectId %>"
  data-project-slug="<%= projectSlug %>">
  <nav
    class="grid grid-cols-5 gap-1 rounded-lg bg-white p-1 shadow-[0_8px_24px_rgba(25,31,40,0.05)] md:hidden"
    aria-label="업무 상태"
    data-task-mobile-tabs>
    <% for (let tabIndex = 0; tabIndex < statusColumns.length; tabIndex += 1) { %>
    <% const tabColumn = statusColumns[tabIndex] %>
    <% const tabTasks = tasksByStatus[tabColumn.value] || [] %>
    <button
      type="button"
      class="flex h-11 min-w-0 flex-col items-center justify-center gap-0.5 rounded-md border-0 bg-[#f2f4f6] px-1 text-[10px] font-bold leading-none text-[#4e5968] hover:bg-[#eaf3ff] sm:h-12"
      data-task-status-tab
      data-status="<%= tabColumn.value %>"
      data-attr="{'aria-pressed': $activeTaskStatus === '<%= tabColumn.value %>' ? 'true' : 'false'}"
      data-class="{'bg-[#eaf3ff] text-[#1b64da] shadow-[inset_0_0_0_1px_rgba(49,130,246,0.28)]': $activeTaskStatus === '<%= tabColumn.value %>', 'bg-[#f2f4f6] text-[#4e5968]': $activeTaskStatus !== '<%= tabColumn.value %>'}"
      data-on:click="$activeTaskStatus = '<%= tabColumn.value %>'; window.launchboardSaveTaskActiveStatus && window.launchboardSaveTaskActiveStatus($activeTaskStatus)">
      <span
        class="<%= tabColumn.icon %> h-3.5 w-3.5"
        aria-hidden="true"></span>
      <span class="flex max-w-full min-w-0 items-center gap-0.5">
        <span class="truncate"><%= tabColumn.label %></span>
        <span
          class="shrink-0 text-[10px] text-[#6b7684]"
          data-task-status-count
          data-status="<%= tabColumn.value %>"
          data-class="{'text-[#1b64da]': $activeTaskStatus === '<%= tabColumn.value %>', 'text-[#6b7684]': $activeTaskStatus !== '<%= tabColumn.value %>'}"
          ><%= tabTasks.length %></span
        >
      </span>
    </button>
    <% } %>
  </nav>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    <% for (let columnIndex = 0; columnIndex < statusColumns.length; columnIndex += 1) { %>
    <% const column = statusColumns[columnIndex] %>
    <% const columnTasks = tasksByStatus[column.value] || [] %>
    <section
      id="task-status-<%= column.value %>"
      class="<%= column.surface %> rounded-lg p-2.5 sm:p-3"
      data-task-column
      data-status="<%= column.value %>"
      data-show="!$isTaskMobile || $activeTaskStatus === '<%= column.value %>'"
      data-class="{'min-h-0': !$isTaskMobile && $collapsedTaskStatuses.<%= column.value %>, 'min-h-[240px]': $isTaskMobile || !$collapsedTaskStatuses.<%= column.value %>}">
      <header class="flex items-center justify-between gap-3 px-1 py-1">
        <div class="flex min-w-0 items-center gap-2">
          <span class="<%= column.iconTone %> inline-flex h-7 w-7 items-center justify-center rounded-lg">
            <span
              class="<%= column.icon %> h-4 w-4"
              aria-hidden="true"></span>
          </span>
          <h2 class="truncate text-sm font-bold text-[#191f28]"><%= column.label %></h2>
          <span
            class="text-xs font-bold text-[#8b95a1]"
            data-task-status-count
            data-status="<%= column.value %>"><%= columnTasks.length %></span>
        </div>

        <button
          type="button"
          class="hidden h-8 w-8 shrink-0 items-center justify-center rounded-lg border-0 bg-white/70 text-[#6b7684] hover:bg-white md:inline-flex"
          data-task-collapse-button
          data-status="<%= column.value %>"
          data-attr="{'aria-label': $collapsedTaskStatuses.<%= column.value %> ? '펼치기' : '접기', 'aria-expanded': $collapsedTaskStatuses.<%= column.value %> ? 'false' : 'true'}"
          data-on:click="$collapsedTaskStatuses.<%= column.value %> = !$collapsedTaskStatuses.<%= column.value %>; window.launchboardSaveTaskCollapsedStatuses && window.launchboardSaveTaskCollapsedStatuses($collapsedTaskStatuses)">
          <span
            data-show="$collapsedTaskStatuses.<%= column.value %>"
            style="display: none"
            class="i-lucide-chevron-down h-4 w-4"
            aria-hidden="true"></span>
          <span
            data-show="!$collapsedTaskStatuses.<%= column.value %>"
            class="i-lucide-chevron-up h-4 w-4"
            aria-hidden="true"></span>
        </button>
      </header>

      <div
        class="mt-3 grid gap-3"
        data-task-sortable-list
        data-status="<%= column.value %>"
        data-show="$isTaskMobile || !$collapsedTaskStatuses.<%= column.value %>">
        <div
          class="rounded-lg bg-white/70 px-3 py-3 text-center text-xs font-medium text-[#8b95a1]"
          <% if (columnTasks.length > 0) { %>hidden<% } %>
          data-task-empty-state>
          비어 있음
        </div>

        <% for (let taskIndex = 0; taskIndex < columnTasks.length; taskIndex += 1) { %>
        <% const task = columnTasks[taskIndex] %>
        <% const taskHref = '/projects/' + encodeURIComponent(projectSlug) + '/tasks/' + encodeURIComponent(task.id) %>
        <article
          class="cursor-pointer rounded-lg bg-white p-2.5 shadow-[0_8px_22px_rgba(25,31,40,0.07),0_0_0_1px_rgba(227,231,237,0.72)] transition hover:-translate-y-0.5 hover:shadow-[0_12px_28px_rgba(25,31,40,0.1),0_0_0_1px_rgba(49,130,246,0.16)] sm:p-3"
          data-task-card
          data-task-id="<%= task.id %>"
          data-status="<%= task.status %>"
          role="link"
          tabindex="0"
          data-on:click="if (document.body.dataset.launchboardTaskDragging !== 'true') window.location.href = '<%= taskHref %>'"
          data-on:keydown="if (evt.key === 'Enter') window.location.href = '<%= taskHref %>'">
          <div class="flex items-start justify-between gap-2">
            <div class="min-w-0">
              <div class="flex min-w-0 items-center gap-1.5">
                <% if (task.isPinned) { %>
                <span
                  class="i-lucide-pin h-3.5 w-3.5 shrink-0 text-[#f59f00]"
                  aria-hidden="true"></span>
                <% } %>
                <h3 class="truncate text-sm font-bold leading-6 text-[#191f28]"><%= task.title %></h3>
              </div>
              <% if (task.description) { %>
              <p class="mt-1 line-clamp-2 text-xs leading-5 text-[#6b7684]"><%= task.description %></p>
              <% } %>
            </div>

            <div class="flex shrink-0 items-center gap-1">
              <% if (task.showPriority) { %>
              <span class="<%= task.priorityTone %> rounded-md px-1.5 py-1 text-[10px] font-bold"><%= task.priorityLabel %></span>
              <% } %>
              <span
                role="button"
                tabindex="-1"
                class="inline-flex h-9 w-9 cursor-grab items-center justify-center rounded-md border-0 bg-[#f2f4f6] text-[#8b95a1] active:cursor-grabbing md:h-7 md:w-7"
                data-task-drag-handle
                aria-label="드래그">
                <span
                  class="i-lucide-grip-vertical h-4 w-4"
                  aria-hidden="true"></span>
              </span>
            </div>
          </div>

          <div class="mt-3 flex items-center justify-between gap-2">
            <div class="flex min-w-0 items-center gap-1.5">
              <span class="rounded-md bg-[#f2f4f6] px-2 py-1 text-[11px] font-bold text-[#6b7684]"><%= task.typeLabel %></span>
              <% if (task.dueAt) { %>
              <span class="inline-flex items-center gap-1 text-[11px] font-medium text-[#8b95a1]">
                <span
                  class="i-lucide-calendar h-3.5 w-3.5"
                  aria-hidden="true"></span>
                <%= task.dueAt %>
              </span>
              <% } %>
            </div>

            <form
              method="post"
              action="/xapi/tasks/delete"
              data-on:submit="@post('/xapi/tasks/delete', {contentType: 'form'})"
              data-on:click__stop="true">
              <input
                type="hidden"
                name="task_id"
                value="<%= task.id %>" />
              <input
                type="hidden"
                name="project_id"
                value="<%= projectId %>" />
              <button
                type="submit"
                class="inline-flex h-7 w-7 items-center justify-center rounded-md border-0 bg-[#f7f8fa] text-[#8b95a1] hover:bg-[#fff0f0] hover:text-[#e03131]"
                aria-label="삭제"
                data-on:click__stop="if (!confirm('이 업무를 완전히 삭제할까요?')) evt.preventDefault()">
                <span
                  class="i-lucide-trash-2 h-3.5 w-3.5"
                  aria-hidden="true"></span>
              </button>
            </form>
          </div>
        </article>
        <% } %>
      </div>
    </section>
    <% } %>
  </div>
</div>
