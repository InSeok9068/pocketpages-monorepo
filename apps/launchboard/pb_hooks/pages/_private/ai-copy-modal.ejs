<div
  class="fixed inset-0 z-50 !mt-0 flex items-end justify-center bg-[#191f28]/45 px-4 py-4 sm:items-center"
  data-show="$aiCopyModalOpen"
  data-on:click="if (evt.target === el) $aiCopyModalOpen = false"
  style="display: none">
  <section
    class="w-full max-w-[560px] rounded-lg bg-white p-4 shadow-[0_24px_80px_rgba(25,31,40,0.28)] sm:p-5"
    data-on:click__stop="true">
    <header class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <p class="text-xs font-bold text-[#8b95a1]">AI 컨텍스트</p>
        <h2 class="mt-1 text-xl font-bold text-[#191f28]">복사</h2>
      </div>
      <button
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border-0 bg-[#f2f4f6] text-[#4e5968] hover:bg-[#e5e8eb]"
        aria-label="닫기"
        data-on:click="$aiCopyModalOpen = false">
        <span
          class="i-lucide-x h-4 w-4"
          aria-hidden="true"></span>
      </button>
    </header>

    <div class="mt-4 grid gap-3">
      <div class="rounded-lg bg-[#f7f8fa] px-3 py-2 text-sm font-semibold text-[#4e5968]">
        범위: <span class="font-bold text-[#191f28]"><%= scopeLabel %></span>
      </div>

      <fieldset class="launchboard-choice-fieldset">
        <legend class="mb-2 text-sm font-semibold text-[#4e5968]">포맷</legend>
        <div class="grid grid-cols-2 gap-2">
          <label class="relative">
            <input
              type="radio"
              name="<%= copyId %>-format"
              value="markdown"
              class="launchboard-choice-input"
              data-bind:ai-copy-format
              checked />
            <span class="launchboard-priority-choice flex h-10 w-full items-center justify-center rounded-lg bg-[#f7f8fa] text-sm font-bold text-[#4e5968] shadow-[inset_0_0_0_1px_rgba(227,231,237,0)] transition-colors duration-150 hover:bg-[#f2f4f6]">
              Markdown
            </span>
          </label>
          <label class="relative">
            <input
              type="radio"
              name="<%= copyId %>-format"
              value="json"
              class="launchboard-choice-input"
              data-bind:ai-copy-format />
            <span class="launchboard-priority-choice flex h-10 w-full items-center justify-center rounded-lg bg-[#f7f8fa] text-sm font-bold text-[#4e5968] shadow-[inset_0_0_0_1px_rgba(227,231,237,0)] transition-colors duration-150 hover:bg-[#f2f4f6]">
              JSON
            </span>
          </label>
        </div>
      </fieldset>

      <textarea
        id="<%= copyId %>-markdown"
        readonly
        rows="13"
        class="resize-none rounded-lg border-0 bg-[#f7f8fa] px-3 py-3 font-mono text-xs leading-5 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
        data-show="$aiCopyFormat === 'markdown'"><%= markdownText %></textarea>
      <textarea
        id="<%= copyId %>-json"
        readonly
        rows="13"
        class="resize-none rounded-lg border-0 bg-[#f7f8fa] px-3 py-3 font-mono text-xs leading-5 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
        data-show="$aiCopyFormat === 'json'"
        style="display: none"><%= jsonText %></textarea>

      <p
        class="rounded-lg bg-[#e9f9ee] px-3 py-2 text-sm font-bold text-[#1b8f3a]"
        data-ai-copy-message="<%= copyId %>"
        style="display: none"></p>

      <div class="grid grid-cols-2 gap-3 pt-1">
        <button
          type="button"
          class="flex h-11 items-center justify-center rounded-lg border-0 bg-[#f2f4f6] px-4 text-sm font-bold text-[#4e5968] hover:bg-[#e5e8eb] sm:h-[50px] sm:text-base"
          data-on:click="$aiCopyModalOpen = false">
          닫기
        </button>
        <button
          type="button"
          class="flex h-11 items-center justify-center gap-2 rounded-lg border-0 bg-[#3182f6] px-4 text-sm font-bold text-white hover:bg-[#1b64da] sm:h-[50px] sm:text-base"
          data-on:click="window.launchboardCopyAiContext('<%= copyId %>', $aiCopyFormat)">
          <span
            class="i-lucide-clipboard-copy h-4 w-4"
            aria-hidden="true"></span>
          복사
        </button>
      </div>
    </div>
  </section>
</div>

<script>
  ;(function () {
    if (window.launchboardCopyAiContext) return

    function showCopyMessage(copyId, message) {
      const messageElement = document.querySelector('[data-ai-copy-message="' + copyId + '"]')

      if (!messageElement) return

      messageElement.textContent = message
      messageElement.style.display = ''

      window.setTimeout(function () {
        messageElement.style.display = 'none'
      }, 1800)
    }

    function copyWithFallback(text) {
      const textarea = document.createElement('textarea')

      textarea.value = text
      textarea.setAttribute('readonly', 'readonly')
      textarea.style.position = 'fixed'
      textarea.style.left = '-9999px'
      document.body.appendChild(textarea)
      textarea.select()

      let copied = false

      try {
        copied = document.execCommand('copy')
      } catch (exception) {
        copied = false
      }

      document.body.removeChild(textarea)

      return copied
    }

    window.launchboardCopyAiContext = function (copyId, format) {
      const normalizedFormat = format === 'json' ? 'json' : 'markdown'
      const textarea = document.getElementById(copyId + '-' + normalizedFormat)

      if (!textarea) return

      const text = textarea.value
      const done = function () {
        showCopyMessage(copyId, normalizedFormat === 'json' ? 'JSON 복사됨' : 'Markdown 복사됨')
      }
      const failed = function () {
        textarea.focus()
        textarea.select()
        showCopyMessage(copyId, '복사 실패. 선택된 내용을 직접 복사하세요.')
      }

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(done).catch(function () {
          if (copyWithFallback(text)) {
            done()
          } else {
            failed()
          }
        })

        return
      }

      if (copyWithFallback(text)) {
        done()
      } else {
        failed()
      }
    }
  })()
</script>
