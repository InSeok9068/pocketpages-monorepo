<script server>
  const projectBoard = resolve('project-board')

  meta('title', 'LaunchBoard')
  meta('description', 'LaunchBoard')

  if (!request.auth) {
    dbg('page/launchboard:index:redirect', {
      status: 303,
      redirectTo: '/sign-in',
    })
    redirect('/sign-in', {
      status: 303,
    })
    return
  }

  const userId = String(request.auth.get('id') || '')
  const boardState = projectBoard.getProjectBoardState($app, userId)

  dbg('page/launchboard:index:response', {
    authId: userId,
    projectCount: boardState.projectCount,
  })
</script>

<div
  class="space-y-3"
  data-signals="{
    projectModalOpen: false,
    projectName: '',
    projectDescription: '',
    userMenuOpen: false,
    projectMessage: '',
    projectMoveId: '',
    projectMoveStatus: '',
    projectMoveOrder: [],
    compactProjectStatuses: {idea: false, building: false, launched: false, paused: false, discarded: false},
    activeProjectStatus: (function () {
      try {
        const status = window.localStorage.getItem('launchboard:active-status') || 'idea'

        return ['idea', 'building', 'launched', 'paused', 'discarded'].indexOf(status) >= 0 ? status : 'idea'
      } catch (exception) {
        return 'idea'
      }
    })()
  }">
  <div
    class="relative z-30 flex justify-end"
    data-on:click__outside="$userMenuOpen = false">
    <div class="flex items-center gap-2">
      <a
        href="/tasks"
        class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-white px-3 text-xs font-bold text-[#4e5968] no-underline shadow-[0_8px_24px_rgba(25,31,40,0.08)] hover:bg-[#f7f8fa]"
        aria-label="전체 업무">
        <span
          class="i-lucide-list-todo h-4 w-4"
          aria-hidden="true"></span>
        업무
      </a>
      <button
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border-0 bg-white text-[#4e5968] shadow-[0_8px_24px_rgba(25,31,40,0.08)] hover:bg-[#f7f8fa]"
        aria-label="메뉴"
        data-on:click="$userMenuOpen = !$userMenuOpen">
        <span
          class="i-lucide-menu h-[18px] w-[18px]"
          aria-hidden="true"></span>
      </button>
    </div>

    <div
      data-show="$userMenuOpen"
      style="display: none"
      class="w-34 absolute right-0 top-11 z-20 rounded-lg bg-white p-1.5 shadow-[0_14px_40px_rgba(25,31,40,0.18)]">
      <form
        method="post"
        action="/xapi/auth/sign-out">
        <button
          type="submit"
          class="flex h-10 w-full items-center gap-2 rounded-md border-0 bg-transparent px-3 text-sm font-bold text-[#4e5968] hover:bg-[#f7f8fa]">
          <span
            class="i-lucide-log-out h-4 w-4"
            aria-hidden="true"></span>
          로그아웃
        </button>
      </form>
    </div>
  </div>

  <div
    class="rounded-lg bg-[#fff4d6] px-3 py-2 text-xs font-medium text-[#8a5b00]"
    data-show="$projectMessage"
    data-text="$projectMessage"
    style="display: none"></div>

  <%- include('project-board.ejs', {
    statusColumns: boardState.statusColumns,
    projectsByStatus: boardState.projectsByStatus,
  }) %>

  <button
    type="button"
    class="hidden"
    data-project-move-trigger
    data-on:click="@post('/xapi/projects/move')">
    이동
  </button>

  <div
    data-show="$projectModalOpen"
    style="display: none"
    class="fixed inset-0 z-50 !mt-0 flex items-end justify-center bg-[#191f28]/45 px-4 py-4"
    data-on:click="if (evt.target === el) $projectModalOpen = false"
    data-on:keydown__window="if (evt.key === 'Escape') { $projectModalOpen = false; $userMenuOpen = false }">
    <section
      class="w-full max-w-[420px] rounded-lg bg-white p-5 shadow-[0_24px_80px_rgba(25,31,40,0.28)]"
      data-on:click__stop="true">
      <header class="flex items-center justify-between gap-3">
        <div>
          <h2 class="text-xl font-bold text-[#191f28]">아이디어 추가</h2>
        </div>
        <button
          type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg border-0 bg-[#f2f4f6] text-[#4e5968] hover:bg-[#e5e8eb]"
          aria-label="닫기"
          data-on:click="$projectModalOpen = false">
          <span
            class="i-lucide-x h-4 w-4"
            aria-hidden="true"></span>
        </button>
      </header>

      <form
        method="post"
        action="/xapi/projects/create"
        data-on:submit="@post('/xapi/projects/create', {contentType: 'form'})"
        class="mt-5 grid gap-4">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          프로젝트명
          <input
            name="name_ko"
            required
            maxlength="120"
            data-bind:project-name
            autofocus
            class="h-[52px] rounded-lg border-0 bg-[#f7f8fa] px-4 text-base text-[#191f28] outline-none placeholder:text-[#b0b8c1] focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
            placeholder="런치보드" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          아이디어
          <textarea
            name="description"
            maxlength="500"
            rows="5"
            data-bind:project-description
            class="resize-none rounded-lg border-0 bg-[#f7f8fa] px-4 py-3 text-base leading-6 text-[#191f28] outline-none placeholder:text-[#b0b8c1] focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
            placeholder="무엇을 만들지 짧게 적기"></textarea>
        </label>

        <div class="grid grid-cols-2 gap-3 pt-1">
          <button
            type="button"
            class="flex h-[50px] items-center justify-center rounded-lg border-0 bg-[#f2f4f6] px-4 text-base font-bold text-[#4e5968] hover:bg-[#e5e8eb]"
            data-on:click="$projectModalOpen = false">
            취소
          </button>
          <button
            type="submit"
            class="flex h-[50px] items-center justify-center gap-2 rounded-lg border-0 bg-[#3182f6] px-4 text-base font-bold text-white hover:bg-[#1b64da]">
            <span
              class="i-lucide-plus h-4 w-4"
              aria-hidden="true"></span>
            추가
          </button>
        </div>
      </form>
    </section>
  </div>
</div>

<script src="<%= asset('/assets/vendor/sortable-1.15.7.min.js') %>"></script>
<script src="<%= asset('/assets/vendor/swiper-12.2.0.min.js') %>"></script>
<script>
  window.launchboardProjectBoard = window.launchboardProjectBoard || {}
  window.launchboardProjectBoard.activeStatusKey = 'launchboard:active-status'
  window.launchboardProjectBoard.statusValues = ['idea', 'building', 'launched', 'paused', 'discarded']

  window.launchboardSaveProjectActiveStatus = function (status) {
    if (window.launchboardProjectBoard.statusValues.indexOf(status) < 0) return

    try {
      window.localStorage.setItem(window.launchboardProjectBoard.activeStatusKey, status)
    } catch (exception) {
      return
    }
  }

  window.launchboardGetProjectActiveStatus = function () {
    try {
      const status = window.localStorage.getItem(window.launchboardProjectBoard.activeStatusKey) || 'idea'

      return window.launchboardProjectBoard.statusValues.indexOf(status) >= 0 ? status : 'idea'
    } catch (exception) {
      return 'idea'
    }
  }

  window.launchboardActivateProjectStatus = function (status, options) {
    const activateOptions = options || {}
    const statusValues = window.launchboardProjectBoard.statusValues
    const statusIndex = statusValues.indexOf(status)

    if (statusIndex < 0) return

    if (window.patchSignals)
      window.patchSignals({
        activeProjectStatus: status,
      })
    window.launchboardSaveProjectActiveStatus(status)

    if (activateOptions.fromSwiper === true) return

    const swiper = window.launchboardProjectBoard.swiper
    if (!swiper || swiper.destroyed || swiper.activeIndex === statusIndex) return

    swiper.slideTo(statusIndex)
  }

  window.launchboardInitProjectSwiper = function () {
    if (!window.Swiper) return

    const board = window.launchboardProjectBoard
    const swiperElement = document.querySelector('[data-project-status-swiper]')

    if (!swiperElement) return

    if (swiperElement.dataset.horizontalWheelReady !== 'true') {
      swiperElement.dataset.horizontalWheelReady = 'true'
      swiperElement.addEventListener(
        'wheel',
        function (event) {
          const deltaX = Number(event.deltaX || 0)
          const deltaY = Number(event.deltaY || 0)

          if (Math.abs(deltaX) < 8 || Math.abs(deltaX) <= Math.abs(deltaY)) return

          const swiper = window.launchboardProjectBoard.swiper

          if (!swiper || swiper.destroyed) return

          event.preventDefault()

          const now = Date.now()
          if (now - Number(board.lastHorizontalWheelAt || 0) < 520) return

          board.lastHorizontalWheelAt = now
          if (deltaX > 0) swiper.slideNext()
          else swiper.slidePrev()
        },
        { passive: false }
      )
    }

    if (board.swiper && board.swiper.el !== swiperElement) {
      board.swiper.destroy(true, false)
      board.swiper = null
    }

    const activeStatus = window.launchboardGetProjectActiveStatus()
    const initialSlide = Math.max(0, board.statusValues.indexOf(activeStatus))

    if (board.swiper && !board.swiper.destroyed) {
      board.swiper.update()
      board.swiper.slideTo(initialSlide, 0)
      return
    }

    board.swiper = new window.Swiper(swiperElement, {
      initialSlide,
      slidesPerView: 1,
      spaceBetween: 16,
      speed: 220,
      threshold: 12,
      resistanceRatio: 0.65,
      noSwipingSelector: '[data-drag-handle], a, button, input, textarea, select',
      on: {
        slideChange: function (swiper) {
          const nextStatus = board.statusValues[swiper.activeIndex]

          if (!nextStatus) return
          window.launchboardActivateProjectStatus(nextStatus, { fromSwiper: true })
        },
      },
    })
  }

  window.launchboardInitSortable = function () {
    if (!window.Sortable) {
      window.launchboardInitProjectSwiper()
      return
    }

    const updateEmptyState = function (list) {
      const emptyState = list.querySelector('[data-empty-state]')
      const hasCards = list.querySelector('[data-project-card]') !== null

      if (emptyState) emptyState.hidden = hasCards
    }

    const updateStatusCounts = function () {
      const counts = {}

      document.querySelectorAll('[data-sortable-list]').forEach(function (list) {
        const status = list.dataset.status || ''

        if (!status) return
        counts[status] = list.querySelectorAll('[data-project-card]').length
      })

      document.querySelectorAll('[data-project-status-count]').forEach(function (count) {
        const status = count.dataset.status || ''

        if (!Object.prototype.hasOwnProperty.call(counts, status)) return
        count.textContent = String(counts[status])
      })
    }

    const collectProjectOrder = function () {
      const order = []

      document.querySelectorAll('[data-sortable-list]').forEach(function (list) {
        const status = list.dataset.status || ''

        if (!status) return
        list.querySelectorAll('[data-project-card]').forEach(function (card, index) {
          order.push({
            id: card.dataset.projectId || '',
            status: status,
            sortOrder: index + 1,
          })
        })
      })

      return order
    }

    document.querySelectorAll('[data-sortable-list]').forEach(function (list) {
      if (list.dataset.sortableReady === 'true') return

      list.dataset.sortableReady = 'true'
      updateEmptyState(list)
      updateStatusCounts()

      Sortable.create(list, {
        group: 'launchboard-projects',
        sort: true,
        animation: 160,
        draggable: '[data-project-card]',
        handle: '[data-drag-handle]',
        ghostClass: 'launchboard-sortable-ghost',
        chosenClass: 'launchboard-sortable-chosen',
        dragClass: 'launchboard-sortable-drag',
        delay: 120,
        delayOnTouchOnly: true,
        filter: 'a, button, input, textarea, select',
        preventOnFilter: false,
        onStart: function () {
          document.body.dataset.launchboardDragging = 'true'
        },
        onEnd: function (event) {
          const card = event.item
          const toList = event.to
          const fromList = event.from
          const status = toList.dataset.status || ''

          window.setTimeout(function () {
            delete document.body.dataset.launchboardDragging
          }, 120)

          updateEmptyState(toList)
          updateEmptyState(fromList)
          updateStatusCounts()

          if (!status) return

          card.dataset.status = status
          if (window.patchSignals) {
            window.patchSignals({
              projectMoveId: card.dataset.projectId || '',
              projectMoveStatus: status,
              projectMoveOrder: collectProjectOrder(),
            })
          }

          const trigger = document.querySelector('[data-project-move-trigger]')
          if (trigger) trigger.click()
        },
      })
    })

    window.launchboardInitProjectSwiper()
  }

  window.launchboardInitSortable()
  window.launchboardInitProjectSwiper()

  window.launchboardNextFavicon = function (image) {
    const urls = String(image.dataset.faviconList || '')
      .split('|')
      .filter(Boolean)
    const nextIndex = Number(image.dataset.faviconIndex || '0') + 1

    if (nextIndex >= urls.length) {
      image.onerror = null
      image.classList.add('hidden')
      return
    }

    image.dataset.faviconIndex = String(nextIndex)
    image.src = urls[nextIndex]
  }
</script>
