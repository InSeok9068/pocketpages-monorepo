<script server>
  const { dateutil } = require('@pocketpages/utils')

  meta('title', 'LaunchBoard')
  meta('description', 'LaunchBoard')

  if (!request.auth) {
    dbg('page/launchboard:index:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      flash: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const statusColumns = [
    { value: 'idea', label: '아이디어', tone: 'bg-[#fff7e6] text-[#8a5b00]', dot: 'bg-[#f59f00]', surface: 'bg-[#fffaf0]' },
    { value: 'ready', label: '작업전', tone: 'bg-[#eef2f6] text-[#4e5968]', dot: 'bg-[#8b95a1]', surface: 'bg-[#f3f5f8]' },
    { value: 'building', label: '작업중', tone: 'bg-[#eaf3ff] text-[#1b64da]', dot: 'bg-[#3182f6]', surface: 'bg-[#f2f7ff]' },
    { value: 'launched', label: '출시', tone: 'bg-[#e9f9ee] text-[#208a3f]', dot: 'bg-[#2fbe5f]', surface: 'bg-[#f1fbf4]' },
    { value: 'paused', label: '보류', tone: 'bg-[#f3efff] text-[#6f4bc4]', dot: 'bg-[#8b5cf6]', surface: 'bg-[#f8f5ff]' },
    { value: 'discarded', label: '폐기', tone: 'bg-[#fff0f0] text-[#e03131]', dot: 'bg-[#ff6b6b]', surface: 'bg-[#fff5f5]' },
  ]
  const priorityLabels = {
    low: '낮음',
    normal: '보통',
    high: '높음',
  }
  const priorityTones = {
    low: 'bg-[#eef2f6] text-[#6b7684]',
    normal: 'bg-[#eaf3ff] text-[#1b64da]',
    high: 'bg-[#fff0f0] text-[#e03131]',
  }
  function formatProjectDate(value) {
    const raw = String(value || '').trim()

    if (!raw) return ''

    return dateutil.formatDate(raw, dateutil.FORMATS.DATE)
  }

  function getUrlOrigin(value) {
    const raw = String(value || '').trim()

    if (!raw) return ''

    const normalized = raw.indexOf('://') === -1 ? 'https://' + raw : raw
    const match = normalized.match(/^(https?:\/\/[^/?#]+)/i)

    if (!match) return ''

    return match[1].replace(/\/+$/, '')
  }

  function getFaviconUrls(domainUrl) {
    const origin = getUrlOrigin(domainUrl)

    if (!origin) return []

    return [
      origin + '/favicon.svg',
      origin + '/favicon.png',
      origin + '/favicon.ico',
    ]
  }

  function toProjectCard(record) {
    const slug = String(record.get('slug') || '').trim()
    const priority = String(record.get('priority') || 'normal')
    const domainUrl = String(record.get('domain_url') || '').trim()

    return {
      id: String(record.get('id') || ''),
      nameKo: String(record.get('name_ko') || '').trim(),
      nameEn: String(record.get('name_en') || '').trim(),
      slug,
      href: '/projects/' + encodeURIComponent(slug),
      status: String(record.get('status') || 'idea'),
      domainUrl,
      faviconUrls: getFaviconUrls(domainUrl),
      repoUrl: String(record.get('repo_url') || '').trim(),
      description: String(record.get('description') || '').trim(),
      priority,
      priorityLabel: priorityLabels[priority] || priority,
      priorityTone: priorityTones[priority] || priorityTones.normal,
      isPinned: record.get('is_pinned') === true,
      startedAt: formatProjectDate(record.get('started_at')),
      launchedAt: formatProjectDate(record.get('launched_at')),
      discardedAt: formatProjectDate(record.get('discarded_at')),
      updatedAt: formatProjectDate(record.get('updated')),
    }
  }

  const userId = String(request.auth.get('id') || '')
  const projects = $app.findRecordsByFilter('projects', 'user = {:userId}', '-is_pinned,+sort_order,-updated', 200, 0, { userId })
  const projectsByStatus = {}

  for (let index = 0; index < statusColumns.length; index += 1) {
    projectsByStatus[statusColumns[index].value] = []
  }

  for (let index = 0; index < projects.length; index += 1) {
    const project = toProjectCard(projects[index])
    const status = project.status
    const bucket = projectsByStatus[status] || projectsByStatus['idea']

    bucket.push(project)
  }

  dbg('page/launchboard:index:response', {
    authId: userId,
    projectCount: projects.length,
  })
</script>

<div
  class="space-y-3 sm:space-y-4"
  x-data="{ projectModalOpen: false, userMenuOpen: false }"
  @keydown.escape.window="projectModalOpen = false; userMenuOpen = false">
  <div
    class="fixed right-4 top-4 z-30 sm:right-6 sm:top-5"
    @click.outside="userMenuOpen = false">
    <button
      type="button"
      class="inline-flex h-9 w-9 items-center justify-center rounded-lg border-0 bg-white text-[#4e5968] shadow-[0_8px_24px_rgba(25,31,40,0.08)] hover:bg-[#f7f8fa] sm:h-10 sm:w-10"
      aria-label="메뉴"
      @click="userMenuOpen = !userMenuOpen">
      <span
        class="i-lucide-menu h-[18px] w-[18px]"
        aria-hidden="true"></span>
    </button>

    <div
      x-cloak
      x-show="userMenuOpen"
      x-transition
      class="absolute right-0 top-11 z-20 w-34 rounded-lg bg-white p-1.5 shadow-[0_14px_40px_rgba(25,31,40,0.18)]">
      <form
        method="post"
        action="/xapi/auth/sign-out">
        <button
          type="submit"
          class="flex h-10 w-full items-center gap-2 rounded-md border-0 bg-transparent px-3 text-sm font-bold text-[#4e5968] hover:bg-[#f7f8fa]">
          <span
            class="i-lucide-log-out h-4 w-4"
            aria-hidden="true"></span>
          로그아웃
        </button>
      </form>
    </div>
  </div>

  <% if (params.__flash) { %>
  <div class="rounded-lg bg-[#fff4d6] px-3 py-2 text-xs font-medium text-[#8a5b00]"><%= params.__flash %></div>
  <% } %>

  <section>
    <div class="min-w-0">
      <div class="grid gap-4 md:grid-cols-2 2xl:grid-cols-3">
        <% for (let columnIndex = 0; columnIndex < statusColumns.length; columnIndex += 1) { %>
        <% const column = statusColumns[columnIndex] %>
        <% const columnProjects = projectsByStatus[column.value] || [] %>
        <section
          id="status-<%= column.value %>"
          class="min-h-[280px] rounded-lg p-3 <%= column.surface %>">
          <header class="flex items-center justify-between gap-3 px-1 py-1">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full <%= column.dot %>"></span>
              <h2 class="text-sm font-bold text-[#191f28]"><%= column.label %></h2>
              <span class="text-xs font-bold text-[#8b95a1]"><%= columnProjects.length %></span>
            </div>
            <% if (column.value === 'idea') { %>
            <button
              type="button"
              class="inline-flex h-8 items-center justify-center gap-1.5 rounded-lg border-0 bg-[#3182f6] px-2.5 text-xs font-bold text-white hover:bg-[#1b64da]"
              @click="projectModalOpen = true">
              <span
                class="i-lucide-plus h-3.5 w-3.5"
                aria-hidden="true"></span>
              추가
            </button>
            <% } %>
          </header>

          <div class="mt-3 grid gap-3">
            <% if (columnProjects.length === 0) { %>
            <div class="rounded-lg border border-dashed border-[#d9dee7] bg-white/70 px-3 py-7 text-center text-sm font-medium text-[#8b95a1]">비어 있음</div>
            <% } %>

            <% for (let projectIndex = 0; projectIndex < columnProjects.length; projectIndex += 1) { %>
            <% const project = columnProjects[projectIndex] %>
            <article
              class="cursor-pointer rounded-lg bg-white p-4 shadow-[0_10px_28px_rgba(25,31,40,0.08),0_0_0_1px_rgba(227,231,237,0.78)] transition hover:-translate-y-0.5 hover:shadow-[0_14px_34px_rgba(25,31,40,0.11),0_0_0_1px_rgba(49,130,246,0.18)]"
              role="link"
              tabindex="0"
              onclick="window.location.href = '<%= project.href %>'"
              onkeydown="if (event.key === 'Enter') window.location.href = '<%= project.href %>'">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="flex min-w-0 items-center gap-2">
                    <% if (project.isPinned) { %>
                    <span
                      class="i-lucide-pin h-3.5 w-3.5 shrink-0 text-[#f59f00]"
                      aria-hidden="true"></span>
                    <% } %>
                    <% if (project.faviconUrls.length > 0) { %>
                    <span class="relative h-5 w-5 shrink-0 overflow-hidden rounded-md bg-[#f2f4f6] text-[#8b95a1]">
                      <span
                        class="i-lucide-globe-2 absolute inset-[3px]"
                        aria-hidden="true"></span>
                      <img
                        src="<%= project.faviconUrls[0] %>"
                        data-favicon-index="0"
                        data-favicon-list="<%= project.faviconUrls.join('|') %>"
                        alt=""
                        loading="lazy"
                        referrerpolicy="no-referrer"
                        class="absolute inset-0 h-full w-full bg-white object-contain"
                        onerror="window.launchboardNextFavicon && window.launchboardNextFavicon(this)" />
                    </span>
                    <% } %>
                    <h3 class="truncate text-base font-bold text-[#191f28]">
                      <%= project.nameKo %><% if (project.nameEn) { %>
                      <span class="font-semibold text-[#8b95a1]"> - <%= project.nameEn %></span><% } %>
                    </h3>
                  </div>
                </div>
                <span class="shrink-0 rounded-md px-2.5 py-1 text-[11px] font-bold <%= project.priorityTone %>"><%= project.priorityLabel %></span>
              </div>

              <% if (project.description) { %>
              <p class="mt-4 line-clamp-3 text-sm leading-6 text-[#4e5968]"><%= project.description %></p>
              <% } %>

              <div class="mt-4 flex flex-wrap gap-2">
                <% if (project.domainUrl) { %>
                <a
                  href="<%= project.domainUrl %>"
                  target="_blank"
                  rel="noreferrer noopener"
                  class="inline-flex h-8 items-center gap-1.5 rounded-md bg-[#f2f4f6] px-2.5 text-xs font-bold text-[#4e5968] no-underline hover:bg-[#e5e8eb]"
                  onclick="event.stopPropagation()">
                  <span
                    class="i-lucide-external-link h-3.5 w-3.5"
                    aria-hidden="true"></span>
                  도메인
                </a>
                <% } %>
                <% if (project.repoUrl) { %>
                <a
                  href="<%= project.repoUrl %>"
                  target="_blank"
                  rel="noreferrer noopener"
                  class="inline-flex h-8 items-center gap-1.5 rounded-md bg-[#f2f4f6] px-2.5 text-xs font-bold text-[#4e5968] no-underline hover:bg-[#e5e8eb]"
                  onclick="event.stopPropagation()">
                  <span
                    class="i-lucide-git-branch h-3.5 w-3.5"
                    aria-hidden="true"></span>
                  저장소
                </a>
                <% } %>
              </div>

              <div class="mt-4 grid gap-1.5 text-[11px] font-medium text-[#8b95a1]">
                <% if (project.startedAt) { %>
                <span class="inline-flex items-center gap-1.5">
                  <span
                    class="i-lucide-play h-3.5 w-3.5"
                    aria-hidden="true"></span>
                  시작 <%= project.startedAt %>
                </span>
                <% } %>
                <% if (project.launchedAt) { %>
                <span class="inline-flex items-center gap-1.5">
                  <span
                    class="i-lucide-rocket h-3.5 w-3.5"
                    aria-hidden="true"></span>
                  출시 <%= project.launchedAt %>
                </span>
                <% } %>
                <% if (project.discardedAt) { %>
                <span class="inline-flex items-center gap-1.5">
                  <span
                    class="i-lucide-archive h-3.5 w-3.5"
                    aria-hidden="true"></span>
                  폐기 <%= project.discardedAt %>
                </span>
                <% } %>
                <% if (project.updatedAt) { %>
                <span class="inline-flex items-center gap-1.5">
                  <span
                    class="i-lucide-clock-3 h-3.5 w-3.5"
                    aria-hidden="true"></span>
                  수정 <%= project.updatedAt %>
                </span>
                <% } %>
              </div>
            </article>
            <% } %>
          </div>
        </section>
        <% } %>
      </div>
    </div>
  </section>

  <div
    x-cloak
    x-show="projectModalOpen"
    class="fixed inset-0 z-50 !mt-0 flex items-end justify-center bg-[#191f28]/45 px-4 py-4 sm:items-center"
    @click.self="projectModalOpen = false">
    <section
      class="w-full max-w-[420px] rounded-lg bg-white p-5 shadow-[0_24px_80px_rgba(25,31,40,0.28)]"
      x-show="projectModalOpen"
      x-transition>
      <header class="flex items-center justify-between gap-3">
        <div>
          <h2 class="text-xl font-bold text-[#191f28]">아이디어 추가</h2>
        </div>
        <button
          type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg border-0 bg-[#f2f4f6] text-[#4e5968] hover:bg-[#e5e8eb]"
          aria-label="닫기"
          @click="projectModalOpen = false">
          <span
            class="i-lucide-x h-4 w-4"
            aria-hidden="true"></span>
        </button>
      </header>

      <form
        method="post"
        action="/xapi/projects/create"
        class="mt-5 grid gap-4">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          프로젝트명
          <input
            name="name_ko"
            required
            maxlength="120"
            autofocus
            class="h-[52px] rounded-lg border-0 bg-[#f7f8fa] px-4 text-base text-[#191f28] outline-none placeholder:text-[#b0b8c1] focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
            placeholder="런치보드" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          아이디어
          <textarea
            name="description"
            maxlength="500"
            rows="5"
            class="resize-none rounded-lg border-0 bg-[#f7f8fa] px-4 py-3 text-base leading-6 text-[#191f28] outline-none placeholder:text-[#b0b8c1] focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
            placeholder="무엇을 만들지 짧게 적기"></textarea>
        </label>

        <div class="grid grid-cols-2 gap-3 pt-1">
          <button
            type="button"
            class="flex h-[50px] items-center justify-center rounded-lg border-0 bg-[#f2f4f6] px-4 text-base font-bold text-[#4e5968] hover:bg-[#e5e8eb]"
            @click="projectModalOpen = false">
            취소
          </button>
          <button
            type="submit"
            class="flex h-[50px] items-center justify-center gap-2 rounded-lg border-0 bg-[#3182f6] px-4 text-base font-bold text-white hover:bg-[#1b64da]">
            <span
              class="i-lucide-plus h-4 w-4"
              aria-hidden="true"></span>
            추가
          </button>
        </div>
      </form>
    </section>
  </div>
</div>

<script>
  window.launchboardNextFavicon = function (image) {
    const urls = String(image.dataset.faviconList || '').split('|').filter(Boolean)
    const nextIndex = Number(image.dataset.faviconIndex || '0') + 1

    if (nextIndex >= urls.length) {
      image.onerror = null
      image.classList.add('hidden')
      return
    }

    image.dataset.faviconIndex = String(nextIndex)
    image.src = urls[nextIndex]
  }
</script>
