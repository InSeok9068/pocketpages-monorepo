<script server>
  const taskBoard = resolve('task-board')

  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const requestedView = String(request.url.query.view || 'all').trim()
  const activeView = requestedView === 'today' ? 'today' : 'all'

  if (!request.auth) {
    dbg('page/tasks:index:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      flash: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const projects = $app.findRecordsByFilter(
    'projects',
    'user = {:userId} && status != {:pausedStatus} && status != {:discardedStatus}',
    '-is_pinned,+sort_order,-updated',
    300,
    0,
    {
      userId,
      pausedStatus: 'paused',
      discardedStatus: 'discarded'
    }
  )
  const projectOptions = []

  for (let index = 0; index < projects.length; index += 1) {
    const project = projects[index]

    projectOptions.push({
      id: String(project.get('id') || ''),
      nameKo: String(project.get('name_ko') || '').trim(),
      nameEn: String(project.get('name_en') || '').trim(),
    })
  }

  const boardState = taskBoard.getTaskInboxState($app, userId, activeView)
  const viewTitle = activeView === 'today' ? '오늘 업무' : '전체 업무'
  const aiCopyContext = taskBoard.getTaskAiCopyContext({
    title: viewTitle + ' AI 컨텍스트',
    scope: activeView === 'today' ? 'today_tasks' : 'all_tasks',
    scopeLabel: viewTitle,
    boardState,
  })

  meta('title', viewTitle + ' | LaunchBoard')
  meta('description', viewTitle)

  dbg('page/tasks:index:response', {
    authId: userId,
    view: activeView,
    taskCount: boardState.taskCount,
  })
</script>

<div
  class="space-y-3 pb-20 md:pl-[88px] md:pb-0"
  data-signals="{
    taskModalOpen: false,
    taskTitle: '',
    taskDescription: '',
    taskDueAt: '',
    aiCopyModalOpen: false,
    aiCopyFormat: 'markdown',
    taskFilterOpen: false,
    activeTaskStatus: (function () {
      try {
        const status = window.localStorage.getItem('launchboard:inbox-active-status') || 'todo'

        return ['todo', 'doing', 'done', 'paused', 'canceled'].indexOf(status) >= 0 ? status : 'todo'
      } catch (exception) {
        return 'todo'
      }
    })(),
    isTaskMobile: window.matchMedia('(max-width: 767px)').matches,
    collapsedTaskStatuses: (function () {
      const defaults = {todo: false, doing: false, done: true, paused: true, canceled: true}

      try {
        const savedText = window.localStorage.getItem('launchboard:inbox-collapsed-statuses')
        const saved = savedText ? JSON.parse(savedText) : {}

        return saved && typeof saved === 'object' && !Array.isArray(saved) ? Object.assign({}, defaults, saved) : defaults
      } catch (exception) {
        return defaults
      }
    })()
  }">
  <%- include('app-nav.ejs', {
    activeNav: activeView === 'today' ? 'today' : 'tasks',
    canCreateTask: projectOptions.length > 0,
  }) %>

  <header class="rounded-lg bg-white px-3 py-3 shadow-[0_8px_24px_rgba(25,31,40,0.05)] sm:px-6 sm:py-5">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <p class="text-xs font-bold text-[#8b95a1] sm:text-sm">LaunchBoard</p>
        <h1 class="mt-1 truncate text-xl font-bold leading-7 text-[#191f28] sm:text-3xl sm:leading-10"><%= viewTitle %></h1>
      </div>

      <div class="flex shrink-0 items-center gap-2">
        <button
          type="button"
          class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border-0 bg-[#f2f4f6] px-3 text-xs font-bold text-[#4e5968] hover:bg-[#e5e8eb] sm:h-10 sm:text-sm"
          data-on:click="$aiCopyModalOpen = true">
          <span
            class="i-lucide-clipboard-copy h-4 w-4"
            aria-hidden="true"></span>
          <span class="hidden sm:inline">AI 복사</span>
        </button>
        <a
          href="/"
          class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-[#f2f4f6] px-3 text-xs font-bold text-[#4e5968] no-underline hover:bg-[#e5e8eb] sm:h-10 sm:text-sm"
          aria-label="프로젝트 보드">
          <span
            class="i-lucide-panels-top-left h-4 w-4"
            aria-hidden="true"></span>
          프로젝트
        </a>
      </div>
    </div>
  </header>

  <% if (params.__flash) { %>
  <div class="rounded-lg bg-[#fff4d6] px-3 py-2 text-xs font-medium text-[#8a5b00] sm:px-4 sm:py-3 sm:text-sm"><%= params.__flash %></div>
  <% } %>

  <%- include('task-board.ejs', {
    projectId: '',
    projectSlug: '',
    statusColumns: boardState.statusColumns,
    tasksByStatus: boardState.tasksByStatus,
    canSortTasks: false,
    canDeleteTasks: false,
    canFilterTasks: true,
  }) %>

  <%- include('ai-copy-modal.ejs', {
    copyId: 'task-inbox-ai-copy',
    scopeLabel: viewTitle,
    markdownText: aiCopyContext.markdown,
    jsonText: aiCopyContext.jsonText,
  }) %>

  <div
    class="fixed inset-0 z-50 !mt-0 flex items-end justify-center bg-[#191f28]/45 px-4 py-4 sm:items-center"
    data-show="$taskModalOpen"
    data-on:click="if (evt.target === el) $taskModalOpen = false"
    style="display: none">
    <section
      class="w-full max-w-[420px] rounded-lg bg-white p-4 shadow-[0_24px_80px_rgba(25,31,40,0.28)] sm:p-5"
      data-on:click__stop="true">
      <header class="flex items-center justify-between gap-3">
        <h2 class="text-xl font-bold text-[#191f28]">업무 추가</h2>
        <button
          type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg border-0 bg-[#f2f4f6] text-[#4e5968] hover:bg-[#e5e8eb]"
          aria-label="닫기"
          data-on:click="$taskModalOpen = false">
          <span
            class="i-lucide-x h-4 w-4"
            aria-hidden="true"></span>
        </button>
      </header>

      <form
        method="post"
        action="/xapi/tasks/create"
        class="mt-4 grid gap-3 sm:mt-5 sm:gap-4">
        <input
          type="hidden"
          name="return_to"
          value="<%= activeView === 'today' ? '/tasks?view=today' : '/tasks' %>" />

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          프로젝트
          <select
            name="project_id"
            required
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-[52px] sm:px-4 sm:text-base">
            <% for (let index = 0; index < projectOptions.length; index += 1) { %>
            <% const option = projectOptions[index] %>
            <option value="<%= option.id %>">
              <%= option.nameKo %><% if (option.nameEn) { %> - <%= option.nameEn %><% } %>
            </option>
            <% } %>
          </select>
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          제목
          <input
            name="title"
            required
            maxlength="160"
            data-bind:task-title
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm text-[#191f28] outline-none placeholder:text-[#b0b8c1] focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-[52px] sm:px-4 sm:text-base"
            placeholder="다음 작업" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          메모
          <textarea
            name="description"
            maxlength="700"
            rows="5"
            data-bind:task-description
            class="resize-none rounded-lg border-0 bg-[#f7f8fa] px-3 py-2.5 text-sm leading-6 text-[#191f28] outline-none placeholder:text-[#b0b8c1] focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:px-4 sm:py-3 sm:text-base"
            placeholder="필요한 내용만 짧게"></textarea>
        </label>

        <fieldset class="launchboard-choice-fieldset">
          <legend class="mb-2 text-sm font-semibold text-[#4e5968]">우선순위</legend>
          <div class="grid grid-cols-3 gap-2">
            <label class="relative">
              <input
                type="radio"
                name="priority"
                value="low"
                class="launchboard-choice-input" />
              <span class="launchboard-priority-choice flex h-10 w-full items-center justify-center rounded-lg bg-[#f7f8fa] text-sm font-bold text-[#4e5968] shadow-[inset_0_0_0_1px_rgba(227,231,237,0)] transition-colors duration-150 hover:bg-[#f2f4f6]">
                낮음
              </span>
            </label>
            <label class="relative">
              <input
                type="radio"
                name="priority"
                value="normal"
                class="launchboard-choice-input"
                checked />
              <span class="launchboard-priority-choice flex h-10 w-full items-center justify-center rounded-lg bg-[#f7f8fa] text-sm font-bold text-[#4e5968] shadow-[inset_0_0_0_1px_rgba(227,231,237,0)] transition-colors duration-150 hover:bg-[#f2f4f6]">
                보통
              </span>
            </label>
            <label class="relative">
              <input
                type="radio"
                name="priority"
                value="high"
                class="launchboard-choice-input" />
              <span class="launchboard-priority-choice flex h-10 w-full items-center justify-center rounded-lg bg-[#f7f8fa] text-sm font-bold text-[#4e5968] shadow-[inset_0_0_0_1px_rgba(227,231,237,0)] transition-colors duration-150 hover:bg-[#f2f4f6]">
                높음
              </span>
            </label>
          </div>
        </fieldset>

        <details class="rounded-lg bg-[#f7f8fa] p-3">
          <summary class="cursor-pointer text-sm font-bold text-[#4e5968]">옵션</summary>
          <div class="mt-3 grid gap-3">
            <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
              마감일
              <input
                type="date"
                name="due_at"
                data-bind:task-due-at
                class="h-10 rounded-lg border-0 bg-white px-3 text-sm font-semibold text-[#191f28] outline-none focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
            </label>
          </div>
        </details>

        <div class="grid grid-cols-2 gap-3 pt-1">
          <button
            type="button"
            class="flex h-11 items-center justify-center rounded-lg border-0 bg-[#f2f4f6] px-4 text-sm font-bold text-[#4e5968] hover:bg-[#e5e8eb] sm:h-[50px] sm:text-base"
            data-on:click="$taskModalOpen = false">
            취소
          </button>
          <button
            type="submit"
            class="flex h-11 items-center justify-center gap-2 rounded-lg border-0 bg-[#3182f6] px-4 text-sm font-bold text-white hover:bg-[#1b64da] sm:h-[50px] sm:text-base">
            <span
              class="i-lucide-plus h-4 w-4"
              aria-hidden="true"></span>
            추가
          </button>
        </div>
      </form>
    </section>
  </div>
</div>

<script src="<%= asset('/assets/vendor/swiper-12.2.0.min.js') %>"></script>
<script>
  window.launchboardTaskBoard = window.launchboardTaskBoard || {}
  window.launchboardTaskBoard.storageKey = 'launchboard:inbox-collapsed-statuses'
  window.launchboardTaskBoard.activeStatusKey = 'launchboard:inbox-active-status'
  window.launchboardTaskBoard.statusValues = ['todo', 'doing', 'done', 'paused', 'canceled']

  window.launchboardPatchTaskBoardSignals = function (signals) {
    if (!window.patchSignals) return

    window.patchSignals(signals)
  }

  window.launchboardSetTaskMobileSignal = function () {
    window.launchboardPatchTaskBoardSignals({
      isTaskMobile: window.matchMedia('(max-width: 767px)').matches,
    })
  }

  window.launchboardSaveTaskActiveStatus = function (status) {
    if (window.launchboardTaskBoard.statusValues.indexOf(status) < 0) return

    try {
      window.localStorage.setItem(window.launchboardTaskBoard.activeStatusKey, status)
    } catch (exception) {
      return
    }
  }

  window.launchboardGetTaskActiveStatus = function () {
    try {
      const status = window.localStorage.getItem(window.launchboardTaskBoard.activeStatusKey) || 'todo'

      return window.launchboardTaskBoard.statusValues.indexOf(status) >= 0 ? status : 'todo'
    } catch (exception) {
      return 'todo'
    }
  }

  window.launchboardActivateTaskStatus = function (status, options) {
    const activateOptions = options || {}
    const statusValues = window.launchboardTaskBoard.statusValues
    const statusIndex = statusValues.indexOf(status)

    if (statusIndex < 0) return

    window.launchboardPatchTaskBoardSignals({
      activeTaskStatus: status,
    })
    window.launchboardSaveTaskActiveStatus(status)

    if (activateOptions.fromSwiper === true) return

    const swiper = window.launchboardTaskBoard.swiper
    if (!swiper || swiper.destroyed || swiper.activeIndex === statusIndex) return

    swiper.slideTo(statusIndex)
  }

  window.launchboardInitTaskSwiper = function () {
    if (!window.Swiper) return

    const board = window.launchboardTaskBoard
    const swiperElement = document.querySelector('[data-task-status-swiper]')

    if (!swiperElement) return

    if (board.swiper && board.swiper.el !== swiperElement) {
      board.swiper.destroy(true, false)
      board.swiper = null
    }

    const activeStatus = window.launchboardGetTaskActiveStatus()
    const initialSlide = Math.max(0, board.statusValues.indexOf(activeStatus))

    if (board.swiper && !board.swiper.destroyed) {
      board.swiper.update()
      board.swiper.slideTo(initialSlide, 0)
      return
    }

    board.swiper = new window.Swiper(swiperElement, {
      initialSlide,
      slidesPerView: 1,
      spaceBetween: 16,
      speed: 220,
      threshold: 12,
      resistanceRatio: 0.65,
      noSwipingSelector: 'a, button, input, textarea, select',
      breakpoints: {
        768: {
          allowTouchMove: false,
          enabled: false,
          spaceBetween: 0,
        },
      },
      on: {
        slideChange: function (swiper) {
          const nextStatus = board.statusValues[swiper.activeIndex]

          if (!nextStatus) return
          window.launchboardActivateTaskStatus(nextStatus, { fromSwiper: true })
        },
      },
    })
  }

  window.launchboardSaveTaskCollapsedStatuses = function (statuses) {
    try {
      window.localStorage.setItem(window.launchboardTaskBoard.storageKey, JSON.stringify(statuses || {}))
    } catch (exception) {
      return
    }
  }

  window.launchboardApplyTaskFilter = function () {
    const filterRoot = document.querySelector('[data-task-filter-panel]') || document
    const queryInput = filterRoot.querySelector('[data-task-filter-query]')
    const highInput = filterRoot.querySelector('[data-task-filter-high]')
    const dueInput = filterRoot.querySelector('[data-task-filter-due]')
    const query = queryInput ? String(queryInput.value || '').trim().toLowerCase() : ''
    const highOnly = highInput ? highInput.checked === true : false
    const dueOnly = dueInput ? dueInput.checked === true : false
    const counts = {}

    window.launchboardTaskBoard.statusValues.forEach(function (status) {
      counts[status] = 0
    })

    document.querySelectorAll('[data-task-card]').forEach(function (card) {
      const searchText = String(card.dataset.taskSearch || '').toLowerCase()
      const status = card.dataset.status || ''
      const matchesQuery = !query || searchText.indexOf(query) >= 0
      const matchesPriority = !highOnly || card.dataset.priority === 'high'
      const matchesDue = !dueOnly || card.dataset.hasDue === 'true'
      const isVisible = matchesQuery && matchesPriority && matchesDue

      card.hidden = !isVisible

      if (isVisible && Object.prototype.hasOwnProperty.call(counts, status)) {
        counts[status] += 1
      }
    })

    document.querySelectorAll('[data-task-status-count]').forEach(function (count) {
      const status = count.dataset.status || ''

      if (!Object.prototype.hasOwnProperty.call(counts, status)) return

      count.textContent = String(counts[status])
    })

    document.querySelectorAll('[data-task-sortable-list]').forEach(function (list) {
      const visibleCount = list.querySelectorAll('[data-task-card]:not([hidden])').length
      const emptyState = list.querySelector('[data-task-empty-state]')

      if (emptyState) emptyState.hidden = visibleCount > 0
    })
  }

  if (window.launchboardTaskBoard.inboxResizeReady !== true) {
    window.launchboardTaskBoard.inboxResizeReady = true
    window.addEventListener('resize', function () {
      window.launchboardSetTaskMobileSignal()
      window.launchboardInitTaskSwiper()
    })
  }

  window.launchboardSetTaskMobileSignal()
  window.launchboardInitTaskSwiper()
  window.launchboardApplyTaskFilter()
</script>
