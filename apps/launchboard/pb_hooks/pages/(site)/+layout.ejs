<% const isProduction = String(env('APP_ENV') || 'development').trim() === 'production' %>
<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1" />
    <title><%= meta('title') %></title>
    <meta
      name="description"
      content="<%= meta('description') %>" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="<%= asset('/assets/favicon.svg') %>" />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href="<%= asset('/assets/icon-192.png') %>" />
    <link
      rel="apple-touch-icon"
      sizes="192x192"
      href="<%= asset('/assets/icon-192.png') %>" />
    <link
      rel="manifest"
      href="<%= asset('/assets/manifest.webmanifest') %>" />
    <meta
      name="theme-color"
      content="#f7f8fa" />
    <link
      rel="stylesheet"
      href="<%= asset('/assets/style.css') %>" />
    <%- include('unocss-head.ejs', { isProduction }) %>
    <%- datastar.scripts() %>
    <%- slots.head %>
  </head>

  <body
    un-cloak
    class="min-h-screen bg-[#f7f8fa] text-[#191f28] antialiased">
    <main class="mx-auto min-h-screen max-w-[1440px] px-3 py-4 sm:px-6 sm:py-7 lg:px-8"><%- slots.body || slot %></main>
  </body>
</html>
