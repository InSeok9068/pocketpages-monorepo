<script server>
  meta('title', 'LaunchBoard 회원가입')
  meta('description', 'LaunchBoard 회원가입')

  if (request.auth) {
    dbg('page/launchboard:sign-up:redirect', {
      status: 303,
      redirectTo: '/',
    })
    redirect('/', {
      status: 303,
    })
    return
  }
</script>

<section class="mx-auto flex min-h-[calc(100vh-72px)] max-w-[420px] items-center">
  <div class="w-full">
    <div class="mb-8 flex items-center gap-3">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#3182f6] text-white shadow-[0_12px_28px_rgba(49,130,246,0.28)]">
        <span
          class="i-lucide-rocket h-5 w-5"
          aria-hidden="true"></span>
      </span>
      <p class="tracking-0 text-lg font-bold text-[#191f28]">LaunchBoard</p>
    </div>

    <h1 class="text-3xl font-bold text-[#191f28]">회원가입</h1>

    <% if (params.__flash) { %>
    <div class="mt-5 rounded-lg bg-[#fff4d6] px-4 py-3 text-sm font-medium text-[#8a5b00]"><%= params.__flash %></div>
    <% } %>

    <form
      method="post"
      action="/xapi/auth/sign-up"
      class="mt-7 grid gap-4">
      <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
        이메일
        <input
          type="email"
          name="email"
          required
          class="h-[52px] rounded-lg border-0 bg-white px-4 text-base text-[#191f28] shadow-[0_1px_2px_rgba(0,0,0,0.04),0_0_0_1px_rgba(227,231,237,0.9)] outline-none placeholder:text-[#b0b8c1] focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
          placeholder="me@example.com" />
      </label>

      <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
        비밀번호
        <input
          type="password"
          name="password"
          required
          minlength="8"
          class="h-[52px] rounded-lg border-0 bg-white px-4 text-base text-[#191f28] shadow-[0_1px_2px_rgba(0,0,0,0.04),0_0_0_1px_rgba(227,231,237,0.9)] outline-none placeholder:text-[#b0b8c1] focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
          placeholder="8자 이상" />
      </label>

      <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
        비밀번호 확인
        <input
          type="password"
          name="passwordConfirm"
          required
          minlength="8"
          class="h-[52px] rounded-lg border-0 bg-white px-4 text-base text-[#191f28] shadow-[0_1px_2px_rgba(0,0,0,0.04),0_0_0_1px_rgba(227,231,237,0.9)] outline-none placeholder:text-[#b0b8c1] focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
          placeholder="비밀번호 확인" />
      </label>

      <button
        type="submit"
        class="mt-2 flex h-[52px] items-center justify-center rounded-lg border-0 bg-[#3182f6] px-4 text-base font-bold text-white hover:bg-[#1b64da]">
        가입
      </button>
    </form>

    <a
      href="/sign-in"
      class="mt-3 flex h-12 items-center justify-center rounded-lg bg-[#f2f4f6] px-4 text-sm font-bold text-[#4e5968] no-underline hover:bg-[#e5e8eb]">
      로그인
    </a>
  </div>
</section>
