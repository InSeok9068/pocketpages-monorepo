<script server>
  const { dateutil } = require('@pocketpages/utils')

  const slug = String(params.slug || '').trim()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const statusOptions = [
    { value: 'idea', label: '아이디어' },
    { value: 'building', label: '작업중' },
    { value: 'launched', label: '출시' },
    { value: 'paused', label: '보류' },
    { value: 'discarded', label: '폐기' },
  ]
  const priorityOptions = [
    { value: 'low', label: '낮음' },
    { value: 'normal', label: '보통' },
    { value: 'high', label: '높음' },
  ]

  function inputDate(value) {
    const raw = String(value || '').trim()

    if (!raw) return ''

    return dateutil.formatDate(raw, 'YYYY-MM-DD')
  }

  function normalizeStatus(value) {
    const raw = String(value || 'idea').trim()

    for (let index = 0; index < statusOptions.length; index += 1) {
      if (statusOptions[index].value === raw) return raw
    }

    return 'idea'
  }

  function normalizeTags(value) {
    if (!value) return []

    if (value && typeof value.string === 'function') {
      try {
        const parsed = JSON.parse(value.string())

        return Array.isArray(parsed) ? parsed : []
      } catch (exception) {
        return []
      }
    }

    if (Array.isArray(value)) {
      const numericItems = value.filter((item) => /^[0-9]+$/.test(String(item || '').trim()))

      if (numericItems.length === value.length) {
        try {
          const decoded = String.fromCharCode.apply(
            null,
            numericItems.map((item) => Number(item))
          )
          const parsed = JSON.parse(decoded)

          return Array.isArray(parsed) ? parsed : []
        } catch (exception) {
          return value
        }
      }

      return value
    }

    try {
      const parsed = JSON.parse(String(value || ''))

      return Array.isArray(parsed) ? parsed : []
    } catch (exception) {
      return []
    }
  }

  function tagsText(value) {
    return normalizeTags(value)
      .map((tag) => String(tag || '').trim())
      .filter((tag) => !!tag)
      .join(', ')
  }

  if (!request.auth) {
    dbg('page/projects/[slug]:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      flash: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  if (!slug) {
    dbg('page/projects/[slug]:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '프로젝트를 찾지 못했습니다.',
    })
    redirect('/', {
      status: 303,
      message: '프로젝트를 찾지 못했습니다.',
    })
    return
  }

  let project = null

  try {
    project = $app.findFirstRecordByFilter('projects', 'slug = {:slug} && user = {:userId}', {
      slug,
      userId,
    })
  } catch (exception) {
    project = null
  }

  if (!project) {
    dbg('page/projects/[slug]:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '프로젝트를 찾지 못했습니다.',
      slug,
    })
    redirect('/', {
      status: 303,
      message: '프로젝트를 찾지 못했습니다.',
    })
    return
  }

  const projectView = {
    id: String(project.get('id') || ''),
    nameKo: String(project.get('name_ko') || '').trim(),
    nameEn: String(project.get('name_en') || '').trim(),
    slug: String(project.get('slug') || '').trim(),
    status: normalizeStatus(project.get('status')),
    priority: String(project.get('priority') || 'normal'),
    isPinned: project.get('is_pinned') === true,
    domainUrl: String(project.get('domain_url') || '').trim(),
    repoUrl: String(project.get('repo_url') || '').trim(),
    description: String(project.get('description') || '').trim(),
    problem: String(project.get('problem') || '').trim(),
    targetUser: String(project.get('target_user') || '').trim(),
    statusReason: String(project.get('status_reason') || '').trim(),
    tags: tagsText(project.get('tags')),
    sortOrder: String(project.get('sort_order') || 0),
    startedAt: inputDate(project.get('started_at')),
    launchedAt: inputDate(project.get('launched_at')),
    discardedAt: inputDate(project.get('discarded_at')),
    updatedAt: inputDate(project.get('updated')),
  }

  meta('title', projectView.nameKo + ' | LaunchBoard')
  meta('description', projectView.nameKo)

  dbg('page/projects/[slug]:response', {
    projectId: projectView.id,
    slug: projectView.slug,
    status: projectView.status,
  })
</script>

<div
  class="mx-auto max-w-[980px] space-y-4 sm:space-y-6"
  x-data="{ advancedOpen: false }">
  <header class="rounded-lg bg-white px-4 py-4 shadow-[0_8px_24px_rgba(25,31,40,0.05)] sm:px-6 sm:py-5">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 rounded-md bg-transparent text-xs font-bold text-[#6b7684] no-underline hover:text-[#191f28] sm:text-sm">
          <span
            class="i-lucide-chevron-left h-4 w-4"
            aria-hidden="true"></span>
          목록
        </a>
        <div class="mt-3 flex min-w-0 items-center">
          <div class="min-w-0">
            <h1 class="truncate text-2xl font-bold leading-8 text-[#191f28] sm:text-3xl sm:leading-10"><%= projectView.nameKo %></h1>
            <% if (projectView.nameEn) { %>
            <p class="truncate text-xs font-semibold text-[#8b95a1] sm:text-sm"><%= projectView.nameEn %></p>
            <% } %>
          </div>
        </div>
      </div>

      <% if (projectView.updatedAt) { %>
      <div class="hidden shrink-0 rounded-lg bg-[#f7f8fa] px-3 py-2 text-right sm:block">
        <p class="text-[11px] font-bold text-[#8b95a1]">수정</p>
        <p class="text-sm font-bold text-[#191f28]"><%= projectView.updatedAt %></p>
      </div>
      <% } %>
    </div>
  </header>

  <% if (params.__flash) { %>
  <div class="rounded-lg bg-[#fff4d6] px-3 py-2 text-xs font-medium text-[#8a5b00] sm:px-4 sm:py-3 sm:text-sm"><%= params.__flash %></div>
  <% } %>

  <form
    method="post"
    action="/xapi/projects/update"
    class="grid gap-4">
    <input
      type="hidden"
      name="project_id"
      value="<%= projectView.id %>" />

    <section class="rounded-lg bg-white p-4 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
      <h2 class="text-base font-bold text-[#191f28]">기본</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          프로젝트명
          <input
            type="text"
            name="name_ko"
            required
            value="<%= projectView.nameKo %>"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-base font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          영문명
          <input
            type="text"
            name="name_en"
            value="<%= projectView.nameEn %>"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-base font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          상태
          <select
            name="status"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-base font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
            <% for (let index = 0; index < statusOptions.length; index += 1) { %>
            <% const option = statusOptions[index] %>
            <option
              value="<%= option.value %>"
              <%= option.value === projectView.status ? 'selected' : '' %>>
              <%= option.label %>
            </option>
            <% } %>
          </select>
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          우선순위
          <select
            name="priority"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-base font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
            <% for (let index = 0; index < priorityOptions.length; index += 1) { %>
            <% const option = priorityOptions[index] %>
            <option
              value="<%= option.value %>"
              <%= option.value === projectView.priority ? 'selected' : '' %>>
              <%= option.label %>
            </option>
            <% } %>
          </select>
        </label>

        <label class="flex items-center justify-between gap-3 rounded-lg bg-[#f7f8fa] px-3 py-3 text-sm font-semibold text-[#4e5968]">
          상단 고정
          <input
            type="checkbox"
            name="is_pinned"
            value="true"
            class="h-5 w-5 accent-[#3182f6]"
            <%= projectView.isPinned ? 'checked' : '' %> />
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-4 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
      <h2 class="text-base font-bold text-[#191f28]">내용</h2>
      <div class="mt-4 grid gap-4">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          짧은 설명
          <textarea
            name="description"
            rows="3"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-3 text-sm leading-6 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"><%= projectView.description %></textarea>
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          해결하려는 문제
          <textarea
            name="problem"
            rows="4"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-3 text-sm leading-6 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"><%= projectView.problem %></textarea>
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          대상 사용자
          <textarea
            name="target_user"
            rows="3"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-3 text-sm leading-6 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"><%= projectView.targetUser %></textarea>
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          상태 메모
          <textarea
            name="status_reason"
            rows="3"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-3 text-sm leading-6 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"><%= projectView.statusReason %></textarea>
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-4 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
      <h2 class="text-base font-bold text-[#191f28]">링크</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          도메인 URL
          <input
            type="url"
            name="domain_url"
            value="<%= projectView.domainUrl %>"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          저장소 URL
          <input
            type="url"
            name="repo_url"
            value="<%= projectView.repoUrl %>"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

      </div>
    </section>

    <section class="rounded-lg bg-white p-4 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
      <h2 class="text-base font-bold text-[#191f28]">일정</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-3">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          작업 시작일
          <input
            type="date"
            name="started_at"
            value="<%= projectView.startedAt %>"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          출시일
          <input
            type="date"
            name="launched_at"
            value="<%= projectView.launchedAt %>"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          폐기일
          <input
            type="date"
            name="discarded_at"
            value="<%= projectView.discardedAt %>"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-4 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
      <button
        type="button"
        class="flex w-full items-center justify-between rounded-lg border-0 bg-transparent p-0 text-left"
        :aria-expanded="advancedOpen"
        @click="advancedOpen = !advancedOpen">
        <span class="text-base font-bold text-[#191f28]">고급</span>
        <span
          x-cloak
          x-show="!advancedOpen"
          class="i-lucide-chevron-down h-4 w-4 text-[#8b95a1]"
          aria-hidden="true"></span>
        <span
          x-cloak
          x-show="advancedOpen"
          class="i-lucide-chevron-up h-4 w-4 text-[#8b95a1]"
          aria-hidden="true"></span>
      </button>

      <div
        x-cloak
        x-show="advancedOpen"
        x-transition
        class="mt-4 grid gap-4 sm:grid-cols-2">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          태그
          <input
            type="text"
            name="tags"
            value="<%= projectView.tags %>"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
            placeholder="쉼표로 구분" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          정렬
          <input
            type="number"
            name="sort_order"
            min="0"
            value="<%= projectView.sortOrder %>"
            class="h-12 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>
      </div>
    </section>

    <div class="sticky bottom-0 -mx-4 bg-[#f7f8fa]/92 px-4 py-3 backdrop-blur sm:static sm:mx-0 sm:bg-transparent sm:px-0 sm:py-0 sm:backdrop-blur-0">
      <div class="flex gap-2">
        <a
          href="/"
          class="inline-flex h-12 flex-1 items-center justify-center rounded-lg bg-[#f2f4f6] px-4 text-sm font-bold text-[#4e5968] no-underline hover:bg-[#e5e8eb] sm:flex-none">
          취소
        </a>
        <button
          type="submit"
          class="inline-flex h-12 flex-[2] items-center justify-center rounded-lg border-0 bg-[#3182f6] px-4 text-sm font-bold text-white hover:bg-[#1b64da] sm:flex-none">
          저장
        </button>
      </div>
    </div>
  </form>

  <section class="rounded-lg bg-white p-4 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-bold text-[#191f28]">삭제</h2>
        <p class="mt-1 text-sm font-medium text-[#8b95a1]">프로젝트 데이터를 완전히 삭제합니다.</p>
      </div>
      <form
        method="post"
        action="/xapi/projects/delete"
        onsubmit="return confirm('이 프로젝트를 완전히 삭제할까요?')">
        <input
          type="hidden"
          name="project_id"
          value="<%= projectView.id %>" />
        <button
          type="submit"
          class="inline-flex h-11 w-full items-center justify-center rounded-lg border-0 bg-[#fff0f0] px-4 text-sm font-bold text-[#e03131] hover:bg-[#ffe3e3] sm:w-auto">
          삭제
        </button>
      </form>
    </div>
  </section>
</div>
