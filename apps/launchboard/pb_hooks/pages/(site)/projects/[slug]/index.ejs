<script server>
  const { dateutil } = require('@pocketpages/utils')

  const slug = String(params.slug || '').trim()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const statusOptions = [
    { value: 'idea', label: '아이디어', icon: 'i-lucide-lightbulb' },
    { value: 'building', label: '작업중', icon: 'i-lucide-hammer' },
    { value: 'launched', label: '출시', icon: 'i-lucide-rocket' },
    { value: 'paused', label: '보류', icon: 'i-lucide-pause' },
    { value: 'discarded', label: '폐기', icon: 'i-lucide-trash-2' },
  ]
  const priorityOptions = [
    { value: 'low', label: '낮음' },
    { value: 'normal', label: '보통' },
    { value: 'high', label: '높음' },
  ]

  function normalizeStatus(value) {
    const raw = String(value || 'idea').trim()

    for (let index = 0; index < statusOptions.length; index += 1) {
      if (statusOptions[index].value === raw) return raw
    }

    return 'idea'
  }

  function normalizeTags(value) {
    if (!value) return []

    if (value && typeof value.string === 'function') {
      try {
        const parsed = JSON.parse(value.string())

        return Array.isArray(parsed) ? parsed : []
      } catch (exception) {
        return []
      }
    }

    if (Array.isArray(value)) {
      const numericItems = value.filter((item) => /^[0-9]+$/.test(String(item || '').trim()))

      if (numericItems.length === value.length) {
        try {
          const decoded = String.fromCharCode.apply(
            null,
            numericItems.map((item) => Number(item))
          )
          const parsed = JSON.parse(decoded)

          return Array.isArray(parsed) ? parsed : []
        } catch (exception) {
          return value
        }
      }

      return value
    }

    try {
      const parsed = JSON.parse(String(value || ''))

      return Array.isArray(parsed) ? parsed : []
    } catch (exception) {
      return []
    }
  }

  function tagsText(value) {
    return normalizeTags(value)
      .map((tag) => String(tag || '').trim())
      .filter((tag) => !!tag)
      .join(', ')
  }

  /**
   * 개발지원 도메인의 관리자 URL을 만든다.
   * @param {unknown} value 도메인 URL
   * @returns {string}
   */
  function getDevelopmentSupportAdminUrl(value) {
    const raw = String(value || '').trim()

    if (!raw) return ''

    const normalized = raw.indexOf('://') === -1 ? 'https://' + raw : raw
    const match = normalized.match(/^(https?:\/\/([^/?#]+))(?:[/?#]|$)/i)

    if (!match) return ''

    const origin = match[1].replace(/\/+$/, '')
    const host = String(match[2] || '')
      .trim()
      .toLowerCase()
      .split(':')[0]
    const suffix = '.development-support.o-r.kr'
    const subdomain = host.slice(0, -suffix.length)

    if (!host.endsWith(suffix) || !subdomain) return ''

    return origin + '/_/'
  }

  if (!request.auth) {
    dbg('page/projects/[slug]:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  if (!slug) {
    dbg('page/projects/[slug]:redirect', {
      status: 303,
      redirectTo: '/',
      message: '프로젝트를 찾지 못했습니다.',
    })
    redirect('/', {
      status: 303,
      message: '프로젝트를 찾지 못했습니다.',
    })
    return
  }

  let project = null

  try {
    project = $app.findFirstRecordByFilter('projects', 'slug = {:slug} && user = {:userId}', {
      slug,
      userId,
    })
  } catch (exception) {
    project = null
  }

  if (!project) {
    dbg('page/projects/[slug]:redirect', {
      status: 303,
      redirectTo: '/',
      message: '프로젝트를 찾지 못했습니다.',
      slug,
    })
    redirect('/', {
      status: 303,
      message: '프로젝트를 찾지 못했습니다.',
    })
    return
  }

  const projectStartedAt = String(project.get('started_at') || '').trim()
  const projectLaunchedAt = String(project.get('launched_at') || '').trim()
  const projectDiscardedAt = String(project.get('discarded_at') || '').trim()
  const projectDomainUrl = String(project.get('domain_url') || '').trim()

  const projectView = {
    id: String(project.get('id') || ''),
    nameKo: String(project.get('name_ko') || '').trim(),
    nameEn: String(project.get('name_en') || '').trim(),
    slug: String(project.get('slug') || '').trim(),
    tasksHref: '/projects/' + encodeURIComponent(String(project.get('slug') || '').trim()) + '/tasks',
    status: normalizeStatus(project.get('status')),
    priority: String(project.get('priority') || 'normal'),
    isPinned: project.get('is_pinned') === true,
    domainUrl: projectDomainUrl,
    adminUrl: getDevelopmentSupportAdminUrl(projectDomainUrl),
    repoUrl: String(project.get('repo_url') || '').trim(),
    description: String(project.get('description') || '').trim(),
    problem: String(project.get('problem') || '').trim(),
    targetUser: String(project.get('target_user') || '').trim(),
    statusReason: String(project.get('status_reason') || '').trim(),
    tags: tagsText(project.get('tags')),
    sortOrder: String(project.get('sort_order') || 0),
    startedAt: projectStartedAt ? dateutil.formatDate(projectStartedAt, dateutil.FORMATS.DATE) : '',
    launchedAt: projectLaunchedAt ? dateutil.formatDate(projectLaunchedAt, dateutil.FORMATS.DATE) : '',
    discardedAt: projectDiscardedAt ? dateutil.formatDate(projectDiscardedAt, dateutil.FORMATS.DATE) : '',
  }

  meta('title', projectView.nameKo + ' | LaunchBoard')
  meta('description', projectView.nameKo)

  dbg('page/projects/[slug]:response', {
    projectId: projectView.id,
    slug: projectView.slug,
    status: projectView.status,
  })
</script>

<div
  class="space-y-2"
  data-signals="{advancedOpen: false, detailToastMessage: '', detailToastTone: 'success'}">
  <header class="rounded-lg bg-white px-3 py-2 shadow-[0_8px_24px_rgba(25,31,40,0.05)]">
    <div class="flex items-start justify-between gap-2">
      <div class="min-w-0">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 rounded-md bg-transparent text-xs font-bold text-[#6b7684] no-underline hover:text-[#191f28]">
          <span
            class="i-lucide-chevron-left h-4 w-4"
            aria-hidden="true"></span>
          목록
        </a>
        <div class="mt-2 flex min-w-0 items-center">
          <div class="min-w-0">
            <h1 class="truncate text-base font-bold leading-6 text-[#191f28]"><%= projectView.nameKo %></h1>
            <% if (projectView.nameEn) { %>
            <p class="truncate text-xs font-semibold text-[#8b95a1]"><%= projectView.nameEn %></p>
            <% } %>
          </div>
        </div>
      </div>

      <div class="flex shrink-0 items-center gap-2">
        <label
          class="inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg bg-[#f2f4f6] text-[#8b95a1] hover:bg-[#fff4d6] hover:text-[#f59f00]"
          title="상단 고정">
          <input
            type="checkbox"
            name="is_pinned"
            value="true"
            form="project-detail-form"
            class="launchboard-choice-input"
            <%= projectView.isPinned ? 'checked' : '' %> />
          <span
            class="launchboard-pin-off-icon i-lucide-pin-off h-4 w-4"
            aria-hidden="true"></span>
          <span
            class="launchboard-pin-on-icon i-lucide-pin h-4 w-4"
            aria-hidden="true"></span>
        </label>
        <a
          href="<%= projectView.tasksHref %>"
          class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-[#f2f4f6] px-3 text-xs font-bold text-[#4e5968] no-underline hover:bg-[#e5e8eb]">
          <span
            class="i-lucide-list-todo h-4 w-4"
            aria-hidden="true"></span>
          업무
        </a>
        <% if (projectView.adminUrl) { %>
        <a
          href="<%= projectView.adminUrl %>"
          target="_blank"
          rel="noreferrer noopener"
          class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-[#f2f4f6] px-3 text-xs font-bold text-[#4e5968] no-underline hover:bg-[#e5e8eb]">
          <span
            class="i-lucide-shield h-4 w-4"
            aria-hidden="true"></span>
          관리
        </a>
        <% } %>
      </div>
    </div>
  </header>

  <%- include('detail-toast.ejs') %>

  <form
    id="project-detail-form"
    method="post"
    action="/xapi/projects/update"
    class="grid gap-2"
    data-on:submit="@post('/xapi/projects/update', {contentType: 'form'})">
    <input
      type="hidden"
      name="project_id"
      value="<%= projectView.id %>" />

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
      <h2 class="text-[15px] font-bold text-[#191f28]">기본</h2>
      <div class="mt-2 grid gap-2">
        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          프로젝트명
          <input
            type="text"
            name="name_ko"
            required
            value="<%= projectView.nameKo %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          영문명
          <input
            type="text"
            name="name_en"
            value="<%= projectView.nameEn %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <fieldset class="launchboard-choice-fieldset m-0 grid gap-1.5 border-0 p-0">
          <legend class="text-[13px] font-semibold text-[#4e5968]">상태</legend>
          <div class="grid grid-cols-3 gap-2">
            <% for (let index = 0; index < statusOptions.length; index += 1) { %>
            <% const option = statusOptions[index] %>
            <label class="cursor-pointer">
              <input
                type="radio"
                name="status"
                class="launchboard-choice-input"
                value="<%= option.value %>"
                <%= option.value === projectView.status ? 'checked' : '' %> />
              <span
                class="launchboard-status-choice flex min-h-9 w-full items-center justify-center gap-1 rounded-lg bg-[#f7f8fa] text-[13px] font-bold text-[#4e5968] shadow-[inset_0_0_0_1px_rgba(227,231,237,0)] transition-colors duration-150 hover:bg-[#f2f4f6]">
                <span
                  class="<%= option.icon %> h-3.5 w-3.5"
                  aria-hidden="true"></span>
                <span><%= option.label %></span>
              </span>
            </label>
            <% } %>
          </div>
        </fieldset>

        <fieldset class="launchboard-choice-fieldset m-0 grid gap-1.5 border-0 p-0">
          <legend class="text-[13px] font-semibold text-[#4e5968]">우선순위</legend>
          <div class="grid grid-cols-3 gap-2">
            <% for (let index = 0; index < priorityOptions.length; index += 1) { %>
            <% const option = priorityOptions[index] %>
            <label class="cursor-pointer">
              <input
                type="radio"
                name="priority"
                class="launchboard-choice-input"
                value="<%= option.value %>"
                <%= option.value === projectView.priority ? 'checked' : '' %> />
              <span
                class="launchboard-priority-choice flex h-9 w-full items-center justify-center rounded-lg bg-[#f7f8fa] text-[13px] font-bold text-[#4e5968] shadow-[inset_0_0_0_1px_rgba(227,231,237,0)] transition-colors duration-150 hover:bg-[#f2f4f6]"
                ><%= option.label %></span
              >
            </label>
            <% } %>
          </div>
        </fieldset>
      </div>
    </section>

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
      <h2 class="text-[15px] font-bold text-[#191f28]">내용</h2>
      <div class="mt-2 grid gap-2">
        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          짧은 설명
          <textarea
            name="description"
            rows="3"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-2 text-sm leading-5 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
<%= projectView.description %></textarea
          >
        </label>

        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          해결하려는 문제
          <textarea
            name="problem"
            rows="4"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-2 text-sm leading-5 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
<%= projectView.problem %></textarea
          >
        </label>

        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          대상 사용자
          <textarea
            name="target_user"
            rows="3"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-2 text-sm leading-5 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
<%= projectView.targetUser %></textarea
          >
        </label>

        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          상태 메모
          <textarea
            name="status_reason"
            rows="3"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-2 text-sm leading-5 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
<%= projectView.statusReason %></textarea
          >
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
      <h2 class="text-[15px] font-bold text-[#191f28]">링크</h2>
      <div class="mt-2 grid gap-2">
        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          도메인 URL
          <input
            type="url"
            name="domain_url"
            value="<%= projectView.domainUrl %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          저장소 URL
          <input
            type="url"
            name="repo_url"
            value="<%= projectView.repoUrl %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
      <h2 class="text-[15px] font-bold text-[#191f28]">일정</h2>
      <div class="mt-2 grid gap-2">
        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          작업 시작일
          <input
            type="date"
            name="started_at"
            value="<%= projectView.startedAt %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          출시일
          <input
            type="date"
            name="launched_at"
            value="<%= projectView.launchedAt %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          폐기일
          <input
            type="date"
            name="discarded_at"
            value="<%= projectView.discardedAt %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
      <button
        type="button"
        class="flex w-full items-center justify-between rounded-lg border-0 bg-transparent p-0 text-left"
        data-attr="{'aria-expanded': $advancedOpen ? 'true' : 'false'}"
        data-on:click="$advancedOpen = !$advancedOpen">
        <span class="text-[15px] font-bold text-[#191f28]">고급</span>
        <span
          data-show="!$advancedOpen"
          class="i-lucide-chevron-down h-4 w-4 text-[#8b95a1]"
          aria-hidden="true"></span>
        <span
          data-show="$advancedOpen"
          style="display: none"
          class="i-lucide-chevron-up h-4 w-4 text-[#8b95a1]"
          aria-hidden="true"></span>
      </button>

      <div
        data-show="$advancedOpen"
        style="display: none"
        class="mt-2 grid gap-2">
        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          태그
          <input
            type="text"
            name="tags"
            value="<%= projectView.tags %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
            placeholder="쉼표로 구분" />
        </label>

        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          정렬
          <input
            type="number"
            name="sort_order"
            min="0"
            value="<%= projectView.sortOrder %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>
      </div>
    </section>

    <div class="bg-[#f7f8fa]/92 sticky bottom-0 -mx-3 px-3 py-2 backdrop-blur">
      <div class="flex gap-2">
        <a
          href="/"
          class="inline-flex h-10 flex-1 items-center justify-center rounded-lg bg-[#f2f4f6] px-4 text-sm font-bold text-[#4e5968] no-underline hover:bg-[#e5e8eb]">
          취소
        </a>
        <button
          type="submit"
          class="inline-flex h-10 flex-[2] items-center justify-center rounded-lg border-0 bg-[#3182f6] px-4 text-sm font-bold text-white hover:bg-[#1b64da]">
          저장
        </button>
      </div>
    </div>
  </form>

  <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
    <div class="flex flex-col gap-2">
      <div>
        <h2 class="text-[15px] font-bold text-[#191f28]">삭제</h2>
        <p class="mt-1 text-sm font-medium text-[#8b95a1]">프로젝트 데이터를 완전히 삭제합니다.</p>
      </div>
      <form
        method="post"
        action="/xapi/projects/delete"
        onsubmit="return confirm('이 프로젝트를 완전히 삭제할까요?')">
        <input
          type="hidden"
          name="project_id"
          value="<%= projectView.id %>" />
        <button
          type="submit"
          class="inline-flex h-11 w-full items-center justify-center rounded-lg border-0 bg-[#fff0f0] px-4 text-sm font-bold text-[#e03131] hover:bg-[#ffe3e3]">
          삭제
        </button>
      </form>
    </div>
  </section>
</div>
