<script server>
  const { dateutil } = require('@pocketpages/utils')
  const taskBoard = resolve('task-board')

  const slug = String(params.slug || '').trim()
  const taskId = String(params.taskId || '').trim()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const statusOptions = [
    { value: 'todo', label: '할 일', icon: 'i-lucide-list-checks' },
    { value: 'doing', label: '진행중', icon: 'i-lucide-hammer' },
    { value: 'done', label: '완료', icon: 'i-lucide-check-circle-2' },
    { value: 'paused', label: '보류', icon: 'i-lucide-pause' },
    { value: 'canceled', label: '취소', icon: 'i-lucide-x-circle' },
  ]
  const priorityOptions = [
    { value: 'low', label: '낮음' },
    { value: 'normal', label: '보통' },
    { value: 'high', label: '높음' },
  ]
  const typeOptions = [
    { value: 'feature', label: '기능' },
    { value: 'bug', label: '버그' },
    { value: 'design', label: '디자인' },
    { value: 'content', label: '콘텐츠' },
    { value: 'infra', label: '인프라' },
    { value: 'research', label: '리서치' },
    { value: 'etc', label: '기타' },
  ]

  function normalizeTags(value) {
    if (!value) return []

    if (value && typeof value.string === 'function') {
      try {
        const parsed = JSON.parse(value.string())

        return Array.isArray(parsed) ? parsed : []
      } catch (exception) {
        return []
      }
    }

    if (Array.isArray(value)) return value

    try {
      const parsed = JSON.parse(String(value || ''))

      return Array.isArray(parsed) ? parsed : []
    } catch (exception) {
      return []
    }
  }

  function tagsText(value) {
    return normalizeTags(value)
      .map((tag) => String(tag || '').trim())
      .filter((tag) => !!tag)
      .join(', ')
  }

  function normalizeReturnTo(value) {
    const raw = String(value || '').trim()

    if (raw === '/tasks' || raw === '/tasks?view=today') return raw

    return ''
  }

  if (!request.auth) {
    dbg('page/projects/[slug]/tasks/[taskId]:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  if (!slug || !taskId) {
    dbg('page/projects/[slug]/tasks/[taskId]:redirect', {
      status: 303,
      redirectTo: '/',
      message: '업무를 찾지 못했습니다.',
    })
    redirect('/', {
      status: 303,
      message: '업무를 찾지 못했습니다.',
    })
    return
  }

  let project = null
  let task = null

  try {
    project = $app.findFirstRecordByFilter('projects', 'slug = {:slug} && user = {:userId}', {
      slug,
      userId,
    })
    task = $app.findFirstRecordByFilter('project_tasks', 'id = {:taskId} && user = {:userId} && project = {:projectId}', {
      taskId,
      userId,
      projectId: String(project.get('id') || ''),
    })
  } catch (exception) {
    project = null
    task = null
  }

  if (!project || !task) {
    const redirectTo = slug ? '/projects/' + encodeURIComponent(slug) + '/tasks' : '/'

    dbg('page/projects/[slug]/tasks/[taskId]:redirect', {
      status: 303,
      redirectTo,
      message: '업무를 찾지 못했습니다.',
      slug,
      taskId,
    })
    redirect(redirectTo, {
      status: 303,
      message: '업무를 찾지 못했습니다.',
    })
    return
  }

  const projectView = {
    id: String(project.get('id') || ''),
    nameKo: String(project.get('name_ko') || '').trim(),
    slug: String(project.get('slug') || '').trim(),
    tasksHref: '/projects/' + encodeURIComponent(String(project.get('slug') || '').trim()) + '/tasks',
  }
  const returnTo = normalizeReturnTo(request.url.query.return_to)
  const taskBackHref = returnTo || projectView.tasksHref
  const taskDueAt = String(task.get('due_at') || '').trim()
  const taskStartedAt = String(task.get('started_at') || '').trim()
  const taskCompletedAt = String(task.get('completed_at') || '').trim()
  const taskCanceledAt = String(task.get('canceled_at') || '').trim()

  const taskView = {
    id: String(task.get('id') || ''),
    title: String(task.get('title') || '').trim(),
    description: String(task.get('description') || '').trim(),
    status: taskBoard.normalizeTaskStatus(task.get('status')),
    priority: taskBoard.normalizeTaskPriority(task.get('priority')),
    type: taskBoard.normalizeTaskType(task.get('type')),
    tags: tagsText(task.get('tags')),
    dueAt: taskDueAt ? dateutil.formatDate(taskDueAt, dateutil.FORMATS.DATE) : '',
    startedAt: taskStartedAt ? dateutil.formatDate(taskStartedAt, dateutil.FORMATS.DATE) : '',
    completedAt: taskCompletedAt ? dateutil.formatDate(taskCompletedAt, dateutil.FORMATS.DATE) : '',
    canceledAt: taskCanceledAt ? dateutil.formatDate(taskCanceledAt, dateutil.FORMATS.DATE) : '',
    statusReason: String(task.get('status_reason') || '').trim(),
    sortOrder: String(task.get('sort_order') || 0),
    isPinned: task.get('is_pinned') === true,
  }

  meta('title', taskView.title + ' | ' + projectView.nameKo + ' 업무')
  meta('description', taskView.title)

  dbg('page/projects/[slug]/tasks/[taskId]:response', {
    projectId: projectView.id,
    taskId: taskView.id,
    status: taskView.status,
  })
</script>

<div
  class="space-y-2"
  data-signals="{advancedOpen: false, detailToastMessage: '', detailToastTone: 'success'}">
  <header class="rounded-lg bg-white px-3 py-2 shadow-[0_8px_24px_rgba(25,31,40,0.05)]">
    <div class="flex items-start justify-between gap-2">
      <div class="min-w-0">
        <a
          href="<%= taskBackHref %>"
          class="inline-flex items-center gap-1.5 rounded-md bg-transparent text-xs font-bold text-[#6b7684] no-underline hover:text-[#191f28]">
          <span
            class="i-lucide-chevron-left h-4 w-4"
            aria-hidden="true"></span>
          업무
        </a>
        <div class="mt-2 min-w-0">
          <p class="truncate text-xs font-bold text-[#8b95a1]"><%= projectView.nameKo %></p>
          <h1 class="truncate text-base leading-6 font-bold text-[#191f28]"><%= taskView.title %></h1>
        </div>
      </div>

      <div class="flex shrink-0 items-center gap-2">
        <label
          class="inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg bg-[#f2f4f6] text-[#8b95a1] hover:bg-[#fff4d6] hover:text-[#f59f00]"
          title="상단 고정">
          <input
            type="checkbox"
            name="is_pinned"
            value="true"
            form="task-detail-form"
            class="launchboard-choice-input"
            <%= taskView.isPinned ? 'checked' : '' %> />
          <span
            class="launchboard-pin-off-icon i-lucide-pin-off h-4 w-4"
            aria-hidden="true"></span>
          <span
            class="launchboard-pin-on-icon i-lucide-pin h-4 w-4"
            aria-hidden="true"></span>
        </label>
      </div>
    </div>
  </header>

  <%- include('detail-toast.ejs') %>

  <form
    id="task-detail-form"
    method="post"
    action="/xapi/tasks/update"
    class="grid gap-2"
    data-on:submit="@post('/xapi/tasks/update', {contentType: 'form'})">
    <input
      type="hidden"
      name="task_id"
      value="<%= taskView.id %>" />
    <input
      type="hidden"
      name="project_id"
      value="<%= projectView.id %>" />
    <input
      type="hidden"
      name="project_slug"
      value="<%= projectView.slug %>" />
    <input
      type="hidden"
      name="return_to"
      value="<%= returnTo %>" />

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
      <h2 class="text-[15px] font-bold text-[#191f28]">기본</h2>
      <div class="mt-2 grid gap-2">
        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          제목
          <input
            type="text"
            name="title"
            required
            value="<%= taskView.title %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>

        <fieldset class="launchboard-choice-fieldset m-0 grid gap-1.5 border-0 p-0">
          <legend class="text-[13px] font-semibold text-[#4e5968]">상태</legend>
          <div class="grid grid-cols-3 gap-2">
            <% for (let index = 0; index < statusOptions.length; index += 1) { %>
            <% const option = statusOptions[index] %>
            <label class="cursor-pointer">
              <input
                type="radio"
                name="status"
                class="launchboard-choice-input"
                value="<%= option.value %>"
                <%= option.value === taskView.status ? 'checked' : '' %> />
              <span
                class="launchboard-status-choice flex min-h-9 w-full items-center justify-center gap-1 rounded-lg bg-[#f7f8fa] text-[13px] font-bold text-[#4e5968] shadow-[inset_0_0_0_1px_rgba(227,231,237,0)] transition-colors duration-150 hover:bg-[#f2f4f6]">
                <span
                  class="<%= option.icon %> h-3.5 w-3.5"
                  aria-hidden="true"></span>
                <span><%= option.label %></span>
              </span>
            </label>
            <% } %>
          </div>
        </fieldset>

        <fieldset class="launchboard-choice-fieldset m-0 grid gap-1.5 border-0 p-0">
          <legend class="text-[13px] font-semibold text-[#4e5968]">우선순위</legend>
          <div class="grid grid-cols-3 gap-2">
            <% for (let index = 0; index < priorityOptions.length; index += 1) { %>
            <% const option = priorityOptions[index] %>
            <label class="cursor-pointer">
              <input
                type="radio"
                name="priority"
                class="launchboard-choice-input"
                value="<%= option.value %>"
                <%= option.value === taskView.priority ? 'checked' : '' %> />
              <span
                class="launchboard-priority-choice flex h-9 w-full items-center justify-center rounded-lg bg-[#f7f8fa] text-[13px] font-bold text-[#4e5968] shadow-[inset_0_0_0_1px_rgba(227,231,237,0)] transition-colors duration-150 hover:bg-[#f2f4f6]"
                ><%= option.label %></span
              >
            </label>
            <% } %>
          </div>
        </fieldset>

        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          타입
          <select
            name="type"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
            <% for (let index = 0; index < typeOptions.length; index += 1) { %>
            <% const option = typeOptions[index] %>
            <option
              value="<%= option.value %>"
              <%= option.value === taskView.type ? 'selected' : '' %>>
              <%= option.label %>
            </option>
            <% } %>
          </select>
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
      <h2 class="text-[15px] font-bold text-[#191f28]">내용</h2>
      <div class="mt-2 grid gap-2">
        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          메모
          <textarea
            name="description"
            rows="6"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-2 text-sm leading-5 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
<%= taskView.description %></textarea>
        </label>

        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          상태 메모
          <textarea
            name="status_reason"
            rows="3"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-2 text-sm leading-5 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
<%= taskView.statusReason %></textarea>
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
      <h2 class="text-[15px] font-bold text-[#191f28]">일정</h2>
      <div class="launchboard-date-grid mt-2 grid grid-cols-[minmax(0,1fr)_minmax(0,1fr)] gap-2">
        <label class="grid min-w-0 gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          마감일
          <input
            type="date"
            name="due_at"
            value="<%= taskView.dueAt %>"
            class="launchboard-date-input h-9 w-full min-w-0 rounded-lg border-0 bg-[#f7f8fa] px-2 text-[12px] font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>
        <label class="grid min-w-0 gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          시작일
          <input
            type="date"
            name="started_at"
            value="<%= taskView.startedAt %>"
            class="launchboard-date-input h-9 w-full min-w-0 rounded-lg border-0 bg-[#f7f8fa] px-2 text-[12px] font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>
        <label class="grid min-w-0 gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          완료일
          <input
            type="date"
            name="completed_at"
            value="<%= taskView.completedAt %>"
            class="launchboard-date-input h-9 w-full min-w-0 rounded-lg border-0 bg-[#f7f8fa] px-2 text-[12px] font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>
        <label class="grid min-w-0 gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          취소일
          <input
            type="date"
            name="canceled_at"
            value="<%= taskView.canceledAt %>"
            class="launchboard-date-input h-9 w-full min-w-0 rounded-lg border-0 bg-[#f7f8fa] px-2 text-[12px] font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
      <button
        type="button"
        class="flex w-full items-center justify-between rounded-lg border-0 bg-transparent p-0 text-left"
        data-attr="{'aria-expanded': $advancedOpen ? 'true' : 'false'}"
        data-on:click="$advancedOpen = !$advancedOpen">
        <span class="text-[15px] font-bold text-[#191f28]">고급</span>
        <span
          data-show="!$advancedOpen"
          class="i-lucide-chevron-down h-4 w-4 text-[#8b95a1]"
          aria-hidden="true"></span>
        <span
          data-show="$advancedOpen"
          style="display: none"
          class="i-lucide-chevron-up h-4 w-4 text-[#8b95a1]"
          aria-hidden="true"></span>
      </button>

      <div
        data-show="$advancedOpen"
        style="display: none"
        class="mt-2 grid gap-2">
        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          태그
          <input
            type="text"
            name="tags"
            value="<%= taskView.tags %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]"
            placeholder="쉼표로 구분" />
        </label>
        <label class="grid gap-1.5 text-[13px] font-semibold text-[#4e5968]">
          정렬
          <input
            type="number"
            name="sort_order"
            min="0"
            value="<%= taskView.sortOrder %>"
            class="h-9 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]" />
        </label>
      </div>
    </section>

    <div class="sticky bottom-0 -mx-3 bg-[#f7f8fa]/92 px-3 py-2 backdrop-blur">
      <div class="flex gap-2">
        <a
          href="<%= taskBackHref %>"
          class="inline-flex h-10 flex-1 items-center justify-center rounded-lg bg-[#f2f4f6] px-4 text-sm font-bold text-[#4e5968] no-underline hover:bg-[#e5e8eb]"
          >취소</a
        >
        <button
          type="submit"
          class="inline-flex h-10 flex-[2] items-center justify-center rounded-lg border-0 bg-[#3182f6] px-4 text-sm font-bold text-white hover:bg-[#1b64da]">
          저장
        </button>
      </div>
    </div>
  </form>

  <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)]">
    <div class="flex flex-col gap-2">
      <div>
        <h2 class="text-[15px] font-bold text-[#191f28]">삭제</h2>
        <p class="mt-1 text-sm font-medium text-[#8b95a1]">업무 데이터를 완전히 삭제합니다.</p>
      </div>
      <form
        method="post"
        action="/xapi/tasks/delete"
        onsubmit="return confirm('이 업무를 완전히 삭제할까요?')">
        <input
          type="hidden"
          name="task_id"
          value="<%= taskView.id %>" />
        <input
          type="hidden"
          name="project_id"
          value="<%= projectView.id %>" />
        <input
          type="hidden"
          name="return_to"
          value="<%= returnTo %>" />
        <button
          type="submit"
          class="inline-flex h-11 w-full items-center justify-center rounded-lg border-0 bg-[#fff0f0] px-4 text-sm font-bold text-[#e03131] hover:bg-[#ffe3e3]">
          삭제
        </button>
      </form>
    </div>
  </section>
</div>
