<script server>
  const { dateutil } = require('@pocketpages/utils')
  const taskBoard = resolve('task-board')

  const slug = String(params.slug || '').trim()
  const taskId = String(params.taskId || '').trim()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const statusOptions = [
    { value: 'todo', label: '할 일' },
    { value: 'doing', label: '진행중' },
    { value: 'done', label: '완료' },
    { value: 'paused', label: '보류' },
    { value: 'canceled', label: '취소' },
  ]
  const priorityOptions = [
    { value: 'low', label: '낮음' },
    { value: 'normal', label: '보통' },
    { value: 'high', label: '높음' },
  ]
  const typeOptions = [
    { value: 'feature', label: '기능' },
    { value: 'bug', label: '버그' },
    { value: 'design', label: '디자인' },
    { value: 'content', label: '콘텐츠' },
    { value: 'infra', label: '인프라' },
    { value: 'research', label: '리서치' },
    { value: 'etc', label: '기타' },
  ]

  function inputDate(value) {
    const raw = String(value || '').trim()

    if (!raw) return ''

    return dateutil.formatDate(raw, 'YYYY-MM-DD')
  }

  function normalizeTags(value) {
    if (!value) return []

    if (value && typeof value.string === 'function') {
      try {
        const parsed = JSON.parse(value.string())

        return Array.isArray(parsed) ? parsed : []
      } catch (exception) {
        return []
      }
    }

    if (Array.isArray(value)) return value

    try {
      const parsed = JSON.parse(String(value || ''))

      return Array.isArray(parsed) ? parsed : []
    } catch (exception) {
      return []
    }
  }

  function tagsText(value) {
    return normalizeTags(value)
      .map((tag) => String(tag || '').trim())
      .filter((tag) => !!tag)
      .join(', ')
  }

  if (!request.auth) {
    dbg('page/projects/[slug]/tasks/[taskId]:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      flash: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  if (!slug || !taskId) {
    dbg('page/projects/[slug]/tasks/[taskId]:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '업무를 찾지 못했습니다.',
    })
    redirect('/', {
      status: 303,
      message: '업무를 찾지 못했습니다.',
    })
    return
  }

  let project = null
  let task = null

  try {
    project = $app.findFirstRecordByFilter('projects', 'slug = {:slug} && user = {:userId}', {
      slug,
      userId,
    })
    task = $app.findFirstRecordByFilter('project_tasks', 'id = {:taskId} && user = {:userId} && project = {:projectId}', {
      taskId,
      userId,
      projectId: String(project.get('id') || ''),
    })
  } catch (exception) {
    project = null
    task = null
  }

  if (!project || !task) {
    const redirectTo = slug ? '/projects/' + encodeURIComponent(slug) + '/tasks' : '/'

    dbg('page/projects/[slug]/tasks/[taskId]:redirect', {
      status: 303,
      redirectTo,
      flash: '업무를 찾지 못했습니다.',
      slug,
      taskId,
    })
    redirect(redirectTo, {
      status: 303,
      message: '업무를 찾지 못했습니다.',
    })
    return
  }

  const projectView = {
    id: String(project.get('id') || ''),
    nameKo: String(project.get('name_ko') || '').trim(),
    slug: String(project.get('slug') || '').trim(),
    tasksHref: '/projects/' + encodeURIComponent(String(project.get('slug') || '').trim()) + '/tasks',
  }
  const taskView = {
    id: String(task.get('id') || ''),
    title: String(task.get('title') || '').trim(),
    description: String(task.get('description') || '').trim(),
    status: taskBoard.normalizeTaskStatus(task.get('status')),
    priority: taskBoard.normalizeTaskPriority(task.get('priority')),
    type: taskBoard.normalizeTaskType(task.get('type')),
    tags: tagsText(task.get('tags')),
    dueAt: inputDate(task.get('due_at')),
    startedAt: inputDate(task.get('started_at')),
    completedAt: inputDate(task.get('completed_at')),
    canceledAt: inputDate(task.get('canceled_at')),
    statusReason: String(task.get('status_reason') || '').trim(),
    sortOrder: String(task.get('sort_order') || 0),
    isPinned: task.get('is_pinned') === true,
    updatedAt: inputDate(task.get('updated')),
  }

  meta('title', taskView.title + ' | ' + projectView.nameKo + ' 업무')
  meta('description', taskView.title)

  dbg('page/projects/[slug]/tasks/[taskId]:response', {
    projectId: projectView.id,
    taskId: taskView.id,
    status: taskView.status,
  })
</script>

<div
  class="mx-auto max-w-[980px] space-y-3 sm:space-y-6"
  x-data="{ advancedOpen: false }">
  <header class="rounded-lg bg-white px-3 py-3 shadow-[0_8px_24px_rgba(25,31,40,0.05)] sm:px-6 sm:py-5">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <a
          href="<%= projectView.tasksHref %>"
          class="inline-flex items-center gap-1.5 rounded-md bg-transparent text-xs font-bold text-[#6b7684] no-underline hover:text-[#191f28] sm:text-sm">
          <span
            class="i-lucide-chevron-left h-4 w-4"
            aria-hidden="true"></span>
          업무
        </a>
        <div class="mt-3 min-w-0">
          <p class="truncate text-xs font-bold text-[#8b95a1] sm:text-sm"><%= projectView.nameKo %></p>
          <h1 class="truncate text-xl font-bold leading-7 text-[#191f28] sm:text-3xl sm:leading-10"><%= taskView.title %></h1>
        </div>
      </div>

      <% if (taskView.updatedAt) { %>
      <div class="hidden shrink-0 rounded-lg bg-[#f7f8fa] px-3 py-2 text-right sm:block">
        <p class="text-[11px] font-bold text-[#8b95a1]">수정</p>
        <p class="text-sm font-bold text-[#191f28]"><%= taskView.updatedAt %></p>
      </div>
      <% } %>
    </div>
  </header>

  <% if (params.__flash) { %>
  <div class="rounded-lg bg-[#fff4d6] px-3 py-2 text-xs font-medium text-[#8a5b00] sm:px-4 sm:py-3 sm:text-sm"><%= params.__flash %></div>
  <% } %>

  <form
    method="post"
    action="/xapi/tasks/update"
    class="grid gap-3 sm:gap-4">
    <input
      type="hidden"
      name="task_id"
      value="<%= taskView.id %>" />
    <input
      type="hidden"
      name="project_id"
      value="<%= projectView.id %>" />
    <input
      type="hidden"
      name="project_slug"
      value="<%= projectView.slug %>" />

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
      <h2 class="text-base font-bold text-[#191f28]">기본</h2>
      <div class="mt-3 grid gap-3 sm:mt-4 sm:grid-cols-2 sm:gap-4">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968] sm:col-span-2">
          제목
          <input
            type="text"
            name="title"
            required
            value="<%= taskView.title %>"
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-12 sm:text-base" />
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          상태
          <select
            name="status"
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-12 sm:text-base">
            <% for (let index = 0; index < statusOptions.length; index += 1) { %>
            <% const option = statusOptions[index] %>
            <option
              value="<%= option.value %>"
              <%= option.value === taskView.status ? 'selected' : '' %>>
              <%= option.label %>
            </option>
            <% } %>
          </select>
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          우선순위
          <select
            name="priority"
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-12 sm:text-base">
            <% for (let index = 0; index < priorityOptions.length; index += 1) { %>
            <% const option = priorityOptions[index] %>
            <option
              value="<%= option.value %>"
              <%= option.value === taskView.priority ? 'selected' : '' %>>
              <%= option.label %>
            </option>
            <% } %>
          </select>
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          타입
          <select
            name="type"
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-bold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-12 sm:text-base">
            <% for (let index = 0; index < typeOptions.length; index += 1) { %>
            <% const option = typeOptions[index] %>
            <option
              value="<%= option.value %>"
              <%= option.value === taskView.type ? 'selected' : '' %>>
              <%= option.label %>
            </option>
            <% } %>
          </select>
        </label>

        <label class="flex items-center justify-between gap-3 rounded-lg bg-[#f7f8fa] px-3 py-3 text-sm font-semibold text-[#4e5968]">
          상단 고정
          <input
            type="checkbox"
            name="is_pinned"
            value="true"
            class="h-5 w-5 accent-[#3182f6]"
            <%= taskView.isPinned ? 'checked' : '' %> />
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
      <h2 class="text-base font-bold text-[#191f28]">내용</h2>
      <div class="mt-3 grid gap-3 sm:mt-4 sm:gap-4">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          메모
          <textarea
            name="description"
            rows="6"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-3 text-sm leading-6 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
<%= taskView.description %></textarea
          >
        </label>

        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          상태 메모
          <textarea
            name="status_reason"
            rows="3"
            class="resize-y rounded-lg border-0 bg-[#f7f8fa] px-3 py-3 text-sm leading-6 text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6]">
<%= taskView.statusReason %></textarea
          >
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
      <h2 class="text-base font-bold text-[#191f28]">일정</h2>
      <div class="mt-3 grid gap-3 sm:mt-4 sm:grid-cols-4 sm:gap-4">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          마감일
          <input
            type="date"
            name="due_at"
            value="<%= taskView.dueAt %>"
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-12" />
        </label>
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          시작일
          <input
            type="date"
            name="started_at"
            value="<%= taskView.startedAt %>"
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-12" />
        </label>
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          완료일
          <input
            type="date"
            name="completed_at"
            value="<%= taskView.completedAt %>"
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-12" />
        </label>
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          취소일
          <input
            type="date"
            name="canceled_at"
            value="<%= taskView.canceledAt %>"
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-12" />
        </label>
      </div>
    </section>

    <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
      <button
        type="button"
        class="flex w-full items-center justify-between rounded-lg border-0 bg-transparent p-0 text-left"
        :aria-expanded="advancedOpen"
        @click="advancedOpen = !advancedOpen">
        <span class="text-base font-bold text-[#191f28]">고급</span>
        <span
          x-cloak
          x-show="!advancedOpen"
          class="i-lucide-chevron-down h-4 w-4 text-[#8b95a1]"
          aria-hidden="true"></span>
        <span
          x-cloak
          x-show="advancedOpen"
          class="i-lucide-chevron-up h-4 w-4 text-[#8b95a1]"
          aria-hidden="true"></span>
      </button>

      <div
        x-cloak
        x-show="advancedOpen"
        x-transition
        class="mt-3 grid gap-3 sm:mt-4 sm:grid-cols-2 sm:gap-4">
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          태그
          <input
            type="text"
            name="tags"
            value="<%= taskView.tags %>"
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-12"
            placeholder="쉼표로 구분" />
        </label>
        <label class="grid gap-2 text-sm font-semibold text-[#4e5968]">
          정렬
          <input
            type="number"
            name="sort_order"
            min="0"
            value="<%= taskView.sortOrder %>"
            class="h-11 rounded-lg border-0 bg-[#f7f8fa] px-3 text-sm font-semibold text-[#191f28] outline-none focus:bg-white focus:shadow-[0_0_0_3px_rgba(49,130,246,0.18),0_0_0_1px_#3182f6] sm:h-12" />
        </label>
      </div>
    </section>

    <div class="bg-[#f7f8fa]/92 sticky bottom-0 -mx-3 px-3 py-2 backdrop-blur sm:static sm:mx-0 sm:bg-transparent sm:px-0 sm:py-0 sm:backdrop-blur-0">
      <div class="flex gap-2">
        <a
          href="<%= projectView.tasksHref %>"
          class="inline-flex h-11 flex-1 items-center justify-center rounded-lg bg-[#f2f4f6] px-4 text-sm font-bold text-[#4e5968] no-underline hover:bg-[#e5e8eb] sm:h-12 sm:flex-none"
          >취소</a
        >
        <button
          type="submit"
          class="inline-flex h-11 flex-[2] items-center justify-center rounded-lg border-0 bg-[#3182f6] px-4 text-sm font-bold text-white hover:bg-[#1b64da] sm:h-12 sm:flex-none">
          저장
        </button>
      </div>
    </div>
  </form>

  <section class="rounded-lg bg-white p-3 shadow-[0_10px_28px_rgba(25,31,40,0.06),0_0_0_1px_rgba(227,231,237,0.78)] sm:p-5">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-bold text-[#191f28]">삭제</h2>
        <p class="mt-1 text-sm font-medium text-[#8b95a1]">업무 데이터를 완전히 삭제합니다.</p>
      </div>
      <form
        method="post"
        action="/xapi/tasks/delete"
        onsubmit="return confirm('이 업무를 완전히 삭제할까요?')">
        <input
          type="hidden"
          name="task_id"
          value="<%= taskView.id %>" />
        <input
          type="hidden"
          name="project_id"
          value="<%= projectView.id %>" />
        <button
          type="submit"
          class="inline-flex h-11 w-full items-center justify-center rounded-lg border-0 bg-[#fff0f0] px-4 text-sm font-bold text-[#e03131] hover:bg-[#ffe3e3] sm:w-auto">
          삭제
        </button>
      </form>
    </div>
  </section>
</div>
