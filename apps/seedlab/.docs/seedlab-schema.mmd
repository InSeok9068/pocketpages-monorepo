  users {
    text id PK "system primaryKey"
    email email "로그인 이메일"
    text name "표시 이름"
    file avatar "프로필 이미지"
    autodate created "생성 시각"
    autodate updated "수정 시각"
  }

  broker_connections {
    text id PK "primaryKey"
    relation owner FK "users"
    select provider "toss"
    select authMode "env user_key"
    text displayName "연결 이름"
    text clientId "사용자 API client_id"
    text encryptedSecret "암호화된 client_secret"
    text secretPreview "마스킹된 secret"
    text accountSeq "조회된 계좌 식별자"
    text accountNoMasked "마스킹된 계좌번호"
    select accountType "BROKERAGE 등"
    text apiKeyEnvName "예: TOSS_APIKEY"
    text secretEnvName "예: TOSS_SECRET"
    select status "pending active paused error"
    date lastCheckedAt "마지막 확인 시각"
    json lastError "최근 연결 오류"
    autodate created "생성 시각"
    autodate updated "수정 시각"
  }

  sync_runs {
