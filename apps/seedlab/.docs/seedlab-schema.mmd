  %% 권장 접근 규칙
  %% - owner가 있는 컬렉션: list/view/update/delete는 owner = @request.auth.id 기준입니다.
  %% - assets, asset_bars, fx_rates: 일반 사용자는 읽기, 서버/관리자만 쓰기를 권장합니다.
  %% - broker_connections: 사용자 secret은 암호화 저장, API 응답에는 마스킹 값만 노출합니다.
  %% - order_records: 실제 주문 추적용이므로 deleteRule은 제한하는 편이 안전합니다.

  %% 권장 인덱스
  %% - broker_connections(owner, provider, accountSeq)
  %% - portfolio_accounts(owner, accountType, isActive)
  %% - assets(symbol) UNIQUE
  %% - asset_bars(asset, interval, barAt, adjusted) UNIQUE
  %% - fx_rates(baseCurrency, quoteCurrency, rateAt) UNIQUE
  %% - account_holdings(owner, account, asset) UNIQUE
  %% - account_snapshots(owner, account, snapshotDate)
  %% - strategy_targets(strategy, asset) UNIQUE
  %% - strategy_asset_targets(strategy, assetClass) UNIQUE
  %% - rebalance_runs(owner, status, runAt)
  %% - rebalance_items(run, assetClass)
  %% - simulations(owner, persona, strategy, startDate, endDate)
  %% - action_batches(owner, strategy, actionDate, status)
  %% - order_records(owner, clientOrderId) UNIQUE WHERE clientOrderId != ''
