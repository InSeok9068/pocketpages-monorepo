<script server>
  meta('title', 'SeedLab 회원가입')
  meta('description', 'SeedLab 회원가입')

  if (request.auth) {
    dbg('seedlab/sign-up:redirect', {
      status: 303,
      redirectTo: '/',
    })
    redirect('/', {
      status: 303,
    })
    return
  }
</script>

<section class="flex min-h-[calc(100vh-2rem)] flex-col pt-5 pb-4">
  <div>
    <div class="pt-2">
      <p class="text-xs font-bold text-[#3182f6]">SeedLab</p>
      <h1 class="mt-1 text-[24px] leading-tight font-bold text-[#191f28]">회원가입</h1>
    </div>

    <div class="mt-5">
      <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

      <form
        method="post"
        action="/xapi/auth/sign-up"
        class="space-y-4">
        <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
          <label class="grid grid-cols-[90px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
            <span class="text-xs font-bold text-[#6b7684]">이메일</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              inputmode="email"
              placeholder="me@example.com"
              class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none placeholder:text-[#b0b8c1]" />
          </label>
          <label class="grid grid-cols-[90px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
            <span class="text-xs font-bold text-[#6b7684]">비밀번호</span>
            <input
              type="password"
              name="password"
              required
              minlength="8"
              autocomplete="new-password"
              placeholder="8자 이상"
              class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none placeholder:text-[#b0b8c1]" />
          </label>
          <label class="grid grid-cols-[90px_1fr] items-center gap-3 px-4 py-3">
            <span class="text-xs font-bold text-[#6b7684]">확인</span>
            <input
              type="password"
              name="passwordConfirm"
              required
              minlength="8"
              autocomplete="new-password"
              placeholder="한 번 더 입력"
              class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none placeholder:text-[#b0b8c1]" />
          </label>
        </div>

        <button
          type="submit"
          class="box-border flex h-12 w-full items-center justify-center gap-2 rounded-lg border-0 bg-[#3182f6] px-4 text-base font-bold text-white shadow-[0_8px_18px_rgba(49,130,246,0.18)] active:bg-[#1b64da]">
          가입하기
          <span
            class="i-lucide-arrow-right h-5 w-5"
            aria-hidden="true"></span>
        </button>
      </form>
    </div>
  </div>

  <div class="mt-5 text-center">
    <p class="text-sm text-[#8b95a1]">이미 계정이 있다면</p>
    <a
      href="/sign-in"
      class="mt-1 inline-flex h-10 items-center justify-center gap-2 rounded-lg px-4 text-sm font-bold text-[#3182f6] no-underline active:bg-[#e8f3ff]">
      로그인
      <span
        class="i-lucide-log-in h-4 w-4"
        aria-hidden="true"></span>
    </a>
  </div>
</section>
