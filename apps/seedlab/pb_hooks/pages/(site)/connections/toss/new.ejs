<script server>
  meta('title', 'SeedLab 토스증권 연결')
  meta('description', 'SeedLab 토스증권 연결')

  if (!request.auth) {
    dbg('seedlab/connections/toss/new:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }
</script>

<section class="flex min-h-[calc(100vh-2rem)] flex-col pt-5 pb-24">
  <header class="flex items-center justify-between">
    <div>
      <p class="text-xs font-bold text-[#3182f6]">연결</p>
      <h1 class="mt-1 text-[24px] leading-tight font-bold text-[#191f28]">토스증권</h1>
    </div>
    <a
      href="/accounts"
      class="inline-flex h-10 items-center justify-center rounded-lg px-3 text-sm font-bold text-[#6b7684] no-underline active:bg-[#f2f4f6]">
      닫기
    </a>
  </header>

  <div class="mt-5">
    <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

    <form
      method="post"
      action="/xapi/connections/toss/create"
      class="space-y-4">
      <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <label class="grid grid-cols-[88px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">이름</span>
          <input
            type="text"
            name="displayName"
            placeholder="토스증권"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none placeholder:text-[#b0b8c1]" />
        </label>
        <label class="grid grid-cols-[88px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">API Key</span>
          <input
            type="text"
            name="clientId"
            required
            autocomplete="off"
            spellcheck="false"
            placeholder="Toss Open API Key"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-sm font-bold text-[#191f28] outline-none placeholder:text-[#b0b8c1]" />
        </label>
        <label class="grid grid-cols-[88px_1fr] items-center gap-3 px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">Secret</span>
          <input
            type="password"
            name="clientSecret"
            required
            autocomplete="off"
            spellcheck="false"
            placeholder="Toss Open API Secret"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-sm font-bold text-[#191f28] outline-none placeholder:text-[#b0b8c1]" />
        </label>
      </div>

      <button
        type="submit"
        class="box-border flex h-12 w-full items-center justify-center gap-2 rounded-lg border-0 bg-[#191f28] px-4 text-base font-bold text-white shadow-[0_8px_18px_rgba(25,31,40,0.16)] active:bg-[#333d4b]">
        연결
        <span
          class="i-lucide-link h-5 w-5"
          aria-hidden="true"></span>
      </button>
    </form>
  </div>
</section>
