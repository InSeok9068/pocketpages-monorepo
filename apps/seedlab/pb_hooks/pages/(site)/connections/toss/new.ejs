<script server>
  meta('title', 'SeedLab 토스증권 연결')
  meta('description', 'SeedLab 토스증권 연결')

  if (!request.auth) {
    dbg('seedlab/connections/toss/new:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }
</script>

<section class="flex min-h-[calc(100vh-2rem)] flex-col pb-4 pt-5">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[#3182f6] text-white shadow-[0_10px_24px_rgba(49,130,246,0.22)]">
        <span
          class="i-lucide-link h-5 w-5"
          aria-hidden="true"></span>
      </div>
      <span class="text-lg font-bold text-[#191f28]">SeedLab</span>
    </div>
    <a
      href="/"
      class="inline-flex h-10 items-center justify-center rounded-lg px-3 text-sm font-bold text-[#6b7684] no-underline active:bg-[#f2f4f6]">
      닫기
    </a>
  </div>

  <div class="mt-8">
    <p class="text-sm font-bold text-[#3182f6]">토스증권 연결</p>
    <h1 class="mt-2 text-[30px] font-bold leading-[1.18] tracking-0 text-[#191f28]">
      키를 확인하고<br />
      계좌를 연결합니다
    </h1>
    <p class="mt-3 max-w-[320px] text-[15px] leading-6 text-[#6b7684]">
      Secret은 암호화하고 계좌번호는 마스킹합니다.
    </p>
  </div>

  <div class="mt-7">
    <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

    <form
      method="post"
      action="/xapi/connections/toss/create"
      class="space-y-4">
      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">연결 이름</span>
        <span class="mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-3 focus-within:ring-[#3182f6]/10">
          <span
            class="i-lucide-wallet-cards h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
          <input
            type="text"
            name="displayName"
            placeholder="토스증권"
            class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-medium text-[#191f28] outline-none placeholder:text-[#adb5bd]" />
        </span>
      </label>

      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">Toss API Key</span>
        <span class="mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-3 focus-within:ring-[#3182f6]/10">
          <span
            class="i-lucide-key-round h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
          <input
            type="text"
            name="clientId"
            required
            autocomplete="off"
            spellcheck="false"
            placeholder="Toss Open API Key"
            class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-medium text-[#191f28] outline-none placeholder:text-[#adb5bd]" />
        </span>
      </label>

      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">Toss Secret</span>
        <span class="mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-3 focus-within:ring-[#3182f6]/10">
          <span
            class="i-lucide-shield-keyhole h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
          <input
            type="password"
            name="clientSecret"
            required
            autocomplete="off"
            spellcheck="false"
            placeholder="Toss Open API Secret"
            class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-medium text-[#191f28] outline-none placeholder:text-[#adb5bd]" />
        </span>
      </label>

      <button
        type="submit"
        class="box-border mt-2 flex h-14 w-full items-center justify-center gap-2 rounded-lg border-0 bg-[#3182f6] px-4 text-base font-bold text-white shadow-[0_10px_24px_rgba(49,130,246,0.22)] active:bg-[#1b64da]">
        계좌 확인하고 연결
        <span
          class="i-lucide-arrow-right h-5 w-5"
          aria-hidden="true"></span>
      </button>
    </form>

    <div class="mt-5 flex items-start gap-3 rounded-lg bg-white px-4 py-3 shadow-[0_1px_2px_rgba(25,31,40,0.04)]">
      <span
        class="i-lucide-shield-check mt-0.5 h-5 w-5 shrink-0 text-[#3182f6]"
        aria-hidden="true"></span>
      <p class="min-w-0 flex-1 text-sm leading-5 text-[#6b7684]">연결 시 계좌 목록 조회를 먼저 실행하고, 성공한 계좌만 저장합니다.</p>
    </div>
  </div>
</section>
