<%
  const isProduction = String(env('APP_ENV') || 'development').trim() === 'production'
  const isSignedIn = !!request.auth
  const currentPath = String(request.url.pathname || '/')
%>
<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1" />
    <title><%= meta('title') %></title>
    <meta
      name="description"
      content="<%= meta('description') %>" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="<%= asset('/assets/favicon.svg') %>" />
    <link
      rel="manifest"
      href="<%= asset('/assets/manifest.webmanifest') %>" />
    <meta
      name="theme-color"
      content="#f7f8fa" />
    <link
      rel="stylesheet"
      href="<%= asset('/assets/style.css') %>" />
    <%- include('unocss-head.ejs', { isProduction }) %>
    <%- datastar.scripts() %>
    <%- slots.head %>
  </head>

  <body
    un-cloak
    class="min-h-screen overflow-x-hidden bg-[#f7f8fa] text-[#191f28] antialiased">
    <% if (isSignedIn) { %>
    <main class="mx-auto box-border min-h-screen w-full max-w-[560px] px-4 pt-4 pb-24 sm:px-5 sm:pt-6 sm:pb-28">
      <%- slots.body || slot %>
    </main>
    <%- include('app-bottom-nav.ejs', { currentPath }) %>
    <% } else { %>
    <main class="mx-auto box-border min-h-screen w-full max-w-[560px] px-4 py-4 sm:px-5 sm:py-6">
      <%- slots.body || slot %>
    </main>
    <% } %>
  </body>
</html>
