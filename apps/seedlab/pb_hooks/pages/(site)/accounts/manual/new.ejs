<script server>
  meta('title', 'SeedLab 수동 계좌 추가')
  meta('description', 'SeedLab 수동 계좌 추가')

  if (!request.auth) {
    dbg('seedlab/accounts/manual/new:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }
</script>

<section class="flex min-h-[calc(100vh-2rem)] flex-col pb-4 pt-5">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[#191f28] text-white shadow-[0_10px_24px_rgba(25,31,40,0.14)]">
        <span
          class="i-lucide-pencil-line h-5 w-5"
          aria-hidden="true"></span>
      </div>
      <span class="text-lg font-bold text-[#191f28]">SeedLab</span>
    </div>
    <a
      href="/"
      class="inline-flex h-10 items-center justify-center rounded-lg px-3 text-sm font-bold text-[#6b7684] no-underline active:bg-[#f2f4f6]">
      닫기
    </a>
  </div>

  <div class="mt-8">
    <p class="text-sm font-bold text-[#3182f6]">직접 입력</p>
    <h1 class="mt-2 text-[30px] font-bold leading-[1.18] tracking-0 text-[#191f28]">
      토스 밖 계좌도<br />
      같이 관리합니다
    </h1>
    <p class="mt-3 max-w-[320px] text-[15px] leading-6 text-[#6b7684]">
      연금저축, IRP, ISA처럼 자동 조회가 어려운 계좌를 먼저 등록합니다.
    </p>
  </div>

  <div class="mt-7">
    <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

    <form
      method="post"
      action="/xapi/accounts/manual/create"
      class="space-y-4">
      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">계좌 이름</span>
        <span class="mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-3 focus-within:ring-[#3182f6]/10">
          <span
            class="i-lucide-wallet-cards h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
          <input
            type="text"
            name="name"
            required
            placeholder="예: 미래에셋 연금저축"
            class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-medium text-[#191f28] outline-none placeholder:text-[#adb5bd]" />
        </span>
      </label>

      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">계좌 종류</span>
        <span class="mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-3 focus-within:ring-[#3182f6]/10">
          <span
            class="i-lucide-list-filter h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
          <select
            name="accountType"
            required
            class="h-full min-w-0 flex-1 appearance-none border-0 bg-transparent p-0 text-base font-bold text-[#191f28] outline-none">
            <option value="pension_saving">연금저축</option>
            <option value="irp">IRP</option>
            <option value="isa">ISA</option>
            <option value="brokerage">일반 증권</option>
            <option value="cash">현금성 자산</option>
          </select>
          <span
            class="i-lucide-chevron-down h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
        </span>
      </label>

      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">금융사</span>
        <span class="mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-3 focus-within:ring-[#3182f6]/10">
          <span
            class="i-lucide-building-2 h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
          <input
            type="text"
            name="providerName"
            placeholder="예: 미래에셋증권"
            class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-medium text-[#191f28] outline-none placeholder:text-[#adb5bd]" />
        </span>
      </label>

      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">기준 통화</span>
        <span class="mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-3 focus-within:ring-[#3182f6]/10">
          <span
            class="i-lucide-circle-dollar-sign h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
          <select
            name="baseCurrency"
            required
            class="h-full min-w-0 flex-1 appearance-none border-0 bg-transparent p-0 text-base font-bold text-[#191f28] outline-none">
            <option value="KRW">KRW</option>
            <option value="USD">USD</option>
          </select>
          <span
            class="i-lucide-chevron-down h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
        </span>
      </label>

      <label class="flex items-start gap-3 rounded-lg bg-white px-4 py-3 shadow-[0_1px_2px_rgba(25,31,40,0.04)]">
        <input
          type="checkbox"
          name="isTaxAdvantaged"
          value="on"
          class="mt-1 h-5 w-5 shrink-0 accent-[#3182f6]" />
        <span class="min-w-0 flex-1">
          <span class="block text-sm font-bold text-[#191f28]">세제 혜택 계좌</span>
          <span class="mt-1 block text-sm leading-5 text-[#6b7684]">연금저축, IRP, ISA는 저장 시 자동으로 세제 혜택 계좌로 처리합니다.</span>
        </span>
      </label>

      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">메모</span>
        <textarea
          name="memo"
          rows="3"
          placeholder="예: 월 50만원 납입, 장기 보유 계좌"
          class="mt-2 box-border w-full resize-none rounded-lg border border-[#e5e8eb] bg-white px-4 py-3 text-base font-medium leading-6 text-[#191f28] shadow-[0_1px_2px_rgba(25,31,40,0.04)] outline-none placeholder:text-[#adb5bd] focus:border-[#3182f6] focus:ring-3 focus:ring-[#3182f6]/10"></textarea>
      </label>

      <button
        type="submit"
        class="box-border mt-2 flex h-14 w-full items-center justify-center gap-2 rounded-lg border-0 bg-[#3182f6] px-4 text-base font-bold text-white shadow-[0_10px_24px_rgba(49,130,246,0.22)] active:bg-[#1b64da]">
        수동 계좌 추가
        <span
          class="i-lucide-arrow-right h-5 w-5"
          aria-hidden="true"></span>
      </button>
    </form>
  </div>
</section>
