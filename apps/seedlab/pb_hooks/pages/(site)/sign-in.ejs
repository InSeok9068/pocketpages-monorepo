<script server>
  meta('title', 'SeedLab 로그인')
  meta('description', 'SeedLab 로그인')

  if (request.auth) {
    dbg('seedlab/sign-in:redirect', {
      status: 303,
      redirectTo: '/',
    })
    redirect('/', {
      status: 303,
    })
    return
  }
</script>

<section class="flex min-h-[calc(100vh-2rem)] flex-col pb-4 pt-5">
  <div>
    <div>
      <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-[#3182f6] text-white shadow-[0_10px_24px_rgba(49,130,246,0.24)]">
        <span
          class="i-lucide-sprout h-7 w-7"
          aria-hidden="true"></span>
      </div>
      <p class="mt-5 text-sm font-bold text-[#3182f6]">SeedLab</p>
      <h1 class="tracking-0 mt-2 text-[30px] font-bold leading-[1.18] text-[#191f28]">
        다시 투자 흐름을<br />
        확인해볼까요?
      </h1>
      <p class="mt-3 max-w-[320px] text-[15px] leading-6 text-[#6b7684]">실계좌와 가상 전략을 같은 기준으로 봅니다.</p>
    </div>

    <div class="mt-7">
      <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

      <form
        method="post"
        action="/xapi/auth/sign-in"
        class="space-y-4">
        <label class="block">
          <span class="text-sm font-bold text-[#4e5968]">이메일</span>
          <span
            class="focus-within:ring-3 mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-[#3182f6]/10">
            <span
              class="i-lucide-mail h-5 w-5 shrink-0 text-[#8b95a1]"
              aria-hidden="true"></span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              inputmode="email"
              placeholder="me@example.com"
              class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-medium text-[#191f28] outline-none placeholder:text-[#adb5bd]" />
          </span>
        </label>

        <label class="block">
          <span class="text-sm font-bold text-[#4e5968]">비밀번호</span>
          <span
            class="focus-within:ring-3 mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-[#3182f6]/10">
            <span
              class="i-lucide-lock-keyhole h-5 w-5 shrink-0 text-[#8b95a1]"
              aria-hidden="true"></span>
            <input
              type="password"
              name="password"
              required
              autocomplete="current-password"
              placeholder="비밀번호"
              class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-medium text-[#191f28] outline-none placeholder:text-[#adb5bd]" />
          </span>
        </label>

        <button
          type="submit"
          class="mt-2 box-border flex h-14 w-full items-center justify-center gap-2 rounded-lg border-0 bg-[#3182f6] px-4 text-base font-bold text-white shadow-[0_10px_24px_rgba(49,130,246,0.22)] active:bg-[#1b64da]">
          로그인
          <span
            class="i-lucide-arrow-right h-5 w-5"
            aria-hidden="true"></span>
        </button>
      </form>
    </div>
  </div>

  <div class="mt-5 text-center">
    <p class="text-sm text-[#8b95a1]">처음 오셨다면</p>
    <a
      href="/sign-up"
      class="mt-1 inline-flex h-10 items-center justify-center gap-2 rounded-lg px-4 text-sm font-bold text-[#3182f6] no-underline active:bg-[#e8f3ff]">
      회원가입
      <span
        class="i-lucide-user-plus h-4 w-4"
        aria-hidden="true"></span>
    </a>
  </div>
</section>
