<script server>
  meta('title', 'SeedLab 실험')
  meta('description', 'SeedLab 전략 실험')

  if (!request.auth) {
    dbg('seedlab/simulations:index:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const userId = String(request.auth.get('id') || '')
  let simulationCards = []
  let completeCount = 0
  let runningCount = 0

  function formatAmount(value) {
    const number = Number(value || 0)
    if (!isFinite(number)) return '0'
    return String(Math.round(number)).replace(/\B(?=(\d{3})+(?!\d))/g, ',')
  }

  function readSummaryValue(summary, fieldName) {
    if (!summary || typeof summary !== 'object') return ''
    return summary[fieldName]
  }

  function buildSimulationCard(record) {
    const summary = record.get('summary') || {}
    const status = String(record.get('status') || 'ready')
    const returnPct = readSummaryValue(summary, 'returnPct')
    const totalValue = readSummaryValue(summary, 'totalValue')

    return {
      name: String(record.get('name') || '실험'),
      periodText: String(record.get('startDate') || '') + ' - ' + String(record.get('endDate') || ''),
      status,
      returnPctText: returnPct === '' ? '-' : String(returnPct) + '%',
      totalValueText: totalValue ? formatAmount(totalValue) : '-',
    }
  }

  if (userId) {
    try {
      dbg('seedlab/simulations:index:db-access', { collection: 'simulations' })
      const simulationRecords = $app.findRecordsByFilter('simulations', 'owner = {:owner}', '-created', 50, 0, { owner: userId })
      simulationCards = simulationRecords.map(buildSimulationCard)
    } catch (exception) {
      warn('seedlab/simulations:index:db-access-failed', { collection: 'simulations', error: String(exception.message || exception) })
      simulationCards = []
    }

    for (let index = 0; index < simulationCards.length; index += 1) {
      if (simulationCards[index].status === 'complete') completeCount += 1
      if (simulationCards[index].status === 'running') runningCount += 1
    }
  }
</script>

<div class="space-y-4 pb-2 pt-1">
  <header class="flex items-center justify-between">
    <div>
      <p class="text-xs font-bold text-[#3182f6]">실험</p>
      <h1 class="mt-1 text-[24px] font-bold leading-tight text-[#191f28]">실험 목록</h1>
    </div>
    <a
      href="/simulations/new"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#3182f6] text-white no-underline shadow-[0_8px_18px_rgba(49,130,246,0.18)] active:bg-[#1b64da]"
      aria-label="새 실험 만들기">
      <span
        class="i-lucide-plus h-5 w-5"
        aria-hidden="true"></span>
    </a>
  </header>

  <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

  <section class="rounded-lg bg-white p-4 shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
    <div class="grid grid-cols-3 gap-2 rounded-lg bg-[#f7f8fa] px-3 py-2">
      <div class="min-w-0">
        <p class="truncate text-[10px] font-bold text-[#8b95a1]">전체</p>
        <p class="mt-0.5 truncate text-sm font-bold leading-none text-[#191f28]"><%= simulationCards.length %></p>
      </div>
      <div class="min-w-0">
        <p class="truncate text-[10px] font-bold text-[#8b95a1]">완료</p>
        <p class="mt-0.5 truncate text-sm font-bold leading-none text-[#191f28]"><%= completeCount %></p>
      </div>
      <div class="min-w-0">
        <p class="truncate text-[10px] font-bold text-[#8b95a1]">진행</p>
        <p class="mt-0.5 truncate text-sm font-bold leading-none text-[#191f28]"><%= runningCount %></p>
      </div>
    </div>
  </section>

  <section class="space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="text-base font-bold text-[#191f28]">실험</h2>
      <a
        href="/simulations/new"
        class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-white px-3 text-sm font-bold text-[#3182f6] no-underline shadow-[0_1px_2px_rgba(25,31,40,0.06)] active:bg-[#e8f3ff]">
        새 실험
        <span
          class="i-lucide-plus h-4 w-4"
          aria-hidden="true"></span>
      </a>
    </div>

    <% if (simulationCards.length === 0) { %>
    <div class="rounded-lg bg-white p-4 shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
      <p class="text-sm font-bold text-[#191f28]">아직 만든 실험이 없습니다</p>
      <p class="mt-1 text-sm leading-5 text-[#6b7684]">가상 인물과 적립식 조건을 넣어 주문 후보를 먼저 만들어봅니다.</p>
      <a
        href="/simulations/new"
        class="mt-4 box-border flex h-11 items-center justify-center gap-2 rounded-lg bg-[#191f28] px-3 text-sm font-bold text-white no-underline shadow-[0_8px_18px_rgba(25,31,40,0.16)] active:bg-[#333d4b]">
        실험 만들기
        <span
          class="i-lucide-arrow-right h-4 w-4"
          aria-hidden="true"></span>
      </a>
    </div>
    <% } else { %>
    <div class="space-y-3">
      <% for (let index = 0; index < simulationCards.length; index += 1) { %>
      <article class="rounded-lg bg-white p-4 shadow-[0_8px_24px_rgba(25,31,40,0.06)]">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="truncate text-sm font-bold text-[#191f28]"><%= simulationCards[index].name %></p>
            <p class="mt-1 text-xs text-[#8b95a1]"><%= simulationCards[index].periodText %></p>
          </div>
          <span class="shrink-0 rounded-md bg-[#ecfdf3] px-2 py-1 text-xs font-bold text-[#008a45]"><%= simulationCards[index].status %></span>
        </div>
        <div class="mt-4 grid grid-cols-2 gap-3">
          <div class="rounded-lg bg-[#f7f8fa] p-3">
            <p class="text-xs font-medium text-[#8b95a1]">수익률</p>
            <p class="mt-1 text-lg font-bold text-[#191f28]"><%= simulationCards[index].returnPctText %></p>
          </div>
          <div class="rounded-lg bg-[#f7f8fa] p-3">
            <p class="text-xs font-medium text-[#8b95a1]">평가액</p>
            <p class="mt-1 text-lg font-bold text-[#191f28]"><%= simulationCards[index].totalValueText %></p>
          </div>
        </div>
      </article>
      <% } %>
    </div>
    <% } %>
  </section>
</div>
