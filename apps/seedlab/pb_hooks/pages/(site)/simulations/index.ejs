<script server>
  const simulationView = resolve('simulation-view')

  meta('title', 'SeedLab 실험')
  meta('description', 'SeedLab 투자 실험')

  if (!request.auth) {
    dbg('seedlab/simulations:index:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const userId = String(request.auth.get('id') || '')
  let simulationCards = []

  if (userId) {
    try {
      dbg('seedlab/simulations:index:db-access', { collection: 'simulations' })
      const simulationRecords = $app.findRecordsByFilter('simulations', 'owner = {:owner}', '-created', 50, 0, { owner: userId })
      simulationCards = simulationRecords.map(simulationView.buildSimulationModel)
    } catch (exception) {
      warn('seedlab/simulations:index:db-access-failed', { collection: 'simulations', error: String(exception.message || exception) })
      simulationCards = []
    }
  }
</script>

<div class="space-y-4 pb-2 pt-1">
  <header class="flex items-center justify-between">
    <div>
      <p class="text-xs font-bold text-[#3182f6]">실험</p>
      <h1 class="mt-1 text-[24px] font-bold leading-tight text-[#191f28]">투자 실험</h1>
    </div>
    <a
      href="/simulations/new"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[#3182f6] text-white no-underline shadow-[0_8px_18px_rgba(49,130,246,0.18)] active:bg-[#1b64da]"
      aria-label="새 실험 만들기">
      <span
        class="i-lucide-plus h-5 w-5"
        aria-hidden="true"></span>
    </a>
  </header>

  <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

  <section class="space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="text-base font-bold text-[#191f28]">실험 카드</h2>
      <a
        href="/simulations/new"
        class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-white px-3 text-sm font-bold text-[#3182f6] no-underline shadow-[0_1px_2px_rgba(25,31,40,0.06)] active:bg-[#e8f3ff]">
        새 실험
        <span
          class="i-lucide-plus h-4 w-4"
          aria-hidden="true"></span>
      </a>
    </div>

    <% if (simulationCards.length === 0) { %>
    <div class="rounded-lg bg-white p-4 shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
      <p class="text-sm font-bold text-[#191f28]">아직 실험이 없습니다</p>
      <p class="mt-1 text-sm leading-5 text-[#6b7684]">목표 비중과 월 납입을 넣으면 결과 카드가 만들어집니다.</p>
      <a
        href="/simulations/new"
        class="mt-4 box-border flex h-11 items-center justify-center gap-2 rounded-lg bg-[#191f28] px-3 text-sm font-bold text-white no-underline shadow-[0_8px_18px_rgba(25,31,40,0.16)] active:bg-[#333d4b]">
        실험 만들기
        <span
          class="i-lucide-arrow-right h-4 w-4"
          aria-hidden="true"></span>
      </a>
    </div>
    <% } else { %>
    <div class="space-y-3">
      <% for (let index = 0; index < simulationCards.length; index += 1) { %>
      <article class="rounded-lg bg-white p-4 shadow-[0_8px_24px_rgba(25,31,40,0.06)]">
        <a
          href="/simulations/detail/<%= simulationCards[index].id %>"
          class="block text-inherit no-underline">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="truncate text-base font-bold text-[#191f28]"><%= simulationCards[index].name %></p>
              <p class="mt-1 text-xs font-bold leading-5 text-[#6b7684]"><%= simulationCards[index].targetText %></p>
            </div>
            <span class="shrink-0 rounded-md bg-[#e8f3ff] px-2 py-1 text-xs font-bold text-[#1b64da]"><%= simulationCards[index].badgeText %></span>
          </div>

          <div class="mt-4">
            <p class="text-xs font-bold text-[#8b95a1]">예상 평가액</p>
            <div class="mt-1 flex items-end justify-between gap-3">
              <p class="min-w-0 truncate text-[24px] font-bold leading-tight text-[#191f28]"><%= simulationCards[index].finalTotalText %></p>
              <p class="<%= String(simulationCards[index].profitText).indexOf('-') === 0 ? 'text-[#1b64da]' : 'text-[#f04452]' %> shrink-0 text-sm font-bold">
                <%= simulationCards[index].profitText %>
              </p>
            </div>
            <div class="mt-3 grid grid-cols-3 gap-2 rounded-lg bg-[#f7f8fa] px-3 py-2">
              <div class="min-w-0">
                <p class="truncate text-[10px] font-bold text-[#8b95a1]">현재</p>
                <p class="mt-0.5 truncate text-xs font-bold text-[#191f28]"><%= simulationCards[index].currentTotalText %></p>
              </div>
              <div class="min-w-0">
                <p class="truncate text-[10px] font-bold text-[#8b95a1]">수익률</p>
                <p class="mt-0.5 truncate text-xs font-bold text-[#191f28]"><%= simulationCards[index].returnText %></p>
              </div>
              <div class="min-w-0">
                <p class="truncate text-[10px] font-bold text-[#8b95a1]">주문 후보</p>
                <p class="mt-0.5 truncate text-xs font-bold text-[#191f28]"><%= simulationCards[index].actionText %></p>
              </div>
            </div>
          </div>

          <% if (simulationCards[index].bucketRows.length > 0) { %>
          <div class="mt-4 space-y-2">
            <% for (let bucketIndex = 0; bucketIndex < simulationCards[index].bucketRows.length && bucketIndex < 4; bucketIndex += 1) { %>
            <div>
              <div class="mb-1 flex items-center justify-between gap-2">
                <p class="truncate text-xs font-bold text-[#191f28]"><%= simulationCards[index].bucketRows[bucketIndex].label %></p>
                <p class="shrink-0 text-xs font-bold text-[#4e5968]">
                  현재 <%= simulationCards[index].bucketRows[bucketIndex].currentPctText %> → 예상 <%= simulationCards[index].bucketRows[bucketIndex].finalPctText %>
                </p>
              </div>
              <div class="h-2 overflow-hidden rounded-full bg-[#f2f4f6]">
                <div
                  class="h-full rounded-full"
                  style="width: <%= simulationCards[index].bucketRows[bucketIndex].barWidth %>%; background: <%= simulationCards[index].bucketRows[bucketIndex].color %>"></div>
              </div>
            </div>
            <% } %>
          </div>
          <% } %>
        </a>

      </article>
      <% } %>
    </div>
    <% } %>
  </section>
</div>
