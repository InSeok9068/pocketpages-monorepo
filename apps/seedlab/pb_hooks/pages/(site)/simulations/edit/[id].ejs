<script server>
  const allocationBuckets = resolve('allocation-buckets')
  const contributionExperiment = resolve('contribution-experiment')
  const holdingValuation = resolve('holding-valuation')
  const simulationView = resolve('simulation-view')

  meta('title', 'SeedLab 실험 수정')
  meta('description', 'SeedLab 투자 실험 수정')

  if (!request.auth) {
    dbg('seedlab/simulations/edit/[id]:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const userId = String(request.auth.get('id') || '')
  const simulationId = String(params.id || '')
  const assetsById = {}
  let accountOptions = []
  let targetBucketCards = []
  let returnBucketCards = []
  let buyTargetCards = []
  let formModel = null

  function accountTypeLabel(value) {
    const labels = {
      toss: '토스증권',
      brokerage: '일반 증권',
      pension_saving: '연금저축',
      irp: 'IRP',
      isa: 'ISA',
      cash: '현금성 자산',
    }

    return labels[String(value || '')] || '계좌'
  }

  function cleanText(value) {
    return String(value === undefined || value === null ? '' : value).trim()
  }

  function readObject(value) {
    return simulationView.readObject(value)
  }

  function readNumber(value) {
    const text = cleanText(value).replace(/,/g, '').replace(/원/g, '').replace(/%/g, '')
    const number = Number(text)
    return isFinite(number) ? number : 0
  }

  function formatNumber(value, maximumFractionDigits) {
    const number = Number(value || 0)
    if (!isFinite(number)) return '0'

    const fixed = Math.abs(number).toFixed(maximumFractionDigits)
    const parts = fixed.split('.')
    const decimal = String(parts[1] || '').replace(/0+$/, '')

    return String(parts[0]) + (decimal ? '.' + decimal : '')
  }

  function formatAmount(value, currency) {
    return formatNumber(value, String(currency || 'KRW') === 'USD' ? 2 : 0)
  }

  function normalizeAssetClass(value) {
    const key = String(value || '')
    if (key === 'equity' || key === 'fixed_income' || key === 'cash' || key === 'alternative') return key
    return 'equity'
  }

  function readAssetRecord(assetId) {
    const id = String(assetId || '')
    if (!id) return null
    if (Object.prototype.hasOwnProperty.call(assetsById, id)) return assetsById[id]

    try {
      dbg('seedlab/simulations/edit/[id]:db-access', { collection: 'assets', assetId: id })
      assetsById[id] = $app.findFirstRecordByFilter('assets', 'id = {:id}', { id })
    } catch (exception) {
      warn('seedlab/simulations/edit/[id]:db-access-failed', { collection: 'assets', assetId: id, error: String(exception.message || exception) })
      assetsById[id] = null
    }

    return assetsById[id]
  }

  function readSavedAllocationBucket(holding) {
    const raw = readObject(holding.get('raw'))
    const seedlab = readObject(raw.seedlab)
    return allocationBuckets.normalizeBucket(raw.allocationBucket || seedlab.allocationBucket)
  }

  function inferAllocationBucket(holding, asset) {
    const savedBucket = readSavedAllocationBucket(holding)
    if (savedBucket) return savedBucket

    const assetClass = normalizeAssetClass(holding.get('assetClassOverride') && holding.get('assetClassOverride') !== 'none' ? holding.get('assetClassOverride') : asset ? asset.get('assetClass') : '')
    const assetType = String(asset ? asset.get('assetType') : '').toLowerCase()
    const symbol = String(asset ? asset.get('symbol') : '').toUpperCase()
    const name = String(asset ? asset.get('name') : '').toUpperCase()
    const searchText = symbol + ' ' + name

    if (assetClass === 'cash' || assetType === 'cash') return 'cash'
    if (assetClass === 'fixed_income' || assetType === 'bond' || searchText.indexOf('BOND') >= 0 || searchText.indexOf('채권') >= 0) return 'bond'
    if (searchText.indexOf('GOLD') >= 0 || searchText.indexOf('금') >= 0) return 'gold'
    if (searchText.indexOf('REIT') >= 0 || searchText.indexOf('리츠') >= 0 || searchText.indexOf('부동산') >= 0) return 'real_estate'
    if (searchText.indexOf('SCHD') >= 0 || searchText.indexOf('DIVIDEND') >= 0 || searchText.indexOf('배당') >= 0) return 'dividend_stock'
    if (assetClass === 'equity') return 'growth_stock'
    return 'other'
  }

  function readLatestUsdKrwRate() {
    try {
      dbg('seedlab/simulations/edit/[id]:db-access', { collection: 'fx_rates' })
      const records = $app.findRecordsByFilter('fx_rates', 'baseCurrency = {:baseCurrency} && quoteCurrency = {:quoteCurrency}', '-rateAt', 1, 0, {
        baseCurrency: 'USD',
        quoteCurrency: 'KRW',
      })
      return records.length > 0 ? Number(records[0].get('rate') || 0) : 0
    } catch (exception) {
      dbg('seedlab/simulations/edit/[id]:fx-rate-missing', { pair: 'USD_KRW' })
      return 0
    }
  }

  function mergeBucketNumbers(base, source) {
    const buckets = allocationBuckets.listBuckets()
    const next = Object.assign({}, base)

    for (let index = 0; index < buckets.length; index += 1) {
      const key = buckets[index].key
      if (source && Object.prototype.hasOwnProperty.call(source, key)) next[key] = readNumber(source[key])
    }

    return next
  }

  function buildTargetBucketCards(targets) {
    const buckets = allocationBuckets.listBuckets()
    return buckets.map(function (bucket) {
      return {
        key: bucket.key,
        label: bucket.label,
        targetField: bucket.targetField,
        tone: bucket.tone,
        targetPctText: formatNumber(targets[bucket.key], 1),
      }
    })
  }

  function buildReturnBucketCards(annualReturnPcts) {
    const buckets = allocationBuckets.listBuckets()
    return buckets.map(function (bucket) {
      return {
        key: bucket.key,
        label: bucket.label,
        returnField: 'return_' + bucket.key,
        tone: bucket.tone,
        returnPctText: formatNumber(annualReturnPcts[bucket.key], 1),
      }
    })
  }

  function buildHoldingOptionsByBucket(selectedAccountId, preferredHoldingIds, latestUsdKrwRate) {
    const buckets = allocationBuckets.listBuckets()
    const optionsByBucket = {}
    const filter = selectedAccountId ? 'owner = {:owner} && account = {:account}' : 'owner = {:owner}'
    const filterParams = selectedAccountId ? { owner: userId, account: selectedAccountId } : { owner: userId }

    for (let index = 0; index < buckets.length; index += 1) {
      optionsByBucket[buckets[index].key] = []
    }

    try {
      dbg('seedlab/simulations/edit/[id]:db-access', { collection: 'account_holdings' })
      const holdingRecords = $app.findRecordsByFilter('account_holdings', filter, '-marketValue', 200, 0, filterParams)
      for (let index = 0; index < holdingRecords.length; index += 1) {
        const holding = holdingRecords[index]
        const asset = readAssetRecord(holding.get('asset'))
        const raw = readObject(holding.get('raw'))
        const currency = String(holding.get('currency') || (asset ? asset.get('currency') : 'KRW') || 'KRW')
        const bucketKey = inferAllocationBucket(holding, asset)
        const symbol = String(asset ? asset.get('symbol') : '') || 'UNKNOWN'
        const name = String(asset ? asset.get('name') : '') || symbol
        const marketValue = holdingValuation.readKrwAmount({
          currency,
          raw,
          storedAmount: Number(holding.get('marketValue') || 0),
          sourceKey: 'marketValueSource',
          krwKey: 'marketValueKrw',
          latestUsdKrwRate,
        })

        if (!optionsByBucket[bucketKey]) optionsByBucket[bucketKey] = []
        optionsByBucket[bucketKey].push({
          id: String(holding.get('id') || ''),
          label: name,
          selected: cleanText(preferredHoldingIds[bucketKey]) === String(holding.get('id') || ''),
          subText: formatAmount(marketValue, 'KRW') + '원 · 현재가 ' + formatAmount(holding.get('currentPrice'), currency) + (currency === 'USD' ? '달러' : '원'),
        })
      }
    } catch (exception) {
      warn('seedlab/simulations/edit/[id]:db-access-failed', { collection: 'account_holdings', error: String(exception.message || exception) })
    }

    return optionsByBucket
  }

  function buildBuyTargetCards(selectedAccountId, preferredHoldingIds, latestUsdKrwRate) {
    const buckets = allocationBuckets.listBuckets()
    const optionsByBucket = buildHoldingOptionsByBucket(selectedAccountId, preferredHoldingIds, latestUsdKrwRate)
    const cards = []

    for (let index = 0; index < buckets.length; index += 1) {
      const bucket = buckets[index]
      if (bucket.key === 'cash') continue
      cards.push({
        key: bucket.key,
        label: bucket.label,
        tone: bucket.tone,
        fieldName: 'buyHolding_' + bucket.key,
        options: optionsByBucket[bucket.key] || [],
      })
    }

    return cards
  }

  try {
    if (!simulationId) throw new Error('실험이 필요합니다.')

    dbg('seedlab/simulations/edit/[id]:db-access', { collection: 'simulations', simulationId })
    const simulationRecord = $app.findFirstRecordByFilter('simulations', 'id = {:id} && owner = {:owner}', {
      id: simulationId,
      owner: userId,
    })
    const settings = readObject(simulationRecord.get('settings'))
    const summary = readObject(simulationRecord.get('summary'))
    const targets = mergeBucketNumbers(allocationBuckets.defaultTargets(), readObject(settings.targets || summary.targets))
    const annualReturnPcts = mergeBucketNumbers(contributionExperiment.defaultAnnualReturnPcts(), readObject(settings.annualReturnPcts || summary.annualReturnPcts))
    const preferredHoldingIds = readObject(settings.preferredHoldingIds)
    const selectedAccountId = cleanText(settings.accountId)
    const latestUsdKrwRate = readNumber(settings.latestUsdKrwRate || summary.latestUsdKrwRate) || readLatestUsdKrwRate()

    formModel = {
      id: simulationId,
      name: cleanText(simulationRecord.get('name')) || '추가 투자 실험',
      accountId: selectedAccountId,
      contributionAmount: formatNumber(readNumber(summary.contributionAmount) || 500000, 0),
      monthlyContributionAmount: formatNumber(readNumber(settings.monthlyContributionAmount || summary.monthlyContributionAmount || simulationRecord.get('monthlyContribution')), 0),
      projectionMonths: formatNumber(readNumber(settings.projectionMonths || summary.projectionMonths || 12), 0),
      priceMode: cleanText(settings.priceMode || summary.priceMode || 'stored'),
      reserveCashAmount: formatNumber(readNumber(settings.reserveCashAmount || summary.reserveCashAmount), 0),
      minimumOrderAmount: formatNumber(readNumber(settings.minimumOrderAmount || summary.minimumOrderAmount), 0),
      priceChangePct: formatNumber(readNumber(settings.priceChangePct || summary.priceChangePct), 1),
      usdKrwRate: latestUsdKrwRate > 0 ? formatNumber(latestUsdKrwRate, 2) : '',
    }

    dbg('seedlab/simulations/edit/[id]:db-access', { collection: 'portfolio_accounts' })
    const accountRecords = $app.findRecordsByFilter('portfolio_accounts', 'owner = {:owner} && isActive = true', '-updated', 50, 0, { owner: userId })
    accountOptions = accountRecords.map(function (record) {
      return {
        id: String(record.get('id') || ''),
        selected: String(record.get('id') || '') === selectedAccountId,
        label: String(record.get('name') || '계좌') + ' · ' + accountTypeLabel(record.get('accountType')),
      }
    })
    targetBucketCards = buildTargetBucketCards(targets)
    returnBucketCards = buildReturnBucketCards(annualReturnPcts)
    buyTargetCards = buildBuyTargetCards(selectedAccountId, preferredHoldingIds, latestUsdKrwRate)
  } catch (exception) {
    warn('seedlab/simulations/edit/[id]:redirect', {
      status: 303,
      redirectTo: '/simulations',
      message: String(exception.message || exception),
    })
    redirect('/simulations', {
      status: 303,
      message: String(exception.message || exception),
    })
    return
  }
</script>

<section class="flex min-h-[calc(100vh-2rem)] flex-col pt-5 pb-24">
  <header class="flex items-center justify-between">
    <div>
      <p class="text-xs font-bold text-[#3182f6]">실험</p>
      <h1 class="mt-1 text-[24px] leading-tight font-bold text-[#191f28]">투자 실험 수정</h1>
    </div>
    <a
      href="/simulations/detail/<%= formModel.id %>"
      class="inline-flex h-10 items-center justify-center rounded-lg px-3 text-sm font-bold text-[#6b7684] no-underline active:bg-[#f2f4f6]">
      닫기
    </a>
  </header>

  <div class="mt-5">
    <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

    <form
      method="post"
      action="/xapi/simulations/recalculate"
      class="space-y-4">
      <input
        type="hidden"
        name="simulationId"
        value="<%= formModel.id %>" />
      <input
        type="hidden"
        name="editMode"
        value="on" />

      <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <label class="grid grid-cols-[92px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">이름</span>
          <input
            type="text"
            name="name"
            required
            value="<%= formModel.name %>"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
        </label>
        <label class="grid grid-cols-[92px_1fr] items-center gap-3 px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">계좌</span>
          <select
            name="accountId"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none">
            <option
              value=""
              <%= formModel.accountId ? '' : 'selected' %>>
              전체 계좌
            </option>
            <% for (let index = 0; index < accountOptions.length; index += 1) { %>
            <option
              value="<%= accountOptions[index].id %>"
              <%= accountOptions[index].selected ? 'selected' : '' %>>
              <%= accountOptions[index].label %>
            </option>
            <% } %>
          </select>
        </label>
      </div>

      <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <label class="grid grid-cols-[92px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">첫 달</span>
          <input
            type="number"
            name="contributionAmount"
            required
            min="0"
            step="10000"
            value="<%= formModel.contributionAmount %>"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
        </label>
        <label class="grid grid-cols-[92px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">월 납입</span>
          <input
            type="number"
            name="monthlyContributionAmount"
            min="0"
            step="10000"
            value="<%= formModel.monthlyContributionAmount %>"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
        </label>
        <label class="grid grid-cols-[92px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">기간</span>
          <div class="flex min-w-0 items-center justify-end gap-2">
            <input
              type="number"
              name="projectionMonths"
              min="1"
              max="360"
              step="1"
              value="<%= formModel.projectionMonths %>"
              class="h-9 w-24 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
            <span class="text-sm font-bold text-[#8b95a1]">개월</span>
          </div>
        </label>
        <label class="grid grid-cols-[92px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">가격 기준</span>
          <select
            name="priceMode"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none">
            <option
              value="stored"
              <%= formModel.priceMode === 'stored' ? 'selected' : '' %>>
              저장된 현재가
            </option>
            <option
              value="refresh"
              <%= formModel.priceMode === 'refresh' ? 'selected' : '' %>>
              토스 현재가 재조회
            </option>
            <option
              value="scenario"
              <%= formModel.priceMode === 'scenario' ? 'selected' : '' %>>
              가격 시나리오
            </option>
          </select>
        </label>
        <details>
          <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-3 text-sm font-bold text-[#4e5968]">
            세부 조건
            <span
              class="i-lucide-chevron-down h-4 w-4 text-[#8b95a1]"
              aria-hidden="true"></span>
          </summary>
          <label class="grid grid-cols-[92px_1fr] items-center gap-3 border-t border-[#f2f4f6] px-4 py-3">
            <span class="text-xs font-bold text-[#6b7684]">남길 현금</span>
            <input
              type="number"
              name="reserveCashAmount"
              min="0"
              step="10000"
              value="<%= formModel.reserveCashAmount %>"
              class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
          </label>
          <label class="grid grid-cols-[92px_1fr] items-center gap-3 border-t border-[#f2f4f6] px-4 py-3">
            <span class="text-xs font-bold text-[#6b7684]">최소 주문</span>
            <input
              type="number"
              name="minimumOrderAmount"
              min="0"
              step="10000"
              value="<%= formModel.minimumOrderAmount %>"
              class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
          </label>
          <label class="grid grid-cols-[92px_1fr] items-center gap-3 border-t border-[#f2f4f6] px-4 py-3">
            <span class="text-xs font-bold text-[#6b7684]">가격 변화</span>
            <div class="flex min-w-0 items-center justify-end gap-2">
              <input
                type="number"
                name="priceChangePct"
                step="0.1"
                value="<%= formModel.priceChangePct %>"
                class="h-9 w-24 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
              <span class="text-sm font-bold text-[#8b95a1]">%</span>
            </div>
          </label>
          <label class="grid grid-cols-[92px_1fr] items-center gap-3 border-t border-[#f2f4f6] px-4 py-3">
            <span class="text-xs font-bold text-[#6b7684]">USD/KRW</span>
            <input
              type="number"
              name="usdKrwRate"
              min="0"
              step="0.01"
              placeholder="자동"
              value="<%= formModel.usdKrwRate %>"
              class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none placeholder:text-[#b0b8c1]" />
          </label>
        </details>
      </div>

      <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <div class="border-b border-[#f2f4f6] px-4 py-3">
          <p class="text-sm font-bold text-[#191f28]">실험 목표</p>
        </div>
        <% for (let index = 0; index < targetBucketCards.length; index += 1) { %>
        <label class="<%= index + 1 === targetBucketCards.length ? '' : 'border-b border-[#f2f4f6]' %> grid grid-cols-[1fr_92px] items-center gap-3 px-4 py-3">
          <span class="<%= targetBucketCards[index].tone %> min-w-0 truncate rounded-md px-2 py-0.5 text-xs font-bold"><%= targetBucketCards[index].label %></span>
          <div class="flex min-w-0 items-center justify-end gap-1.5">
            <input
              type="number"
              name="<%= targetBucketCards[index].targetField %>"
              min="0"
              max="100"
              step="0.1"
              value="<%= targetBucketCards[index].targetPctText %>"
              class="h-8 w-16 min-w-0 border-0 bg-transparent p-0 text-right text-sm font-bold text-[#191f28] outline-none" />
            <span class="text-xs font-bold text-[#8b95a1]">%</span>
          </div>
        </label>
        <% } %>
      </div>

      <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <div class="border-b border-[#f2f4f6] px-4 py-3">
          <p class="text-sm font-bold text-[#191f28]">연수익률 가정</p>
        </div>
        <% for (let index = 0; index < returnBucketCards.length; index += 1) { %>
        <label class="<%= index + 1 === returnBucketCards.length ? '' : 'border-b border-[#f2f4f6]' %> grid grid-cols-[1fr_92px] items-center gap-3 px-4 py-3">
          <span class="<%= returnBucketCards[index].tone %> min-w-0 truncate rounded-md px-2 py-0.5 text-xs font-bold"><%= returnBucketCards[index].label %></span>
          <div class="flex min-w-0 items-center justify-end gap-1.5">
            <input
              type="number"
              name="<%= returnBucketCards[index].returnField %>"
              min="-100"
              max="100"
              step="0.1"
              value="<%= returnBucketCards[index].returnPctText %>"
              class="h-8 w-16 min-w-0 border-0 bg-transparent p-0 text-right text-sm font-bold text-[#191f28] outline-none" />
            <span class="text-xs font-bold text-[#8b95a1]">%</span>
          </div>
        </label>
        <% } %>
      </div>

      <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <div class="border-b border-[#f2f4f6] px-4 py-3">
          <p class="text-sm font-bold text-[#191f28]">매수 종목</p>
        </div>
        <% for (let index = 0; index < buyTargetCards.length; index += 1) { %>
        <label class="<%= index + 1 === buyTargetCards.length ? '' : 'border-b border-[#f2f4f6]' %> block px-4 py-3">
          <span class="<%= buyTargetCards[index].tone %> inline-flex max-w-full truncate rounded-md px-2 py-0.5 text-xs font-bold"><%= buyTargetCards[index].label %></span>
          <select
            name="<%= buyTargetCards[index].fieldName %>"
            class="mt-2 h-9 w-full min-w-0 border-0 bg-transparent p-0 text-sm font-bold text-[#191f28] outline-none">
            <option value="">자동 선택</option>
            <% for (let optionIndex = 0; optionIndex < buyTargetCards[index].options.length; optionIndex += 1) { %>
            <option
              value="<%= buyTargetCards[index].options[optionIndex].id %>"
              <%= buyTargetCards[index].options[optionIndex].selected ? 'selected' : '' %>>
              <%= buyTargetCards[index].options[optionIndex].label %>
            </option>
            <% } %>
          </select>
          <% if (buyTargetCards[index].options.length === 0) { %>
          <span class="mt-1 block text-xs font-medium text-[#8b95a1]">선택 가능한 종목 없음</span>
          <% } %>
        </label>
        <% } %>
      </div>

      <label class="flex min-h-12 items-center justify-between gap-4 rounded-lg bg-white px-4 py-3 shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
