<script server>
  const allocationBuckets = resolve('allocation-buckets')
  const simulationView = resolve('simulation-view')

  meta('title', 'SeedLab 실험 상세')
  meta('description', 'SeedLab 투자 실험 상세')

  if (!request.auth) {
    dbg('seedlab/simulations/[id]:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const userId = String(request.auth.get('id') || '')
  const simulationId = String(params.id || '')
  const assetsById = {}
  let simulationCard = null
  let holdingRows = []

  function readObject(value) {
    return simulationView.readObject(value)
  }

  function normalizeAssetClass(value) {
    const key = String(value || '')
    if (key === 'equity' || key === 'fixed_income' || key === 'cash' || key === 'alternative') return key
    return 'equity'
  }

  function readAssetRecord(assetId) {
    const id = String(assetId || '')
    if (!id) return null
    if (Object.prototype.hasOwnProperty.call(assetsById, id)) return assetsById[id]

    try {
      dbg('seedlab/simulations/[id]:db-access', { collection: 'assets', assetId: id })
      assetsById[id] = $app.findFirstRecordByFilter('assets', 'id = {:id}', { id })
    } catch (exception) {
      warn('seedlab/simulations/[id]:db-access-failed', { collection: 'assets', assetId: id, error: String(exception.message || exception) })
      assetsById[id] = null
    }

    return assetsById[id]
  }

  function readSavedAllocationBucket(holding) {
    const raw = readObject(holding.get('raw'))
    const seedlab = readObject(raw.seedlab)
    return allocationBuckets.normalizeBucket(raw.allocationBucket || seedlab.allocationBucket)
  }

  function inferAllocationBucket(holding, asset) {
    const savedBucket = readSavedAllocationBucket(holding)
    if (savedBucket) return savedBucket

    const assetClass = normalizeAssetClass(holding.get('assetClassOverride') && holding.get('assetClassOverride') !== 'none' ? holding.get('assetClassOverride') : asset ? asset.get('assetClass') : '')
    const assetType = String(asset ? asset.get('assetType') : '').toLowerCase()
    const symbol = String(asset ? asset.get('symbol') : '').toUpperCase()
    const name = String(asset ? asset.get('name') : '').toUpperCase()
    const searchText = symbol + ' ' + name

    if (assetClass === 'cash' || assetType === 'cash') return 'cash'
    if (assetClass === 'fixed_income' || assetType === 'bond' || searchText.indexOf('BOND') >= 0 || searchText.indexOf('채권') >= 0) return 'bond'
    if (searchText.indexOf('GOLD') >= 0 || searchText.indexOf('금') >= 0) return 'gold'
    if (searchText.indexOf('REIT') >= 0 || searchText.indexOf('리츠') >= 0 || searchText.indexOf('부동산') >= 0) return 'real_estate'
    if (searchText.indexOf('SCHD') >= 0 || searchText.indexOf('DIVIDEND') >= 0 || searchText.indexOf('배당') >= 0) return 'dividend_stock'
    if (assetClass === 'equity') return 'growth_stock'
    return 'other'
  }

  function buildHoldingRows(userId, accountId) {
    const rows = []
    const filter = accountId ? 'owner = {:owner} && account = {:account}' : 'owner = {:owner}'
    const filterParams = accountId ? { owner: userId, account: accountId } : { owner: userId }

    try {
      dbg('seedlab/simulations/[id]:db-access', { collection: 'account_holdings' })
      const records = $app.findRecordsByFilter('account_holdings', filter, '-marketValue', 200, 0, filterParams)
      for (let index = 0; index < records.length; index += 1) {
        const holding = records[index]
        const asset = readAssetRecord(holding.get('asset'))
        const bucket = allocationBuckets.bucketMeta(inferAllocationBucket(holding, asset))
        const symbol = String(asset ? asset.get('symbol') : '') || 'UNKNOWN'
        const name = String(asset ? asset.get('name') : '') || '종목 정보 없음'
        rows.push({
          symbol,
          name,
          displayName: name || symbol,
          bucketLabel: bucket.label,
          tone: bucket.tone,
          valueText: simulationView.formatAmount(holding.get('marketValue')) + '원',
          profitText: simulationView.formatAmount(holding.get('profitLoss')) + '원',
          profitTone: Number(holding.get('profitLoss') || 0) >= 0 ? 'text-[#f04452]' : 'text-[#1b64da]',
          quantityText: simulationView.formatNumber(holding.get('quantity'), 6) + '주',
        })
      }
    } catch (exception) {
      warn('seedlab/simulations/[id]:db-access-failed', { collection: 'account_holdings', error: String(exception.message || exception) })
    }

    return rows
  }

  try {
    dbg('seedlab/simulations/[id]:db-access', { collection: 'simulations', simulationId })
    const simulationRecord = $app.findFirstRecordByFilter('simulations', 'id = {:id} && owner = {:owner}', {
      id: simulationId,
      owner: userId,
    })
    simulationCard = simulationView.buildSimulationModel(simulationRecord)
    const settings = readObject(simulationRecord.get('settings'))
    holdingRows = buildHoldingRows(userId, String(settings.accountId || ''))
  } catch (exception) {
    warn('seedlab/simulations/[id]:not-found', { simulationId, error: String(exception.message || exception) })
    dbg('seedlab/simulations/[id]:redirect', {
      status: 303,
      redirectTo: '/simulations',
      message: '실험을 찾을 수 없습니다.',
    })
    redirect('/simulations', {
      status: 303,
      message: '실험을 찾을 수 없습니다.',
    })
    return
  }
</script>

<div class="space-y-4 pt-1 pb-2">
  <header class="space-y-3">
    <div class="flex items-center justify-between gap-3">
      <p class="text-xs font-bold text-[#3182f6]">실험 상세</p>
      <div class="flex shrink-0 items-center gap-2">
        <a
          href="/simulations/edit/<%= simulationCard.id %>"
          class="inline-flex h-10 items-center justify-center rounded-lg bg-white px-3 text-sm font-bold text-[#4e5968] no-underline shadow-[inset_0_0_0_1px_#e5e8eb] active:bg-[#f2f4f6]">
          수정
        </a>
        <form
          method="post"
          action="/xapi/simulations/recalculate">
          <input
            type="hidden"
            name="simulationId"
            value="<%= simulationCard.id %>" />
          <button
            type="submit"
            class="inline-flex h-10 items-center justify-center rounded-lg bg-[#3182f6] px-3 text-sm font-bold text-white shadow-[0_8px_18px_rgba(49,130,246,0.18)] active:bg-[#1b64da]">
            최신 기준
          </button>
        </form>
        <a
          href="/simulations"
          class="inline-flex h-10 items-center justify-center rounded-lg px-3 text-sm font-bold text-[#6b7684] no-underline active:bg-[#f2f4f6]">
          닫기
        </a>
      </div>
    </div>
    <h1 class="text-[24px] leading-tight font-bold text-[#191f28]"><%= simulationCard.name %></h1>
  </header>

  <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

  <section class="rounded-lg bg-white p-4 shadow-[0_8px_24px_rgba(25,31,40,0.06)]">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <p class="text-xs font-bold text-[#8b95a1]">예상 평가액</p>
        <p class="mt-1 text-[28px] leading-tight font-bold text-[#191f28]"><%= simulationCard.finalTotalText %></p>
      </div>
      <span class="shrink-0 rounded-md bg-[#e8f3ff] px-2 py-1 text-xs font-bold text-[#1b64da]"><%= simulationCard.badgeText %></span>
    </div>
    <div class="mt-3 flex items-center justify-between gap-3">
      <p class="<%= String(simulationCard.profitText).indexOf('-') === 0 ? 'text-[#1b64da]' : 'text-[#f04452]' %> text-sm font-bold"><%= simulationCard.profitText %></p>
      <p class="text-sm font-bold text-[#191f28]">수익률 <%= simulationCard.returnText %></p>
    </div>
    <div class="mt-4 grid grid-cols-2 gap-2 rounded-lg bg-[#f7f8fa] px-3 py-2">
      <div class="min-w-0">
        <p class="truncate text-[10px] font-bold text-[#8b95a1]">투입 방식</p>
        <p class="mt-0.5 truncate text-xs font-bold text-[#191f28]"><%= simulationCard.contributionText %></p>
      </div>
      <div class="min-w-0">
        <p class="truncate text-[10px] font-bold text-[#8b95a1]">수익률 가정</p>
        <p class="mt-0.5 truncate text-xs font-bold text-[#191f28]"><%= simulationCard.returnAssumptionText %></p>
      </div>
    </div>
  </section>

  <section class="space-y-3">
    <h2 class="text-base font-bold text-[#191f28]">자산군 변화</h2>
    <div class="space-y-2">
      <% for (let index = 0; index < simulationCard.bucketRows.length; index += 1) { %>
      <article class="rounded-lg bg-white p-4 shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <span class="<%= simulationCard.bucketRows[index].tone %> inline-flex max-w-full truncate rounded-md px-2 py-0.5 text-xs font-bold"><%= simulationCard.bucketRows[index].label %></span>
            <p class="mt-2 text-sm font-bold text-[#191f28]">
              목표 <%= simulationCard.bucketRows[index].targetPctText %> · 현재 <%= simulationCard.bucketRows[index].currentPctText %> · 예상 <%= simulationCard.bucketRows[index].finalPctText %>
            </p>
          </div>
          <p class="<%= simulationCard.bucketRows[index].driftTone %> shrink-0 text-sm font-bold"><%= simulationCard.bucketRows[index].driftPctText %></p>
        </div>
        <div class="mt-3 h-2 overflow-hidden rounded-full bg-[#f2f4f6]">
          <div
            class="h-full rounded-full"
            style="width: <%= simulationCard.bucketRows[index].barWidth %>%; background: <%= simulationCard.bucketRows[index].color %>"></div>
        </div>
        <div class="mt-3 grid grid-cols-2 gap-2 rounded-lg bg-[#f7f8fa] px-3 py-2">
          <div>
            <p class="text-[10px] font-bold text-[#8b95a1]">현재 금액</p>
            <p class="mt-0.5 text-xs font-bold text-[#191f28]"><%= simulationCard.bucketRows[index].currentValueText %></p>
          </div>
          <div>
            <p class="text-[10px] font-bold text-[#8b95a1]">예상 금액</p>
            <p class="mt-0.5 text-xs font-bold text-[#191f28]"><%= simulationCard.bucketRows[index].finalValueText %></p>
          </div>
        </div>
      </article>
      <% } %>
    </div>
  </section>

  <section class="space-y-3">
    <h2 class="text-base font-bold text-[#191f28]">첫 달 매수 후보</h2>
    <% if (simulationCard.candidateRows.length === 0) { %>
    <div class="rounded-lg bg-white p-4 shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
      <p class="text-sm font-bold text-[#191f28]">매수 후보가 없습니다</p>
      <p class="mt-1 text-sm leading-5 text-[#6b7684]">목표 비중과 최소 주문 조건 때문에 첫 달 주문 후보가 만들어지지 않았습니다.</p>
    </div>
    <% } else { %>
    <div class="space-y-2">
      <% for (let index = 0; index < simulationCard.candidateRows.length; index += 1) { %>
      <article class="grid grid-cols-[1fr_auto] items-center gap-3 rounded-lg bg-white p-4 shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <div class="min-w-0">
          <p class="<%= simulationCard.candidateRows[index].tone %> truncate text-sm font-bold">
            <%= simulationCard.candidateRows[index].displayName %> · <%= simulationCard.candidateRows[index].bucketLabel %>
          </p>
          <p class="mt-1 truncate text-xs font-medium text-[#8b95a1]"><%= simulationCard.candidateRows[index].statusText %> <%= simulationCard.candidateRows[index].quantityText %></p>
        </div>
        <p class="<%= simulationCard.candidateRows[index].tone %> shrink-0 text-sm font-bold"><%= simulationCard.candidateRows[index].amountText %></p>
      </article>
      <% } %>
    </div>
    <% } %>
  </section>

  <section class="space-y-3">
    <h2 class="text-base font-bold text-[#191f28]">보유 종목 근거</h2>
    <div class="space-y-2">
      <% for (let index = 0; index < holdingRows.length && index < 12; index += 1) { %>
      <article class="grid grid-cols-[1fr_auto] items-center gap-3 rounded-lg bg-white p-4 shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <div class="min-w-0">
          <div class="flex min-w-0 items-center gap-2">
            <p class="truncate text-sm font-bold text-[#191f28]"><%= holdingRows[index].displayName %></p>
            <span class="<%= holdingRows[index].tone %> shrink-0 rounded-md px-2 py-0.5 text-[10px] font-bold"><%= holdingRows[index].bucketLabel %></span>
          </div>
          <p class="mt-1 truncate text-xs font-medium text-[#8b95a1]"><%= holdingRows[index].quantityText %></p>
        </div>
        <div class="shrink-0 text-right">
          <p class="text-sm font-bold text-[#191f28]"><%= holdingRows[index].valueText %></p>
          <p class="<%= holdingRows[index].profitTone %> mt-1 text-xs font-bold"><%= holdingRows[index].profitText %></p>
        </div>
      </article>
      <% } %>
    </div>
  </section>

  <section class="space-y-3">
    <h2 class="text-base font-bold text-[#191f28]">월별 흐름</h2>
    <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
      <% for (let index = 0; index < simulationCard.timelineRows.length; index += 1) { %>
      <div class="grid grid-cols-[64px_1fr_auto] items-center gap-2 border-b border-[#f2f4f6] px-4 py-3 last:border-b-0">
        <p class="truncate text-xs font-bold text-[#6b7684]"><%= simulationCard.timelineRows[index].label %></p>
        <p class="truncate text-sm font-bold text-[#191f28]"><%= simulationCard.timelineRows[index].totalText %></p>
        <p class="<%= simulationCard.timelineRows[index].tone %> shrink-0 text-xs font-bold"><%= simulationCard.timelineRows[index].profitText %></p>
      </div>
      <% } %>
    </div>
  </section>

  <form
    method="post"
    action="/xapi/simulations/delete"
    onsubmit="return confirm('이 실험을 삭제할까요?')">
    <input
      type="hidden"
      name="simulationId"
      value="<%= simulationCard.id %>" />
    <button
      type="submit"
      class="box-border flex h-11 w-full items-center justify-center rounded-lg border-0 bg-white px-4 text-sm font-bold text-[#f04452] shadow-[inset_0_0_0_1px_#fee4e7] active:bg-[#fff1f2]">
      실험 삭제
    </button>
  </form>
</div>
