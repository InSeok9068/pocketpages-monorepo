<script server>
  meta('title', 'SeedLab 전략 실험')
  meta('description', 'SeedLab 전략 실험')

  if (!request.auth) {
    dbg('seedlab/simulations/new:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }
</script>

<section class="flex min-h-[calc(100vh-2rem)] flex-col pb-24 pt-5">
  <header class="flex items-center justify-between">
    <div>
      <p class="text-xs font-bold text-[#3182f6]">실험</p>
      <h1 class="mt-1 text-[24px] font-bold leading-tight text-[#191f28]">새 실험</h1>
    </div>
    <a
      href="/simulations"
      class="inline-flex h-10 items-center justify-center rounded-lg px-3 text-sm font-bold text-[#6b7684] no-underline active:bg-[#f2f4f6]">
      닫기
    </a>
  </header>

  <div class="mt-5">
    <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

    <form
      method="post"
      action="/xapi/simulations/create"
      class="space-y-4">
      <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <label class="grid grid-cols-[88px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">이름</span>
          <input
            type="text"
            name="personaName"
            required
            value="장기 적립 투자자"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
        </label>
        <label class="grid grid-cols-[88px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">성향</span>
          <select
            name="riskProfile"
            required
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none">
            <option value="balanced">균형형</option>
            <option value="conservative">안정형</option>
            <option value="aggressive">공격형</option>
          </select>
        </label>
        <label class="grid grid-cols-[88px_1fr] items-center gap-3 px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">행동</span>
          <select
            name="behaviorProfile"
            required
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none">
            <option value="disciplined">원칙형</option>
            <option value="dip_buyer">하락매수형</option>
            <option value="panic_seller">손절민감형</option>
          </select>
        </label>
      </div>

      <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <label class="grid grid-cols-[88px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">초기 자금</span>
          <input
            type="number"
            name="initialCapital"
            required
            min="0"
            step="10000"
            value="10000000"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
        </label>
        <label class="grid grid-cols-[88px_1fr] items-center gap-3 px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">월 투자금</span>
          <input
            type="number"
            name="monthlyContribution"
            required
            min="0"
            step="10000"
            value="500000"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
        </label>
      </div>

      <div class="overflow-hidden rounded-lg bg-white shadow-[0_4px_16px_rgba(25,31,40,0.05)]">
        <label class="grid grid-cols-[88px_1fr] items-center gap-3 border-b border-[#f2f4f6] px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">시작일</span>
          <input
            type="date"
            name="startDate"
            required
            value="2021-01-01"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
        </label>
        <label class="grid grid-cols-[88px_1fr] items-center gap-3 px-4 py-3">
          <span class="text-xs font-bold text-[#6b7684]">종료일</span>
          <input
            type="date"
            name="endDate"
            required
            value="2026-06-30"
            class="h-9 min-w-0 border-0 bg-transparent p-0 text-right text-base font-bold text-[#191f28] outline-none" />
        </label>
      </div>

      <button
        type="submit"
        class="box-border flex h-12 w-full items-center justify-center gap-2 rounded-lg border-0 bg-[#191f28] px-4 text-base font-bold text-white shadow-[0_8px_18px_rgba(25,31,40,0.16)] active:bg-[#333d4b]">
        만들기
        <span
          class="i-lucide-flask-conical h-5 w-5"
          aria-hidden="true"></span>
      </button>
    </form>
  </div>
</section>
