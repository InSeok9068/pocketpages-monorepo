<script server>
  meta('title', 'SeedLab 전략 실험')
  meta('description', 'SeedLab 전략 실험')

  if (!request.auth) {
    dbg('seedlab/simulations/new:redirect', {
      status: 303,
      redirectTo: '/sign-in',
      message: '로그인이 필요합니다.',
    })
    redirect('/sign-in', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }
</script>

<section class="flex min-h-[calc(100vh-2rem)] flex-col pb-4 pt-5">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[#3182f6] text-white shadow-[0_10px_24px_rgba(49,130,246,0.22)]">
        <span
          class="i-lucide-user-round-cog h-5 w-5"
          aria-hidden="true"></span>
      </div>
      <span class="text-lg font-bold text-[#191f28]">SeedLab</span>
    </div>
    <a
      href="/"
      class="inline-flex h-10 items-center justify-center rounded-lg px-3 text-sm font-bold text-[#6b7684] no-underline active:bg-[#f2f4f6]">
      닫기
    </a>
  </div>

  <div class="mt-8">
    <p class="text-sm font-bold text-[#3182f6]">가상 인물 실험</p>
    <h1 class="tracking-0 mt-2 text-[30px] font-bold leading-[1.18] text-[#191f28]">
      적립식 전략을<br />
      먼저 굴려봅니다
    </h1>
    <p class="mt-3 max-w-[320px] text-[15px] leading-6 text-[#6b7684]">실계좌 주문 전에 같은 기준으로 가상 인물 결과와 주문 후보를 만듭니다.</p>
  </div>

  <div class="mt-7">
    <%- include('flash-alert.ejs', { flashMessage: params.__flash }) %>

    <form
      method="post"
      action="/xapi/simulations/create"
      class="space-y-4">
      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">가상 인물 이름</span>
        <span
          class="focus-within:ring-3 mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-[#3182f6]/10">
          <span
            class="i-lucide-user h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
          <input
            type="text"
            name="personaName"
            required
            value="장기 적립 투자자"
            class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-medium text-[#191f28] outline-none placeholder:text-[#adb5bd]" />
        </span>
      </label>

      <div class="grid grid-cols-2 gap-3">
        <label class="block">
          <span class="text-sm font-bold text-[#4e5968]">성향</span>
          <span
            class="focus-within:ring-3 mt-2 flex h-14 items-center gap-2 rounded-lg border border-[#e5e8eb] bg-white px-3 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-[#3182f6]/10">
            <select
              name="riskProfile"
              required
              class="h-full min-w-0 flex-1 appearance-none border-0 bg-transparent p-0 text-sm font-bold text-[#191f28] outline-none">
              <option value="balanced">균형형</option>
              <option value="conservative">안정형</option>
              <option value="aggressive">공격형</option>
            </select>
            <span
              class="i-lucide-chevron-down h-4 w-4 shrink-0 text-[#8b95a1]"
              aria-hidden="true"></span>
          </span>
        </label>

        <label class="block">
          <span class="text-sm font-bold text-[#4e5968]">행동</span>
          <span
            class="focus-within:ring-3 mt-2 flex h-14 items-center gap-2 rounded-lg border border-[#e5e8eb] bg-white px-3 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-[#3182f6]/10">
            <select
              name="behaviorProfile"
              required
              class="h-full min-w-0 flex-1 appearance-none border-0 bg-transparent p-0 text-sm font-bold text-[#191f28] outline-none">
              <option value="disciplined">원칙형</option>
              <option value="dip_buyer">하락매수형</option>
              <option value="panic_seller">손절민감형</option>
            </select>
            <span
              class="i-lucide-chevron-down h-4 w-4 shrink-0 text-[#8b95a1]"
              aria-hidden="true"></span>
          </span>
        </label>
      </div>

      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">초기 자금</span>
        <span
          class="focus-within:ring-3 mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-[#3182f6]/10">
          <span
            class="i-lucide-coins h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
          <input
            type="number"
            name="initialCapital"
            required
            min="0"
            step="10000"
            value="10000000"
            class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-medium text-[#191f28] outline-none placeholder:text-[#adb5bd]" />
        </span>
      </label>

      <label class="block">
        <span class="text-sm font-bold text-[#4e5968]">월 투자금</span>
        <span
          class="focus-within:ring-3 mt-2 flex h-14 items-center gap-3 rounded-lg border border-[#e5e8eb] bg-white px-4 shadow-[0_1px_2px_rgba(25,31,40,0.04)] focus-within:border-[#3182f6] focus-within:ring-[#3182f6]/10">
          <span
            class="i-lucide-calendar-plus h-5 w-5 shrink-0 text-[#8b95a1]"
            aria-hidden="true"></span>
          <input
            type="number"
            name="monthlyContribution"
            required
            min="0"
            step="10000"
            value="500000"
            class="h-full min-w-0 flex-1 border-0 bg-transparent p-0 text-base font-medium text-[#191f28] outline-none placeholder:text-[#adb5bd]" />
        </span>
      </label>

      <div class="grid grid-cols-2 gap-3">
        <label class="block">
          <span class="text-sm font-bold text-[#4e5968]">시작일</span>
          <input
            type="date"
            name="startDate"
            required
            value="2021-01-01"
            class="focus:ring-3 mt-2 box-border h-14 w-full rounded-lg border border-[#e5e8eb] bg-white px-3 text-sm font-bold text-[#191f28] shadow-[0_1px_2px_rgba(25,31,40,0.04)] outline-none focus:border-[#3182f6] focus:ring-[#3182f6]/10" />
        </label>

        <label class="block">
          <span class="text-sm font-bold text-[#4e5968]">종료일</span>
          <input
            type="date"
            name="endDate"
            required
            value="2026-06-30"
            class="focus:ring-3 mt-2 box-border h-14 w-full rounded-lg border border-[#e5e8eb] bg-white px-3 text-sm font-bold text-[#191f28] shadow-[0_1px_2px_rgba(25,31,40,0.04)] outline-none focus:border-[#3182f6] focus:ring-[#3182f6]/10" />
        </label>
      </div>

      <button
        type="submit"
        class="mt-2 box-border flex h-14 w-full items-center justify-center gap-2 rounded-lg border-0 bg-[#3182f6] px-4 text-base font-bold text-white shadow-[0_10px_24px_rgba(49,130,246,0.22)] active:bg-[#1b64da]">
        실험 만들기
        <span
          class="i-lucide-arrow-right h-5 w-5"
          aria-hidden="true"></span>
      </button>
    </form>
  </div>
</section>
