<script server>
  const allocationBuckets = resolve('allocation-buckets')
  const holdingValuation = resolve('holding-valuation')

  meta('title', 'SeedLab')
  meta('description', '계좌와 투자 전략을 함께 점검하는 SeedLab 홈')

  const isSignedIn = !!request.auth
  const userId = isSignedIn ? String(request.auth.get('id') || '') : ''
  const userEmail = isSignedIn ? String(request.auth.get('email') || '').trim() : ''
  const userName = isSignedIn ? String(request.auth.get('name') || '').trim() : ''
  const displayName = userName || (userEmail ? userEmail.split('@')[0] : '투자자')
  let latestUsdKrwRate = 0
  const assetsById = {}
  const bucketTotals = {}

  const dashboard = {
    accountCount: 0,
    holdingCount: 0,
    totalValue: 0,
    profitLoss: 0,
    strategyCount: 0,
    draftActionCount: 0,
    simulationCount: 0,
    runningSimulationCount: 0,
    pendingOrderCount: 0,
  }
  let allocationChart = {
    segments: [],
    chartLabelsText: '',
    chartDataText: '',
    chartColorsText: '',
    hasValue: false,
  }

  function formatNumber(value, maximumFractionDigits) {
    const number = Number(value || 0)
    if (!isFinite(number)) return '0'

    const sign = number < 0 ? '-' : ''
    const fixed = Math.abs(number).toFixed(maximumFractionDigits)
    const parts = fixed.split('.')
    let integer = parts[0]
    let formattedInteger = ''

    while (integer.length > 3) {
      formattedInteger = ',' + integer.slice(-3) + formattedInteger
      integer = integer.slice(0, -3)
    }

    formattedInteger = integer + formattedInteger
    const decimal = String(parts[1] || '').replace(/0+$/, '')

    return sign + formattedInteger + (decimal ? '.' + decimal : '')
  }

  function formatAmount(value) {
    return formatNumber(value, 0)
  }

  function profitClass(value) {
    const number = Number(value || 0)
    if (number > 0) return 'text-[#e5484d]'
    if (number < 0) return 'text-[#1b64da]'
    return 'text-[#4e5968]'
  }

  function readObject(value) {
    if (value && typeof value === 'object' && !Array.isArray(value)) return value
    if (typeof value === 'string' && value.trim()) {
      try {
        const parsed = JSON.parse(value)
        if (parsed && typeof parsed === 'object' && !Array.isArray(parsed)) return parsed
      } catch (_exception) {
        return {}
      }
    }
    return {}
  }

  function readLatestUsdKrwRate() {
    try {
      dbg('seedlab/index:db-access', { collection: 'fx_rates' })
      const records = $app.findRecordsByFilter('fx_rates', 'baseCurrency = {:baseCurrency} && quoteCurrency = {:quoteCurrency}', '-rateAt', 1, 0, {
        baseCurrency: 'USD',
        quoteCurrency: 'KRW',
      })
      return records.length > 0 ? Number(records[0].get('rate') || 0) : 0
    } catch (exception) {
      dbg('seedlab/index:fx-rate-missing', { pair: 'USD_KRW' })
      return 0
    }
  }

  function readHoldingKrwAmount(holding, amountField, sourceKey, krwKey) {
    return holdingValuation.readKrwAmount({
      currency: String(holding.get('currency') || 'KRW'),
      raw: readObject(holding.get('raw')),
      storedAmount: Number(holding.get(amountField) || 0),
      sourceKey,
      krwKey,
      latestUsdKrwRate,
    })
  }

  function holdingMarketValueKrw(holding) {
    return readHoldingKrwAmount(holding, 'marketValue', 'marketValueSource', 'marketValueKrw')
  }

  function holdingProfitLossKrw(holding) {
    return readHoldingKrwAmount(holding, 'profitLoss', 'profitLossSource', 'profitLossKrw')
  }

  function readAssetRecord(assetId) {
    const id = String(assetId || '')
    if (!id) return null
    if (Object.prototype.hasOwnProperty.call(assetsById, id)) return assetsById[id]

    try {
      dbg('seedlab/index:db-access', { collection: 'assets', assetId: id })
      assetsById[id] = $app.findFirstRecordByFilter('assets', 'id = {:id}', { id })
    } catch (exception) {
      warn('seedlab/index:db-access-failed', { collection: 'assets', assetId: id, error: String(exception.message || exception) })
      assetsById[id] = null
    }

    return assetsById[id]
  }

  function inferAllocationBucket(holding) {
    const raw = readObject(holding.get('raw'))
    const seedlab = readObject(raw.seedlab)
    const savedBucket = allocationBuckets.normalizeBucket(seedlab.allocationBucket)
    if (savedBucket) return savedBucket

    const asset = readAssetRecord(holding.get('asset'))
    const overrideClass = String(holding.get('assetClassOverride') || '')
    const assetClass = overrideClass && overrideClass !== 'none' ? overrideClass : String(asset ? asset.get('assetClass') : '')
    const assetType = String(asset ? asset.get('assetType') : '').toLowerCase()
    const symbol = String(asset ? asset.get('symbol') : '').toUpperCase()
    const name = String(asset ? asset.get('name') : '').toUpperCase()
    const searchText = symbol + ' ' + name

    if (assetClass === 'cash' || assetType === 'cash') return 'cash'
    if (assetClass === 'fixed_income' || assetType === 'bond' || searchText.indexOf('BOND') >= 0 || searchText.indexOf('채권') >= 0) return 'bond'
    if (searchText.indexOf('GOLD') >= 0 || searchText.indexOf('금') >= 0) return 'gold'
    if (searchText.indexOf('REIT') >= 0 || searchText.indexOf('리츠') >= 0 || searchText.indexOf('부동산') >= 0) return 'real_estate'
    if (searchText.indexOf('SCHD') >= 0 || searchText.indexOf('DIVIDEND') >= 0 || searchText.indexOf('배당') >= 0) return 'dividend_stock'
    if (assetClass === 'equity') return 'growth_stock'
    return 'other'
  }

  function addBucketValue(bucket, value) {
    const key = allocationBuckets.normalizeBucket(bucket) || 'other'
    bucketTotals[key] = Number(bucketTotals[key] || 0) + Number(value || 0)
  }

  function buildAllocationChart(totalValue) {
    const buckets = allocationBuckets.listBuckets()
    const segments = []
    const chartLabels = []
    const chartData = []
    const chartColors = []
    const total = Number(totalValue || 0)

    for (let index = 0; index < buckets.length; index += 1) {
      const bucket = buckets[index]
      const value = Number(bucketTotals[bucket.key] || 0)
      if (value <= 0) continue

      const pct = total > 0 ? Math.round((value / total) * 1000) / 10 : 0
      segments.push({
        label: bucket.label,
        pctText: formatNumber(pct, 1) + '%',
        valueText: formatAmount(value),
        color: bucket.color,
      })
      chartLabels.push(bucket.label)
      chartData.push(value)
      chartColors.push(bucket.color)
    }

    return {
      segments,
      chartLabelsText: chartLabels.join('|'),
      chartDataText: chartData.join('|'),
      chartColorsText: chartColors.join('|'),
      hasValue: total > 0 && segments.length > 0,
    }
  }

  function applyLatestSnapshotTotals() {
    const seen = {}
    let cashValue = 0
    let profitLoss = 0
    let hasSnapshot = false

    try {
      dbg('seedlab/index:db-access', { collection: 'account_snapshots' })
      const snapshots = $app.findRecordsByFilter('account_snapshots', 'owner = {:owner}', '-snapshotDate', 200, 0, { owner: userId })
      for (let index = 0; index < snapshots.length; index += 1) {
        const snapshot = snapshots[index]
        const accountId = String(snapshot.get('account') || '')
        if (!accountId || seen[accountId]) continue
        seen[accountId] = true
        cashValue += Number(snapshot.get('cashValue') || 0)
        profitLoss += Number(snapshot.get('profitLoss') || 0)
        hasSnapshot = true
      }
    } catch (exception) {
      warn('seedlab/index:db-access-failed', { collection: 'account_snapshots', error: String(exception.message || exception) })
    }

    if (hasSnapshot && cashValue > 0) {
      addBucketValue('cash', cashValue)
      dashboard.totalValue += cashValue
      dashboard.profitLoss = profitLoss
    }
  }

  if (isSignedIn) {
    latestUsdKrwRate = readLatestUsdKrwRate()

    try {
      dbg('seedlab/index:db-access', { collection: 'portfolio_accounts' })
      dashboard.accountCount = $app.findRecordsByFilter('portfolio_accounts', 'owner = {:owner} && isActive = true', '-updated', 200, 0, { owner: userId }).length
    } catch (exception) {
      warn('seedlab/index:db-access-failed', { collection: 'portfolio_accounts', error: String(exception.message || exception) })
    }

    try {
      dbg('seedlab/index:db-access', { collection: 'account_holdings' })
      const holdingRecords = $app.findRecordsByFilter('account_holdings', 'owner = {:owner}', '-updated', 200, 0, { owner: userId })
      dashboard.holdingCount = holdingRecords.length
      for (let index = 0; index < holdingRecords.length; index += 1) {
        const marketValue = holdingMarketValueKrw(holdingRecords[index])
        dashboard.totalValue += marketValue
        dashboard.profitLoss += holdingProfitLossKrw(holdingRecords[index])
        addBucketValue(inferAllocationBucket(holdingRecords[index]), marketValue)
      }
    } catch (exception) {
      warn('seedlab/index:db-access-failed', { collection: 'account_holdings', error: String(exception.message || exception) })
    }

    try {
      dbg('seedlab/index:db-access', { collection: 'investment_strategies' })
      dashboard.strategyCount = $app.findRecordsByFilter('investment_strategies', 'owner = {:owner} && isActive = true', '-updated', 200, 0, { owner: userId }).length
    } catch (exception) {
      warn('seedlab/index:db-access-failed', { collection: 'investment_strategies', error: String(exception.message || exception) })
    }

    try {
      dbg('seedlab/index:db-access', { collection: 'action_items' })
      dashboard.draftActionCount = $app.findRecordsByFilter('action_items', 'owner = {:owner} && status = {:status}', '-updated', 200, 0, { owner: userId, status: 'draft' }).length
    } catch (exception) {
      warn('seedlab/index:db-access-failed', { collection: 'action_items', error: String(exception.message || exception) })
    }

    try {
      dbg('seedlab/index:db-access', { collection: 'simulations' })
      dashboard.simulationCount = $app.findRecordsByFilter('simulations', 'owner = {:owner}', '-updated', 200, 0, { owner: userId }).length
    } catch (exception) {
      warn('seedlab/index:db-access-failed', { collection: 'simulations', error: String(exception.message || exception) })
    }

    try {
      dbg('seedlab/index:db-access', { collection: 'simulations' })
      dashboard.runningSimulationCount = $app.findRecordsByFilter('simulations', 'owner = {:owner} && status = {:status}', '-updated', 200, 0, { owner: userId, status: 'running' }).length
    } catch (exception) {
      warn('seedlab/index:db-access-failed', { collection: 'simulations', status: 'running', error: String(exception.message || exception) })
    }

    try {
      dbg('seedlab/index:db-access', { collection: 'order_records' })
      dashboard.pendingOrderCount = $app.findRecordsByFilter('order_records', 'owner = {:owner} && status = {:status}', '-updated', 200, 0, { owner: userId, status: 'pending' }).length
    } catch (exception) {
      warn('seedlab/index:db-access-failed', { collection: 'order_records', error: String(exception.message || exception) })
    }

    applyLatestSnapshotTotals()
    allocationChart = buildAllocationChart(dashboard.totalValue)
  }

  const activeActionCount = dashboard.draftActionCount + dashboard.pendingOrderCount
  const totalValueText = formatAmount(dashboard.totalValue)
  const profitLossText = (dashboard.profitLoss > 0 ? '+' : '') + formatAmount(dashboard.profitLoss)
  const readinessText = dashboard.accountCount === 0 ? '계좌 연결 필요' : dashboard.holdingCount === 0 ? '보유 종목 동기화 필요' : '점검 완료'
  const primaryHref = dashboard.accountCount === 0 ? '/connections/toss/new' : '/accounts'
  const primaryLabel = dashboard.accountCount === 0 ? '계좌 연결' : '종목 동기화'
  const hasMainTask = dashboard.accountCount === 0 || dashboard.holdingCount === 0
  const mainTaskTitle = dashboard.accountCount === 0 ? '계좌를 먼저 연결하세요' : '보유 종목을 동기화하세요'
  const mainTaskDescription = dashboard.accountCount === 0 ? '토스증권 API 연결 후 보유 종목과 비중을 계산합니다.' : '연결된 계좌에서 보유 종목을 가져와야 리밸런싱이 가능합니다.'
  const statusRows = [
    { label: '계좌', value: String(dashboard.accountCount) },
    { label: '종목', value: String(dashboard.holdingCount) },
    { label: '검토', value: String(activeActionCount) },
  ]
  const quickLinks = [
    { href: '/accounts', label: '계좌/비중', icon: 'i-lucide-wallet-cards' },
    { href: '/accounts/holdings/new', label: '종목 추가', icon: 'i-lucide-plus' },
    { href: '/simulations/new', label: '실험', icon: 'i-lucide-flask-conical' },
  ]

  dbg('seedlab/index:response', {
    isSignedIn: isSignedIn,
    authId: userId,
    accountCount: dashboard.accountCount,
    strategyCount: dashboard.strategyCount,
  })
</script>

