    <div class="grid grid-cols-3 gap-2">
      <% for (let index = 0; index < quickLinks.length; index += 1) { %>
      <a
        href="<%= quickLinks[index].href %>"
        class="box-border flex h-12 min-w-0 items-center justify-center gap-1.5 rounded-lg bg-white px-2 text-sm font-bold text-[#191f28] no-underline shadow-[0_1px_2px_rgba(25,31,40,0.06)] active:bg-[#f2f4f6]">
