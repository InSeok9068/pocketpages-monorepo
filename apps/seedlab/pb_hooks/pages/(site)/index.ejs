<% if (isSignedIn && allocationChart.hasValue) { %>
<script src="<%= asset('/assets/vendor/chart.umd.4.5.1.min.js') %>"></script>
<script>
  ;(function () {
    var element = document.getElementById('home-allocation-chart')
    if (!element || !window.Chart) return
    var labels = String(element.getAttribute('data-labels') || '')
      .split('|')
      .filter(Boolean)
    var data = String(element.getAttribute('data-values') || '')
      .split('|')
      .filter(Boolean)
      .map(function (value) {
        return Number(value) || 0
      })
    var colors = String(element.getAttribute('data-colors') || '')
      .split('|')
      .filter(Boolean)
    new window.Chart(element, {
      type: 'doughnut',
      data: {
        labels: labels,
        datasets: [{
            data: data,
            backgroundColor: colors,
            borderWidth: 0,
          }],
      },
      options: {
        animation: false,
        cutout: '68%',
        plugins: {
          legend: {
            display: false,
          },
          tooltip: {
            enabled: true,
          },
        },
      },
    })
  })()
</script>
<% } %>
