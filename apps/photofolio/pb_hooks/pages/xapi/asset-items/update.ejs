<script server>
  const photofolioAssetMeta = resolve('photofolio-asset-meta')

  function normalizeAmountKrw(rawValue) {
    const text = String(rawValue === undefined || rawValue === null ? '' : rawValue).trim()

    if (!text) {
      throw new Error('금액을 입력해 주세요.')
    }

    const amountValue = Number(text)

    if (!isFinite(amountValue) || amountValue < 0) {
      throw new Error('금액은 0 이상의 숫자여야 합니다.')
    }

    return Math.round(amountValue)
  }

  function decodeJsonByteArray(value) {
    if (!Array.isArray(value) || value.length === 0) {
      return ''
    }

    try {
      return new TextDecoder('utf-8').decode(Uint8Array.from(value))
    } catch (exception) {
      warn('xapi/asset-items/update:decode-json-byte-array-failed', {
        error: String(exception.message || exception),
      })
    }

    return ''
  }

  function normalizeJsonObject(value) {
    if (!value) {
      return {}
    }

    if (typeof value === 'string') {
      try {
        const parsedValue = JSON.parse(value)
        return parsedValue && typeof parsedValue === 'object' && !Array.isArray(parsedValue) ? parsedValue : {}
      } catch (exception) {
        warn('xapi/asset-items/update:parse-json-string-failed', {
          error: String(exception.message || exception),
        })
        return {}
      }
    }

    if (Array.isArray(value)) {
      return normalizeJsonObject(decodeJsonByteArray(value))
    }

    if (typeof value === 'object') {
      return JSON.parse(JSON.stringify(value))
    }

    return {}
  }

  if (request.method !== 'POST') {
    dbg('xapi/asset-items/update:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '잘못된 요청입니다.',
    })
    redirect('/', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    dbg('xapi/asset-items/update:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인 후 자산을 수정해 주세요.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인 후 자산을 수정해 주세요.',
    })
    return
  }

  const form = body()
  const userId = String(request.auth.get('id') || '')
  const itemId = String(form.itemId || '').trim()
  const assetClassCode = String(form.assetClassCode || '').trim()
  let errorMessage = ''

  dbg('xapi/asset-items/update:start', {
    userId: userId,
    itemId: itemId,
    assetClassCode: assetClassCode,
  })

  try {
    if (!itemId) {
      throw new Error('수정할 자산 항목이 필요합니다.')
    }

    if (!photofolioAssetMeta.ASSET_CLASS_META[assetClassCode]) {
      throw new Error('자산 카테고리가 올바르지 않습니다.')
    }

    const amountKrw = normalizeAmountKrw(form.amountKrw)
    const itemRecord = $app.findFirstRecordByFilter('asset_items', 'id = {:itemId} && snapshot_id.user_id = {:userId}', {
      itemId: itemId,
      userId: userId,
    })
    const snapshotId = String(itemRecord.get('snapshot_id') || '')
    const snapshotRecord = $app.findFirstRecordByFilter('asset_snapshots', 'id = {:snapshotId} && user_id = {:userId}', {
      snapshotId: snapshotId,
      userId: userId,
    })
    const sourceJson = normalizeJsonObject(itemRecord.get('source_json'))
    const currencyCode = String(itemRecord.get('currency_code') || '').trim().toUpperCase()

    dbg('xapi/asset-items/update:db-read', {
      userId: userId,
      itemId: itemId,
      snapshotId: snapshotId,
      previousAmountKrw: Number(itemRecord.get('amount_krw') || 0),
      previousAssetClassCode: String(itemRecord.get('asset_class_code') || ''),
    })

    itemRecord.set('asset_class_code', assetClassCode)
    itemRecord.set('amount_krw', amountKrw)
    itemRecord.set('is_manual_adjusted', true)

    if (!currencyCode || currencyCode === 'KRW') {
      itemRecord.set('amount_original', amountKrw)
    }

    sourceJson.manual_override = {
      asset_class_code: assetClassCode,
      amount_krw: amountKrw,
      updated_at: new Date().toISOString(),
    }
    itemRecord.set('source_json', sourceJson)
    $app.save(itemRecord)

    const snapshotItemRecords = $app.findRecordsByFilter('asset_items', 'snapshot_id = {:snapshotId}', '-amount_krw,-created', 500, 0, {
      snapshotId: snapshotId,
    }) || []
    const totalAmountKrw = snapshotItemRecords.reduce(function (sum, record) {
      return sum + Number(record.get('amount_krw') || 0)
    }, 0)

    snapshotRecord.set('total_amount_krw', totalAmountKrw)
    $app.save(snapshotRecord)

    info('xapi/asset-items/update:updated', {
      userId: userId,
      itemId: itemId,
      snapshotId: snapshotId,
      assetClassCode: assetClassCode,
      amountKrw: amountKrw,
      totalAmountKrw: totalAmountKrw,
    })

    dbg('xapi/asset-items/update:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '자산 항목을 수정했습니다.',
    })
    redirect('/', {
      status: 303,
      message: '자산 항목을 수정했습니다.',
    })
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('xapi/asset-items/update:failed', {
      userId: userId,
      itemId: itemId,
      error: errorMessage,
    })
  }

  dbg('xapi/asset-items/update:redirect', {
    status: 303,
    redirectTo: '/',
    error: errorMessage || '자산 항목 수정에 실패했습니다.',
  })
  redirect('/', {
    status: 303,
    message: errorMessage || '자산 항목 수정에 실패했습니다.',
  })
  return
</script>
