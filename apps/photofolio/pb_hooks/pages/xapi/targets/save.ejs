<script server>
  const photofolioAssetMeta = resolve('photofolio-asset-meta')
  const assetClassOrder = photofolioAssetMeta.ASSET_CLASS_ORDER

  function normalizePercentValue(rawValue) {
    const text = String(rawValue || '').trim()

    if (!text) {
      return null
    }

    const value = Number(text)

    if (isNaN(value) || !isFinite(value)) {
      throw new Error('목표 비율은 숫자로 입력해 주세요.')
    }

    if (value < 0 || value > 100) {
      throw new Error('목표 비율은 0%부터 100% 사이여야 합니다.')
    }

    return Math.round(value * 10) / 10
  }

  if (request.method !== 'POST') {
    dbg('xapi/targets/save:redirect', {
      status: 303,
      redirectTo: '/targets',
      flash: '잘못된 요청입니다.',
    })
    redirect('/targets', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    dbg('xapi/targets/save:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인 후 목표 비율을 저장해 주세요.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인 후 목표 비율을 저장해 주세요.',
    })
    return
  }

  const form = body()
  const userId = String(request.auth.get('id') || '')
  const normalizedTargetByClass = {}
  let totalTargetPercent = 0
  let errorMessage = ''

  dbg('xapi/targets/save:start', {
    userId: userId,
  })

  try {
    if (!userId) {
      throw new Error('로그인이 필요합니다.')
    }

    for (let index = 0; index < assetClassOrder.length; index += 1) {
      const code = assetClassOrder[index]
      const normalizedPercent = normalizePercentValue(form[code])

      normalizedTargetByClass[code] = normalizedPercent

      if (normalizedPercent !== null && normalizedPercent > 0) {
        totalTargetPercent += normalizedPercent
      }
    }

    totalTargetPercent = Math.round(totalTargetPercent * 10) / 10

    if (totalTargetPercent > 100) {
      throw new Error('목표 비율 합계는 100%를 넘을 수 없습니다.')
    }

    dbg('xapi/targets/save:db-read', {
      userId: userId,
      totalTargetPercent: totalTargetPercent,
    })

    const existingRecords = $app.findRecordsByFilter('user_target_allocations', 'user_id = {:userId}', 'created', 50, 0, { userId: userId }) || []
    const existingByClass = {}
    const collection = $app.findCollectionByNameOrId('user_target_allocations')
    let createdCount = 0
    let updatedCount = 0
    let deletedCount = 0

    for (let index = 0; index < existingRecords.length; index += 1) {
      const record = existingRecords[index]
      const code = String(record.get('asset_class_code') || '')

      if (!existingByClass[code]) {
        existingByClass[code] = record
      }
    }

    for (let index = 0; index < assetClassOrder.length; index += 1) {
      const code = assetClassOrder[index]
      const targetPercent = normalizedTargetByClass[code]
      const existingRecord = existingByClass[code] || null

      if (targetPercent === null || targetPercent <= 0) {
        if (existingRecord) {
          info('xapi/targets/save:delete', {
            userId: userId,
            code: code,
            recordId: existingRecord.get('id'),
          })
          $app.delete(existingRecord)
          deletedCount += 1
        }
        continue
      }

      if (existingRecord) {
        existingRecord.set('target_percent', targetPercent)
        $app.save(existingRecord)
        updatedCount += 1
        info('xapi/targets/save:update', {
          userId: userId,
          code: code,
          targetPercent: targetPercent,
          recordId: existingRecord.get('id'),
        })
        continue
      }

      const record = new Record(collection)
      record.set('user_id', userId)
      record.set('asset_class_code', code)
      record.set('target_percent', targetPercent)

      $app.save(record)
      createdCount += 1

      info('xapi/targets/save:create', {
        userId: userId,
        code: code,
        targetPercent: targetPercent,
        recordId: record.get('id'),
      })
    }

    dbg('xapi/targets/save:redirect', {
      status: 303,
      redirectTo: '/targets',
      flash: '목표 비율을 저장했습니다.',
      createdCount: createdCount,
      updatedCount: updatedCount,
      deletedCount: deletedCount,
      totalTargetPercent: totalTargetPercent,
    })
    redirect('/targets', {
      status: 303,
      message: '목표 비율을 저장했습니다.',
    })
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('xapi/targets/save:failed', {
      userId: userId,
      error: errorMessage,
      totalTargetPercent: totalTargetPercent,
    })
  }

  dbg('xapi/targets/save:redirect', {
    status: 303,
    redirectTo: '/targets',
    error: errorMessage || '목표 비율 저장에 실패했습니다.',
  })
  redirect('/targets', {
    status: 303,
    message: errorMessage || '목표 비율 저장에 실패했습니다.',
  })
  return
</script>
