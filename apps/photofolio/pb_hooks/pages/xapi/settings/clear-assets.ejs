<script server>
  if (request.method !== 'POST') {
    dbg('xapi/settings/clear-assets:redirect', {
      status: 303,
      redirectTo: '/settings',
      flash: '잘못된 요청입니다.',
    })
    redirect('/settings', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    dbg('xapi/settings/clear-assets:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인 후 자산 데이터를 정리해 주세요.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인 후 자산 데이터를 정리해 주세요.',
    })
    return
  }

  const userId = String(request.auth.get('id') || '')

  dbg('xapi/settings/clear-assets:start', {
    userId: userId,
  })

  try {
    if (!userId) {
      throw new Error('로그인이 필요합니다.')
    }

    const snapshotRecords = $app.findRecordsByFilter('asset_snapshots', 'user_id = {:userId}', '-created', 1000, 0, {
      userId: userId,
    }) || []
    const captureRecords = $app.findRecordsByFilter('snapshot_capture_images', 'snapshot_id.user_id = {:userId}', '-created', 1000, 0, {
      userId: userId,
    }) || []
    const sectionRecords = $app.findRecordsByFilter('snapshot_sections', 'snapshot_id.user_id = {:userId}', '-created', 1000, 0, {
      userId: userId,
    }) || []
    const assetRecords = $app.findRecordsByFilter('asset_items', 'snapshot_id.user_id = {:userId}', '-created', 1000, 0, {
      userId: userId,
    }) || []

    dbg('xapi/settings/clear-assets:db-read', {
      userId: userId,
      snapshotCount: snapshotRecords.length,
      captureCount: captureRecords.length,
      sectionCount: sectionRecords.length,
      assetCount: assetRecords.length,
    })

    for (let index = 0; index < snapshotRecords.length; index += 1) {
      const snapshotRecord = snapshotRecords[index]

      info('xapi/settings/clear-assets:delete-snapshot', {
        userId: userId,
        snapshotId: snapshotRecord.get('id'),
      })
      $app.delete(snapshotRecord)
    }

    dbg('xapi/settings/clear-assets:redirect', {
      status: 303,
      redirectTo: '/settings',
      flash:
        '자산 스냅샷 ' +
        snapshotRecords.length +
        '건, 캡처 ' +
        captureRecords.length +
        '건, 섹션 ' +
        sectionRecords.length +
        '건, 자산 항목 ' +
        assetRecords.length +
        '건을 정리했습니다.',
    })
    redirect('/settings', {
      status: 303,
      message:
        '자산 스냅샷 ' +
        snapshotRecords.length +
        '건, 캡처 ' +
        captureRecords.length +
        '건, 섹션 ' +
        sectionRecords.length +
        '건, 자산 항목 ' +
        assetRecords.length +
        '건을 정리했습니다.',
    })
    return
  } catch (exception) {
    const errorMessage = String(exception.message || exception)

    error('xapi/settings/clear-assets:failed', {
      userId: userId,
      error: errorMessage,
    })

    dbg('xapi/settings/clear-assets:redirect', {
      status: 303,
      redirectTo: '/settings',
      error: errorMessage,
    })
    redirect('/settings', {
      status: 303,
      message: errorMessage || '자산 데이터 정리에 실패했습니다.',
    })
    return
  }
</script>
