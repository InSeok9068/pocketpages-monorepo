<script server>
  meta('title', 'Photofolio')
  meta('description', '자산 캡처를 올리고 목표 비율과 현재 비율을 함께 정리하는 개인 자산 기록 서비스.')

  const flashMessage = params.__flash ? String(params.__flash) : ''
  const goalCards = [
    { code: 'cash', label: '현금', target: 10, current: 14, tone: 'bg-[#eef6ff] text-[#3182f6]' },
    { code: 'stock_growth', label: '주식(성장형)', target: 35, current: 31, tone: 'bg-[#f1f6ff] text-[#2563eb]' },
    { code: 'stock_dividend', label: '주식(배당형)', target: 20, current: 18, tone: 'bg-[#f5f7ff] text-[#4f46e5]' },
    { code: 'bond', label: '채권', target: 15, current: 17, tone: 'bg-[#f2fbf7] text-[#0f9f6e]' },
    { code: 'gold', label: '금', target: 10, current: 11, tone: 'bg-[#fff8e8] text-[#d97706]' },
    { code: 'real_estate', label: '부동산', target: 10, current: 9, tone: 'bg-[#fff3f1] text-[#e85d3f]' },
  ]
  const accounts = [
    { institution: '토스증권', name: '미국 성장주 ETF', classLabel: '주식(성장형)', amount: '₩12,480,000', change: '+3.2%' },
    { institution: '미래에셋', name: '월배당 ETF', classLabel: '주식(배당형)', amount: '₩7,320,000', change: '+1.4%' },
    { institution: '카카오뱅크', name: '생활비 통장', classLabel: '현금', amount: '₩4,180,000', change: '대기자금' },
    { institution: '삼성증권', name: '국채 ETF', classLabel: '채권', amount: '₩6,210,000', change: '+0.6%' },
  ]
</script>

<section class="space-y-5">
  <header class="flex items-start justify-between gap-4">
    <p class="m-0 pt-2 text-[13px] font-semibold tracking-[-0.01em] text-[var(--pf-primary)]">Photofolio</p>
    <a
      href="/auth"
      class="inline-flex min-h-11 min-w-18 items-center justify-center whitespace-nowrap rounded-full bg-white px-5 text-sm font-semibold text-[var(--pf-text)] no-underline shadow-[0_12px_24px_rgba(15,23,42,0.08)]">
      로그인
    </a>
  </header>

  <% if (flashMessage) { %>
  <section class="rounded-[1.5rem] border border-[var(--pf-line)] bg-[var(--pf-primary-soft)] px-4 py-4 text-sm font-medium text-[var(--pf-primary)] shadow-[0_10px_30px_rgba(49,130,246,0.10)]">
    <%= flashMessage %>
  </section>
  <% } %>

  <section class="rounded-[2rem] bg-[var(--pf-primary)] px-5 py-5 text-white shadow-[0_24px_50px_rgba(49,130,246,0.30)]">
    <p class="m-0 text-[13px] font-medium text-white/78">총 자산</p>
    <h2 class="mt-2 m-0 text-[2.1rem] font-bold tracking-[-0.05em]">₩42,930,000</h2>
    <p class="mt-2 m-0 text-sm leading-6 text-white/78">이번 달 캡처 3건 기준으로 정리한 더미 화면이다.</p>
    <div class="mt-5 grid grid-cols-3 gap-2">
      <div class="rounded-[1.3rem] bg-white/16 px-3 py-3 backdrop-blur-sm">
        <p class="m-0 text-[12px] text-white/72">목표 달성도</p>
        <p class="mt-1 m-0 text-lg font-semibold">89%</p>
      </div>
      <div class="rounded-[1.3rem] bg-white/16 px-3 py-3 backdrop-blur-sm">
        <p class="m-0 text-[12px] text-white/72">리밸런싱 차이</p>
        <p class="mt-1 m-0 text-lg font-semibold">3.8%</p>
      </div>
      <div class="rounded-[1.3rem] bg-white/16 px-3 py-3 backdrop-blur-sm">
        <p class="m-0 text-[12px] text-white/72">최근 업데이트</p>
        <p class="mt-1 m-0 text-lg font-semibold">오늘</p>
      </div>
    </div>
  </section>

  <section class="space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="m-0 text-[1.05rem] font-bold tracking-[-0.03em] text-[var(--pf-text)]">목표와 현재</h2>
      <span class="text-sm font-medium text-[var(--pf-text-faint)]">6개 분류</span>
    </div>
    <div class="space-y-3">
      <% for (let index = 0; index < goalCards.length; index += 1) { const goalCard = goalCards[index] %>
      <article class="rounded-[1.7rem] border border-[var(--pf-line)] bg-[var(--pf-surface)] px-4 py-4 shadow-[0_16px_36px_rgba(15,23,42,0.06)]">
        <div class="flex items-center justify-between gap-3">
          <div class="min-w-0">
            <div class="<%= goalCard.tone %> inline-flex rounded-full px-2.5 py-1 text-[12px] font-semibold">
              <%= goalCard.label %>
            </div>
            <p class="mt-3 m-0 text-sm font-semibold text-[var(--pf-text)]">목표 <%= goalCard.target %>% / 현재 <%= goalCard.current %>%</p>
          </div>
          <p class="m-0 text-sm font-semibold <%= goalCard.current > goalCard.target ? 'text-[#e85d3f]' : 'text-[#3182f6]' %>">
            <%= goalCard.current > goalCard.target ? '+' : '' %><%= goalCard.current - goalCard.target %>%
          </p>
        </div>
        <div class="mt-3 h-3 rounded-full bg-[#eef2f6]">
          <div
            class="h-3 rounded-full bg-[var(--pf-primary)]"
            style="width: <%= Math.min(goalCard.current, 100) %>%"></div>
        </div>
      </article>
      <% } %>
    </div>
  </section>

  <section class="space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="m-0 text-[1.05rem] font-bold tracking-[-0.03em] text-[var(--pf-text)]">자산 목록</h2>
      <button
        type="button"
        class="h-9 rounded-full border-none bg-white px-3.5 text-sm font-semibold text-[var(--pf-text)] shadow-[0_10px_20px_rgba(15,23,42,0.06)]">
        캡처 추가
      </button>
    </div>
    <div class="space-y-3">
      <% for (let index = 0; index < accounts.length; index += 1) { const account = accounts[index] %>
      <article class="rounded-[1.7rem] border border-[var(--pf-line)] bg-[var(--pf-surface)] px-4 py-4 shadow-[0_16px_36px_rgba(15,23,42,0.06)]">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="m-0 text-[13px] font-medium text-[var(--pf-text-faint)]"><%= account.institution %></p>
            <p class="mt-1 m-0 truncate text-[15px] font-semibold text-[var(--pf-text)]"><%= account.name %></p>
            <p class="mt-2 m-0 text-[13px] text-[var(--pf-text-soft)]"><%= account.classLabel %></p>
          </div>
          <div class="text-right">
            <p class="m-0 text-[15px] font-semibold tracking-[-0.02em] text-[var(--pf-text)]"><%= account.amount %></p>
            <p class="mt-1 m-0 text-[13px] font-medium text-[var(--pf-text-faint)]"><%= account.change %></p>
          </div>
        </div>
      </article>
      <% } %>
    </div>
  </section>

  <nav class="fixed bottom-4 left-1/2 z-20 w-[calc(100%-2rem)] max-w-[28rem] -translate-x-1/2 rounded-[1.7rem] border border-white/70 bg-white/92 px-3 py-3 shadow-[0_18px_36px_rgba(15,23,42,0.12)] backdrop-blur-sm">
    <div class="grid grid-cols-4 gap-2">
      <a
        href="/"
        class="rounded-[1.1rem] bg-[var(--pf-primary-soft)] px-2 py-2 text-center text-[12px] font-semibold text-[var(--pf-primary)] no-underline">
        홈
      </a>
      <a
        href="#"
        class="rounded-[1.1rem] px-2 py-2 text-center text-[12px] font-semibold text-[var(--pf-text-faint)] no-underline">
        목표
      </a>
      <a
        href="#"
        class="rounded-[1.1rem] px-2 py-2 text-center text-[12px] font-semibold text-[var(--pf-text-faint)] no-underline">
        캡처
      </a>
      <a
        href="/auth"
        class="rounded-[1.1rem] px-2 py-2 text-center text-[12px] font-semibold text-[var(--pf-text-faint)] no-underline">
        내 정보
      </a>
    </div>
  </nav>
</section>
