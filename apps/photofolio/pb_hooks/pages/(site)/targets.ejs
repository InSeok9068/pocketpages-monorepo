<script server>
  meta('title', '목표 비율 | Photofolio')
  meta('description', '자산 카테고리별 목표 비율을 설정하는 페이지.')

  const flashMessage = params.__flash ? String(params.__flash) : ''

  if (!request.auth) {
    dbg('targets:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인 후 목표 비율을 설정해 주세요.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인 후 목표 비율을 설정해 주세요.',
    })
    return
  }

  const assetClasses = [
    {
      code: 'cash',
      label: '현금',
      description: '예금, 적금, CMA, 예수금 같은 대기 자금.',
      tone: 'bg-[#eef6ff] text-[#3182f6]',
    },
    {
      code: 'stock_growth',
      label: '주식(성장형)',
      description: '성장주, 지수 ETF, 장기 성장 노출 자산.',
      tone: 'bg-[#f1f6ff] text-[#2563eb]',
    },
    {
      code: 'stock_dividend',
      label: '주식(배당형)',
      description: '배당주, 배당 ETF, 현금흐름 중심 자산.',
      tone: 'bg-[#f5f7ff] text-[#4f46e5]',
    },
    {
      code: 'bond',
      label: '채권',
      description: '국채, 회사채, 채권 ETF 같은 방어 자산.',
      tone: 'bg-[#f2fbf7] text-[#0f9f6e]',
    },
    {
      code: 'gold',
      label: '금',
      description: '금 현물, 금 ETF, 금 계좌 자산.',
      tone: 'bg-[#fff8e8] text-[#d97706]',
    },
    {
      code: 'real_estate',
      label: '부동산',
      description: '실물 부동산, 리츠, 부동산 ETF.',
      tone: 'bg-[#fff3f1] text-[#e85d3f]',
    },
    {
      code: 'other',
      label: '기타',
      description: '위 분류에 딱 맞지 않는 예외 자산.',
      tone: 'bg-[#f4f6f8] text-[#6b7684]',
    },
  ]
  const userId = String(request.auth.get('id') || '')
  const targetRecords = $app.findRecordsByFilter('user_target_allocations', 'user_id = {:userId}', 'created', 50, 0, { userId: userId }) || []
  const targetByClass = {}
  let totalTargetPercent = 0
  let configuredCount = 0

  function formatInputValue(value) {
    const normalizedValue = Number(value || 0)

    if (!normalizedValue) {
      return ''
    }

    if (Math.abs(normalizedValue - Math.round(normalizedValue)) < 0.001) {
      return String(Math.round(normalizedValue))
    }

    return String(Math.round(normalizedValue * 10) / 10)
  }

  for (let index = 0; index < assetClasses.length; index += 1) {
    targetByClass[assetClasses[index].code] = ''
  }

  for (let index = 0; index < targetRecords.length; index += 1) {
    const record = targetRecords[index]
    const code = String(record.get('asset_class_code') || '')
    const targetPercent = Number(record.get('target_percent') || 0)

    if (targetByClass[code] !== undefined && targetPercent > 0) {
      targetByClass[code] = formatInputValue(targetPercent)
      totalTargetPercent += targetPercent
      configuredCount += 1
    }
  }

  const remainingTargetPercent = Math.max(0, Math.round((100 - totalTargetPercent) * 10) / 10)
</script>

<section class="space-y-5">
  <header class="flex items-start justify-between gap-4">
    <div class="space-y-1">
      <p class="m-0 pt-2 text-[13px] font-semibold tracking-[-0.01em] text-[var(--pf-primary)]">Photofolio</p>
      <h1 class="m-0 text-[1.65rem] font-bold tracking-[-0.04em] text-[var(--pf-text)]">목표 비율</h1>
      <p class="m-0 text-[13px] leading-5 text-[var(--pf-text-faint)]"><%= String(request.auth.get('email') || '').trim() %></p>
    </div>

    <a
      href="/"
      class="inline-flex min-h-11 min-w-18 items-center justify-center whitespace-nowrap rounded-full bg-white px-5 text-sm font-semibold text-[var(--pf-text)] no-underline shadow-[0_12px_24px_rgba(15,23,42,0.08)]">
      홈으로
    </a>
  </header>

  <% if (flashMessage) { %>
  <section class="rounded-[1.5rem] border border-[var(--pf-line)] bg-[var(--pf-primary-soft)] px-4 py-4 text-sm font-medium text-[var(--pf-primary)] shadow-[0_10px_30px_rgba(49,130,246,0.10)]">
    <%= flashMessage %>
  </section>
  <% } %>

  <section class="rounded-[2rem] bg-[var(--pf-primary)] px-5 py-5 text-white shadow-[0_24px_50px_rgba(49,130,246,0.30)]">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="m-0 text-[13px] font-medium text-white/78">설정된 목표</p>
        <h2 class="mt-2 m-0 text-[2.1rem] font-bold tracking-[-0.05em]"><%= configuredCount %>개</h2>
      </div>
      <div class="rounded-[1.35rem] bg-white/16 px-4 py-3 text-right backdrop-blur-sm">
        <p class="m-0 text-[12px] text-white/72">남은 비율</p>
        <p class="mt-1 m-0 text-lg font-semibold"><%= remainingTargetPercent %>%</p>
      </div>
    </div>
    <p class="mt-3 m-0 text-sm leading-6 text-white/78">값을 비워두거나 0으로 저장하면 메인 화면에서 숨긴다. 합계는 100%를 넘을 수 없다.</p>
  </section>

  <form
    method="post"
    action="/xapi/targets/save"
    class="space-y-3">
    <% for (let index = 0; index < assetClasses.length; index += 1) { const assetClass = assetClasses[index] %>
    <article class="rounded-[1.7rem] border border-[var(--pf-line)] bg-[var(--pf-surface)] px-4 py-4 shadow-[0_16px_36px_rgba(15,23,42,0.06)]">
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <div class="<%= assetClass.tone %> inline-flex rounded-full px-2.5 py-1 text-[12px] font-semibold">
            <%= assetClass.label %>
          </div>
          <p class="mt-3 m-0 text-[13px] leading-6 text-[var(--pf-text-soft)]"><%= assetClass.description %></p>
        </div>
        <div class="w-28 shrink-0">
          <label
            for="target-<%= assetClass.code %>"
            class="block text-[12px] font-semibold text-[var(--pf-text-faint)]">
            목표 비율
          </label>
          <div class="mt-2 flex items-center rounded-[1rem] bg-[var(--pf-surface-soft)] px-3 py-3">
            <input
              id="target-<%= assetClass.code %>"
              name="<%= assetClass.code %>"
              type="number"
              min="0"
              max="100"
              step="0.1"
              inputmode="decimal"
              value="<%= targetByClass[assetClass.code] %>"
              placeholder="0"
              class="w-full border-none bg-transparent p-0 text-right text-[15px] font-semibold text-[var(--pf-text)] outline-none" />
            <span class="ml-2 text-sm font-semibold text-[var(--pf-text-faint)]">%</span>
          </div>
        </div>
      </div>
    </article>
    <% } %>

    <button
      type="submit"
      class="min-h-13 w-full rounded-[1.2rem] border-none bg-[var(--pf-primary)] px-4 text-[15px] font-semibold text-white shadow-[0_18px_28px_rgba(49,130,246,0.24)]">
      목표 비율 저장
    </button>
  </form>

  <nav class="fixed bottom-4 left-1/2 z-20 w-[calc(100%-2rem)] max-w-[28rem] -translate-x-1/2 rounded-[1.7rem] border border-white/70 bg-white/92 px-3 py-3 shadow-[0_18px_36px_rgba(15,23,42,0.12)] backdrop-blur-sm">
    <div class="grid grid-cols-4 gap-2">
      <a
        href="/"
        class="rounded-[1.1rem] px-2 py-2 text-center text-[12px] font-semibold text-[var(--pf-text-faint)] no-underline">
        홈
      </a>
      <a
        href="/targets"
        class="rounded-[1.1rem] bg-[var(--pf-primary-soft)] px-2 py-2 text-center text-[12px] font-semibold text-[var(--pf-primary)] no-underline">
        목표
      </a>
      <a
        href="/#captures"
        class="rounded-[1.1rem] px-2 py-2 text-center text-[12px] font-semibold text-[var(--pf-text-faint)] no-underline">
        캡처
      </a>
      <a
        href="/auth"
        class="rounded-[1.1rem] px-2 py-2 text-center text-[12px] font-semibold text-[var(--pf-text-faint)] no-underline">
        내 정보
      </a>
    </div>
  </nav>
</section>
