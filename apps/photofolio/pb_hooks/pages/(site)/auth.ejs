<script server>
  meta('title', 'Photofolio 로그인')
  meta('description', 'Photofolio에 로그인하거나 회원가입해서 목표 비율과 자산 스냅샷을 정리할 수 있다.')

  if (request.auth) {
    dbg('site/auth:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '이미 로그인되어 있습니다.',
    })
    redirect('/', {
      status: 303,
      message: '이미 로그인되어 있습니다.',
    })
    return
  }

  const flashMessage = params.__flash ? String(params.__flash) : ''
</script>

<section
  x-data="{ tab: 'signin' }"
  class="space-y-5">
  <div class="space-y-3">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm font-medium text-[var(--pf-text-soft)] no-underline">
      <span class="text-base">‹</span>
      홈으로
    </a>
    <div class="space-y-2">
      <p class="m-0 text-[13px] font-semibold tracking-[-0.01em] text-[var(--pf-primary)]">Photofolio</p>
      <h1 class="m-0 text-[2rem] font-bold leading-[1.2] tracking-[-0.04em] text-[var(--pf-text)]">자산 흐름을 가장 단순하게 시작해보자</h1>
      <p class="m-0 text-[15px] leading-7 text-[var(--pf-text-soft)]">캡처를 올리고, 항목을 정리하고, 목표 비율과 현재 비율을 한눈에 비교하는 흐름을 준비한다.</p>
    </div>
  </div>

  <% if (flashMessage) { %>
  <section class="rounded-[1.5rem] border border-[var(--pf-line)] bg-[var(--pf-primary-soft)] px-4 py-4 text-sm font-medium text-[var(--pf-primary)] shadow-[0_10px_30px_rgba(49,130,246,0.10)]">
    <%= flashMessage %>
  </section>
  <% } %>

  <section class="rounded-[2rem] border border-[var(--pf-line)] bg-[var(--pf-surface)] p-3 shadow-[0_22px_50px_rgba(15,23,42,0.08)]">
    <div class="grid grid-cols-2 gap-2 rounded-[1.35rem] bg-[var(--pf-bg)] p-1.5">
      <button
        type="button"
        x-on:click="tab = 'signin'"
        x-bind:class="tab === 'signin' ? 'bg-white text-[var(--pf-text)] shadow-[0_8px_18px_rgba(15,23,42,0.08)]' : 'text-[var(--pf-text-faint)]'"
        class="min-h-11 rounded-[1rem] border-none bg-transparent px-4 text-sm font-semibold tracking-[-0.01em] transition">
        로그인
      </button>
      <button
        type="button"
        x-on:click="tab = 'signup'"
        x-bind:class="tab === 'signup' ? 'bg-white text-[var(--pf-text)] shadow-[0_8px_18px_rgba(15,23,42,0.08)]' : 'text-[var(--pf-text-faint)]'"
        class="min-h-11 rounded-[1rem] border-none bg-transparent px-4 text-sm font-semibold tracking-[-0.01em] transition">
        회원가입
      </button>
    </div>

    <form
      x-show="tab === 'signin'"
      x-cloak
      method="post"
      action="/xapi/auth/sign-in"
      class="space-y-4 px-3 pb-3 pt-5">
      <div class="space-y-2">
        <label
          for="signin-email"
          class="block text-sm font-semibold text-[var(--pf-text)]">
          이메일
        </label>
        <input
          id="signin-email"
          name="email"
          type="email"
          placeholder="name@example.com"
          class="min-h-13 box-border w-full rounded-[1.2rem] border border-[var(--pf-line)] bg-[var(--pf-surface-soft)] px-4 text-[15px] text-[var(--pf-text)] outline-none focus:border-[rgba(49,130,246,0.35)] focus:bg-white" />
      </div>

      <div class="space-y-2">
        <label
          for="signin-password"
          class="block text-sm font-semibold text-[var(--pf-text)]">
          비밀번호
        </label>
        <input
          id="signin-password"
          name="password"
          type="password"
          placeholder="비밀번호를 입력해줘"
          class="min-h-13 box-border w-full rounded-[1.2rem] border border-[var(--pf-line)] bg-[var(--pf-surface-soft)] px-4 text-[15px] text-[var(--pf-text)] outline-none focus:border-[rgba(49,130,246,0.35)] focus:bg-white" />
      </div>

      <button
        type="submit"
        class="min-h-13 w-full rounded-[1.2rem] border-none bg-[var(--pf-primary)] px-4 text-[15px] font-semibold text-white shadow-[0_18px_28px_rgba(49,130,246,0.24)]">
        로그인
      </button>
    </form>

    <form
      x-show="tab === 'signup'"
      x-cloak
      method="post"
      action="/xapi/auth/sign-up"
      class="space-y-4 px-3 pb-3 pt-5">
      <div class="space-y-2">
        <label
          for="signup-email"
          class="block text-sm font-semibold text-[var(--pf-text)]">
          이메일
        </label>
        <input
          id="signup-email"
          name="email"
          type="email"
          placeholder="name@example.com"
          class="min-h-13 box-border w-full rounded-[1.2rem] border border-[var(--pf-line)] bg-[var(--pf-surface-soft)] px-4 text-[15px] text-[var(--pf-text)] outline-none focus:border-[rgba(49,130,246,0.35)] focus:bg-white" />
      </div>

      <div class="space-y-2">
        <label
          for="signup-password"
          class="block text-sm font-semibold text-[var(--pf-text)]">
          비밀번호
        </label>
        <input
          id="signup-password"
          name="password"
          type="password"
          placeholder="8자 이상으로 입력해줘"
          class="min-h-13 box-border w-full rounded-[1.2rem] border border-[var(--pf-line)] bg-[var(--pf-surface-soft)] px-4 text-[15px] text-[var(--pf-text)] outline-none focus:border-[rgba(49,130,246,0.35)] focus:bg-white" />
      </div>

      <div class="space-y-2">
        <label
          for="signup-password-confirm"
          class="block text-sm font-semibold text-[var(--pf-text)]">
          비밀번호 확인
        </label>
        <input
          id="signup-password-confirm"
          name="passwordConfirm"
          type="password"
          placeholder="한 번 더 입력해줘"
          class="min-h-13 box-border w-full rounded-[1.2rem] border border-[var(--pf-line)] bg-[var(--pf-surface-soft)] px-4 text-[15px] text-[var(--pf-text)] outline-none focus:border-[rgba(49,130,246,0.35)] focus:bg-white" />
      </div>

      <button
        type="submit"
        class="min-h-13 w-full rounded-[1.2rem] border-none bg-[var(--pf-primary)] px-4 text-[15px] font-semibold text-white shadow-[0_18px_28px_rgba(49,130,246,0.24)]">
        회원가입
      </button>
    </form>
  </section>

  <section class="rounded-[1.8rem] bg-[var(--pf-primary-soft)] px-5 py-5">
    <p class="m-0 text-sm font-semibold text-[var(--pf-primary)]">준비 중인 흐름</p>
    <div class="mt-3 space-y-3">
      <div class="bg-white/82 rounded-[1.25rem] px-4 py-4">
        <p class="m-0 text-sm font-semibold text-[var(--pf-text)]">1. 목표 비율 입력</p>
        <p class="m-0 mt-1 text-[13px] leading-6 text-[var(--pf-text-soft)]">현금, 성장형, 배당형, 채권, 금, 부동산 비율을 간단하게 정한다.</p>
      </div>
      <div class="bg-white/82 rounded-[1.25rem] px-4 py-4">
        <p class="m-0 text-sm font-semibold text-[var(--pf-text)]">2. 캡처 업로드</p>
        <p class="m-0 mt-1 text-[13px] leading-6 text-[var(--pf-text-soft)]">토스 자산 캡처를 올리고 OCR 결과를 항목별로 수정한다.</p>
      </div>
    </div>
  </section>
</section>
