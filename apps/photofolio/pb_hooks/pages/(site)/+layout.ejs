<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1" />
    <title><%= meta('title') %></title>
    <meta
      name="description"
      content="<%= meta('description') %>" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="<%= asset('/assets/favicon.svg') %>" />
    <link
      rel="stylesheet"
      href="<%= asset('/assets/style.css') %>" />
    <script>
      window.__assetFallback = function (element) {
        element.onerror = null
        element.src = element.dataset.fallbackSrc
      }
    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.10/dist/htmx.min.js"
      data-fallback-src="<%= asset('/assets/vendor/htmx-2.0.10.min.js') %>"
      onerror="window.__assetFallback(this)"></script>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.15.11/dist/cdn.min.js"
      data-fallback-src="<%= asset('/assets/vendor/alpine-3.15.11-cdn.min.js') %>"
      onerror="window.__assetFallback(this)"></script>
    <script
      src="https://cdn.jsdelivr.net/npm/@unocss/runtime@66.6.8/uno.global.js"
      data-fallback-src="<%= asset('/assets/vendor/uno-66.6.8.global.js') %>"
      onerror="window.__assetFallback(this)"></script>
    <script>
      window.__releasePhotofolioUncloak = function () {
        document.body.removeAttribute('un-cloak')
      }

      window.__unocss = {
        presets: [() => window.__unocss_runtime.presets.presetUno()],
        ready: () => {
          window.__releasePhotofolioUncloak()
        },
      }

      window.addEventListener('load', function () {
        window.setTimeout(window.__releasePhotofolioUncloak, 1200)
      })
    </script>
    <%- slots.head %>
  </head>
  <body
    un-cloak
    class="m-0 min-h-screen text-[var(--pf-text)] antialiased">
    <main class="mx-auto min-h-screen max-w-[30rem] px-4 pb-28 pt-5 sm:px-5 sm:pt-6">
      <%- slots.body || slot %>
    </main>
  </body>
</html>
