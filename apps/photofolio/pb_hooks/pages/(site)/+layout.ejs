<% const isProduction = String(env('APP_ENV') || 'development').trim() === 'production' %>
<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1" />
    <title><%= meta('title') %></title>
    <meta
      name="description"
      content="<%= meta('description') %>" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="<%= asset('/assets/favicon.svg') %>" />
    <link
      rel="stylesheet"
      href="<%= asset('/assets/style.css') %>" />
    <%- include('unocss-head.ejs', { isProduction }) %>
    <script src="<%= asset('/assets/vendor/htmx-2.0.10.min.js') %>"></script>
    <script
      defer
      src="<%= asset('/assets/vendor/alpine-3.15.11-cdn.min.js') %>"></script>
    <%- slots.head %>
  </head>
  <body
    un-cloak
    class="m-0 min-h-screen text-[var(--pf-text)] antialiased">
    <main class="mx-auto min-h-screen max-w-[30rem] px-4 pb-28 pt-5 sm:px-5 sm:pt-6">
      <%- slots.body || slot %>
    </main>
  </body>
</html>
