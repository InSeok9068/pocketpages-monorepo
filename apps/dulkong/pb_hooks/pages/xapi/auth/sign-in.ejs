<script server>
  const { createAuthCookie } = require('@pocketpages/auth-cookie')
  const authCookie = createAuthCookie()
  const { patchAppToast } = resolve('patch-app-toast')
  const isDatastarRequest = datastar.isRequest(request)

  if (request.method !== 'POST') {
    dbg('dulkong/xapi/auth/sign-in:redirect', {
      status: isDatastarRequest ? 200 : 303,
      redirectTo: '/sign-in',
      message: '잘못된 요청입니다.',
    })
    if (isDatastarRequest) {
      patchAppToast(datastar, '잘못된 요청입니다.', 'error')
      return
    }
    redirect('/sign-in', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  const form = isDatastarRequest ? datastar.requestSignals({ profileKey: '', password: '' }) : body()
  const profileKey = String(form.profileKey || '').trim()
  const password = form.password === undefined || form.password === null ? '' : String(form.password)
  let email = ''
  let errorMessage = ''

  dbg('dulkong/xapi/auth/sign-in:start', {
    profileKey,
  })

  try {
    if (['inseok', 'solmi'].indexOf(profileKey) < 0) throw new Error('인석과 솔미 중에서 선택해 주세요.')
    if (!password) throw new Error('비밀번호가 필요합니다.')

    const user = $app.findFirstRecordByFilter('users', 'profileKey = {:profileKey}', { profileKey })
    email = String(user.get('email') || '')
    if (!email) throw new Error('선택한 계정이 준비되지 않았어요.')

    const authData = signInWithPassword(email, password)
    authCookie.writeAuthCookie(response, authData)

    dbg('dulkong/xapi/auth/sign-in:response', {
      status: isDatastarRequest ? 200 : 303,
      redirectTo: '/',
      authId: String((authData.record && authData.record.id) || ''),
    })
    if (isDatastarRequest) {
      datastar.redirect('/')
      return
    }
    redirect('/', {
      status: 303,
    })
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('dulkong/xapi/auth/sign-in:failed', {
      email,
      error: errorMessage,
    })
  }

  dbg('dulkong/xapi/auth/sign-in:response', {
    status: isDatastarRequest ? 200 : 303,
    redirectTo: '/sign-in',
    message: errorMessage || '로그인에 실패했습니다.',
  })
  if (isDatastarRequest) {
    patchAppToast(datastar, errorMessage || '로그인에 실패했습니다.', 'error')
    return
  }
  redirect('/sign-in', {
    status: 303,
    message: errorMessage || '로그인에 실패했습니다.',
  })
  return
</script>
