<script server>
  const coupleData = resolve('couple-data')
  const { patchAppToast } = resolve('patch-app-toast')

  if (request.method !== 'POST' || !request.auth) {
    patchAppToast(datastar, '로그인이 필요합니다.', 'error')
    return
  }

  const signals = datastar.requestSignals({ photoId: '', photoFilter: 'all' })
  const photoId = String(signals.photoId || '')
  const photoFilter = String(signals.photoFilter || 'all')
  const userId = String(request.auth.get('id') || '')

  dbg('dulkong/xapi/photos/favorite:start', { photoId, userId })

  try {
    const photo = $app.findFirstRecordByFilter('photos', "id = {:photoId} && deletedAt = ''", { photoId })
    photo.set('isFavorite', !photo.get('isFavorite'))
    $app.save(photo)
    info('dulkong/xapi/photos/favorite:success', { photoId, userId, isFavorite: Boolean(photo.get('isFavorite')) })
    datastar.patchElements(include('photo-grid.ejs', { photos: coupleData.listPhotos($app, photoFilter) }), { selector: '#photo-results', mode: 'outer' })
  } catch (exception) {
    error('dulkong/xapi/photos/favorite:failed', { photoId, userId, error: String(exception.message || exception) })
    patchAppToast(datastar, '즐겨찾기를 변경하지 못했어요.', 'error')
  }
</script>
