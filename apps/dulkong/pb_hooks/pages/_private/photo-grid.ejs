<div id="photo-results">
  <section
    class="rounded-[26px] bg-[#302f2a] p-5 text-white"
    aria-labelledby="memory-summary-title">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="m-0 text-xs font-semibold text-white/55">함께 모은 순간</p>
        <h2
          id="memory-summary-title"
          class="mt-1 mb-0 text-2xl font-extrabold">
          <%= photos.length %>장
        </h2>
      </div>
      <span class="text-sm font-semibold text-[#cbe39f]">
        <%= photos.length ? photos[photos.length - 1].takenAt.replace(/-/g, '.') + '부터' : '첫 사진을 기다리는 중' %>
      </span>
    </div>
  </section>

  <section
    class="mt-5"
    aria-label="사진 목록">
    <% if (!photos.length) { %>
    <div class="rounded-[24px] border border-dashed border-[#d9d7cc] bg-white/65 px-5 py-12 text-center">
      <span
        class="i-lucide-image-plus mx-auto block h-9 w-9 text-[#9bb471]"
        aria-hidden="true"></span>
      <p class="mt-3 mb-0 text-sm font-extrabold text-[#55554d]">아직 모은 사진이 없어요.</p>
      <p class="mt-1 mb-0 text-xs text-[#99988e]">오늘의 순간을 첫 추억으로 올려 보세요.</p>
    </div>
    <% } else { %>
    <div class="grid grid-cols-2 gap-3">
      <% photos.forEach(function (photo) { %>
      <article class="photo-card group relative aspect-square overflow-hidden rounded-[24px] bg-[#e8e6dc]">
        <img
          src="<%= photo.imageUrl %>"
          alt="<%= photo.caption %>"
          class="h-full w-full object-cover"
          loading="lazy" />
        <div
          class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/65 to-transparent px-3 pt-10 pb-3 text-white">
          <p class="m-0 truncate text-sm font-extrabold"><%= photo.caption %></p>
          <p class="mt-0.5 mb-0 text-[11px] font-semibold text-white/75">
            <%= photo.dateLabel %><%= photo.locationName ? ' · ' + photo.locationName : '' %>
          </p>
        </div>
        <button
          type="button"
          data-on:click="$photoViewerUrl = <%= stringify(photo.imageUrl) %>; $photoViewerCaption = <%= stringify(photo.caption) %>; $photoViewerMeta = <%= stringify(photo.dateLabel + (photo.locationName ? ' · ' + photo.locationName : '')) %>; $photoViewerOpen = true"
          class="photo-viewer-trigger absolute inset-0 cursor-zoom-in rounded-[24px] border-0 bg-transparent"
          aria-label="<%= photo.caption %> 크게 보기"></button>
        <button
          type="button"
          data-on:click__stop="@post('/xapi/photos/favorite', {payload: {photoId: '<%= photo.id %>', photoFilter: $photoFilter}})"
          class="photo-favorite-button <%= photo.isFavorite ? 'photo-favorite-button--active' : '' %> absolute top-2 right-2 flex h-8 w-8 items-center justify-center rounded-full border-0 bg-black/28 text-white backdrop-blur-sm"
          aria-pressed="<%= photo.isFavorite ? 'true' : 'false' %>"
          aria-label="즐겨찾기 <%= photo.isFavorite ? '해제' : '추가' %>">
          <% if (photo.isFavorite) { %>
          <span
            class="photo-favorite-heart"
            aria-hidden="true">
            ♥
          </span>
          <% } else { %>
          <span
            class="i-lucide-heart h-4 w-4"
            aria-hidden="true"></span>
          <% } %>
        </button>
      </article>
      <% }) %>
    </div>
    <% } %>
  </section>
</div>
