<main
  id="message-list"
  class="message-list--positioning min-h-0 flex-1 overflow-y-auto px-5 py-5"
  data-on:scroll__throttle.100ms="$chatAtBottom = evt.currentTarget.scrollHeight - evt.currentTarget.scrollTop - evt.currentTarget.clientHeight < 48"
  aria-live="polite">
  <% if (!messages.length) { %>
  <div class="flex h-full min-h-64 flex-col items-center justify-center text-center">
    <span
      class="flex h-15 w-15 items-center justify-center rounded-full bg-[#e7efd8] text-2xl"
      aria-hidden="true"
      >💬</span
    >
    <p class="mt-4 mb-0 text-sm font-extrabold text-[#55554d]">아직 대화가 없어요.</p>
    <p class="mt-1 mb-0 text-xs text-[#99988e]"><%= partnerName %>님에게 첫 인사를 보내 보세요.</p>
  </div>
  <% } else { %>
  <div
    id="message-history-sentinel"
    data-show="$messageHasMore"
    data-on-intersect="if (document.getElementById('message-list').dataset.ready === 'true' && $messageHasMore && !$messageHistoryLoading) { $messageHistoryLoading = true; @get('/xapi/messages/history') }"
    class="flex h-10 items-center justify-center text-[11px] font-semibold text-[#99988e]">
    <span data-show="!$messageHistoryLoading">이전 대화 불러오기</span>
    <span data-show="$messageHistoryLoading">이전 대화 불러오는 중…</span>
  </div>
  <div
    id="message-rows"
    class="space-y-4">
    <%- include('message-rows.ejs', { messages }) %>
  </div>
  <% } %>
</main>
