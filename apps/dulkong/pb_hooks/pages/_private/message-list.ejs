<main
  id="message-list"
  class="min-h-0 flex-1 overflow-y-auto px-5 py-5"
  aria-live="polite">
  <% if (!messages.length) { %>
  <div class="flex h-full min-h-64 flex-col items-center justify-center text-center">
    <span
      class="flex h-15 w-15 items-center justify-center rounded-full bg-[#e7efd8] text-2xl"
      aria-hidden="true"
      >💬</span
    >
    <p class="mt-4 mb-0 text-sm font-extrabold text-[#55554d]">아직 대화가 없어요.</p>
    <p class="mt-1 mb-0 text-xs text-[#99988e]"><%= partnerName %>님에게 첫 인사를 보내 보세요.</p>
  </div>
  <% } else { %>
  <div class="space-y-4">
    <% messages.forEach(function (message) { %>
    <div
      id="message-<%= message.id %>"
      class="<%= message.mine ? 'justify-end' : '' %> flex items-end gap-2">
      <% if (message.mine) { %><time class="mb-1 text-[10px] font-semibold text-[#aaa99f]"><%= message.timeLabel %></time><% } %>
      <div
        class="<%= message.mine ? 'rounded-[18px_18px_6px_18px] bg-[#cfe5a6] text-[#30421d]' : 'rounded-[18px_18px_18px_6px] bg-white' %> max-w-[76%] px-3.5 py-2.5 text-sm leading-5 break-words whitespace-pre-wrap shadow-[0_5px_16px_rgba(58,59,51,0.06)]">
        <%= message.body %>
      </div>
      <% if (!message.mine) { %><time class="mb-1 text-[10px] font-semibold text-[#aaa99f]"><%= message.timeLabel %></time><% } %>
    </div>
    <% }) %>
  </div>
  <% } %>
</main>
