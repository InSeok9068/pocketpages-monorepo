<script server>
  const coupleData = resolve('couple-data')
  const profiles = coupleData.getCoupleProfiles($app, request.auth)
  const messagePage = coupleData.getMessagePage($app, profiles.current.id, { limit: 50 })
  const messages = messagePage.messages
  const oldestMessage = messages.length ? messages[0] : null

  meta('title', '대화 | 둘콩')
  meta('description', '우리 둘만의 실시간 대화')
</script>

<div
  class="relative mx-auto flex h-[100dvh] w-full max-w-[480px] flex-col bg-[#f7f5ee] text-[#292923] shadow-[0_0_60px_rgba(70,76,53,0.08)]"
  data-signals="<%= stringify({ draft: '', clientMessageId: '', chatRevision: 0, chatHandledRevision: 0, chatSending: false, chatAtBottom: true, chatHasNewMessage: false, messageHasMore: messagePage.hasMore, messageHistoryLoading: false, oldestMessageCreated: oldestMessage ? oldestMessage.createdAt : '', oldestMessageId: oldestMessage ? oldestMessage.id : '' }) %>"
  data-effect="if ($chatRevision && $chatRevision !== $chatHandledRevision) { $chatHandledRevision = $chatRevision; if ($chatAtBottom) @get('/xapi/messages/list'); else $chatHasNewMessage = true }">
  <header class="shrink-0 border-b border-[#e8e5da] bg-[#fbfaf6]/92 px-5 pt-[max(1rem,env(safe-area-inset-top))] pb-3 backdrop-blur-md">
    <div class="flex items-center gap-3">
      <span
        class="<%= profiles.partner.colorClass %> relative flex h-11 w-11 items-center justify-center rounded-full text-lg"
        aria-hidden="true">
        <%= profiles.partner.emoji %>
      </span>
      <div>
        <h1 class="m-0 text-[17px] font-extrabold"><%= profiles.partner.name %></h1>
        <p class="mt-0.5 mb-0 flex items-center gap-1.5 text-xs font-semibold text-[#779550]">
          <span class="h-1.5 w-1.5 rounded-full bg-[#82ae4d]"></span>
          둘콩으로 연결됨
        </p>
      </div>
    </div>
  </header>

  <%- include('message-list.ejs', { messages, partnerName: profiles.partner.name }) %>

  <button
    type="button"
    data-show="$chatHasNewMessage"
    data-on:click="$chatHasNewMessage = false; @get('/xapi/messages/list')"
    class="chat-new-message-button flex items-center gap-1.5 rounded-full border-0 bg-[#354922] px-4 py-2.5 text-xs font-extrabold text-white shadow-[0_10px_28px_rgba(53,73,34,0.24)]">
    새 메시지
    <span aria-hidden="true">↓</span>
  </button>

  <form
    method="post"
    action="/xapi/messages/send"
    data-on:submit__prevent="if (!$chatSending) { $chatSending = true; $clientMessageId = 'web_' + Date.now(); @post('/xapi/messages/send') }"
    class="shrink-0 border-t border-[#e8e5da] bg-[#fffefa] px-4 pt-3 pb-[calc(4.75rem+env(safe-area-inset-bottom))]">
    <div class="flex items-end gap-2">
      <label class="min-w-0 flex-1">
        <span class="sr-only">메시지</span>
        <textarea
          id="chat-draft"
          data-bind:draft
          rows="1"
          maxlength="5000"
          class="box-border max-h-28 min-h-11 w-full resize-none rounded-[22px] border border-[#e4e1d6] bg-[#f7f5ef] px-4 py-3 text-sm outline-none focus:border-[#9fbd6f]"
          placeholder="메시지를 입력하세요"></textarea>
      </label>
      <button
        type="submit"
        data-attr:disabled="$chatSending || !$draft.trim()"
        class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border-0 bg-[#354922] text-white disabled:opacity-35"
        aria-label="메시지 보내기">
        <span class="i-lucide-arrow-up h-5 w-5"></span>
      </button>
    </div>
  </form>

  <script>
    window.dulkongScrollChatToBottom = function () {
      requestAnimationFrame(function () {
        var list = document.getElementById('message-list')
        if (!list) return
        list.scrollTop = list.scrollHeight
        list.classList.remove('message-list--positioning')
        list.dataset.ready = 'true'
      })
    }

    window.dulkongScrollChatToBottom()
    if (document.readyState !== 'complete') window.addEventListener('load', window.dulkongScrollChatToBottom, { once: true })
    setTimeout(window.dulkongScrollChatToBottom, 100)
  </script>
  <%- include('app-bottom-nav.ejs', { currentPath: '/chat' }) %>
</div>
