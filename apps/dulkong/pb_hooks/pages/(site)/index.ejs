<script server>
  const { dateutil } = require('@pocketpages/utils')
  const coupleData = resolve('couple-data')
  const profiles = coupleData.getCoupleProfiles($app, request.auth)
  const anniversaries = coupleData.listAnniversaries($app)
  const relationship =
    anniversaries.filter(function (item) {
      return item.kind === 'relationship_start'
    })[0] || null
  const nextAnniversary =
    anniversaries.filter(function (item) {
      return item.kind !== 'relationship_start' && item.difference >= 0
    })[0] || null
  const recentPhotos = coupleData.listPhotos($app, 'all').slice(0, 3)
  const recentMessages = coupleData.listMessages($app, profiles.current.id)
  const lastMessage = recentMessages.length ? recentMessages[recentMessages.length - 1] : null
  const todayLabel = dateutil.formatDate(new Date(), 'M월 D일')

  meta('title', '둘콩 | 우리 둘의 공간')
  meta('description', '커플의 기념일과 사진, 대화를 함께 모아보는 둘콩')
</script>

<div
  id="home"
  class="mx-auto min-h-[100dvh] w-full max-w-[480px] bg-[#fbfaf6] text-[#292923] shadow-[0_0_60px_rgba(70,76,53,0.08)]">
  <div class="px-5 pt-[max(1.25rem,env(safe-area-inset-top))] pb-30">
    <header class="flex items-center justify-between py-2">
      <a
        href="#home"
        class="inline-flex items-center gap-2 text-[#292923] no-underline"
        aria-label="둘콩 홈"
        ><span class="flex h-9 w-9 items-center justify-center rounded-[14px] bg-[#b9d986] text-[#33451e] shadow-[0_6px_16px_rgba(92,120,51,0.18)]"
          ><span class="i-lucide-heart h-4.5 w-4.5"></span></span
        ><span class="text-xl font-extrabold tracking-[-0.04em]">둘콩</span></a
      >
      <span class="rounded-full bg-white px-3 py-2 text-xs font-bold text-[#71834f] shadow-[0_5px_18px_rgba(58,59,51,0.08)]"><%= profiles.current.name %></span>
    </header>

    <main class="mt-5 space-y-7">
      <section aria-labelledby="welcome-title">
        <p class="m-0 text-sm font-semibold text-[#85857a]"><%= todayLabel %></p>
        <h1
          id="welcome-title"
          class="mt-2 mb-0 text-[28px] leading-[1.28] font-extrabold tracking-[-0.045em]">
          오늘도 우리답게 <span aria-hidden="true">🌱</span>
        </h1>
      </section>

      <section
        class="relative overflow-hidden rounded-[28px] bg-[#dcebbf] p-6 shadow-[0_16px_36px_rgba(92,112,57,0.15)]"
        aria-labelledby="anniversary-title">
        <div class="absolute -top-8 -right-4 h-34 w-34 rounded-full bg-white/24"></div>
        <div class="absolute right-16 -bottom-12 h-26 w-26 rounded-full bg-[#bdd78d]/55"></div>
        <div class="relative flex items-start justify-between gap-4">
          <div>
            <p class="m-0 text-sm font-bold text-[#5b7040]">우리가 함께한 지</p>
            <h2
              id="anniversary-title"
              class="mt-2 mb-0 text-[38px] leading-none font-black tracking-[-0.055em] text-[#2f401e]">
              <%= relationship ? relationship.dayLabel.slice(1) + '일' : '첫날 대기 중' %>
            </h2>
          </div>
          <span class="flex h-12 w-12 items-center justify-center rounded-[18px] bg-white/65 text-[#567336]"><span class="i-lucide-calendar-heart h-6 w-6"></span></span>
        </div>
        <div class="relative mt-8 flex items-center justify-between border-t border-[#9fbd6f]/45 pt-4">
          <div>
            <p class="m-0 text-xs font-semibold text-[#6d8053]">다음 기념일</p>
            <p class="mt-1 mb-0 text-sm font-extrabold text-[#3a4d25]"><%= nextAnniversary ? nextAnniversary.title + ' · ' + nextAnniversary.dayLabel : '우리의 날을 추가해 보세요' %></p>
          </div>
          <a
            href="/us"
            class="inline-flex h-9 items-center gap-1 rounded-full bg-[#354922] px-3.5 text-xs font-bold text-white no-underline"
            >관리 <span class="i-lucide-chevron-right h-3.5 w-3.5"></span
          ></a>
        </div>
      </section>

      <section aria-label="바로가기">
        <div class="grid grid-cols-2 gap-3">
          <a
            href="/memories"
            class="flex items-center gap-3 rounded-[22px] border border-[#ebe9df] bg-white p-4 text-inherit no-underline shadow-[0_8px_24px_rgba(48,49,43,0.055)]"
            ><span class="flex h-11 w-11 items-center justify-center rounded-[16px] bg-[#fff0e7] text-[#d27355]"><span class="i-lucide-camera h-5 w-5"></span></span
            ><span><span class="block text-[13px] font-bold text-[#88877d]">오늘의</span><span class="block text-[15px] font-extrabold">사진 올리기</span></span></a
          ><a
            href="/chat"
            class="flex items-center gap-3 rounded-[22px] border border-[#ebe9df] bg-white p-4 text-inherit no-underline shadow-[0_8px_24px_rgba(48,49,43,0.055)]"
            ><span class="flex h-11 w-11 items-center justify-center rounded-[16px] bg-[#e9f0ff] text-[#627fb5]"><span class="i-lucide-message-circle h-5 w-5"></span></span
            ><span><span class="block text-[13px] font-bold text-[#88877d]"><%= profiles.partner.name %>에게</span><span class="block text-[15px] font-extrabold">대화 보내기</span></span></a
          >
        </div>
      </section>

      <section aria-labelledby="memory-title">
        <div class="mb-3 flex items-center justify-between">
          <div>
            <p class="m-0 text-xs font-bold tracking-[0.08em] text-[#98a081]">우리의 기록</p>
            <h2
              id="memory-title"
              class="mt-1 mb-0 text-xl font-extrabold">
              최근 사진
            </h2>
          </div>
          <a
            href="/memories"
            class="p-2 text-sm font-bold text-[#71834f] no-underline"
            >전체보기</a
          >
        </div>
        <% if (recentPhotos.length) { %>
        <div class="grid grid-cols-3 gap-2.5">
          <% recentPhotos.forEach(function (photo) { %><a
            href="/memories"
            class="relative aspect-[0.84] overflow-hidden rounded-[20px]"
            ><img
              src="<%= photo.imageUrl %>"
              alt="<%= photo.caption %>"
              class="h-full w-full object-cover" /><span class="absolute inset-x-0 bottom-0 truncate bg-gradient-to-t from-black/65 to-transparent px-2 pt-8 pb-2 text-[11px] font-bold text-white"
              ><%= photo.caption %></span
            ></a
          ><% }) %>
        </div>
        <% } else { %><a
          href="/memories"
          class="flex min-h-28 flex-col items-center justify-center rounded-[22px] border border-dashed border-[#d9d7cc] bg-white/60 text-center no-underline"
          ><span class="i-lucide-image-plus h-6 w-6 text-[#9bb471]"></span><span class="mt-2 text-sm font-bold text-[#77766d]">첫 사진을 올려 보세요</span></a
        ><% } %>
      </section>

      <section aria-labelledby="chat-title">
        <div class="mb-3">
          <p class="m-0 text-xs font-bold tracking-[0.08em] text-[#98a081]">둘만의 이야기</p>
          <h2
            id="chat-title"
            class="mt-1 mb-0 text-xl font-extrabold">
            최근 대화
          </h2>
        </div>
        <a
          href="/chat"
          class="block rounded-[24px] border border-[#ebe9df] bg-white p-4 text-inherit no-underline shadow-[0_9px_26px_rgba(48,49,43,0.06)]"
          ><div class="flex items-center gap-3">
            <span class="<%= profiles.partner.colorClass %> flex h-12 w-12 items-center justify-center rounded-full text-xl"><%= profiles.partner.emoji %></span>
            <div class="min-w-0 flex-1">
              <div class="flex justify-between gap-3">
                <strong class="text-[15px]"><%= profiles.partner.name %></strong><time class="text-[11px] text-[#aaa99f]"><%= lastMessage ? lastMessage.timeLabel : '' %></time>
              </div>
              <p class="mt-1 mb-0 truncate text-sm text-[#77766d]"><%= lastMessage ? lastMessage.body : '아직 대화가 없어요. 첫 인사를 보내 보세요.' %></p>
            </div>
            <span class="i-lucide-chevron-right h-4.5 w-4.5 text-[#b3b2a8]"></span></div
        ></a>
      </section>
    </main>
  </div>
  <%- include('app-bottom-nav.ejs', { currentPath: '/' }) %>
</div>
