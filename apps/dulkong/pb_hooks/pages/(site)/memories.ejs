<script server>
  const coupleData = resolve('couple-data')
  const currentYear = String(new Date().getFullYear())
  const previousYear = String(Number(currentYear) - 1)
  const photos = coupleData.listPhotos($app, 'all')

  meta('title', '추억 | 둘콩')
  meta('description', '우리 둘의 사진과 추억')
</script>

<div
  class="mx-auto min-h-[100dvh] w-full max-w-[480px] bg-[#fbfaf6] text-[#292923] shadow-[0_0_60px_rgba(70,76,53,0.08)]"
  data-signals="<%= stringify({ photoModalOpen: false, photoFilter: 'all', photoViewerOpen: false, photoViewerUrl: '', photoViewerCaption: '', photoViewerMeta: '' }) %>">
  <div class="px-5 pt-[max(1.25rem,env(safe-area-inset-top))] pb-30">
    <header class="flex items-center justify-between py-2">
      <div>
        <p class="m-0 text-xs font-bold tracking-[0.1em] text-[#98a081]">우리의 기록</p>
        <h1 class="mt-1 mb-0 text-[28px] font-extrabold tracking-[-0.045em]">추억</h1>
      </div>
      <button
        type="button"
        data-on:click="$photoModalOpen = true"
        class="flex h-11 w-11 items-center justify-center rounded-[16px] border-0 bg-[#dcebbf] text-[#4e672f] shadow-[0_6px_18px_rgba(92,112,57,0.15)]"
        aria-label="사진 추가">
        <span
          class="i-lucide-plus h-5 w-5"
          aria-hidden="true"></span>
      </button>
    </header>

    <main class="mt-6">
      <div
        class="mb-5 flex gap-2 overflow-x-auto pb-1"
        aria-label="추억 기간 필터">
        <% [{ value: 'all', label: '전체' }, { value: currentYear, label: currentYear + '년' }, { value: previousYear, label: previousYear + '년' }, { value: 'favorite', label: '즐겨찾기' }].forEach(function (filter) { %>
        <button
          type="button"
          data-on:click="$photoFilter = '<%= filter.value %>'; @get('/xapi/photos/list')"
          data-class="{'bg-[#354922] text-white': $photoFilter === '<%= filter.value %>', 'bg-[#efede5] text-[#77766d]': $photoFilter !== '<%= filter.value %>'}"
          class="shrink-0 rounded-full border-0 px-4 py-2 text-sm font-bold">
          <%= filter.label %>
        </button>
        <% }) %>
      </div>
      <%- include('photo-grid.ejs', { photos }) %>
    </main>
  </div>

  <div
    data-show="$photoModalOpen"
    class="fixed inset-0 z-60 flex items-end justify-center bg-black/35 px-3"
    data-on:click="$photoModalOpen = false">
    <section
      class="mb-[max(0.75rem,env(safe-area-inset-bottom))] max-h-[calc(100dvh-1.5rem)] w-full max-w-[456px] overflow-y-auto rounded-[28px] bg-[#fffefa] p-5 shadow-[0_24px_70px_rgba(30,31,27,0.28)]"
      data-on:click__stop="true">
      <div class="mb-4 flex items-center justify-between">
        <div>
          <p class="m-0 text-xs font-bold text-[#98a081]">새 추억</p>
          <h2 class="mt-1 mb-0 text-xl font-extrabold">사진 올리기</h2>
        </div>
        <button
          type="button"
          data-on:click="$photoModalOpen = false"
          class="flex h-9 w-9 items-center justify-center rounded-full border-0 bg-[#f0eee7]"
          aria-label="닫기">
          <span class="i-lucide-x h-4 w-4"></span>
        </button>
      </div>
      <form
        id="photo-upload-form"
        method="post"
        action="/xapi/photos/upload"
        enctype="multipart/form-data"
        data-on:submit__prevent="@post('/xapi/photos/upload', {contentType: 'form'})"
        class="space-y-3">
        <input
          id="photo-image"
          class="filepond"
          type="file"
          name="image"
          accept="image/jpeg,image/png,image/webp,image/heic,image/heif"
          required />
        <input
          type="text"
          name="caption"
          maxlength="1000"
          placeholder="이 순간의 한마디"
          class="box-border w-full rounded-[18px] border border-[#e4e1d6] bg-[#f7f5ef] px-4 py-3 text-sm outline-none focus:border-[#9fbd6f]" />
        <div class="grid grid-cols-2 gap-2">
          <input
            type="date"
            name="takenAt"
            class="box-border min-w-0 rounded-[18px] border border-[#e4e1d6] bg-[#f7f5ef] px-3 py-3 text-sm outline-none" />
          <input
            type="text"
            name="locationName"
            maxlength="120"
            placeholder="장소(선택)"
            class="box-border min-w-0 rounded-[18px] border border-[#e4e1d6] bg-[#f7f5ef] px-3 py-3 text-sm outline-none" />
        </div>
        <button
          type="submit"
          class="h-12 w-full rounded-[18px] border-0 bg-[#354922] text-sm font-extrabold text-white">
          추억으로 저장
        </button>
      </form>
    </section>
  </div>

  <div
    data-show="$photoViewerOpen"
    class="fixed inset-0 z-80 flex items-center justify-center bg-[#181914]/94 px-4 pt-[max(1rem,env(safe-area-inset-top))] pb-[max(1rem,env(safe-area-inset-bottom))] backdrop-blur-sm"
    data-on:click="$photoViewerOpen = false">
    <section
      class="relative flex max-h-full w-full max-w-[720px] flex-col items-center justify-center"
      data-on:click__stop="true"
      aria-label="확대된 추억 사진">
      <button
        type="button"
        data-on:click="$photoViewerOpen = false"
        class="absolute top-0 right-0 z-10 flex h-10 w-10 items-center justify-center rounded-full border-0 bg-white/12 text-white backdrop-blur-md"
        aria-label="사진 닫기">
        <span
          class="i-lucide-x h-5 w-5"
          aria-hidden="true"></span>
      </button>
      <img
        data-attr:src="$photoViewerUrl"
        data-attr:alt="$photoViewerCaption"
        class="max-h-[calc(100dvh-10rem)] max-w-full rounded-[24px] object-contain shadow-[0_24px_80px_rgba(0,0,0,0.38)]" />
      <div class="mt-4 w-full max-w-[560px] text-center text-white">
        <p
          class="m-0 text-base font-extrabold"
          data-text="$photoViewerCaption"></p>
        <p
          class="mt-1 mb-0 text-xs font-semibold text-white/55"
          data-text="$photoViewerMeta"></p>
      </div>
    </section>
  </div>

  <%- include('app-bottom-nav.ejs', { currentPath: '/memories' }) %>
</div>

<script>
  ;(function () {
    var input = document.getElementById('photo-image')
    if (!input || !window.FilePond || window.FilePond.find(input)) return

    if (!window.dulkongFilePondReady) {
      window.FilePond.registerPlugin(window.FilePondPluginImagePreview)
      window.dulkongFilePondReady = true
    }

    window.dulkongPhotoPond = window.FilePond.create(input, {
      storeAsFile: true,
      allowMultiple: false,
      allowProcess: false,
      credits: false,
      imagePreviewHeight: 180,
      labelIdle: '<span class="filepond-label"><span class="i-lucide-image-plus filepond-label-icon"></span><strong>사진 선택</strong><small>눌러서 고르거나 이곳에 놓아주세요</small></span>',
      labelFileWaitingForSize: '사진 확인 중',
      labelFileLoading: '사진 불러오는 중',
      labelFileLoadError: '사진을 불러오지 못했어요',
      labelFileRemoveError: '사진을 제거하지 못했어요',
      labelButtonRemoveItem: '사진 제거',
      labelTapToCancel: '눌러서 취소',
      labelTapToRetry: '눌러서 다시 시도',
      labelTapToUndo: '눌러서 되돌리기',
    })
  })()
</script>
