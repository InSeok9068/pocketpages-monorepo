<script server>
  const bookId = String(params.bookId || '').trim()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''

  if (!request.auth) {
    warn('xapi/books/[bookId]/read-file:unauthorized', {
      bookId: bookId,
    })
    response.html(401, '로그인이 필요합니다.')
    return
  }

  if (!bookId) {
    response.html(400, '책 정보가 필요합니다.')
    return
  }

  let shelfRecord = null
  let bookFileRecord = null

  /**
   * ETag에 안전한 값을 만듭니다.
   *
   * @param {string} value 파일 식별 값
   * @returns {string} HTTP ETag 값
   */
  function buildEtag(value) {
    return (
      '"' +
      String(value || '')
        .replace(/\\/g, '\\\\')
        .replace(/"/g, '\\"') +
      '"'
    )
  }

  /**
   * 조건부 요청 헤더가 현재 ETag와 맞는지 확인합니다.
   *
   * @param {string} headerValue If-None-Match 헤더
   * @param {string} etag 현재 ETag
   * @returns {boolean} 캐시 재사용 가능 여부
   */
  function matchesEtag(headerValue, etag) {
    const normalizedHeaderValue = String(headerValue || '').trim()
    const normalizedEtag = String(etag || '').trim()

    if (!normalizedHeaderValue || !normalizedEtag) {
      return false
    }

    if (normalizedHeaderValue === '*') {
      return true
    }

    return normalizedHeaderValue.split(',').some(function (candidate) {
      const normalizedCandidate = String(candidate || '').trim()

      return normalizedCandidate === normalizedEtag || normalizedCandidate === 'W/' + normalizedEtag
    })
  }

  try {
    shelfRecord = $app.findFirstRecordByFilter('book_shelves', 'user_id = {:userId} && book_id = {:bookId}', {
      userId: userId,
      bookId: bookId,
    })
  } catch (exception) {
    shelfRecord = null
  }

  const shelfBookFileId = shelfRecord ? String(shelfRecord.get('book_file_id') || '').trim() : ''

  if (shelfBookFileId) {
    try {
      bookFileRecord = $app.findFirstRecordByFilter('book_files', 'id = {:bookFileId}', {
        bookFileId: shelfBookFileId,
      })
    } catch (exception) {
      bookFileRecord = null
    }
  }

  if (!bookFileRecord) {
    response.html(404, 'EPUB 파일을 찾을 수 없습니다.')
    return
  }

  const storedFileName = String(bookFileRecord.get('stored_file') || '').trim()

  if (!storedFileName) {
    response.html(404, 'EPUB 파일을 찾을 수 없습니다.')
    return
  }

  const storageFileKey = String(bookFileRecord.baseFilesPath() || '') + '/' + storedFileName
  const localFilePath = String($app.dataDir() || '') + '/storage/' + storageFileKey
  const fileHash = String(bookFileRecord.get('file_hash') || '').trim()
  const fileSizeValue = bookFileRecord.get('file_size')
  const fileSize = fileSizeValue === null || typeof fileSizeValue === 'undefined' ? '' : String(fileSizeValue)
  const etagSource = fileHash || [String(bookFileRecord.get('id') || ''), storedFileName, fileSize].join(':')
  const etag = buildEtag('booklog-epub:' + etagSource)
  const ifNoneMatch = request.header('If-None-Match')

  dbg('xapi/books/[bookId]/read-file:serve', {
    userId: userId,
    bookId: bookId,
    bookFileId: String(bookFileRecord.get('id') || ''),
    fileKey: storageFileKey,
    filePath: localFilePath,
    etag: etag,
  })

  response.header('Cache-Control', 'private, max-age=0, must-revalidate')
  response.header('Content-Type', 'application/epub+zip')
  response.header('ETag', etag)
  response.header('Vary', 'Cookie')

  if (matchesEtag(ifNoneMatch, etag)) {
    dbg('xapi/books/[bookId]/read-file:not-modified', {
      userId: userId,
      bookId: bookId,
      bookFileId: String(bookFileRecord.get('id') || ''),
      etag: etag,
    })
    response.status(304)
    return
  }

  response.file(localFilePath)
  return
</script>
