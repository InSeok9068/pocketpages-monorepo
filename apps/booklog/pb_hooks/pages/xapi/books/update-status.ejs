<script server>
  if (request.method !== 'POST') {
    dbg('xapi/books/update-status:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '잘못된 요청입니다.',
    })
    redirect('/', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    dbg('xapi/books/update-status:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const form = body()
  const userId = String(request.auth.get('id') || '')
  const bookId = String(form.bookId || '').trim()
  const bookDetailPath = '/books/' + bookId
  const status = String(form.status || '').trim()
  const today = new Date().toISOString().slice(0, 10)
  let errorMessage = ''

  dbg('xapi/books/update-status:start', {
    userId: userId,
    bookId: bookId,
    status: status,
  })

  try {
    if (!bookId) throw new Error('책 정보가 필요합니다.')
    if (status !== 'queued' && status !== 'reading' && status !== 'finished') throw new Error('변경할 수 없는 상태입니다.')

    const bookRecord = $app.findFirstRecordByFilter('books', 'id = {:bookId}', { bookId: bookId })
    let shelfRecord = null

    try {
      shelfRecord = $app.findFirstRecordByFilter('book_shelves', 'user_id = {:userId} && book_id = {:bookId}', {
        userId: userId,
        bookId: bookId,
      })
    } catch (exception) {
      shelfRecord = null
    }

    if (!shelfRecord && status === 'queued') {
      dbg('xapi/books/update-status:redirect', {
        status: 303,
        redirectTo: bookDetailPath,
        flash: '읽을 예정으로 되돌렸습니다.',
      })
      redirect(bookDetailPath, {
        status: 303,
        message: '읽을 예정으로 되돌렸습니다.',
      })
      return
    }

    if (!shelfRecord) {
      const collection = $app.findCollectionByNameOrId('book_shelves')
      shelfRecord = new Record(collection)
      shelfRecord.set('user_id', userId)
      shelfRecord.set('book_id', String(bookRecord.get('id') || ''))
    }

    shelfRecord.set('status', status)
    shelfRecord.set('last_read_at', today)

    if (status === 'queued') {
      shelfRecord.set('started_at', '')
      shelfRecord.set('finished_at', '')
      shelfRecord.set('progress_percent', 0)
    }

    if (status === 'reading') {
      if (!String(shelfRecord.get('started_at') || '').trim()) {
        shelfRecord.set('started_at', today)
      }
      shelfRecord.set('finished_at', '')
    }

    if (status === 'finished') {
      if (!String(shelfRecord.get('started_at') || '').trim()) {
        shelfRecord.set('started_at', today)
      }
      shelfRecord.set('finished_at', today)
      shelfRecord.set('progress_percent', 100)
    }

    $app.save(shelfRecord)

    let flashMessage = '읽는 중으로 표시했습니다.'

    if (status === 'finished') {
      flashMessage = '다 읽음으로 표시했습니다.'
    }

    if (status === 'queued') {
      flashMessage = '읽을 예정으로 되돌렸습니다.'
    }

    dbg('xapi/books/update-status:redirect', {
      status: 303,
      redirectTo: bookDetailPath,
      flash: flashMessage,
    })
    redirect(bookDetailPath, {
      status: 303,
      message: flashMessage,
    })
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('xapi/books/update-status:failed', {
      userId: userId,
      bookId: bookId,
      status: status,
      error: errorMessage,
    })
  }

  dbg('xapi/books/update-status:redirect', {
    status: 303,
    redirectTo: bookId ? bookDetailPath : '/',
    error: errorMessage || '상태 변경에 실패했습니다.',
  })
  redirect(bookId ? bookDetailPath : '/', {
    status: 303,
    message: errorMessage || '상태 변경에 실패했습니다.',
  })
</script>
