<script server>
  if (request.method !== 'POST') {
    dbg('xapi/books/delete-review:redirect', {
      status: 303,
      redirectTo: '/',
      message: '잘못된 요청입니다.',
    })
    redirect('/', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    dbg('xapi/books/delete-review:redirect', {
      status: 303,
      redirectTo: '/auth',
      message: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const form = body()
  const userId = String(request.auth.get('id') || '')
  const bookId = String(form.bookId || '').trim()
  const fromPath = String(form.from || '').trim()
  let bookDetailPath = '/books/' + bookId
  let errorMessage = ''

  if (fromPath === '/' || fromPath === '/library' || fromPath === '/reviews' || fromPath === '/highlights') {
    bookDetailPath += '?from=' + encodeURIComponent(fromPath)
  }

  dbg('xapi/books/delete-review:start', {
    userId: userId,
    bookId: bookId,
  })

  try {
    if (!bookId) throw new Error('책 정보가 필요합니다.')

    const reviewRecord = $app.findFirstRecordByFilter('book_reviews', 'user_id = {:userId} && book_id = {:bookId}', {
      userId: userId,
      bookId: bookId,
    })

    $app.delete(reviewRecord)

    dbg('xapi/books/delete-review:redirect', {
      status: 303,
      redirectTo: bookDetailPath,
      message: '감상평을 삭제했습니다.',
    })
    redirect(bookDetailPath, {
      status: 303,
      message: '감상평을 삭제했습니다.',
    })
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('xapi/books/delete-review:failed', {
      userId: userId,
      bookId: bookId,
      error: errorMessage,
    })
  }

  dbg('xapi/books/delete-review:redirect', {
    status: 303,
    redirectTo: bookId ? bookDetailPath : '/',
    error: errorMessage || '감상평 삭제에 실패했습니다.',
  })
  redirect(bookId ? bookDetailPath : '/', {
    status: 303,
    message: errorMessage || '감상평 삭제에 실패했습니다.',
  })
  return
</script>
