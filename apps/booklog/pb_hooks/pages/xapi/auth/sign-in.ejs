<script server>
  const booklogAuthCookie = resolve('booklog-auth-cookie')
  if (request.method !== 'POST') {
    dbg('xapi/auth/sign-in:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '잘못된 요청입니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  const form = body()
  const email = String(form.email || '')
    .trim()
    .toLowerCase()
  const password = form.password === undefined || form.password === null ? '' : String(form.password)
  let errorMessage = ''

  dbg('xapi/auth/sign-in:start', {
    email: email,
  })

  try {
    if (!email) throw new Error('이메일이 필요합니다.')
    if (!password) throw new Error('비밀번호가 필요합니다.')

    const authData = booklogAuthCookie.authenticateWithPassword(env, email, password)
    booklogAuthCookie.writePersistedAuthCookie(response, authData, env)

    dbg('xapi/auth/sign-in:response', {
      status: 303,
      redirectTo: '/',
      flash: '로그인 완료',
      authId: String((authData.record && authData.record.id) || ''),
    })
    redirect('/', {
      status: 303,
      message: '로그인 완료',
    })
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('xapi/auth/sign-in:failed', {
      email: email,
      error: errorMessage,
    })
  }

  dbg('xapi/auth/sign-in:response', {
    status: 303,
    redirectTo: '/auth',
    error: errorMessage || '로그인에 실패했습니다.',
  })
  redirect('/auth', {
    status: 303,
    message: errorMessage || '로그인에 실패했습니다.',
  })
</script>
