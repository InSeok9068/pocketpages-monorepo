<script server>
  const { dateutil } = require('@pocketpages/utils')

  if (request.method !== 'GET') {
    dbg('xapi/highlights-more:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '잘못된 요청입니다.',
    })
    redirect('/', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    dbg('xapi/highlights-more:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const queryText = String(request.url.query.q || '').trim()
  const requestedOffset = Number(request.url.query.offset || 30)
  const maxHighlightLimit = 5000
  const pageLimit = 30
  const pageOffset = isNaN(requestedOffset) || requestedOffset < 0 ? 30 : Math.min(Math.round(requestedOffset), maxHighlightLimit)
  const nextOffset = Math.min(pageOffset + pageLimit, maxHighlightLimit)
  const nextVisibleLimit = Math.min(nextOffset + pageLimit, maxHighlightLimit)
  const highlightItems = []
  const normalizedQuery = queryText.toLowerCase()

  /**
   * 문구 조회 조건을 붙입니다.
   *
   * @param {object} query 쿼리 빌더
   * @returns {object} 쿼리 빌더
   */
  function applyHighlightWhere(query) {
    query.where($dbx.exp('book_highlights.user_id = {:userId}', { userId: request.auth.get('id') }))

    if (normalizedQuery) {
      query.andWhere($dbx.exp("(instr(lower(coalesce(book_highlights.quote_text, '')), {:query}) > 0 OR instr(lower(coalesce(books.title, '')), {:query}) > 0)", {
        query: normalizedQuery,
      }))
    }

    return query
  }

  /**
   * 문구 전체 페이지 링크를 만듭니다.
   *
   * @param {number} visibleLimit 표시 개수
   * @returns {string} 이동 링크
   */
  function buildHighlightsHref(visibleLimit) {
    const pairs = []

    if (queryText) {
      pairs.push('q=' + encodeURIComponent(queryText))
    }

    if (visibleLimit > 30) {
      pairs.push('limit=' + encodeURIComponent(String(visibleLimit)))
    }

    return pairs.length ? '/highlights?' + pairs.join('&') : '/highlights'
  }

  /**
   * 문구 더 보기 조각 링크를 만듭니다.
   *
   * @param {number} offset 시작 위치
   * @returns {string} 더 보기 링크
   */
  function buildHighlightsMoreHref(offset) {
    const pairs = [
      'offset=' + encodeURIComponent(String(offset)),
      'limit=30',
    ]

    if (queryText) {
      pairs.push('q=' + encodeURIComponent(queryText))
    }

    return '/xapi/highlights-more?' + pairs.join('&')
  }

  const highlightRows = arrayOf(new DynamicModel({
    bookId: '',
    bookTitle: '',
    quoteText: '',
    highlightedAtValue: '',
  }))

  applyHighlightWhere(
    $app
      .db()
      .select(
        'book_highlights.book_id as bookId',
        'books.title as bookTitle',
        'book_highlights.quote_text as quoteText',
        'book_highlights.highlighted_at as highlightedAtValue'
      )
      .from('book_highlights')
      .innerJoin('books', $dbx.exp('books.id = book_highlights.book_id'))
      .orderBy('book_highlights.highlighted_at DESC', 'book_highlights.updated DESC')
      .limit(pageLimit + 1)
      .offset(pageOffset)
  ).all(highlightRows)

  const hasMoreHighlights = nextOffset < maxHighlightLimit && highlightRows.length > pageLimit
  const visibleHighlightRowCount = Math.min(highlightRows.length, pageLimit)

  for (let index = 0; index < visibleHighlightRowCount; index += 1) {
    const row = highlightRows[index]
    const highlightedAtValue = String(row.highlightedAtValue || '').trim()
    highlightItems.push({
      bookId: String(row.bookId || '').trim(),
      bookTitle: String(row.bookTitle || '제목 없음'),
      quoteText: String(row.quoteText || '').trim(),
      highlightedAt: highlightedAtValue ? dateutil.formatDate(highlightedAtValue, dateutil.FORMATS.DATE) : '',
    })
  }
</script>

<% for (let index = 0; index < highlightItems.length; index += 1) { const item = highlightItems[index] %>
<a
  href="/books/<%= item.bookId %>?from=/highlights"
  class="block rounded-[1.4rem] bg-[#fbf7ef] px-4 py-3.5 text-stone-900 no-underline shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)] transition hover:bg-[#f7f0e3]">
  <p class="text-[15px] font-semibold leading-[1.65] tracking-[-0.02em] text-stone-900 sm:text-base"><%= item.quoteText %></p>
  <p class="mt-2.5 text-[12px] leading-5 text-stone-500"><%= item.bookTitle %></p>
  <% if (item.highlightedAt) { %>
  <p class="mt-1.5 text-[12px] font-medium text-stone-400"><%= item.highlightedAt %></p>
  <% } %>
</a>
<% } %>

<% if (hasMoreHighlights) { %>
<div
  id="highlights-more-control"
  class="flex justify-center">
  <a
    href="<%= buildHighlightsHref(nextVisibleLimit) %>"
    hx-get="<%= buildHighlightsMoreHref(nextOffset) %>"
    hx-target="#highlights-more-control"
    hx-push-url="<%= buildHighlightsHref(nextVisibleLimit) %>"
    hx-swap="outerHTML"
    class="inline-flex items-center rounded-full bg-stone-900 px-5 py-3 text-sm font-semibold text-white no-underline shadow-[0_10px_22px_rgba(24,19,16,0.12)]">
    더 보기
  </a>
</div>
<% } %>
