<script server>
  if (request.method !== 'POST') {
    dbg('xapi/settings/save:redirect', {
      status: 303,
      redirectTo: '/settings',
      flash: '잘못된 요청입니다.',
    })
    redirect('/settings', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    dbg('xapi/settings/save:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const form = body()
  const userId = String(request.auth.get('id') || '')
  const readingReminderCycleRaw = String(form.readingReminderCycle || '').trim()
  const highlightPushCycleRaw = String(form.highlightPushCycle || '').trim()
  const readingReminderCycle = readingReminderCycleRaw ? Number(readingReminderCycleRaw) : null
  const highlightPushCycle = highlightPushCycleRaw ? Number(highlightPushCycleRaw) : null
  const pushEnabled = String(form.pushEnabled || '').trim() === 'true'
  let errorMessage = ''

  dbg('xapi/settings/save:start', {
    userId: userId,
    readingReminderCycle: readingReminderCycle,
    highlightPushCycle: highlightPushCycle,
    pushEnabled: pushEnabled,
  })

  try {
    if (!userId) {
      throw new Error('로그인이 필요합니다.')
    }

    if (readingReminderCycle !== null && (isNaN(readingReminderCycle) || readingReminderCycle < 1 || readingReminderCycle > 365 || Math.floor(readingReminderCycle) !== readingReminderCycle)) {
      throw new Error('읽기 리마인더 주기는 1일부터 365일 사이의 정수여야 합니다.')
    }

    if (highlightPushCycle !== null && (isNaN(highlightPushCycle) || highlightPushCycle < 1 || highlightPushCycle > 365 || Math.floor(highlightPushCycle) !== highlightPushCycle)) {
      throw new Error('하이라이트 리마인더 주기는 1일부터 365일 사이의 정수여야 합니다.')
    }

    let settingsRecord = null

    try {
      settingsRecord = $app.findFirstRecordByFilter('user_settings', 'user_id = {:userId}', {
        userId: userId,
      })
    } catch (exception) {
      settingsRecord = null
    }

    if (!settingsRecord) {
      const collection = $app.findCollectionByNameOrId('user_settings')

      settingsRecord = new Record(collection)
      settingsRecord.set('user_id', userId)
      settingsRecord.set('preferred_view_mode', 'scrolled')
    }

    settingsRecord.set('push_enabled', pushEnabled)
    settingsRecord.set('reading_reminder_cycle', readingReminderCycle)
    settingsRecord.set('highlight_push_cycle', highlightPushCycle)

    $app.save(settingsRecord)

    dbg('xapi/settings/save:redirect', {
      status: 303,
      redirectTo: '/settings',
      flash: '설정을 저장했습니다.',
    })
    redirect('/settings', {
      status: 303,
      message: '설정을 저장했습니다.',
    })
    return
  } catch (exception) {
    errorMessage = String(exception.message || exception)
    error('xapi/settings/save:failed', {
      userId: userId,
      error: errorMessage,
    })
  }

  dbg('xapi/settings/save:redirect', {
    status: 303,
    redirectTo: '/settings',
    error: errorMessage || '설정 저장에 실패했습니다.',
  })
  redirect('/settings', {
    status: 303,
    message: errorMessage || '설정 저장에 실패했습니다.',
  })
</script>
