<script server>
  const fflate = require('fflate')
  const data4libraryService = resolve('data4library-service')
  const MAX_EPUB_BYTES = 1024 * 1024 * 100
  const MIN_BOOK_SEARCH_SCORE = 80
  const MAX_METADATA_PAGE_FALLBACKS = 12

  function normalizePreview(input, maxLength) {
    return String(input || '')
      .replace(/[^\x20-\x7E\u00A0-\uFFFF\r\n\t]/g, ' ')
      .replace(/\s+/g, ' ')
      .slice(0, maxLength)
  }

  function dirname(filePath) {
    const lastSlashIndex = String(filePath || '').lastIndexOf('/')
    if (lastSlashIndex === -1) {
      return ''
    }

    return filePath.slice(0, lastSlashIndex)
  }

  function joinPath(basePath, relativePath) {
    const rawPath = (basePath ? basePath + '/' : '') + String(relativePath || '')
    const segments = rawPath.split('/')
    const normalizedSegments = []

    for (let index = 0; index < segments.length; index += 1) {
      const segment = segments[index]

      if (!segment || segment === '.') {
        continue
      }

      if (segment === '..') {
        normalizedSegments.pop()
        continue
      }

      normalizedSegments.push(segment)
    }

    return normalizedSegments.join('/')
  }

  function readArchiveText(archiveEntries, entryPath) {
    if (!entryPath || !archiveEntries[entryPath]) {
      return ''
    }

    return fflate.strFromU8(archiveEntries[entryPath])
  }

  function extractAttribute(tagText, attributeName) {
    const pattern = new RegExp(attributeName + '=(?:"([^"]+)"|\'([^\']+)\')', 'i')
    const match = String(tagText || '').match(pattern)
    return match ? match[1] || match[2] || '' : ''
  }

  function decodeXmlText(input) {
    return String(input || '')
      .replace(/<!\[CDATA\[([\s\S]*?)\]\]>/g, '$1')
      .replace(/&amp;/g, '&')
      .replace(/&lt;/g, '<')
      .replace(/&gt;/g, '>')
      .replace(/&quot;/g, '"')
      .replace(/&#39;/g, "'")
      .replace(/&#x27;/gi, "'")
      .replace(/\s+/g, ' ')
      .trim()
  }

  function extractXmlText(xmlText, tagName) {
    const pattern = new RegExp('<(?:\\w+:)?' + tagName + '\\b[^>]*>([\\s\\S]*?)<\\/(?:\\w+:)?' + tagName + '>', 'i')
    const match = String(xmlText || '').match(pattern)
    return match ? decodeXmlText(match[1]) : ''
  }

  function extractXmlTexts(xmlText, tagName) {
    const pattern = new RegExp('<(?:\\w+:)?' + tagName + '\\b[^>]*>([\\s\\S]*?)<\\/(?:\\w+:)?' + tagName + '>', 'gi')
    const matches = []
    let match = null

    while ((match = pattern.exec(String(xmlText || '')))) {
      const value = decodeXmlText(match[1])
      if (value) {
        matches.push(value)
      }
    }

    return matches
  }

  function extractXmlNodes(xmlText, tagName) {
    const pattern = new RegExp('<(?:\\w+:)?' + tagName + '\\b([^>]*)>([\\s\\S]*?)<\\/(?:\\w+:)?' + tagName + '>', 'gi')
    const nodes = []
    let match = null

    while ((match = pattern.exec(String(xmlText || '')))) {
      nodes.push({
        attributesText: match[1] || '',
        value: decodeXmlText(match[2]),
      })
    }

    return nodes
  }

  function extractDigits(input) {
    const digits = String(input || '').replace(/\D+/g, '')
    return digits || ''
  }

  function pushUniqueValue(list, value) {
    const normalizedValue = String(value || '').trim()

    if (!normalizedValue) {
      return
    }

    for (let index = 0; index < list.length; index += 1) {
      if (list[index] === normalizedValue) {
        return
      }
    }

    list.push(normalizedValue)
  }

  function addIsbnCandidate(candidates, candidate) {
    if (!candidate || !candidate.isbn13) {
      return
    }

    for (let index = 0; index < candidates.length; index += 1) {
      if (candidates[index].isbn13 === candidate.isbn13) {
        return
      }
    }

    candidates.push(candidate)
  }

  function normalizeIsbnScanText(input) {
    return String(input || '')
      .replace(/[–—−]/g, '-')
      .replace(/[（]/g, '(')
      .replace(/[）]/g, ')')
  }

  function extractIsbn13Matches(input) {
    const normalizedInput = normalizeIsbnScanText(input)
    const pattern = /97[89](?:[\s-]*\d){10}/g
    const matches = []
    let match = null

    while ((match = pattern.exec(normalizedInput))) {
      const isbn13 = extractDigits(match[0]).slice(0, 13)

      if (isbn13.length === 13) {
        pushUniqueValue(matches, isbn13)
      }
    }

    return matches
  }

  function isLikelyUuidIdentifier(value, attributesText) {
    const normalizedValue = String(value || '').toLowerCase()
    const normalizedAttributesText = String(attributesText || '').toLowerCase()

    if (normalizedValue.indexOf('urn:uuid:') !== -1) {
      return true
    }

    if (/^[0-9a-f]{8}-[0-9a-f]{4}-/i.test(normalizedValue)) {
      return true
    }

    return normalizedAttributesText.indexOf('uuid') !== -1 && normalizedValue.indexOf('urn:isbn:') === -1
  }

  function isExplicitIsbnIdentifier(attributesText) {
    return /(?:opf:)?scheme\s*=\s*['"]isbn['"]/i.test(String(attributesText || ''))
  }

  function extractIdentifierIsbnCandidates(identifierNodes) {
    const explicitCandidates = []
    const fallbackCandidates = []
    const nodes = Array.isArray(identifierNodes) ? identifierNodes : []

    for (let index = 0; index < nodes.length; index += 1) {
      const identifierNode = nodes[index]
      const identifierValue = identifierNode && identifierNode.value ? identifierNode.value : ''
      const attributesText = identifierNode && identifierNode.attributesText ? identifierNode.attributesText : ''

      if (!identifierValue || isLikelyUuidIdentifier(identifierValue, attributesText)) {
        continue
      }

      const matches = extractIsbn13Matches(identifierValue)

      for (let matchIndex = 0; matchIndex < matches.length; matchIndex += 1) {
        const isbn13 = matches[matchIndex]
        const targetList = isExplicitIsbnIdentifier(attributesText) ? explicitCandidates : fallbackCandidates

        addIsbnCandidate(targetList, {
          isbn13: isbn13,
          source: isExplicitIsbnIdentifier(attributesText) ? 'opf-identifier-isbn' : 'opf-identifier-value',
          entryPath: '',
          context: normalizePreview(identifierValue, 160),
        })
      }
    }

    return explicitCandidates.concat(fallbackCandidates)
  }

  function htmlToPlainText(input) {
    return decodeXmlText(
      String(input || '')
        .replace(/<script[\s\S]*?<\/script>/gi, ' ')
        .replace(/<style[\s\S]*?<\/style>/gi, ' ')
        .replace(/<[^>]+>/g, ' ')
        .replace(/&nbsp;/gi, ' ')
    )
  }

  function buildMetadataEntryPaths(manifestItems, packageDocumentPath, entryNames) {
    const orderedPaths = []
    const keywordPaths = []
    const leadingTextPaths = []
    const metadataPathPattern = /(rights|copyright|colophon|author|about|credit|imprint|title|cover)/i
    const manifestList = Array.isArray(manifestItems) ? manifestItems : []
    const normalizedEntryNames = Array.isArray(entryNames) ? entryNames : []

    for (let index = 0; index < manifestList.length; index += 1) {
      const manifestItem = manifestList[index]

      if (!manifestItem || !manifestItem.href) {
        continue
      }

      if (!(manifestItem.mediaType === 'application/xhtml+xml' || /\.(xhtml|html|htm)$/i.test(manifestItem.href))) {
        continue
      }

      const entryPath = joinPath(dirname(packageDocumentPath), manifestItem.href)

      if (metadataPathPattern.test(entryPath)) {
        pushUniqueValue(keywordPaths, entryPath)
      } else if (leadingTextPaths.length < MAX_METADATA_PAGE_FALLBACKS) {
        pushUniqueValue(leadingTextPaths, entryPath)
      }
    }

    for (let index = 0; index < normalizedEntryNames.length; index += 1) {
      const entryName = normalizedEntryNames[index]

      if (!/\.(xhtml|html|htm)$/i.test(entryName) || !metadataPathPattern.test(entryName)) {
        continue
      }

      pushUniqueValue(keywordPaths, entryName)
    }

    for (let index = 0; index < keywordPaths.length; index += 1) {
      pushUniqueValue(orderedPaths, keywordPaths[index])
    }

    for (let index = 0; index < leadingTextPaths.length; index += 1) {
      pushUniqueValue(orderedPaths, leadingTextPaths[index])
    }

    return orderedPaths
  }

  function extractPageIsbnCandidates(plainText, entryPath) {
    const normalizedText = normalizeIsbnScanText(plainText)
    const pattern = /97[89](?:[\s-]*\d){10}/g
    const matches = []
    let match = null

    while ((match = pattern.exec(normalizedText))) {
      const isbn13 = extractDigits(match[0]).slice(0, 13)

      if (isbn13.length !== 13) {
        continue
      }

      const contextStart = Math.max(0, match.index - 48)
      const contextEnd = Math.min(normalizedText.length, pattern.lastIndex + 48)
      const context = normalizedText.slice(contextStart, contextEnd)
      let score = 0

      if (/isbn/i.test(context)) {
        score += 10
      }

      if (/전자책|ebook|e-book/i.test(context)) {
        score += 20
      }

      if (/종이책|paper/i.test(context)) {
        score -= 5
      }

      matches.push({
        isbn13: isbn13,
        source: 'metadata-page',
        entryPath: entryPath,
        context: normalizePreview(context, 160),
        score: score,
      })
    }

    matches.sort(function (left, right) {
      return right.score - left.score
    })

    return matches
  }

  function collectEpubIsbnCandidates(epubMetadata, archiveEntries, manifestItems, packageDocumentPath, entryNames) {
    const candidates = []
    const identifierCandidates = extractIdentifierIsbnCandidates(epubMetadata.identifierNodes)
    const metadataEntryPaths = buildMetadataEntryPaths(manifestItems, packageDocumentPath, entryNames)

    for (let index = 0; index < identifierCandidates.length; index += 1) {
      addIsbnCandidate(candidates, identifierCandidates[index])
    }

    for (let index = 0; index < metadataEntryPaths.length; index += 1) {
      const entryPath = metadataEntryPaths[index]
      const plainText = htmlToPlainText(readArchiveText(archiveEntries, entryPath))
      const pageCandidates = extractPageIsbnCandidates(plainText, entryPath)

      for (let candidateIndex = 0; candidateIndex < pageCandidates.length; candidateIndex += 1) {
        addIsbnCandidate(candidates, pageCandidates[candidateIndex])
      }
    }

    return candidates
  }

  function extractPrimaryAuthorName(authorText) {
    let normalizedAuthor = String(authorText || '').trim()

    if (!normalizedAuthor) {
      return ''
    }

    normalizedAuthor = normalizedAuthor.replace(/[|│/]/g, '|')

    if (normalizedAuthor.indexOf('|') !== -1) {
      normalizedAuthor = normalizedAuthor.split('|')[0]
    }

    const translatorRoleMatch = normalizedAuthor.match(/옮긴이|옮김|역자|그림|감수/i)

    if (translatorRoleMatch) {
      normalizedAuthor = normalizedAuthor.slice(0, translatorRoleMatch.index)
    }

    normalizedAuthor = normalizedAuthor
      .replace(/\([^)]*\)/g, ' ')
      .replace(/(?:지은이|지음|글쓴이|글|저자)\s*[·:|-]?\s*/g, ' ')
      .replace(/\s+/g, ' ')
      .trim()

    return normalizedAuthor
  }

  function stripFileExtension(fileName) {
    return String(fileName || '').replace(/\.[^.]+$/, '')
  }

  function parseFilenameMetadata(fileName) {
    let normalizedName = stripFileExtension(fileName).trim()
    const sourceSuffixPattern = /\s*\((?:[^)]*(?:z-library|z-lib|1lib)[^)]*)\)\s*$/i

    while (sourceSuffixPattern.test(normalizedName)) {
      normalizedName = normalizedName.replace(sourceSuffixPattern, '').trim()
    }

    const authorMatch = normalizedName.match(/^(.*)\s+\(([^()]+)\)$/)

    if (!authorMatch) {
      return {
        title: normalizedName,
        author: '',
      }
    }

    return {
      title: String(authorMatch[1] || '').trim(),
      author: String(authorMatch[2] || '').trim(),
    }
  }

  function normalizeMatchText(input) {
    return String(input || '')
      .toLowerCase()
      .replace(/[^a-z0-9\u00C0-\uFFFF]+/g, '')
  }

  function bytesToBinaryString(bytes) {
    const list = bytes instanceof Uint8Array ? bytes : new Uint8Array(bytes || [])
    const chunkSize = 8192
    const chunks = []

    for (let index = 0; index < list.length; index += chunkSize) {
      const chunk = list.slice(index, index + chunkSize)
      chunks.push(String.fromCharCode.apply(null, chunk))
    }

    return chunks.join('')
  }

  function parsePublicationDate(input) {
    const digits = extractDigits(input)

    if (digits.length === 8) {
      return digits.slice(0, 4) + '-' + digits.slice(4, 6) + '-' + digits.slice(6, 8)
    }

    return ''
  }

  function parseManifestItems(packageDocumentXml) {
    const manifestItemPattern = /<item\b[^>]*>/g
    const manifestItems = packageDocumentXml.match(manifestItemPattern) || []
    const normalizedItems = []

    for (let index = 0; index < manifestItems.length; index += 1) {
      const manifestItem = manifestItems[index]
      const href = extractAttribute(manifestItem, 'href')

      normalizedItems.push({
        id: extractAttribute(manifestItem, 'id'),
        href: href,
        mediaType: extractAttribute(manifestItem, 'media-type'),
        properties: extractAttribute(manifestItem, 'properties'),
      })
    }

    return normalizedItems
  }

  function parseEpubMetadata(packageDocumentXml) {
    const versionMatch = String(packageDocumentXml || '').match(/<package\b[^>]*version="([^"]+)"/i)
    const identifierNodes = extractXmlNodes(packageDocumentXml, 'identifier')
    const identifiers = []
    const title = extractXmlText(packageDocumentXml, 'title')
    const creatorNodes = extractXmlNodes(packageDocumentXml, 'creator')
    const author = creatorNodes.length > 0 ? creatorNodes[0].value : ''
    const languageCode = extractXmlText(packageDocumentXml, 'language')
    const identifierCandidates = extractIdentifierIsbnCandidates(identifierNodes)

    for (let index = 0; index < identifierNodes.length; index += 1) {
      if (identifierNodes[index].value) {
        identifiers.push(identifierNodes[index].value)
      }
    }

    const identifierValue = identifiers.length > 0 ? identifiers[0] : ''

    return {
      title: title,
      author: author,
      languageCode: languageCode,
      identifierValue: identifierValue,
      identifiers: identifiers,
      identifierNodes: identifierNodes,
      isbn13: identifierCandidates.length > 0 ? identifierCandidates[0].isbn13 : '',
      epubVersion: versionMatch ? versionMatch[1] : '',
    }
  }

  function buildSearchKeyword(title, author) {
    const segments = []
    const normalizedTitle = String(title || '').trim()
    const normalizedAuthor = String(author || '').trim()

    if (normalizedTitle) {
      segments.push(normalizedTitle)
    }

    if (normalizedAuthor) {
      segments.push(normalizedAuthor)
    }

    return segments.join(' ')
  }

  function addSearchProfile(profiles, title, author, source) {
    const normalizedTitle = String(title || '').trim()
    const normalizedAuthor = String(author || '').trim()
    const combinedKeyword = buildSearchKeyword(normalizedTitle, normalizedAuthor)

    if (combinedKeyword) {
      pushUniqueSearchProfile(profiles, {
        keyword: combinedKeyword,
        title: normalizedTitle,
        author: normalizedAuthor,
        source: source + ':combined',
      })
    }

    if (normalizedTitle) {
      pushUniqueSearchProfile(profiles, {
        keyword: normalizedTitle,
        title: normalizedTitle,
        author: normalizedAuthor,
        source: source + ':title',
      })
    }

    if (normalizedAuthor) {
      pushUniqueSearchProfile(profiles, {
        keyword: normalizedAuthor,
        title: normalizedTitle,
        author: normalizedAuthor,
        source: source + ':author',
      })
    }
  }

  function pushUniqueSearchProfile(profiles, profile) {
    if (!profile || !profile.keyword) {
      return
    }

    for (let index = 0; index < profiles.length; index += 1) {
      if (profiles[index].keyword === profile.keyword) {
        return
      }
    }

    profiles.push(profile)
  }

  function collectSearchProfiles(epubMetadata, originalName) {
    const profiles = []
    const filenameMetadata = parseFilenameMetadata(originalName)
    const primaryAuthor = extractPrimaryAuthorName(epubMetadata.author)
    const filePrimaryAuthor = extractPrimaryAuthorName(filenameMetadata.author)

    addSearchProfile(profiles, epubMetadata.title, primaryAuthor || epubMetadata.author, 'epub')

    if (epubMetadata.author && primaryAuthor && epubMetadata.author !== primaryAuthor) {
      addSearchProfile(profiles, epubMetadata.title, epubMetadata.author, 'epub-raw-author')
    }

    if (filenameMetadata.title && (filenameMetadata.title !== String(epubMetadata.title || '').trim() || filePrimaryAuthor !== (primaryAuthor || String(epubMetadata.author || '').trim()))) {
      addSearchProfile(profiles, filenameMetadata.title, filePrimaryAuthor || filenameMetadata.author, 'filename')
    }

    return profiles
  }

  function scoreSearchDoc(doc, epubMetadata) {
    const titleText = normalizeMatchText(epubMetadata.title)
    const authorText = normalizeMatchText(epubMetadata.author)
    const epubIsbn13 = extractDigits(epubMetadata.isbn13)
    const docTitle = normalizeMatchText(doc && doc.bookname)
    const docAuthor = normalizeMatchText(doc && doc.authors)
    const docIsbn13 = extractDigits(doc && doc.isbn13)
    let score = 0

    if (titleText && docTitle) {
      if (docTitle === titleText) {
        score += 120
      } else if (docTitle.indexOf(titleText) !== -1 || titleText.indexOf(docTitle) !== -1) {
        score += 80
      }
    }

    if (authorText && docAuthor) {
      if (docAuthor === authorText) {
        score += 70
      } else if (docAuthor.indexOf(authorText) !== -1 || authorText.indexOf(docAuthor) !== -1) {
        score += 45
      }
    }

    if (epubIsbn13 && docIsbn13 && epubIsbn13 === docIsbn13) {
      score += 300
    }

    if (docIsbn13) {
      score += 5
    }

    return score
  }

  function chooseBestSearchDoc(docs, epubMetadata) {
    const list = Array.isArray(docs) ? docs : []
    let bestDoc = null
    let bestScore = -1

    for (let index = 0; index < list.length; index += 1) {
      const doc = list[index]
      const score = scoreSearchDoc(doc, epubMetadata)

      if (score > bestScore) {
        bestDoc = doc
        bestScore = score
      }
    }

    return {
      bestDoc: bestDoc,
      bestScore: bestScore,
    }
  }

  function loadBookDetailByIsbn13(isbn13) {
    const normalizedIsbn13 = extractDigits(isbn13).slice(0, 13)

    if (normalizedIsbn13.length !== 13) {
      return null
    }

    dbg('xapi/epub/upload:detail-by-isbn13:start', {
      isbn13: normalizedIsbn13,
    })

    try {
      const detailResult = data4libraryService.getBookDetail({ apiKey: env('DATA4LIBRARY_APIKEY') }, { isbn13: normalizedIsbn13 })

      dbg('xapi/epub/upload:detail-by-isbn13:done', {
        isbn13: normalizedIsbn13,
        found: !!(detailResult && detailResult.book),
        bookname: detailResult && detailResult.book ? String(detailResult.book.bookname || '') : '',
      })

      if (!detailResult || !detailResult.book) {
        return null
      }

      return detailResult
    } catch (exception) {
      warn('xapi/epub/upload:detail-by-isbn13:failed', {
        isbn13: normalizedIsbn13,
        error: String(exception && exception.message ? exception.message : exception),
      })
      return null
    }
  }

  function loadBookDetailByIsbnCandidates(isbnCandidates) {
    const candidates = Array.isArray(isbnCandidates) ? isbnCandidates : []

    for (let index = 0; index < candidates.length; index += 1) {
      const candidate = candidates[index]
      const detailResult = loadBookDetailByIsbn13(candidate.isbn13)

      dbg('xapi/epub/upload:isbn-candidate-result', {
        isbn13: candidate.isbn13,
        source: candidate.source,
        entryPath: candidate.entryPath || '',
        found: !!(detailResult && detailResult.book),
      })

      if (detailResult && detailResult.book) {
        return {
          detailResult: detailResult,
          matchedCandidate: candidate,
        }
      }
    }

    return {
      detailResult: null,
      matchedCandidate: null,
    }
  }

  function findBestBookSearchResult(epubMetadata, originalName) {
    const profiles = collectSearchProfiles(epubMetadata, originalName)
    let selectedDoc = null
    let selectedSearchKeyword = ''
    let selectedSearchResult = null
    let selectedSearchScore = -1
    let matchedSource = ''

    for (let index = 0; index < profiles.length; index += 1) {
      const profile = profiles[index]
      const keyword = profile.keyword
      dbg('xapi/epub/upload:search-attempt', {
        keyword: keyword,
        source: profile.source,
      })
      const searchResult = data4libraryService.searchBooks(
        { apiKey: env('DATA4LIBRARY_APIKEY') },
        {
          keyword: keyword,
          pageNo: 1,
          pageSize: 10,
        }
      )
      const bestMatch = chooseBestSearchDoc(searchResult.docs, {
        title: profile.title,
        author: profile.author,
        isbn13: '',
      })

      dbg('xapi/epub/upload:search-result', {
        keyword: keyword,
        source: profile.source,
        numFound: searchResult.numFound,
        docsCount: Array.isArray(searchResult.docs) ? searchResult.docs.length : 0,
        bestScore: bestMatch.bestScore,
        matchedIsbn13: bestMatch.bestDoc && bestMatch.bestDoc.isbn13 ? String(bestMatch.bestDoc.isbn13) : '',
        matchedBookname: bestMatch.bestDoc && bestMatch.bestDoc.bookname ? String(bestMatch.bestDoc.bookname) : '',
      })

      if (bestMatch.bestDoc && bestMatch.bestScore >= MIN_BOOK_SEARCH_SCORE) {
        selectedDoc = bestMatch.bestDoc
        selectedSearchKeyword = keyword
        selectedSearchResult = searchResult
        selectedSearchScore = bestMatch.bestScore
        matchedSource = profile.source
        break
      }
    }

    return {
      searchKeyword: selectedSearchKeyword,
      searchResult: selectedSearchResult,
      selectedDoc: selectedDoc,
      detailResult: null,
      matchedSource: matchedSource,
      matchedScore: selectedSearchScore,
      matchedBy: selectedDoc ? 'keyword' : '',
    }
  }

  function resolveBookLookup(epubMetadata, archiveEntries, manifestItems, packageDocumentPath, entryNames, originalName) {
    const isbnCandidates = collectEpubIsbnCandidates(epubMetadata, archiveEntries, manifestItems, packageDocumentPath, entryNames)

    dbg('xapi/epub/upload:isbn-candidates', {
      count: isbnCandidates.length,
      items: isbnCandidates.map(function (candidate) {
        return {
          isbn13: candidate.isbn13,
          source: candidate.source,
          entryPath: candidate.entryPath || '',
          context: candidate.context || '',
        }
      }),
    })

    const detailLookup = loadBookDetailByIsbnCandidates(isbnCandidates)

    if (detailLookup.detailResult && detailLookup.detailResult.book) {
      return {
        searchKeyword: '',
        searchResult: null,
        selectedDoc: detailLookup.detailResult.book,
        detailResult: detailLookup.detailResult,
        matchedBy: 'isbn13',
        matchedSource: detailLookup.matchedCandidate ? detailLookup.matchedCandidate.source : '',
        matchedScore: 0,
        matchedIsbn13: detailLookup.matchedCandidate ? detailLookup.matchedCandidate.isbn13 : '',
      }
    }

    const searchLookup = findBestBookSearchResult(epubMetadata, originalName)

    return {
      searchKeyword: searchLookup.searchKeyword,
      searchResult: searchLookup.searchResult,
      selectedDoc: searchLookup.selectedDoc,
      detailResult: searchLookup.detailResult,
      matchedBy: searchLookup.matchedBy,
      matchedSource: searchLookup.matchedSource || '',
      matchedScore: searchLookup.matchedScore,
      matchedIsbn13: searchLookup.selectedDoc && searchLookup.selectedDoc.isbn13 ? String(searchLookup.selectedDoc.isbn13) : '',
    }
  }

  function findFirstRecordOrNull(collectionName, filter, queryValues) {
    try {
      return $app.findFirstRecordByFilter(collectionName, filter, queryValues || {})
    } catch (exception) {
      return null
    }
  }

  function saveBookRecord(bookInput) {
    const collection = $app.findCollectionByNameOrId('books')
    let record = null

    if (bookInput.isbn13) {
      record = findFirstRecordOrNull('books', 'isbn13 = {:isbn13}', {
        isbn13: bookInput.isbn13,
      })
    }

    if (!record) {
      record = new Record(collection)
    }

    dbg('xapi/epub/upload:save-book:start', {
      existingId: record.get('id') || '',
      isbn13: bookInput.isbn13,
      title: bookInput.title,
    })

    record.set('title', bookInput.title)
    record.set('author', bookInput.author)
    record.set('publisher', bookInput.publisher)
    record.set('publication_date', bookInput.publicationDate)
    record.set('publication_year', bookInput.publicationYear)
    record.set('class_no', bookInput.classNo)
    record.set('isbn', bookInput.isbn)
    record.set('isbn13', bookInput.isbn13)
    record.set('book_image_url', bookInput.bookImageUrl)
    record.set('description', bookInput.description)
    record.set('metadata_json', bookInput.metadataJson)

    $app.save(record)

    dbg('xapi/epub/upload:save-book:done', {
      id: record.get('id'),
      isbn13: record.get('isbn13'),
      title: record.get('title'),
    })

    return record
  }

  function saveBookFileRecord(fileInput) {
    const collection = $app.findCollectionByNameOrId('book_files')
    let record = findFirstRecordOrNull('book_files', 'file_hash = {:fileHash}', {
      fileHash: fileInput.fileHash,
    })

    if (!record) {
      record = new Record(collection)
    }

    dbg('xapi/epub/upload:save-book-file:start', {
      existingId: record.get('id') || '',
      bookId: fileInput.bookId,
      fileHash: fileInput.fileHash,
      originalName: fileInput.originalName,
      fileSize: fileInput.fileSize,
    })

    record.set('book_id', fileInput.bookId)
    record.set('original_name', fileInput.originalName)
    record.set('mime_type', fileInput.mimeType)
    record.set('file_size', fileInput.fileSize)
    record.set('file_hash', fileInput.fileHash)
    record.set('epub_version', fileInput.epubVersion)
    record.set('language_code', fileInput.languageCode)
    record.set('identifier_value', fileInput.identifierValue)
    record.set('preview_text', fileInput.previewText)
    record.set('toc_json', fileInput.tocJson)
    record.set('manifest_json', fileInput.manifestJson)

    if (!record.get('id')) {
      dbg('xapi/epub/upload:save-book-file:set-stored-file', {
        fileHash: fileInput.fileHash,
        originalName: fileInput.originalName,
      })
      record.set('stored_file', fileInput.uploadedFile)
    }

    dbg('xapi/epub/upload:save-book-file:before-save', {
      id: record.get('id') || '',
      bookId: record.get('book_id'),
      fileHash: record.get('file_hash'),
      hasStoredFile: !!record.get('stored_file'),
    })

    $app.save(record)

    dbg('xapi/epub/upload:save-book-file:done', {
      id: record.get('id'),
      bookId: record.get('book_id'),
      fileHash: record.get('file_hash'),
    })

    return record
  }

  function saveBookShelfRecord(shelfInput) {
    const collection = $app.findCollectionByNameOrId('book_shelves')
    let record = findFirstRecordOrNull('book_shelves', 'user_id = {:userId} && book_id = {:bookId}', {
      userId: shelfInput.userId,
      bookId: shelfInput.bookId,
    })

    if (!record) {
      record = new Record(collection)
      record.set('user_id', shelfInput.userId)
      record.set('book_id', shelfInput.bookId)
      record.set('status', 'queued')
    }

    dbg('xapi/epub/upload:save-shelf:start', {
      existingId: record.get('id') || '',
      userId: shelfInput.userId,
      bookId: shelfInput.bookId,
      bookFileId: shelfInput.bookFileId,
    })

    record.set('book_file_id', shelfInput.bookFileId)
    $app.save(record)

    dbg('xapi/epub/upload:save-shelf:done', {
      id: record.get('id'),
      userId: record.get('user_id'),
      bookId: record.get('book_id'),
      bookFileId: record.get('book_file_id'),
    })

    return record
  }

  if (!request.auth) {
    warn('xapi/epub/upload:unauthorized', {
      method: request.method,
    })
    dbg('xapi/epub/upload:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인 후 EPUB 파일을 업로드할 수 있습니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인 후 EPUB 파일을 업로드할 수 있습니다.',
    })
    return
  }

  if (request.method !== 'POST') {
    dbg('xapi/epub/upload:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '잘못된 요청입니다.',
    })
    redirect('/', {
      status: 303,
      message: '잘못된 요청입니다.',
    })
    return
  }

  dbg('xapi/epub/upload:start', {
    method: request.method,
    userId: request.auth.get('id'),
  })

  try {
    let uploadedFiles = []

    try {
      uploadedFiles = request.event.findUploadedFiles('epubFile') || []
      dbg('xapi/epub/upload:uploaded-files', {
        count: uploadedFiles.length,
      })
    } catch (exception) {
      error('xapi/epub/upload:find-uploaded-files:failed', {
        error: String(exception.message || exception),
      })
      throw exception
    }

    const epubFile = uploadedFiles[0]

    if (!epubFile) {
      throw new Error('EPUB 파일이 필요합니다.')
    }

    dbg('xapi/epub/upload:selected-file', {
      name: epubFile.name,
      originalName: epubFile.originalName,
      size: epubFile.size,
      hasReader: !!epubFile.reader,
    })

    const fileSize = Number(epubFile.size || 0)

    dbg('xapi/epub/upload:file-size', {
      fileSize: fileSize,
      maxBytes: MAX_EPUB_BYTES,
    })

    if (fileSize > MAX_EPUB_BYTES) {
      throw new Error('EPUB 파일은 최대 100MB까지 업로드할 수 있습니다.')
    }

    dbg('xapi/epub/upload:reader-open:start', {
      originalName: epubFile.originalName || epubFile.name,
    })
    const reader = epubFile.reader.open()
    dbg('xapi/epub/upload:reader-open:done', {
      hasReader: !!reader,
    })
    const maxReadableBytes = fileSize || MAX_EPUB_BYTES
    dbg('xapi/epub/upload:to-bytes:start', {
      maxReadableBytes: maxReadableBytes,
    })
    const epubBytes = toBytes(reader, maxReadableBytes)
    dbg('xapi/epub/upload:to-bytes:done', {
      bytesLength: Array.isArray(epubBytes) ? epubBytes.length : 0,
    })
    reader.close()

    const epubByteArray = new Uint8Array(epubBytes)
    const fileHash = $security.sha256(bytesToBinaryString(epubByteArray))
    dbg('xapi/epub/upload:file-ready', {
      originalName: epubFile.originalName || epubFile.name,
      fileSize: fileSize,
      fileHash: fileHash,
    })
    const archiveEntries = fflate.unzipSync(epubByteArray)
    const entryNames = Object.keys(archiveEntries).sort()
    const mimetypeText = readArchiveText(archiveEntries, 'mimetype')
    const containerXml = readArchiveText(archiveEntries, 'META-INF/container.xml')
    const containerRootfileMatch = containerXml.match(/full-path="([^"]+)"/)
    const packageDocumentPath = containerRootfileMatch ? containerRootfileMatch[1] : ''
    const packageDocumentXml = readArchiveText(archiveEntries, packageDocumentPath)
    const manifestItems = parseManifestItems(packageDocumentXml)
    const epubMetadata = parseEpubMetadata(packageDocumentXml)
    const filenameMetadata = parseFilenameMetadata(epubFile.originalName || epubFile.name)
    const fallbackTitle = epubMetadata.title || filenameMetadata.title || stripFileExtension(epubFile.originalName || epubFile.name)
    const fallbackAuthor = extractPrimaryAuthorName(epubMetadata.author) || extractPrimaryAuthorName(filenameMetadata.author) || epubMetadata.author || filenameMetadata.author
    dbg('xapi/epub/upload:epub-metadata', {
      title: epubMetadata.title,
      author: epubMetadata.author,
      isbn13: epubMetadata.isbn13,
      languageCode: epubMetadata.languageCode,
      epubVersion: epubMetadata.epubVersion,
    })
    let firstContentPath = ''

    for (let index = 0; index < manifestItems.length; index += 1) {
      const manifestItem = manifestItems[index]

      if (!manifestItem.href) {
        continue
      }

      if (manifestItem.mediaType === 'application/xhtml+xml' || /\.(xhtml|html|htm)$/i.test(manifestItem.href)) {
        firstContentPath = joinPath(dirname(packageDocumentPath), manifestItem.href)
        break
      }
    }

    if (!firstContentPath) {
      for (let index = 0; index < entryNames.length; index += 1) {
        const entryName = entryNames[index]
        if (/\.(xhtml|html|htm)$/i.test(entryName)) {
          firstContentPath = entryName
          break
        }
      }
    }

    const firstContentXml = readArchiveText(archiveEntries, firstContentPath)
    const firstContentText = normalizePreview(
      firstContentXml
        .replace(/<script[\s\S]*?<\/script>/gi, ' ')
        .replace(/<style[\s\S]*?<\/style>/gi, ' ')
        .replace(/<[^>]+>/g, ' '),
      800
    )
    let searchKeyword = ''
    let searchResult = null
    let selectedDoc = null
    let detailResult = null
    let matchedBy = ''
    let matchedSource = ''
    let matchedIsbn13 = ''

    if (epubMetadata.title || epubMetadata.author || filenameMetadata.title || filenameMetadata.author) {
      const lookupResult = resolveBookLookup(epubMetadata, archiveEntries, manifestItems, packageDocumentPath, entryNames, epubFile.originalName || epubFile.name)
      searchKeyword = lookupResult.searchKeyword
      searchResult = lookupResult.searchResult
      selectedDoc = lookupResult.selectedDoc
      detailResult = lookupResult.detailResult || null
      matchedBy = lookupResult.matchedBy || ''
      matchedSource = lookupResult.matchedSource || ''
      matchedIsbn13 = lookupResult.matchedIsbn13 || ''

      dbg('xapi/epub/upload:search-selection', {
        searchKeyword: searchKeyword,
        hasSearchResult: !!searchResult,
        matchedBy: matchedBy,
        matchedSource: matchedSource,
        matchedIsbn13: matchedIsbn13,
        selectedIsbn13: selectedDoc && selectedDoc.isbn13 ? String(selectedDoc.isbn13) : '',
        selectedBookname: selectedDoc && selectedDoc.bookname ? String(selectedDoc.bookname) : '',
      })
    }

    if (!detailResult && selectedDoc && selectedDoc.isbn13) {
      dbg('xapi/epub/upload:detail-request', {
        isbn13: String(selectedDoc.isbn13),
      })
      detailResult = loadBookDetailByIsbn13(String(selectedDoc.isbn13))
    }

    const detailBook = detailResult && detailResult.book ? detailResult.book : null
    const matchedBook = detailBook || selectedDoc || null
    const resolvedIsbn13 = detailBook && detailBook.isbn13 ? String(detailBook.isbn13) : matchedIsbn13 || epubMetadata.isbn13 || ''
    const bookRecord = saveBookRecord({
      title: matchedBook && matchedBook.bookname ? matchedBook.bookname : fallbackTitle,
      author: matchedBook && matchedBook.authors ? matchedBook.authors : fallbackAuthor,
      publisher: matchedBook && matchedBook.publisher ? matchedBook.publisher : '',
      publicationDate: matchedBook ? parsePublicationDate(matchedBook.publication_date) : '',
      publicationYear: matchedBook && matchedBook.publication_year ? String(matchedBook.publication_year) : '',
      classNo: matchedBook && matchedBook.class_no ? String(matchedBook.class_no) : '',
      isbn: matchedBook && matchedBook.isbn ? String(matchedBook.isbn) : '',
      isbn13: resolvedIsbn13,
      bookImageUrl: matchedBook && matchedBook.bookImageURL ? matchedBook.bookImageURL : '',
      description: matchedBook && matchedBook.description ? matchedBook.description : '',
      metadataJson: detailResult ? detailResult.raw : null,
    })
    const existingBookFile = findFirstRecordOrNull('book_files', 'file_hash = {:fileHash}', {
      fileHash: fileHash,
    })
    dbg('xapi/epub/upload:existing-book-file', {
      fileHash: fileHash,
      existingId: existingBookFile ? existingBookFile.get('id') : '',
      existingBookId: existingBookFile ? existingBookFile.get('book_id') : '',
    })
    const targetBookId = existingBookFile && existingBookFile.get('book_id') ? existingBookFile.get('book_id') : bookRecord.get('id')

    if (existingBookFile && existingBookFile.get('book_id') && existingBookFile.get('book_id') !== bookRecord.get('id')) {
      warn('xapi/epub/upload:file-book-mismatch', {
        fileHash: fileHash,
        existingBookId: existingBookFile.get('book_id'),
        newBookId: bookRecord.get('id'),
      })
    }

    const bookFileRecord = saveBookFileRecord({
      bookId: targetBookId,
      originalName: epubFile.originalName || epubFile.name,
      uploadedFile: epubFile,
      mimeType: normalizePreview(mimetypeText, 120) || 'application/epub+zip',
      fileSize: Number(epubFile.size || 0),
      fileHash: fileHash,
      epubVersion: epubMetadata.epubVersion,
      languageCode: epubMetadata.languageCode,
      identifierValue: epubMetadata.identifierValue,
      previewText: firstContentText,
      tocJson: [],
      manifestJson: manifestItems,
    })
    const shelfRecord = saveBookShelfRecord({
      userId: request.auth.get('id'),
      bookId: targetBookId,
      bookFileId: bookFileRecord.get('id'),
    })

    info('xapi/epub/upload:success', {
      userId: request.auth.get('id'),
      bookId: targetBookId,
      bookFileId: bookFileRecord.get('id'),
      shelfId: shelfRecord.get('id'),
      fileHash: fileHash,
      epubTitle: epubMetadata.title,
      epubAuthor: epubMetadata.author,
      searchKeyword: searchKeyword,
      matchedBy: matchedBy,
      matchedSource: matchedSource,
      selectedIsbn13: resolvedIsbn13,
    })

    dbg('xapi/epub/upload:redirect', {
      status: 303,
      redirectTo: '/',
      flash: 'EPUB 파일과 도서 메타데이터를 저장했습니다.',
    })
    redirect('/', {
      status: 303,
      message: 'EPUB 파일과 도서 메타데이터를 저장했습니다.',
    })
    return
  } catch (exception) {
    const errorMessage = String(exception.message || exception)

    error('xapi/epub/upload:failed', {
      error: errorMessage,
    })

    dbg('xapi/epub/upload:redirect', {
      status: 303,
      redirectTo: '/',
      error: errorMessage,
    })
    redirect('/', {
      status: 303,
      message: errorMessage,
    })
  }
</script>
