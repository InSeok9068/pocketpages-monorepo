    loading: true,
    errorMessage: '',
    savePositionMessage: '',
    savePositionMessageTimer: null,
    savingPosition: false,
    loadingSavedPosition: false,
    controlsVisible: false,
    searchQuery: '',
    searchResults: [],
    searchOpen: false,
    searching: false,
    searchMessage: '',
    currentProgressPercent: '',
    tocOpen: false,
    tocItems: [],
    tocReady: false,
    tocMessage: '목차를 불러오는 중입니다.',
    activeTocKey: '',
    activeTocHref: '',
    progressJumpValue: '',
    progressJumpEditing: false,
    jumpingProgress: false,
    highlightOpen: false,
    savingHighlight: false,
    highlightMessage: '',
    highlightQuoteText: '',
    highlightNoteText: '',
    currentChapterLabel: '',
    openSearch: function () {
      this.searchOpen = true
      this.controlsVisible = true
      this.searchMessage = ''
      this.$nextTick(function () {
        var input = document.getElementById('reader-search-input')

        if (input) {
          input.focus()
        }
      })
    },
    closeSearch: function () {
      this.searchOpen = false
    },
    openToc: function () {
      this.tocOpen = true
      this.controlsVisible = true
    },
    closeToc: function () {
      this.tocOpen = false
    },
    openHighlight: function () {
      this.highlightOpen = true
      this.highlightMessage = ''
      this.controlsVisible = true
      this.$nextTick(function () {
        var input = document.getElementById('reader-highlight-quote')

        if (input) {
          input.focus()
        }
      })
    },
    closeHighlight: function () {
      if (this.savingHighlight) {
        return
      }

      this.highlightOpen = false
    },
    saveHighlight: function () {
      window.booklogReaderLogic.saveHighlight(this)
    },
    saveCurrentPosition: function () {
      window.booklogReaderLogic.saveCurrentPosition(this)
    },
    loadSavedPosition: function () {
      window.booklogReaderLogic.loadSavedPosition(this)
    },
    showSavePositionMessage: function (message) {
      var self = this

      this.savePositionMessage = String(message || '').trim()

      if (this.savePositionMessageTimer) {
        clearTimeout(this.savePositionMessageTimer)
        this.savePositionMessageTimer = null
      }

      if (!this.savePositionMessage) {
        return
      }

      this.savePositionMessageTimer = setTimeout(function () {
        self.savePositionMessage = ''
        self.savePositionMessageTimer = null
      }, 1000)
    },
    toggleControls: function () {
      this.controlsVisible = !this.controlsVisible
    },
    goToSearchResult: function (result) {
      window.booklogReaderLogic.goToSearchResult(this, result)
    },
    performSearch: function () {
      window.booklogReaderLogic.performSearch(this)
    },
    goToTocItem: function (item) {
      window.booklogReaderLogic.goToTocItem(this, item)
    },
    isActiveTocItem: function (item) {
      return window.booklogReaderLogic.isActiveTocItem(this, item)
    },
    goToProgress: function () {
      window.booklogReaderLogic.goToProgress(this)
    },
  }"
