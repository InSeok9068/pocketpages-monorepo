  </div>

  <div
    x-show="searchOpen"
    x-cloak
    class="fixed inset-0 z-40 bg-[rgba(24,19,16,0.2)] backdrop-blur-[2px]">
    <div class="mx-auto flex min-h-screen max-w-3xl items-start justify-center px-4 pt-20 sm:px-6">
      <div class="bg-white/88 w-full rounded-[1.75rem] border border-stone-200/80 p-4 shadow-[0_24px_60px_rgba(24,19,16,0.16)] backdrop-blur-sm">
