          </template>

          <template x-if="tocReady && tocItems.length">
            <div class="space-y-1">
              <template
                x-for="item in tocItems"
                :key="item.id || item.href || item.label">
                <div class="space-y-1">
                  <button
                    type="button"
                    x-on:click="goToTocItem(item)"
                    x-bind:data-toc-key="item.key || ''"
                    x-bind:aria-current="isActiveTocItem(item) ? 'true' : null"
                    x-bind:class="isActiveTocItem(item) ? 'bg-stone-950 text-white' : 'bg-[#fbf7ef] text-stone-700 hover:bg-[#f7f0e3]'"
                    class="block w-full rounded-[1.1rem] border-none px-4 py-3 text-left text-sm leading-6 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)] outline-none ring-0 transition">
                    <span x-text="item.label || '제목 없음'"></span>
                  </button>
                  <template x-if="item.subitems && item.subitems.length">
                    <div class="ml-4 border-l border-[rgba(118,87,52,0.12)] pl-3">
                      <template
                        x-for="child in item.subitems"
                        :key="child.id || child.href || child.label">
                        <button
                          type="button"
                          x-on:click="goToTocItem(child)"
                          x-bind:data-toc-key="child.key || ''"
                          x-bind:aria-current="isActiveTocItem(child) ? 'true' : null"
                          x-bind:class="isActiveTocItem(child) ? 'bg-stone-950 text-white' : 'bg-[#fbf7ef] text-stone-700 hover:bg-[#f7f0e3]'"
                          class="block w-full rounded-[1.1rem] border-none px-4 py-3 text-left text-sm leading-6 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)] outline-none ring-0 transition">
                          <span x-text="child.label || '제목 없음'"></span>
                        </button>
                      </template>
                    </div>
                  </template>
                </div>
              </template>
            </div>
          </template>
        </div>
      </div>
    </div>
  </div>

  <div
    x-show="highlightOpen"
    x-cloak
    class="fixed inset-0 z-40 bg-[rgba(24,19,16,0.2)] backdrop-blur-[2px]">
    <div class="mx-auto flex min-h-screen max-w-3xl items-start justify-center px-4 pt-20 sm:px-6">
      <div class="w-full rounded-[1.75rem] bg-white p-4 shadow-[0_24px_60px_rgba(24,19,16,0.16)]">
        <div class="mb-3 flex items-center justify-between gap-3">
          <div>
            <h2 class="text-base font-semibold text-stone-950">인상 깊은 문구 추가</h2>
            <p
              x-show="currentChapterLabel"
              x-cloak
              class="mt-1 text-sm text-stone-500"
              x-text="currentChapterLabel"></p>
          </div>
          <button
            type="button"
            x-on:click="closeHighlight()"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border-none bg-stone-100 text-stone-500 outline-none ring-0">
            ×
          </button>
        </div>

        <div class="space-y-3">
          <label class="block space-y-2">
            <span class="text-sm font-medium text-stone-700">문구</span>
            <textarea
              id="reader-highlight-quote"
              x-model="highlightQuoteText"
              rows="5"
              class="box-border block w-full min-w-0 rounded-[1.25rem] border-0 bg-[#fbf5ec] px-4 py-4 text-[15px] leading-7 text-[#2f251c] shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1),0_10px_24px_rgba(157,121,72,0.08)] outline-none transition placeholder:text-[#b59f87]"
              placeholder="복사한 문구를 붙여넣어 주세요."></textarea>
          </label>

          <label class="block space-y-2">
            <span class="text-sm font-medium text-stone-700">메모</span>
            <textarea
              x-model="highlightNoteText"
              rows="3"
              class="box-border block w-full min-w-0 rounded-[1.25rem] border-0 bg-[#fbf5ec] px-4 py-4 text-[15px] leading-7 text-[#2f251c] shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1),0_10px_24px_rgba(157,121,72,0.08)] outline-none transition placeholder:text-[#b59f87]"
              placeholder="짧은 생각이 있으면 같이 남겨두세요."></textarea>
          </label>
        </div>

        <p
          x-show="highlightMessage"
          x-cloak
          class="mt-3 text-sm text-stone-500"
          x-text="highlightMessage"></p>

        <div class="mt-4 flex gap-2">
          <button
            type="button"
            x-on:click="saveHighlight()"
            x-bind:disabled="savingHighlight"
            class="inline-flex items-center justify-center rounded-full border-none bg-stone-950 px-4 py-3 text-sm font-semibold text-white outline-none ring-0 disabled:opacity-60">
            <span
              x-show="!savingHighlight"
              x-cloak
              >문구 저장</span
            >
            <span
              x-show="savingHighlight"
              x-cloak
              >저장 중</span
            >
          </button>
          <button
            type="button"
            x-on:click="closeHighlight()"
            x-bind:disabled="savingHighlight"
            class="inline-flex items-center justify-center rounded-full border-none bg-stone-100 px-4 py-3 text-sm font-semibold text-stone-700 outline-none ring-0 disabled:opacity-60">
            닫기
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto flex min-h-screen max-w-none flex-col px-0 pb-0 pt-0 sm:px-0">
    <div
      x-cloak
      x-show="loading"
      class="pointer-events-none fixed left-1/2 top-5 z-40 max-w-[calc(100vw-6rem)] -translate-x-1/2 rounded-full bg-[rgba(24,19,16,0.82)] px-5 py-3 text-center text-sm font-medium text-white shadow-[0_18px_40px_rgba(24,19,16,0.28)] backdrop-blur-sm">
      EPUB 파일을 불러오는 중입니다.
    </div>

    <div
      x-cloak
      x-show="errorMessage"
      class="pointer-events-none fixed left-1/2 top-5 z-40 max-w-[calc(100vw-6rem)] -translate-x-1/2 rounded-full bg-[rgba(122,54,32,0.9)] px-5 py-3 text-center text-sm font-medium text-white shadow-[0_18px_40px_rgba(67,28,16,0.28)] backdrop-blur-sm"
      x-text="errorMessage"></div>

    <div
      x-cloak
      x-show="savePositionMessage"
      class="pointer-events-none fixed left-1/2 top-5 z-40 max-w-[calc(100vw-6rem)] -translate-x-1/2 rounded-full bg-[rgba(24,19,16,0.82)] px-5 py-3 text-center text-sm font-medium text-white shadow-[0_18px_40px_rgba(24,19,16,0.28)] backdrop-blur-sm"
      x-text="savePositionMessage"></div>

    <div class="min-h-0 flex-1 bg-white">
      <div
        id="epub-reader"
        class="h-screen overflow-y-auto px-0 py-0 sm:px-0 sm:py-0"></div>
    </div>
  </div>
</section>

<script>
  window.booklogReaderConfig = {
    readerUrl: '<%= epubReaderUrl %>',
    bookId: '<%= bookId %>',
    readerCacheKey: '<%= userId %>:<%= bookFileHash || bookId %>',
  }
</script>
<script src="<%= asset('/assets/booklog-reader.js') %>"></script>
