      if (direction === 'next') {
        if (lastSpineIndex >= 0 && endIndex === lastSpineIndex && page !== null && total !== null && page >= total) {
          return true
        }

        if (lastSpineIndex >= 0 && endIndex === lastSpineIndex && progressPercent === 100) {
          return true
        }
      }

      return false
