          </div>
          <button
            type="button"
            x-on:click="closeToc()"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border-none bg-stone-100 text-stone-700 outline-none ring-0">
            ×
          </button>
        </div>

        <div
          id="reader-toc-scroll"
          class="max-h-[60vh] overflow-y-auto">
          <template x-if="!tocReady || !tocItems.length">
            <p
              class="rounded-[1.25rem] bg-[#fbf7ef] px-4 py-4 text-sm leading-6 text-stone-500 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]"
