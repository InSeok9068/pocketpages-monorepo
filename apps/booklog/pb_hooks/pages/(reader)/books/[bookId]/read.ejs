        x-on:focus="progressJumpEditing = true"
        x-on:blur="progressJumpEditing = false"
        type="range"
        min="0"
        max="100"
        step="1"
        class="mt-3 block w-full accent-stone-900" />
      <div class="mt-2 flex items-center gap-2">
