<script server>
  meta('title', 'Booklog 리더')
  meta('description', 'Booklog EPUB 리더')

  const bookId = String(params.bookId || '').trim()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  let bookRecord = null
  let shelfRecord = null
  let bookFileRecord = null

  if (!request.auth) {
    dbg('page/books/[bookId]/read:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  if (!bookId) {
    dbg('page/books/[bookId]/read:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '책 정보를 찾을 수 없습니다.',
    })
    redirect('/', {
      status: 303,
      message: '책 정보를 찾을 수 없습니다.',
    })
    return
  }

  try {
    bookRecord = $app.findFirstRecordByFilter('books', 'id = {:bookId}', { bookId: bookId })
  } catch (exception) {
    bookRecord = null
  }

  if (!bookRecord) {
    dbg('page/books/[bookId]/read:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '책 정보를 찾을 수 없습니다.',
      bookId: bookId,
    })
    redirect('/', {
      status: 303,
      message: '책 정보를 찾을 수 없습니다.',
    })
    return
  }

  const bookDetailPath = '/books/' + bookId

  try {
    shelfRecord = $app.findFirstRecordByFilter('book_shelves', 'user_id = {:userId} && book_id = {:bookId}', {
      userId: userId,
      bookId: bookId,
    })
  } catch (exception) {
    shelfRecord = null
  }

  if (shelfRecord) {
    const shelfStatus = String(shelfRecord.get('status') || '').trim()

    if (shelfStatus !== 'finished' && shelfStatus !== 'reading') {
      shelfRecord.set('status', 'reading')
    }

    if (!String(shelfRecord.get('started_at') || '').trim()) {
      shelfRecord.set('started_at', new Date().toISOString().slice(0, 10))
    }

    shelfRecord.set('last_read_at', new Date().toISOString().slice(0, 10))
    $app.save(shelfRecord)
  }

  const shelfBookFileId = shelfRecord ? String(shelfRecord.get('book_file_id') || '').trim() : ''

  if (shelfBookFileId) {
    try {
      bookFileRecord = $app.findFirstRecordByFilter('book_files', 'id = {:bookFileId}', {
        bookFileId: shelfBookFileId,
      })
    } catch (exception) {
      bookFileRecord = null
    }
  }

  if (!bookFileRecord && !shelfBookFileId) {
    try {
      const matchedBookFileRecords = $app.findRecordsByFilter('book_files', 'book_id = {:bookId}', '-updated', 2, 0, {
        bookId: bookId,
      })

      if (matchedBookFileRecords.length === 1) {
        bookFileRecord = matchedBookFileRecords[0]
      }
    } catch (exception) {
      bookFileRecord = null
    }
  }

  const storedFileName = bookFileRecord ? String(bookFileRecord.get('stored_file') || '').trim() : ''
  const bookFileHash = bookFileRecord ? String(bookFileRecord.get('file_hash') || '').trim() : ''
  const epubReaderUrl = bookFileRecord && storedFileName ? '/xapi/books/' + encodeURIComponent(bookId) + '/read-file' : ''

  if (!epubReaderUrl) {
    dbg('page/books/[bookId]/read:redirect', {
      status: 303,
      redirectTo: bookDetailPath,
      flash: 'EPUB 파일을 찾을 수 없습니다.',
      bookId: bookId,
    })
    redirect(bookDetailPath, {
      status: 303,
      message: 'EPUB 파일을 찾을 수 없습니다.',
    })
    return
  }
</script>

<!-- slot:head -->
<script>
  window.__assetFallback = function (element) {
    element.onerror = null
    element.src = element.dataset.fallbackSrc
  }
</script>
<script
  src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"
  data-fallback-src="<%= asset('/assets/vendor/jszip-3.10.1.min.js') %>"
  onerror="window.__assetFallback(this)"></script>
<script
  src="https://cdn.jsdelivr.net/npm/epubjs/dist/epub.min.js"
  data-fallback-src="<%= asset('/assets/vendor/epubjs-latest.min.js') %>"
  onerror="window.__assetFallback(this)"></script>

<!-- slot:body -->
<section
