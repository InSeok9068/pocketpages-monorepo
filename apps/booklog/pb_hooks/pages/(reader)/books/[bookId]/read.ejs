            <span
              x-show="savingHighlight"
              x-cloak
              >저장 중</span
            >
          </button>
          <button
            type="button"
            x-on:click="closeHighlight()"
            x-bind:disabled="savingHighlight"
            class="inline-flex items-center justify-center rounded-full border-none bg-stone-100 px-4 py-3 text-sm font-semibold text-stone-700 outline-none ring-0 disabled:opacity-60">
            닫기
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto flex min-h-screen max-w-none flex-col px-0 pb-0 pt-0 sm:px-0">
    <div
      x-cloak
      x-show="loading"
      class="pointer-events-none fixed left-1/2 top-5 z-40 max-w-[calc(100vw-6rem)] -translate-x-1/2 rounded-full bg-[rgba(24,19,16,0.82)] px-5 py-3 text-center text-sm font-medium text-white shadow-[0_18px_40px_rgba(24,19,16,0.28)] backdrop-blur-sm">
