<% const isProduction = String(env('APP_ENV') || 'development').trim() === 'production' %>
<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1" />
    <title><%= meta('title') %></title>
    <meta
      name="description"
      content="<%= meta('description') %>" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="<%= asset('/assets/favicon.svg') %>" />
    <link
      rel="manifest"
      href="<%= asset('/assets/manifest.webmanifest') %>" />
    <meta
      name="theme-color"
      content="#f7f2e6" />
    <link
      rel="stylesheet"
      href="<%= asset('/assets/style.css') %>" />
    <style>
      [x-cloak] {
        display: none !important;
      }
    </style>
    <%- include('unocss-head.ejs', { isProduction }) %>
    <script
      defer
      src="<%= asset('/assets/vendor/alpine-3.15.11-cdn.min.js') %>"></script>
    <%- slots.head %>
  </head>

  <body
    un-cloak
    class="m-0 min-h-screen bg-[#f7f2e6] text-stone-900 antialiased">
    <%- slots.body || slot %>
  </body>
</html>
