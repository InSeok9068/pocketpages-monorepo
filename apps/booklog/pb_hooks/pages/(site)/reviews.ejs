<script server>
  meta('title', 'Booklog 감상평')
  meta('description', 'Booklog 감상평 리스트')

  const flashMessage = params.__flash ? String(params.__flash) : ''
  const formatDateText = function (value) {
    return String(value || '')
      .trim()
      .slice(0, 10)
  }

  if (!request.auth) {
    dbg('page/reviews:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const reviewRecords = $app.findRecordsByFilter('book_reviews', 'user_id = {:userId}', '-reviewed_at,-updated', 100, 0, { userId: request.auth.get('id') })
  const reviewItems = []

  for (let index = 0; index < reviewRecords.length; index += 1) {
    const reviewRecord = reviewRecords[index]
    const bookId = String(reviewRecord.get('book_id') || '').trim()
    const reviewText = String(reviewRecord.get('review_text') || '').trim()
    const reviewedAt = formatDateText(reviewRecord.get('reviewed_at'))
    let bookRecord = null

    try {
      bookRecord = $app.findFirstRecordByFilter('books', 'id = {:id}', { id: bookId })
    } catch (exception) {
      bookRecord = null
    }

    reviewItems.push({
      bookId: bookId,
      bookTitle: bookRecord ? String(bookRecord.get('title') || '제목 없음') : '제목 없음',
      reviewText: reviewText,
      reviewedAt: reviewedAt,
    })
  }
</script>

<section class="space-y-7">
  <div class="space-y-3">
    <a
      href="/"
      class="bg-white/78 inline-flex items-center gap-2 rounded-full border-none px-3 py-2 text-sm font-medium text-stone-700 no-underline shadow-[0_10px_22px_rgba(70,52,31,0.08)] outline-none ring-0">
      <span aria-hidden="true">←</span>
      메인으로
    </a>
    <h1 class="text-4xl font-semibold tracking-tight text-stone-950">감상평 리스트</h1>
  </div>

  <% if (flashMessage) { %>
  <section class="rounded-[1.6rem] border border-stone-200 bg-white/85 px-5 py-4 text-sm text-stone-700 shadow-sm backdrop-blur-sm">
    <%= flashMessage %>
  </section>
  <% } %>

  <section class="rounded-[2rem] border border-stone-200/80 bg-white/80 p-5 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm">
    <% if (reviewItems.length > 0) { %>
    <div class="space-y-3">
      <% for (let index = 0; index < reviewItems.length; index += 1) { const item = reviewItems[index] %>
      <a
        href="/books/<%= item.bookId %>"
        class="block rounded-[1.4rem] bg-[#fbf7ef] px-4 py-4 text-stone-900 no-underline shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)] transition hover:bg-[#f7f0e3]">
        <p class="text-base font-semibold leading-7 tracking-[-0.02em] text-stone-900"><%= item.reviewText %></p>
        <p class="mt-2 text-[12px] leading-5 text-stone-500">
          <span><%= item.bookTitle %></span>
          <% if (item.reviewedAt) { %>
          <span> · <%= item.reviewedAt %></span>
          <% } %>
        </p>
      </a>
      <% } %>
    </div>
    <% } else { %>
    <div class="rounded-[1.4rem] bg-[#fbf7ef] px-4 py-4 text-sm leading-6 text-stone-500 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">아직 저장된 감상평이 없습니다.</div>
    <% } %>
  </section>
</section>
