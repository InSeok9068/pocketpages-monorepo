<script server>
  meta('title', 'Booklog 감상평')
  meta('description', 'Booklog 감상평 리스트')

  const { dateutil } = require('@pocketpages/utils')
  const flashMessage = params.__flash ? String(params.__flash) : ''
  const queryText = String(request.url.query.q || '').trim()
  const requestedLimit = Number(request.url.query.limit || 30)
  const maxReviewLimit = 5000
  const visibleLimit = isNaN(requestedLimit) || requestedLimit < 1 ? 30 : Math.min(Math.max(Math.round(requestedLimit), 30), maxReviewLimit)
  const nextLimit = Math.min(visibleLimit + 30, maxReviewLimit)
  const normalizedQuery = queryText.toLowerCase()

  if (!request.auth) {
    dbg('page/reviews:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  /**
   * 감상평 조회 조건을 붙입니다.
   *
   * @param {object} query 쿼리 빌더
   * @returns {object} 쿼리 빌더
   */
  function applyReviewWhere(query) {
    query.where($dbx.exp('book_reviews.user_id = {:userId}', { userId: request.auth.get('id') }))

    if (normalizedQuery) {
      query.andWhere(
        $dbx.exp("(instr(lower(coalesce(book_reviews.review_text, '')), {:query}) > 0 OR instr(lower(coalesce(books.title, '')), {:query}) > 0)", {
          query: normalizedQuery,
        })
      )
    }

    return query
  }

  /**
   * 감상평 리스트 이동 링크를 만듭니다.
   *
   * @param {{ q?: string, limit?: number }} options 링크 옵션
   * @returns {string} 이동 링크
   */
  function buildReviewsHref(options) {
    const nextQuery = typeof options.q === 'string' ? options.q : queryText
    const nextVisibleLimit = typeof options.limit === 'number' ? options.limit : visibleLimit
    const pairs = []

    if (nextQuery) {
      pairs.push('q=' + encodeURIComponent(nextQuery))
    }

    if (nextVisibleLimit > 30) {
      pairs.push('limit=' + encodeURIComponent(String(nextVisibleLimit)))
    }

    return pairs.length ? '/reviews?' + pairs.join('&') : '/reviews'
  }

  /**
   * 감상평 더 보기 조각 링크를 만듭니다.
   *
   * @param {number} offset 시작 위치
   * @returns {string} 더 보기 링크
   */
  function buildReviewsMoreHref(offset) {
    const pairs = ['offset=' + encodeURIComponent(String(offset)), 'limit=30']

    if (queryText) {
      pairs.push('q=' + encodeURIComponent(queryText))
    }

    return '/xapi/reviews-more?' + pairs.join('&')
  }

  const reviewRows = arrayOf(
    new DynamicModel({
      bookId: '',
      bookTitle: '',
      reviewText: '',
      reviewedAtValue: '',
    })
  )
  const reviewItems = []

  applyReviewWhere(
    $app
      .db()
      .select('book_reviews.book_id as bookId', 'books.title as bookTitle', 'book_reviews.review_text as reviewText', 'book_reviews.reviewed_at as reviewedAtValue')
      .from('book_reviews')
      .innerJoin('books', $dbx.exp('books.id = book_reviews.book_id'))
      .orderBy('book_reviews.reviewed_at DESC', 'book_reviews.updated DESC')
      .limit(visibleLimit + 1)
      .offset(0)
  ).all(reviewRows)

  const hasMoreReviews = reviewRows.length > visibleLimit
  const visibleReviewRowCount = Math.min(reviewRows.length, visibleLimit)

  for (let index = 0; index < visibleReviewRowCount; index += 1) {
    const row = reviewRows[index]
    const reviewedAtValue = String(row.reviewedAtValue || '').trim()
    reviewItems.push({
      bookId: String(row.bookId || '').trim(),
      bookTitle: String(row.bookTitle || '제목 없음'),
      reviewText: String(row.reviewText || '').trim(),
      reviewedAt: reviewedAtValue ? dateutil.formatDate(reviewedAtValue, dateutil.FORMATS.DATE) : '',
    })
  }
</script>

<section class="space-y-7">
  <div class="space-y-3">
    <a
      href="/"
      class="bg-white/78 inline-flex items-center gap-2 rounded-full border-none px-3 py-2 text-sm font-medium text-stone-700 no-underline shadow-[0_10px_22px_rgba(70,52,31,0.08)] outline-none ring-0">
      <span
        class="i-lucide-arrow-left h-4 w-4"
        aria-hidden="true"></span>
      메인으로
    </a>
    <h1 class="text-2xl font-semibold tracking-tight text-stone-950 sm:text-3xl">감상평 리스트</h1>
  </div>

  <% if (flashMessage) { %>
  <section class="rounded-[1.6rem] border border-stone-200 bg-white/85 px-5 py-4 text-sm text-stone-700 shadow-sm backdrop-blur-sm">
    <%= flashMessage %>
  </section>
  <% } %>

  <section class="rounded-[2rem] border border-stone-200/80 bg-white/80 p-4 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm sm:p-[1.2rem]">
    <form
      action="/reviews"
      method="get"
      class="mb-4 space-y-2 rounded-[1.35rem] bg-[#fbf7ef] p-3 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
      <div class="flex gap-2">
        <label class="relative block min-w-0 flex-1">
          <span class="sr-only">감상평 검색</span>
          <span
            class="i-lucide-search pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-stone-400"
            aria-hidden="true"></span>
          <input
            name="q"
            value="<%= queryText %>"
            type="search"
            placeholder="감상평이나 책 제목 검색"
            class="bg-white/88 box-border h-11 w-full rounded-full border-0 pl-9 pr-4 text-sm font-medium text-stone-900 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)] outline-none placeholder:text-stone-400" />
        </label>
        <button
          type="submit"
          class="inline-flex h-11 shrink-0 items-center justify-center rounded-full border-0 bg-stone-900 px-4 text-sm font-semibold text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)] outline-none ring-0">
          검색
        </button>
      </div>
      <% if (queryText) { %>
      <a
        href="/reviews"
        class="bg-white/88 inline-flex h-11 items-center justify-center rounded-full px-4 text-sm font-semibold text-stone-600 no-underline shadow-[0_8px_18px_rgba(70,52,31,0.08)]">
        검색 해제
      </a>
      <% } %>
    </form>

    <% if (reviewItems.length > 0) { %>
    <div class="space-y-2.5">
      <% for (let index = 0; index < reviewItems.length; index += 1) { const item = reviewItems[index] %>
      <a
        href="/books/<%= item.bookId %>?from=/reviews"
        class="block rounded-[1.4rem] bg-[#fbf7ef] px-4 py-3.5 text-stone-900 no-underline shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)] transition hover:bg-[#f7f0e3]">
        <p class="text-[15px] font-semibold leading-[1.65] tracking-[-0.02em] text-stone-900 sm:text-base"><%= item.reviewText %></p>
        <p class="mt-2.5 text-[12px] leading-5 text-stone-500">
          <span><%= item.bookTitle %></span>
        </p>
        <% if (item.reviewedAt) { %>
        <p class="mt-1.5 text-[12px] font-medium text-stone-400"><%= item.reviewedAt %></p>
        <% } %>
      </a>
      <% } %>
      <% if (hasMoreReviews) { %>
      <div
        id="reviews-more-control"
        class="flex justify-center">
        <a
          href="<%= buildReviewsHref({ limit: nextLimit }) %>"
          hx-get="<%= buildReviewsMoreHref(visibleLimit) %>"
          hx-target="#reviews-more-control"
          hx-push-url="<%= buildReviewsHref({ limit: nextLimit }) %>"
          hx-swap="outerHTML"
          class="inline-flex items-center rounded-full bg-stone-900 px-5 py-3 text-sm font-semibold text-white no-underline shadow-[0_10px_22px_rgba(24,19,16,0.12)]">
          더 보기
        </a>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <div class="rounded-[1.4rem] bg-[#fbf7ef] px-3.5 py-3.5 text-sm leading-6 text-stone-500 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
      <%= queryText ? '조건에 맞는 감상평이 없습니다.' : '아직 저장된 감상평이 없습니다.' %>
    </div>
    <% } %>
  </section>
</section>
