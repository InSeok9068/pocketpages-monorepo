<script server>
  meta('title', 'Booklog 로그인')
  meta('description', 'Booklog 로그인 및 회원가입 페이지')

  if (request.auth) {
    dbg('page/auth:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '이미 로그인되어 있습니다.',
    })
    redirect('/', {
      status: 303,
      message: '이미 로그인되어 있습니다.',
    })
    return
  }
</script>

<section class="mx-auto max-w-sm">
  <div
    x-data="{ mode: 'sign-in' }"
    class="min-w-0 overflow-hidden rounded-[2.4rem] border-none bg-[linear-gradient(180deg,rgba(255,252,246,0.98),rgba(249,242,230,0.98)_56%,rgba(241,231,216,0.98))] p-4 shadow-[0_30px_80px_rgba(81,58,32,0.12)] sm:p-5">
    <div class="rounded-[1.9rem] bg-[linear-gradient(180deg,rgba(255,255,255,0.45),rgba(255,250,242,0.78))] px-4 py-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.75)] sm:px-5 sm:py-5">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.38em] text-[#9b6f45]">Booklog</p>
          <h1
            x-text="mode === 'sign-in' ? '로그인' : '회원가입'"
            class="mt-3 text-[2.2rem] leading-none font-semibold tracking-[-0.06em] text-[#2d2218]"></h1>
        </div>
        <div class="mt-1 h-11 w-11 rounded-full bg-[radial-gradient(circle_at_30%_30%,#f8e5bd,#d5a565_58%,#b57a3e)] shadow-[inset_0_2px_4px_rgba(255,255,255,0.45),0_10px_20px_rgba(166,119,57,0.18)]"></div>
      </div>

      <div class="mt-5 rounded-[1.45rem] bg-[#efe2ce] p-1.5 shadow-[inset_0_1px_0_rgba(255,255,255,0.45)]">
        <div class="grid grid-cols-2 gap-1.5">
          <button
            type="button"
            x-on:click="mode = 'sign-in'"
            x-bind:class="mode === 'sign-in' ? 'bg-[linear-gradient(180deg,#3d2d20,#22170f)] text-[#fff9f1] shadow-[0_12px_26px_rgba(49,34,20,0.24)]' : 'text-[#7d6247]'"
            class="rounded-[1.15rem] border-none px-4 py-3 text-sm font-medium tracking-[-0.02em] outline-none ring-0 transition">
            로그인
          </button>
          <button
            type="button"
            x-on:click="mode = 'sign-up'"
            x-bind:class="mode === 'sign-up' ? 'bg-[linear-gradient(180deg,#3d2d20,#22170f)] text-[#fff9f1] shadow-[0_12px_26px_rgba(49,34,20,0.24)]' : 'text-[#7d6247]'"
            class="rounded-[1.15rem] border-none px-4 py-3 text-sm font-medium tracking-[-0.02em] outline-none ring-0 transition">
            회원가입
          </button>
        </div>
      </div>

      <div class="mt-5"><%- include('flash-alert.ejs') %></div>

      <form
        x-show="mode === 'sign-in'"
        class="mt-5 min-w-0 space-y-3.5"
        action="/xapi/auth/sign-in"
        method="post">
        <label class="block">
          <span class="mb-2 block pl-1 text-[12px] font-medium tracking-[0.08em] text-[#7f6246]">이메일</span>
          <input
            class="block w-full min-w-0 box-border rounded-[1.4rem] border-0 bg-[#fbf5ec] px-4 py-4 text-[15px] text-[#2f251c] shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1),0_10px_24px_rgba(157,121,72,0.08)] outline-none transition placeholder:text-[#b59f87] focus:bg-[#fffaf2] focus:shadow-[inset_0_0_0_1.5px_rgba(155,111,69,0.42),0_14px_28px_rgba(157,121,72,0.12)]"
            type="email"
            name="email"
            placeholder="you@example.com"
            required />
        </label>

        <label class="block">
          <span class="mb-2 block pl-1 text-[12px] font-medium tracking-[0.08em] text-[#7f6246]">비밀번호</span>
          <input
            class="block w-full min-w-0 box-border rounded-[1.4rem] border-0 bg-[#fbf5ec] px-4 py-4 text-[15px] text-[#2f251c] shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1),0_10px_24px_rgba(157,121,72,0.08)] outline-none transition placeholder:text-[#b59f87] focus:bg-[#fffaf2] focus:shadow-[inset_0_0_0_1.5px_rgba(155,111,69,0.42),0_14px_28px_rgba(157,121,72,0.12)]"
            type="password"
            name="password"
            placeholder="비밀번호 입력"
            required />
        </label>

        <button
          class="inline-flex w-full items-center justify-center rounded-[1.45rem] border-none bg-[linear-gradient(180deg,#3f2f22,#21160f)] px-4 py-4 text-sm font-semibold tracking-[0.02em] text-[#fff9f1] shadow-[0_18px_34px_rgba(53,36,20,0.18)] outline-none ring-0 transition hover:translate-y-[-1px]"
          type="submit">
          로그인
        </button>
      </form>

      <form
        x-show="mode === 'sign-up'"
        class="mt-5 min-w-0 space-y-3.5"
        action="/xapi/auth/sign-up"
        method="post">
        <label class="block">
          <span class="mb-2 block pl-1 text-[12px] font-medium tracking-[0.08em] text-[#7f6246]">이메일</span>
          <input
            class="block w-full min-w-0 box-border rounded-[1.4rem] border-0 bg-[#fbf5ec] px-4 py-4 text-[15px] text-[#2f251c] shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1),0_10px_24px_rgba(157,121,72,0.08)] outline-none transition placeholder:text-[#b59f87] focus:bg-[#fffaf2] focus:shadow-[inset_0_0_0_1.5px_rgba(155,111,69,0.42),0_14px_28px_rgba(157,121,72,0.12)]"
            type="email"
            name="email"
            placeholder="you@example.com"
            required />
        </label>

        <label class="block">
          <span class="mb-2 block pl-1 text-[12px] font-medium tracking-[0.08em] text-[#7f6246]">비밀번호</span>
          <input
            class="block w-full min-w-0 box-border rounded-[1.4rem] border-0 bg-[#fbf5ec] px-4 py-4 text-[15px] text-[#2f251c] shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1),0_10px_24px_rgba(157,121,72,0.08)] outline-none transition placeholder:text-[#b59f87] focus:bg-[#fffaf2] focus:shadow-[inset_0_0_0_1.5px_rgba(155,111,69,0.42),0_14px_28px_rgba(157,121,72,0.12)]"
            type="password"
            name="password"
            placeholder="8자 이상 비밀번호"
            minlength="8"
            required />
        </label>

        <label class="block">
          <span class="mb-2 block pl-1 text-[12px] font-medium tracking-[0.08em] text-[#7f6246]">비밀번호 확인</span>
          <input
            class="block w-full min-w-0 box-border rounded-[1.4rem] border-0 bg-[#fbf5ec] px-4 py-4 text-[15px] text-[#2f251c] shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1),0_10px_24px_rgba(157,121,72,0.08)] outline-none transition placeholder:text-[#b59f87] focus:bg-[#fffaf2] focus:shadow-[inset_0_0_0_1.5px_rgba(155,111,69,0.42),0_14px_28px_rgba(157,121,72,0.12)]"
            type="password"
            name="passwordConfirm"
            placeholder="비밀번호 다시 입력"
            minlength="8"
            required />
        </label>

        <button
          class="inline-flex w-full items-center justify-center rounded-[1.45rem] border-none bg-[linear-gradient(180deg,#cd8c3d,#9e6125)] px-4 py-4 text-sm font-semibold tracking-[0.02em] text-[#fffaf2] shadow-[0_18px_34px_rgba(165,103,38,0.18)] outline-none ring-0 transition hover:translate-y-[-1px]"
          type="submit">
          회원가입
        </button>
      </form>

      <div class="mt-5 border-t border-[#eadcc7] pt-4 text-center">
        <template x-if="mode === 'sign-in'">
          <button
            type="button"
            x-on:click="mode = 'sign-up'"
            class="inline-flex items-center gap-2 rounded-full border-none bg-white/65 px-3 py-2 text-sm font-medium text-[#7d6247] shadow-[0_8px_18px_rgba(125,98,71,0.06)] outline-none ring-0">
            <span class="h-1.5 w-1.5 rounded-full bg-[#cd8c3d]"></span>
            회원가입으로 전환
          </button>
        </template>
        <template x-if="mode === 'sign-up'">
          <button
            type="button"
            x-on:click="mode = 'sign-in'"
            class="inline-flex items-center gap-2 rounded-full border-none bg-white/65 px-3 py-2 text-sm font-medium text-[#7d6247] shadow-[0_8px_18px_rgba(125,98,71,0.06)] outline-none ring-0">
            <span class="h-1.5 w-1.5 rounded-full bg-[#2d2218]"></span>
            로그인으로 전환
          </button>
        </template>
      </div>
    </div>
  </div>
</section>
