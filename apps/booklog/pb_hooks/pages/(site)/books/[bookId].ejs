<script server>
  meta('title', 'Booklog 책 상세')
  meta('description', 'Booklog 책 상세 페이지')

  const flashMessage = params.__flash ? String(params.__flash) : ''
  const bookId = String(params.bookId || '').trim()
  const userId = request.auth ? String(request.auth.get('id') || '') : ''
  const shelfStatusLabels = {
    queued: '읽을 예정',
    reading: '읽는 중',
    finished: '완독',
    dropped: '중단함',
  }

  if (!request.auth) {
    dbg('page/books/[bookId]:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  if (!bookId) {
    dbg('page/books/[bookId]:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '책 정보를 찾을 수 없습니다.',
    })
    redirect('/', {
      status: 303,
      message: '책 정보를 찾을 수 없습니다.',
    })
    return
  }

  let bookRecord = null
  let shelfRecord = null
  let reviewRecord = null
  let bookFileRecord = null
  let highlightRecords = []
  let highlightCards = []

  try {
    bookRecord = $app.findFirstRecordByFilter('books', 'id = {:bookId}', { bookId: bookId })
  } catch (exception) {
    bookRecord = null
  }

  if (!bookRecord) {
    dbg('page/books/[bookId]:redirect', {
      status: 303,
      redirectTo: '/',
      flash: '책 정보를 찾을 수 없습니다.',
      bookId: bookId,
    })
    redirect('/', {
      status: 303,
      message: '책 정보를 찾을 수 없습니다.',
    })
    return
  }

  const title = String(bookRecord.get('title') || '제목 없음')
  const author = String(bookRecord.get('author') || '').trim()
  const publicationDate = String(bookRecord.get('publication_date') || '').trim()
  const publicationYear = String(bookRecord.get('publication_year') || '').trim()
  const publisher = String(bookRecord.get('publisher') || '').trim()
  const bookImageUrl = String(bookRecord.get('book_image_url') || '').trim()

  try {
    shelfRecord = $app.findFirstRecordByFilter('book_shelves', 'user_id = {:userId} && book_id = {:bookId}', {
      userId: userId,
      bookId: bookId,
    })
  } catch (exception) {
    shelfRecord = null
  }

  const shelfStatus = shelfRecord ? String(shelfRecord.get('status') || 'queued') : 'queued'
  const shelfBookFileId = shelfRecord ? String(shelfRecord.get('book_file_id') || '').trim() : ''

  try {
    reviewRecord = $app.findFirstRecordByFilter('book_reviews', 'user_id = {:userId} && book_id = {:bookId}', {
      userId: userId,
      bookId: bookId,
    })
  } catch (exception) {
    reviewRecord = null
  }

  const reviewText = reviewRecord ? String(reviewRecord.get('review_text') || '') : ''

  if (shelfBookFileId) {
    try {
      bookFileRecord = $app.findFirstRecordByFilter('book_files', 'id = {:bookFileId}', {
        bookFileId: shelfBookFileId,
      })
    } catch (exception) {
      bookFileRecord = null
    }
  }

  if (!bookFileRecord && !shelfBookFileId) {
    try {
      const matchedBookFileRecords = $app.findRecordsByFilter('book_files', 'book_id = {:bookId}', '-updated', 2, 0, {
        bookId: bookId,
      })

      if (matchedBookFileRecords.length === 1) {
        bookFileRecord = matchedBookFileRecords[0]
      }
    } catch (exception) {
      bookFileRecord = null
    }
  }

  const storedFileName = bookFileRecord ? String(bookFileRecord.get('stored_file') || '').trim() : ''
  const bookFileUrl =
    bookFileRecord && storedFileName
      ? '/api/files/' +
        encodeURIComponent(String(bookFileRecord.collection().name || 'book_files')) +
        '/' +
        encodeURIComponent(String(bookFileRecord.get('id') || '')) +
        '/' +
        encodeURIComponent(storedFileName)
      : ''

  try {
    highlightRecords = $app.findRecordsByFilter('book_highlights', 'user_id = {:userId} && book_id = {:bookId}', '-highlighted_at,-updated', 20, 0, {
      userId: userId,
      bookId: bookId,
    })
  } catch (exception) {
    highlightRecords = []
  }

  /**
   * 문구 표시용 챕터 라벨을 정리합니다.
   * @param {string} value 원본 라벨 문자열
   * @returns {string} 사용자에게 보여줄 라벨
   */
  function formatHighlightLabel(value) {
    const normalizedValue = String(value || '').trim()

    if (!normalizedValue) {
      return ''
    }

    if (/[\\/]/.test(normalizedValue) || /\.x?html?$/i.test(normalizedValue) || /^section\d+/i.test(normalizedValue) || /^text$/i.test(normalizedValue)) {
      return ''
    }

    return normalizedValue
  }

  /**
   * 문구 표시용 날짜 문자열을 정리합니다.
   * @param {string} value 원본 날짜 문자열
   * @returns {string} 사용자에게 보여줄 날짜
   */
  function formatHighlightDate(value) {
    const normalizedValue = String(value || '').trim()

    if (!normalizedValue) {
      return ''
    }

    return normalizedValue.slice(0, 10)
  }

  highlightCards = highlightRecords.map(function (highlight) {
    return {
      id: String(highlight.get('id') || ''),
      label: formatHighlightLabel(String(highlight.get('chapter_label') || '')),
      pageNumber: String(highlight.get('page_number') || '').trim(),
      highlightedAt: formatHighlightDate(String(highlight.get('highlighted_at') || '')),
      quoteText: String(highlight.get('quote_text') || '').trim(),
      noteText: String(highlight.get('note_text') || '').trim(),
    }
  })

  let bookMetaText = publicationDate

  if (!bookMetaText && publicationYear) {
    bookMetaText = publicationYear
  }

  if (!bookMetaText) {
    bookMetaText = '출판일 정보 없음'
  }
</script>

<section class="space-y-7">
  <div class="space-y-3">
    <a
      href="/"
      class="bg-white/78 inline-flex items-center gap-2 rounded-full border-none px-3 py-2 text-sm font-medium text-stone-700 no-underline shadow-[0_10px_22px_rgba(70,52,31,0.08)] outline-none ring-0">
      <span aria-hidden="true">←</span>
      도서함으로
    </a>
    <h1 class="text-4xl font-semibold tracking-tight text-stone-950">책 상세</h1>
  </div>

  <% if (flashMessage) { %>
  <section class="rounded-[1.6rem] border border-stone-200 bg-white/85 px-5 py-4 text-sm text-stone-700 shadow-sm backdrop-blur-sm">
    <%= flashMessage %>
  </section>
  <% } %>

  <section
    class="relative rounded-[2rem] border border-stone-200/80 bg-[linear-gradient(180deg,rgba(255,252,245,0.94),rgba(245,236,222,0.96))] p-5 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm">
    <% if (shelfRecord) { %>
    <form
      method="post"
      action="/xapi/books/remove-from-shelf"
      class="absolute right-5 top-5 z-10 m-0"
      onsubmit="return window.confirm('이 책을 내 도서함에서 제거할까요? 감상평과 저장한 문구도 함께 정리됩니다.')">
      <input
        type="hidden"
        name="bookId"
        value="<%= bookId %>" />
      <button
        type="submit"
        class="inline-flex items-center rounded-full border-none bg-[#efe2d2] px-3.5 py-2 text-[12px] font-medium text-[#8e5521] shadow-[0_10px_22px_rgba(132,90,47,0.10)] outline-none ring-0 transition hover:bg-[#ead9c4]">
        도서함에서 제거
      </button>
    </form>
    <% } %>
    <div class="flex flex-col gap-5 md:grid md:grid-cols-[14rem_minmax(0,1fr)] md:items-start md:gap-x-8 md:gap-y-5 lg:gap-x-12">
      <div class="w-34 shrink-0 sm:w-40 md:w-[14rem]">
        <% if (bookImageUrl) { %>
        <div class="flex aspect-[5/7] w-full items-center justify-center overflow-hidden rounded-[1.5rem] bg-white px-2 py-2 shadow-[0_18px_30px_rgba(74,50,28,0.12)]">
          <img
            src="<%= bookImageUrl %>"
            alt="<%= title %> 표지"
            class="block h-full w-full object-contain" />
        </div>
        <% } else { %>
        <div class="flex aspect-[5/7] w-full items-center justify-center overflow-hidden rounded-[1.5rem] bg-white px-2 py-2 shadow-[0_18px_30px_rgba(74,50,28,0.12)]">
          <div class="relative h-full w-full rounded-[1.2rem] bg-gradient-to-b from-[#d8c3a5] to-[#b08968] text-white shadow-[0_18px_28px_rgba(74,50,28,0.18)]">
            <div class="absolute inset-0 box-border px-4 py-5 text-white">
              <div class="absolute left-1/2 top-[34%] w-[7.6rem] -translate-x-1/2 -translate-y-1/2 text-center">
                <h3 class="m-0 break-keep text-lg font-semibold leading-6 tracking-[-0.03em]"><%= title %></h3>
              </div>
              <p class="leading-4.5 text-white/78 absolute bottom-5 left-4 right-4 m-0 break-keep text-right text-[12px]"><%= author || '저자 정보 없음' %></p>
            </div>
          </div>
        </div>
        <% } %>
        <% if (bookFileUrl) { %>
        <a
          href="/books/<%= bookId %>/read"
          class="mt-3 inline-flex w-full items-center justify-center rounded-full border-none bg-stone-900 px-4 py-3 text-sm font-medium text-white no-underline shadow-[0_10px_22px_rgba(24,19,16,0.12)] outline-none ring-0 transition hover:bg-stone-700 md:w-auto md:min-w-[10.5rem] md:self-start">
          EPUB 뷰어로 보기
        </a>
        <% } %>
      </div>

      <div class="min-w-0 flex-1 space-y-4">
        <div class="space-y-2">
          <p class="text-[11px] font-semibold uppercase tracking-[0.26em] text-stone-500">Book</p>
          <h2 class="text-3xl font-semibold leading-tight tracking-[-0.04em] text-stone-950"><%= title %></h2>
        </div>

        <dl class="grid gap-3 text-sm text-stone-700 sm:grid-cols-2 lg:gap-4">
          <div class="rounded-[1.2rem] bg-white/75 px-4 py-3 shadow-[inset_0_0_0_1px_rgba(120,93,63,0.08)]">
            <dt class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500">저자</dt>
            <dd class="mt-1 text-base font-medium text-stone-900"><%= author || '저자 정보 없음' %></dd>
          </div>
          <div class="rounded-[1.2rem] bg-white/75 px-4 py-3 shadow-[inset_0_0_0_1px_rgba(120,93,63,0.08)]">
            <dt class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500">출판일</dt>
            <dd class="mt-1 text-base font-medium text-stone-900"><%= bookMetaText %></dd>
          </div>
          <div class="rounded-[1.2rem] bg-white/75 px-4 py-3 shadow-[inset_0_0_0_1px_rgba(120,93,63,0.08)]">
            <dt class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500">출판사</dt>
            <dd class="mt-1 text-base font-medium text-stone-900"><%= publisher || '출판사 정보 없음' %></dd>
          </div>
          <div class="rounded-[1.2rem] bg-white/75 px-4 py-3 shadow-[inset_0_0_0_1px_rgba(120,93,63,0.08)]">
            <dt class="text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500">현재 상태</dt>
            <dd class="mt-1 text-base font-medium text-stone-900"><%= shelfStatusLabels[shelfStatus] || '읽을 예정' %></dd>
          </div>
        </dl>

        <div class="flex flex-wrap gap-2 pt-1">
          <form
            method="post"
            action="/xapi/books/update-status"
            class="m-0">
            <input
              type="hidden"
              name="bookId"
              value="<%= bookId %>" />
            <input
              type="hidden"
              name="status"
              value="<%= shelfStatus === 'reading' ? 'queued' : 'reading' %>" />
            <button
              type="submit"
              class="<%= shelfStatus === 'reading' ? 'bg-stone-900 text-white shadow-[0_10px_22px_rgba(24,19,16,0.12)]' : 'bg-white/88 text-stone-700 shadow-[0_10px_22px_rgba(70,52,31,0.08)] hover:bg-stone-100/80' %> inline-flex items-center rounded-full border-none px-4 py-2.5 text-sm font-medium outline-none ring-0 transition">
              <%= shelfStatus === 'reading' ? '읽는 중 풀기' : '읽는 중' %>
            </button>
          </form>
          <form
            method="post"
            action="/xapi/books/update-status"
            class="m-0">
            <input
              type="hidden"
              name="bookId"
              value="<%= bookId %>" />
            <input
              type="hidden"
              name="status"
              value="<%= shelfStatus === 'finished' ? 'queued' : 'finished' %>" />
            <button
              type="submit"
              class="<%= shelfStatus === 'finished' ? 'bg-[#9e6125] text-white shadow-[0_10px_22px_rgba(165,103,38,0.14)]' : 'bg-white/88 text-stone-700 shadow-[0_10px_22px_rgba(70,52,31,0.08)] hover:bg-stone-100/80' %> inline-flex items-center rounded-full border-none px-4 py-2.5 text-sm font-medium outline-none ring-0 transition">
              <%= shelfStatus === 'finished' ? '완독 풀기' : '완독' %>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="relative rounded-[2rem] border border-stone-200/80 bg-white/80 p-5 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm">
    <div class="space-y-2">
      <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-stone-500">Review</p>
      <h3 class="text-2xl font-semibold tracking-tight text-stone-950">감상평</h3>
      <p class="text-sm leading-6 text-stone-600">책을 읽으며 느낀 점을 간단하게 남겨두세요.</p>
    </div>

    <% if (reviewText.trim()) { %>
    <form
      method="post"
      action="/xapi/books/delete-review"
      class="absolute right-5 top-5 m-0"
      onsubmit="return window.confirm('감상평을 삭제할까요?')">
      <input
        type="hidden"
        name="bookId"
        value="<%= bookId %>" />
      <button
        type="submit"
        aria-label="감상평 삭제"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full border-none bg-[#efe2d2] text-sm font-semibold text-[#8e5521] shadow-[0_8px_18px_rgba(132,90,47,0.08)] outline-none ring-0 transition hover:bg-[#ead9c4]">
        ×
      </button>
    </form>
    <% } %>

    <div class="mt-5 space-y-4">
      <form
        class="space-y-4"
        method="post"
        action="/xapi/books/save-review">
        <input
          type="hidden"
          name="bookId"
          value="<%= bookId %>" />
        <label class="block space-y-2">
          <span class="text-sm font-medium text-stone-700">내 감상</span>
          <textarea
            name="reviewText"
            rows="8"
            class="box-border block w-full min-w-0 rounded-[1.4rem] border-0 bg-[#fbf5ec] px-4 py-4 text-[15px] leading-7 text-[#2f251c] shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1),0_10px_24px_rgba(157,121,72,0.08)] outline-none transition placeholder:text-[#b59f87] focus:bg-[#fffaf2] focus:shadow-[inset_0_0_0_1.5px_rgba(155,111,69,0.42),0_14px_28px_rgba(157,121,72,0.12)]"
            placeholder="읽으며 들었던 생각을 적어보세요.">
<%= reviewText %></textarea
          >
        </label>
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-full border-none bg-stone-900 px-5 py-3 text-sm font-medium text-white shadow-[0_10px_22px_rgba(24,19,16,0.12)] outline-none ring-0 transition hover:bg-stone-700">
          감상평 저장
        </button>
      </form>
    </div>
  </section>

  <section class="rounded-[2rem] border border-stone-200/80 bg-white/80 p-5 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm">
    <div class="space-y-2">
      <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-stone-500">Highlights</p>
      <h3 class="text-2xl font-semibold tracking-tight text-stone-950">인상 깊은 문구</h3>
      <p class="text-sm leading-6 text-stone-600">리더에서 저장한 문구와 메모를 이곳에서 다시 볼 수 있습니다.</p>
    </div>

    <% if (highlightCards.length > 0) { %>
    <div class="mt-5 space-y-3">
      <% for (let index = 0; index < highlightCards.length; index += 1) { const highlight = highlightCards[index] %>
      <article class="rounded-[1.4rem] bg-[#fbf7ef] px-4 py-4 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <div class="flex min-w-0 flex-wrap items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-stone-500">
              <% if (highlight.label) { %>
              <span><%= highlight.label %></span>
              <% } %>
              <% if (highlight.pageNumber) { %>
              <span>Page <%= highlight.pageNumber %></span>
              <% } %>
            </div>
            <% if (highlight.highlightedAt) { %>
            <p class="mt-1 text-[12px] font-medium text-stone-400"><%= highlight.highlightedAt %></p>
            <% } %>
          </div>
          <form
            method="post"
            action="/xapi/books/delete-highlight"
            class="m-0 shrink-0"
            onsubmit="return window.confirm('이 문구를 삭제할까요?')">
            <input
              type="hidden"
              name="bookId"
              value="<%= bookId %>" />
            <input
              type="hidden"
              name="highlightId"
              value="<%= highlight.id %>" />
            <button
              type="submit"
              aria-label="인상 깊은 문구 삭제"
              class="inline-flex h-8 w-8 items-center justify-center rounded-full border-none bg-[#efe2d2] text-sm font-semibold text-[#8e5521] shadow-[0_6px_14px_rgba(132,90,47,0.06)] outline-none ring-0 transition hover:bg-[#ead9c4]">
              ×
            </button>
          </form>
        </div>
        <p class="mt-3 text-base font-medium leading-7 text-stone-900"><%= highlight.quoteText %></p>
        <% if (highlight.noteText) { %>
        <p class="mt-3 text-sm leading-6 text-stone-600"><%= highlight.noteText %></p>
        <% } %>
      </article>
      <% } %>
    </div>
    <% } else { %>
    <div class="mt-5 rounded-[1.4rem] bg-[#fbf7ef] px-4 py-4 text-sm leading-6 text-stone-500 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
      아직 저장된 문구가 없습니다. 리더에서 마음에 드는 문장을 복사해 저장해 보세요.
    </div>
    <% } %>
  </section>
</section>
