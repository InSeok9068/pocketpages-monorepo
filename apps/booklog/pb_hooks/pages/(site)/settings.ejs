<script server>
  meta('title', '설정 관리')
  meta('description', '알림과 리더 기본 동작을 관리하는 페이지')

  if (!request.auth) {
    dbg('page/settings:redirect', {
      status: 303,
      redirectTo: '/auth',
      message: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const flashMessage = params.__flash ? String(params.__flash) : ''
  const userId = String(request.auth.get('id') || '')
  let settingsRecord = null

  try {
    settingsRecord = $app.findFirstRecordByFilter('user_settings', 'user_id = {:userId}', {
      userId: userId,
    })
  } catch (exception) {
    settingsRecord = null
  }

  const settings = {
    pushEnabled: settingsRecord ? !!settingsRecord.get('push_enabled') : false,
    weeklyReadingNudgeEnabled: settingsRecord ? !!settingsRecord.get('weekly_reading_nudge_enabled') : false,
    readingReminderCycle: settingsRecord && settingsRecord.get('reading_reminder_cycle') ? Number(settingsRecord.get('reading_reminder_cycle')) : '',
    highlightPushCycle: settingsRecord && settingsRecord.get('highlight_push_cycle') ? Number(settingsRecord.get('highlight_push_cycle')) : '',
  }
</script>

<section class="space-y-6">
  <div class="space-y-3">
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-full border-none bg-white/78 px-3 py-2 text-sm font-medium text-stone-700 no-underline shadow-[0_10px_22px_rgba(70,52,31,0.08)] ring-0 outline-none">
      <span
        class="i-lucide-arrow-left h-4 w-4"
        aria-hidden="true"></span>
      메인으로
    </a>
    <h1 class="text-2xl font-semibold tracking-tight text-stone-950 sm:text-3xl">설정 관리</h1>
  </div>

  <div><%- include('flash-alert.ejs') %></div>

  <section class="rounded-[1.75rem] border border-stone-200/80 bg-white/88 px-4 py-5 shadow-[0_18px_38px_rgba(73,54,31,0.07)] backdrop-blur-sm sm:p-6">
    <form
      id="settings-form"
      action="/xapi/settings/save"
      method="post"
      class="space-y-6">
      <div class="space-y-4">
        <div class="space-y-1.5">
          <h2 class="text-[1.35rem] font-semibold tracking-tight text-stone-950">푸시 알림</h2>
          <p class="text-sm leading-6 text-stone-600">알림 사용 여부와 받을 주기를 관리합니다.</p>
        </div>

        <label class="flex items-center justify-between gap-4 rounded-[1.25rem] bg-[#faf7ef] px-4 py-4 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
          <span class="min-w-0 flex-1">
            <span class="block text-sm font-semibold text-stone-900">푸시 알림 사용</span>
            <span class="mt-1 block text-sm leading-6 text-stone-600">브라우저 구독이 허용되면 알림을 받습니다.</span>
          </span>
          <input
            id="push-enabled-input"
            type="checkbox"
            name="pushEnabled"
            value="true"
            <% if (settings.pushEnabled) { %>checked<% } %>
            class="peer sr-only" />
          <span
            class="relative inline-flex h-7 w-12 flex-none items-center rounded-full bg-stone-200 transition peer-checked:bg-stone-900 after:absolute after:left-1 after:h-5 after:w-5 after:rounded-full after:bg-white after:shadow-[0_4px_10px_rgba(24,19,16,0.18)] after:transition after:content-[''] peer-checked:after:translate-x-5"
            aria-hidden="true"></span>
        </label>

        <label class="flex items-center justify-between gap-4 rounded-[1.25rem] bg-[#faf7ef] px-4 py-4 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
          <span class="min-w-0 flex-1">
            <span class="block text-sm font-semibold text-stone-900">주간 독서 리마인더</span>
            <span class="mt-1 block text-sm leading-6 text-stone-600">일요일 저녁까지 이번 주 독서 세션이 없으면 짧은 알림을 받습니다.</span>
          </span>
          <input
            type="checkbox"
            name="weeklyReadingNudgeEnabled"
            value="true"
            <% if (settings.weeklyReadingNudgeEnabled) { %>checked<% } %>
            class="peer sr-only" />
          <span
            class="relative inline-flex h-7 w-12 flex-none items-center rounded-full bg-stone-200 transition peer-checked:bg-stone-900 after:absolute after:left-1 after:h-5 after:w-5 after:rounded-full after:bg-white after:shadow-[0_4px_10px_rgba(24,19,16,0.18)] after:transition after:content-[''] peer-checked:after:translate-x-5"
            aria-hidden="true"></span>
        </label>

        <div class="space-y-2">
          <p
            id="push-notice"
            hidden
            class="rounded-[1.15rem] bg-amber-50 px-4 py-3 text-sm leading-6 text-amber-800 shadow-[inset_0_0_0_1px_rgba(180,83,9,0.08)]"></p>

          <p
            id="push-state-notice"
            hidden
            class="rounded-[1.15rem] bg-stone-100/90 px-4 py-3 text-sm leading-6 text-stone-700 shadow-[inset_0_0_0_1px_rgba(120,92,57,0.08)]"></p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <label class="block rounded-[1.25rem] bg-[#faf7ef] px-4 py-4 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
            <span class="block text-sm font-semibold text-stone-900">읽기 리마인더</span>
            <span class="mt-1 block text-sm leading-6 text-stone-600">마지막 읽기 후 며칠 뒤 알림을 보낼지 정합니다.</span>
            <input
              id="reading-reminder-cycle-input"
              type="number"
              name="readingReminderCycle"
              min="1"
              max="90"
              value="<%= settings.readingReminderCycle === '' ? '' : String(settings.readingReminderCycle) %>"
              placeholder="꺼짐"
              class="mt-3 box-border block w-full rounded-[1rem] border-0 bg-white px-4 py-3 text-sm text-stone-900 shadow-[inset_0_0_0_1px_rgba(120,92,57,0.14)] outline-none placeholder:text-stone-400" />
          </label>

          <label class="block rounded-[1.25rem] bg-[#faf7ef] px-4 py-4 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
            <span class="block text-sm font-semibold text-stone-900">하이라이트 알림</span>
            <span class="mt-1 block text-sm leading-6 text-stone-600">저장한 문구를 며칠마다 다시 보여줄지 정합니다.</span>
            <input
              id="highlight-push-cycle-input"
              type="number"
              name="highlightPushCycle"
              min="1"
              max="90"
              value="<%= settings.highlightPushCycle === '' ? '' : String(settings.highlightPushCycle) %>"
              placeholder="꺼짐"
              class="mt-3 box-border block w-full rounded-[1rem] border-0 bg-white px-4 py-3 text-sm text-stone-900 shadow-[inset_0_0_0_1px_rgba(120,92,57,0.14)] outline-none placeholder:text-stone-400" />
          </label>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-3 border-t border-stone-200/80 pt-5">
        <button
          id="settings-submit-button"
          type="submit"
          class="inline-flex w-full items-center justify-center rounded-full border-none bg-stone-900 px-5 py-3 text-sm font-semibold text-white shadow-[0_12px_26px_rgba(24,19,16,0.12)] ring-0 transition outline-none hover:bg-stone-700 sm:w-auto">
          <span id="settings-submit-label">설정 저장</span>
        </button>
      </div>
    </form>
  </section>
</section>

<script>
  ;(function () {
    const form = document.getElementById('settings-form')
    const pushEnabledInput = document.getElementById('push-enabled-input')
    const readingReminderCycleInput = document.getElementById('reading-reminder-cycle-input')
    const highlightPushCycleInput = document.getElementById('highlight-push-cycle-input')
    const pushNoticeElement = document.getElementById('push-notice')
    const pushStateNoticeElement = document.getElementById('push-state-notice')
    const submitButton = document.getElementById('settings-submit-button')
    const submitLabel = document.getElementById('settings-submit-label')
    const maxReminderCycleDays = 90

    if (!form || !pushEnabledInput || !readingReminderCycleInput || !highlightPushCycleInput || !pushNoticeElement || !pushStateNoticeElement || !submitButton || !submitLabel) {
      return
    }

    const initialPushEnabled = pushEnabledInput.checked
    const state = {
      submitting: false,
      pushState: {
        ready: false,
        supported: typeof window !== 'undefined' && 'Notification' in window,
        permission: typeof Notification !== 'undefined' ? Notification.permission : 'default',
        optedIn: false,
      },
    }

    /**
     * 알림 문구를 표시하거나 숨깁니다.
     *
     * @param {HTMLElement} element 표시할 요소
     * @param {string} message 표시할 문구
     */
    function renderMessage(element, message) {
      const normalizedMessage = String(message || '')

      element.textContent = normalizedMessage
      element.hidden = !normalizedMessage
    }

    /**
     * 저장 버튼 상태를 갱신합니다.
     */
    function renderSubmittingState() {
      submitButton.disabled = state.submitting
      submitLabel.textContent = state.submitting ? '저장 중...' : '설정 저장'
    }

    /**
     * 현재 기기가 iPhone/iPad 계열인지 확인합니다.
     *
     * @returns {boolean} iOS 계열 기기 여부
     */
    function isIosDevice() {
      const platform = typeof navigator !== 'undefined' ? String(navigator.platform || '') : ''
      const userAgent = typeof navigator !== 'undefined' ? String(navigator.userAgent || '') : ''
      const touchPoints = typeof navigator !== 'undefined' && typeof navigator.maxTouchPoints === 'number' ? navigator.maxTouchPoints : 0

      return /iPad|iPhone|iPod/i.test(userAgent) || /iPad|iPhone|iPod/i.test(platform) || (platform === 'MacIntel' && touchPoints > 1)
    }

    /**
     * 현재 페이지가 홈 화면 웹앱으로 실행 중인지 확인합니다.
     *
     * @returns {boolean} standalone 실행 여부
     */
    function isStandaloneWebApp() {
      const displayModeStandalone = typeof window !== 'undefined' && typeof window.matchMedia === 'function' && window.matchMedia('(display-mode: standalone)').matches
      const navigatorStandalone = typeof navigator !== 'undefined' && navigator.standalone === true

      return !!(displayModeStandalone || navigatorStandalone)
    }

    /**
     * 현재 푸시 상태 안내 문구를 갱신합니다.
     */
    function renderPushStateNotice() {
      let message = ''

      if (isIosDevice() && !isStandaloneWebApp()) {
        message = 'iPhone/iPad에서는 북로그를 홈 화면에 추가한 뒤 앱처럼 연 상태에서만 푸시 알림을 켤 수 있습니다.'
      } else if (!state.pushState.supported) {
        message = '현재 브라우저에서는 웹 푸시 알림을 지원하지 않습니다.'
      } else if (!state.pushState.ready) {
        message = pushEnabledInput.checked ? '브라우저 알림 상태를 확인하는 중입니다.' : ''
      } else if (!pushEnabledInput.checked) {
        message = state.pushState.optedIn ? '북로그 알림은 꺼져 있지만, 브라우저 구독은 아직 남아 있습니다. 저장하면 북로그 알림도 함께 꺼집니다.' : ''
      } else if (state.pushState.optedIn) {
        message = ''
      } else if (state.pushState.permission === 'denied') {
        message = '브라우저 알림 권한이 차단되어 있습니다. 브라우저 설정에서 권한을 다시 허용해야 북로그 알림을 받을 수 있습니다.'
      } else {
        message = '북로그 알림은 켜져 있지만 현재 브라우저 구독은 연결되지 않았습니다. 설정을 저장하면 브라우저 구독을 다시 확인합니다.'
      }

      renderMessage(pushStateNoticeElement, message)
    }

    /**
     * 브리지에서 받은 푸시 상태를 반영합니다.
     *
     * @param {Object} nextState 브리지 상태
     */
    function applyPushState(nextState) {
      state.pushState = {
        ready: !!(nextState && nextState.ready),
        supported: nextState && typeof nextState.supported === 'boolean' ? nextState.supported : state.pushState.supported,
        permission: nextState && typeof nextState.permission === 'string' ? nextState.permission : state.pushState.permission,
        optedIn: !!(nextState && nextState.optedIn),
      }

      renderPushStateNotice()
    }

    /**
     * 브라우저 권한 문자열을 조회합니다.
     *
     * @param {any} oneSignal OneSignal SDK 객체
     * @returns {string} 권한 상태 문자열
     */
    function readPermission(oneSignal) {
      if (oneSignal && oneSignal.Notifications && typeof oneSignal.Notifications.permission === 'string') {
        return oneSignal.Notifications.permission
      }

      if (typeof Notification !== 'undefined' && typeof Notification.permission === 'string') {
        return Notification.permission
      }

      return state.pushState.permission
    }

    /**
     * OneSignal 푸시 구독 객체를 읽습니다.
     *
     * @param {any} oneSignal OneSignal SDK 객체
     * @returns {any | null} 푸시 구독 객체
     */
    function findPushSubscription(oneSignal) {
      if (oneSignal && oneSignal.User && oneSignal.User.PushSubscription) {
        return oneSignal.User.PushSubscription
      }

      return null
    }

    /**
     * 실제 form submit을 실행합니다.
     */
    function finishSubmit() {
      HTMLFormElement.prototype.submit.call(form)
    }

    /**
     * 저장 중 상태를 해제하고 오류 문구를 표시합니다.
     *
     * @param {string} message 표시할 오류 문구
     */
    function stopSubmit(message) {
      state.submitting = false
      renderSubmittingState()
      renderMessage(pushNoticeElement, message)
    }

    /**
     * OneSignal 푸시 상태 변경을 반영합니다.
     *
     * @param {any} oneSignal OneSignal SDK 객체
     */
    function updatePushStateFromOneSignal(oneSignal) {
      const pushSubscription = findPushSubscription(oneSignal)

      applyPushState({
        ready: true,
        supported: typeof window !== 'undefined' && 'Notification' in window,
        permission: readPermission(oneSignal),
        optedIn: !!(pushSubscription && pushSubscription.optedIn),
      })
    }

    /**
     * 현재 저장에서 브라우저 푸시 상태를 함께 맞춰야 하는지 확인합니다.
     *
     * @returns {boolean} 재동기화 필요 여부
     */
    function isPushSyncRequired() {
      const pushEnabled = pushEnabledInput.checked
      const pushIntentChanged = pushEnabled !== initialPushEnabled

      if (pushEnabled) {
        return pushIntentChanged || !state.pushState.ready || !state.pushState.supported || !state.pushState.optedIn
      }

      return pushIntentChanged || state.pushState.optedIn
    }

    /**
     * 브라우저에서 푸시 끄기를 먼저 반영한 뒤 저장합니다.
     *
     * @param {any} oneSignal OneSignal SDK 객체
     */
    function syncPushDisableAndSubmit(oneSignal) {
      const pushSubscription = findPushSubscription(oneSignal)

      if (!pushSubscription || typeof pushSubscription.optOut !== 'function') {
        stopSubmit('푸시 설정을 불러오지 못했습니다. 잠시 후 다시 시도해주세요.')
        return
      }

      Promise.resolve(pushSubscription.optOut())
        .then(function () {
          updatePushStateFromOneSignal(oneSignal)

          if (pushSubscription.optedIn) {
            stopSubmit('브라우저 구독을 끄지 못했습니다. 잠시 후 다시 시도해주세요.')
            return
          }

          finishSubmit()
        })
        .catch(function (error) {
          console.warn('OneSignal optOut failed', error)
          stopSubmit('브라우저 구독을 끄지 못했습니다. 잠시 후 다시 시도해주세요.')
        })
    }

    /**
     * 브라우저에서 푸시 켜기를 먼저 반영한 뒤 저장합니다.
     *
     * @param {any} oneSignal OneSignal SDK 객체
     */
    function syncPushEnableAndSubmit(oneSignal) {
      const pushSubscription = findPushSubscription(oneSignal)

      if (!pushSubscription || typeof pushSubscription.optIn !== 'function') {
        stopSubmit('푸시 설정을 불러오지 못했습니다. 잠시 후 다시 시도해주세요.')
        return
      }

      Promise.resolve(pushSubscription.optIn())
        .then(function () {
          updatePushStateFromOneSignal(oneSignal)

          if (pushSubscription.optedIn) {
            finishSubmit()
            return
          }

          stopSubmit('브라우저 알림 권한이 허용되지 않아 푸시 사용을 켤 수 없습니다.')
        })
        .catch(function (error) {
          console.warn('OneSignal optIn failed', error)
          stopSubmit('브라우저 알림 권한 요청에 실패했습니다. 다시 시도해주세요.')
        })
    }

    /**
     * OneSignal SDK 준비를 기다린 뒤 콜백을 실행합니다.
     *
     * @param {(oneSignal: any) => void} callback SDK 준비 후 실행할 콜백
     */
    function runWithOneSignal(callback) {
      let handled = false
      const timeoutId = window.setTimeout(function () {
        if (handled) {
          return
        }

        handled = true
        stopSubmit('푸시 설정을 불러오지 못했습니다. 잠시 후 다시 시도해주세요.')
      }, 4000)

      window.OneSignalDeferred.push(function (OneSignal) {
        if (handled) {
          return
        }

        handled = true
        window.clearTimeout(timeoutId)
        callback(OneSignal)
      })
    }

    pushEnabledInput.addEventListener('change', function () {
      renderPushStateNotice()
    })

    if (window.__booklogPushBridge && typeof window.__booklogPushBridge.subscribe === 'function') {
      window.__booklogPushBridge.subscribe(function (nextState) {
        applyPushState(nextState)
      })
    } else {
      renderPushStateNotice()
    }

    form.addEventListener('submit', function (event) {
      if (state.submitting) {
        event.preventDefault()
        return
      }

      renderMessage(pushNoticeElement, '')
      state.submitting = true
      renderSubmittingState()

      if (readingReminderCycleInput.value) {
        const readingReminderCycle = Number(readingReminderCycleInput.value || '')

        if (isNaN(readingReminderCycle) || readingReminderCycle < 1 || readingReminderCycle > maxReminderCycleDays || Math.floor(readingReminderCycle) !== readingReminderCycle) {
          event.preventDefault()
          stopSubmit('읽기 리마인더 주기는 1일부터 90일 사이의 정수여야 합니다.')
          return
        }
      }

      if (highlightPushCycleInput.value) {
        const highlightPushCycle = Number(highlightPushCycleInput.value || '')

        if (isNaN(highlightPushCycle) || highlightPushCycle < 1 || highlightPushCycle > maxReminderCycleDays || Math.floor(highlightPushCycle) !== highlightPushCycle) {
          event.preventDefault()
          stopSubmit('하이라이트 리마인더 주기는 1일부터 90일 사이의 정수여야 합니다.')
          return
        }
      }

      if (!isPushSyncRequired()) {
        return
      }

      event.preventDefault()

      if (pushEnabledInput.checked && isIosDevice() && !isStandaloneWebApp()) {
        stopSubmit('iPhone/iPad에서는 북로그를 홈 화면에 추가한 뒤 앱처럼 연 상태에서만 푸시를 켤 수 있습니다.')
        return
      }

      if (pushEnabledInput.checked && state.pushState.ready && !state.pushState.supported) {
        stopSubmit('현재 브라우저에서는 웹 푸시 알림을 지원하지 않습니다.')
        return
      }

      if (typeof window.OneSignalDeferred === 'undefined') {
        stopSubmit('푸시 설정을 불러오지 못했습니다. 잠시 후 다시 시도해주세요.')
        return
      }

      runWithOneSignal(function (OneSignal) {
        if (!pushEnabledInput.checked) {
          syncPushDisableAndSubmit(OneSignal)
          return
        }

        syncPushEnableAndSubmit(OneSignal)
      })
    })
  })()
</script>
