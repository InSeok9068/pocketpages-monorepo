<script server>
  meta('title', 'Booklog 도서함')
  meta('description', '내 도서함에 담긴 책 목록')

  const flashMessage = params.__flash ? String(params.__flash) : ''
  const shelfStatusLabels = {
    queued: '읽을 예정',
    reading: '읽는 중',
    finished: '완독',
    dropped: '중단함',
  }

  if (!request.auth) {
    dbg('page/library:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const userId = String(request.auth.get('id') || '')
  const libraryBooks = []

  dbg('page/library:start', {
    userId: userId,
  })
  dbg('page/library:find-shelves', {
    userId: userId,
  })

  const shelfRecords = $app.findRecordsByFilter('book_shelves', 'user_id = {:userId}', '-last_read_at,-updated', 300, 0, { userId: userId })

  for (let index = 0; index < shelfRecords.length; index += 1) {
    const shelfRecord = shelfRecords[index]
    const bookId = String(shelfRecord.get('book_id') || '').trim()
    const status = String(shelfRecord.get('status') || 'queued').trim()
    let bookRecord = null

    if (!bookId) {
      continue
    }

    try {
      bookRecord = $app.findRecordById('books', bookId)
    } catch (exception) {
      bookRecord = null
    }

    if (!bookRecord) {
      warn('page/library:book-not-found', {
        userId: userId,
        bookId: bookId,
      })
      continue
    }

    libraryBooks.push({
      bookId: String(bookRecord.get('id') || ''),
      title: String(bookRecord.get('title') || '제목 없음'),
      author: String(bookRecord.get('author') || '').trim(),
      coverUrl: String(bookRecord.get('book_image_url') || '').trim(),
      status: status,
      statusLabel: shelfStatusLabels[status] || '보관 중',
      statusBadgeLabel: status === 'reading' || status === 'finished' ? shelfStatusLabels[status] : '',
      statusBadgeClass: status === 'finished' ? 'bg-[#9e6125]/88 text-white shadow-[0_8px_18px_rgba(165,103,38,0.14)]' : 'bg-stone-900/84 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]',
      recentOrder: index,
      titleOrder: 0,
    })
  }

  const titleSortedBooks = libraryBooks.slice().sort(function (left, right) {
    const leftTitle = String(left.title || '')
    const rightTitle = String(right.title || '')

    if (leftTitle < rightTitle) {
      return -1
    }

    if (leftTitle > rightTitle) {
      return 1
    }

    return 0
  })

  for (let index = 0; index < titleSortedBooks.length; index += 1) {
    titleSortedBooks[index].titleOrder = index
  }
</script>

<script>
  window.booklogLibrary = {
    normalize: function (value) {
      return String(value || '').toLowerCase()
    },
    isBookVisible: function (component, element) {
      const query = this.normalize(component.query).trim()
      const status = String(component.status || 'all')
      const bookStatus = String(element.dataset.status || '')
      const searchText = this.normalize(element.dataset.search)

      if (status !== 'all' && bookStatus !== status) {
        return false
      }

      if (query && searchText.indexOf(query) === -1) {
        return false
      }

      return true
    },
    getBookOrder: function (component, element) {
      if (component.sort === 'title') {
        return Number(element.dataset.titleOrder || 0)
      }

      return Number(element.dataset.recentOrder || 0)
    },
    hasVisibleBooks: function (component, grid) {
      const cards = grid ? grid.querySelectorAll('[data-library-book]') : []

      for (let index = 0; index < cards.length; index += 1) {
        if (this.isBookVisible(component, cards[index])) {
          return true
        }
      }

      return false
    },
  }
</script>

<section
  x-data="{
    query: '',
    status: 'all',
    sort: 'recent',
    isBookVisible(element) {
      return window.booklogLibrary.isBookVisible(this, element)
    },
    getBookOrder(element) {
      return window.booklogLibrary.getBookOrder(this, element)
    },
    resetFilters() {
      this.query = ''
      this.status = 'all'
      this.sort = 'recent'
    },
    hasVisibleBooks() {
      return window.booklogLibrary.hasVisibleBooks(this, this.$refs.libraryGrid)
    },
  }"
  class="space-y-7">
  <div class="space-y-4">
    <a
      href="/"
      class="bg-white/78 inline-flex items-center gap-2 rounded-full border-none px-3 py-2 text-sm font-medium text-stone-700 no-underline shadow-[0_10px_22px_rgba(70,52,31,0.08)] outline-none ring-0">
      <span
        class="i-lucide-arrow-left h-4 w-4"
        aria-hidden="true"></span>
      메인으로
    </a>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-2">
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-stone-500">My Shelf</p>
        <h1 class="text-3xl font-semibold tracking-tight text-stone-950">도서함</h1>
      </div>
      <p class="bg-white/78 inline-flex w-max items-center rounded-full px-3 py-1.5 text-sm font-medium text-stone-600 shadow-[inset_0_0_0_1px_rgba(120,93,63,0.08)]"><%= libraryBooks.length %>권</p>
    </div>
  </div>

  <% if (flashMessage) { %>
  <section class="rounded-[1.6rem] border border-stone-200 bg-white/85 px-5 py-4 text-sm text-stone-700 shadow-sm backdrop-blur-sm">
    <%= flashMessage %>
  </section>
  <% } %>

  <section class="rounded-[2rem] border border-stone-200/80 bg-white/80 p-4 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm sm:p-5">
    <% if (libraryBooks.length > 0) { %>
    <div class="mb-5 space-y-3 rounded-[1.35rem] bg-[#fbf7ef] p-3 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)] sm:p-4">
      <label class="relative block">
        <span class="sr-only">도서함 검색</span>
        <span
          class="i-lucide-search pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-stone-400"
          aria-hidden="true"></span>
        <input
          x-model="query"
          type="search"
          placeholder="제목이나 저자 검색"
          class="box-border h-11 w-full rounded-full border-0 bg-white/88 pl-9 pr-4 text-sm font-medium text-stone-900 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)] outline-none placeholder:text-stone-400" />
      </label>

      <div class="space-y-3">
        <div class="grid grid-cols-4 rounded-full bg-white/72 p-1 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)] sm:flex">
          <button
            type="button"
            x-on:click="status = 'all'"
            x-bind:aria-pressed="status === 'all' ? 'true' : 'false'"
            x-bind:class="status === 'all' ? 'bg-stone-900 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]' : 'bg-transparent text-stone-600'"
            class="inline-flex h-9 items-center justify-center rounded-full border-0 px-2 text-xs font-semibold outline-none ring-0 sm:min-w-18 sm:px-3 sm:text-sm">
            전체
          </button>
          <button
            type="button"
            x-on:click="status = 'queued'"
            x-bind:aria-pressed="status === 'queued' ? 'true' : 'false'"
            x-bind:class="status === 'queued' ? 'bg-stone-900 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]' : 'bg-transparent text-stone-600'"
            class="inline-flex h-9 items-center justify-center rounded-full border-0 px-2 text-xs font-semibold outline-none ring-0 sm:min-w-18 sm:px-3 sm:text-sm">
            읽을 예정
          </button>
          <button
            type="button"
            x-on:click="status = 'reading'"
            x-bind:aria-pressed="status === 'reading' ? 'true' : 'false'"
            x-bind:class="status === 'reading' ? 'bg-stone-900 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]' : 'bg-transparent text-stone-600'"
            class="inline-flex h-9 items-center justify-center rounded-full border-0 px-2 text-xs font-semibold outline-none ring-0 sm:min-w-18 sm:px-3 sm:text-sm">
            읽는 중
          </button>
          <button
            type="button"
            x-on:click="status = 'finished'"
            x-bind:aria-pressed="status === 'finished' ? 'true' : 'false'"
            x-bind:class="status === 'finished' ? 'bg-stone-900 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]' : 'bg-transparent text-stone-600'"
            class="inline-flex h-9 items-center justify-center rounded-full border-0 px-2 text-xs font-semibold outline-none ring-0 sm:min-w-18 sm:px-3 sm:text-sm">
            완독
          </button>
        </div>

        <label class="flex items-center gap-2">
          <span class="text-xs font-semibold text-stone-500">정렬</span>
          <select
            x-model="sort"
            class="h-10 rounded-full border-0 bg-white/88 px-3 text-sm font-semibold text-stone-700 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)] outline-none">
            <option value="recent">최근 읽은 순</option>
            <option value="title">제목순</option>
          </select>
        </label>
      </div>
    </div>

    <div
      x-ref="libraryGrid"
      class="grid grid-cols-2 gap-x-4 gap-y-6 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      <% for (let index = 0; index < libraryBooks.length; index += 1) { const book = libraryBooks[index] %>
      <a
        href="/books/<%= book.bookId %>?from=/library"
        data-library-book
        data-status="<%= book.status %>"
        data-search="<%= book.title %> <%= book.author %>"
        data-recent-order="<%= book.recentOrder %>"
        data-title-order="<%= book.titleOrder %>"
        x-show="isBookVisible($el)"
        x-bind:style="'order: ' + String(getBookOrder($el))"
        class="group block min-w-0 text-stone-900 no-underline">
        <div
          class="relative aspect-[5/7] overflow-hidden rounded-[1.3rem] bg-gradient-to-b from-[#d8c3a5] to-[#b08968] shadow-[0_16px_26px_rgba(74,50,28,0.12)] transition group-hover:translate-y-[-1px]">
          <% if (book.statusBadgeLabel) { %>
          <span class="<%= book.statusBadgeClass %> absolute right-2 top-2 z-10 inline-flex items-center rounded-full px-2 py-1 text-[10px] font-semibold tracking-[0.08em] backdrop-blur-sm">
            <%= book.statusBadgeLabel %>
          </span>
          <% } %>
          <% if (book.coverUrl) { %>
          <div class="box-border flex h-full w-full items-center justify-center bg-white px-1.5 py-1.5">
            <img
              src="<%= book.coverUrl %>"
              alt="<%= book.title %> 표지"
              loading="lazy"
              decoding="async"
              class="block h-full w-full object-contain" />
          </div>
          <% } else { %>
          <div class="absolute inset-0 box-border px-3 py-4 text-white">
            <div class="absolute left-1/2 top-[34%] w-[78%] -translate-x-1/2 -translate-y-1/2 text-center">
              <h2 class="m-0 break-keep text-base font-semibold leading-5"><%= book.title %></h2>
            </div>
          </div>
          <% } %>
        </div>
        <div class="mt-3 min-w-0 space-y-1">
          <h2 class="m-0 min-w-0 break-words text-sm font-semibold leading-5 text-stone-950"><%= book.title %></h2>
          <p class="m-0 text-[12px] font-medium leading-5 text-stone-500"><%= book.author ? book.author + ' · ' : '' %><%= book.statusLabel %></p>
        </div>
      </a>
      <% } %>
    </div>
    <div
      x-show="!hasVisibleBooks()"
      x-cloak
      class="mt-4 flex flex-col gap-3 rounded-[1.4rem] bg-[#fbf7ef] px-4 py-4 text-sm leading-6 text-stone-500 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)] sm:flex-row sm:items-center sm:justify-between">
      <span>조건에 맞는 책이 없습니다.</span>
      <button
        type="button"
        x-on:click="resetFilters()"
        class="inline-flex w-max items-center rounded-full border-0 bg-white/88 px-3 py-2 text-sm font-semibold text-stone-700 shadow-[0_8px_18px_rgba(70,52,31,0.08)] outline-none ring-0">
        필터 초기화
      </button>
    </div>
    <% } else { %>
    <div class="rounded-[1.4rem] bg-[#fbf7ef] px-4 py-4 text-sm leading-6 text-stone-500 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
      아직 도서함에 담긴 책이 없습니다. 메인에서 EPUB를 올리면 이곳에 책이 쌓입니다.
    </div>
    <% } %>
  </section>
</section>
