<script server>
  meta('title', 'Booklog 도서함')
  meta('description', '내 도서함에 담긴 책 목록')

  const flashMessage = params.__flash ? String(params.__flash) : ''
  const shelfStatusLabels = {
    queued: '읽을 예정',
    reading: '읽는 중',
    finished: '완독',
    dropped: '중단함',
  }

  if (!request.auth) {
    dbg('page/library:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const userId = String(request.auth.get('id') || '')
  const libraryBooks = []
  const queryText = String(request.url.query.q || '').trim()
  const requestedStatus = String(request.url.query.status || 'all').trim()
  const requestedSort = String(request.url.query.sort || 'recent').trim()
  const requestedLimit = Number(request.url.query.limit || 50)
  const maxLibraryLimit = 5000
  const statusFilter = requestedStatus === 'queued' || requestedStatus === 'reading' || requestedStatus === 'finished' ? requestedStatus : 'all'
  const sortMode = requestedSort === 'title' ? 'title' : 'recent'
  const visibleLimit = isNaN(requestedLimit) || requestedLimit < 1 ? 50 : Math.min(Math.max(Math.round(requestedLimit), 50), maxLibraryLimit)
  const nextLimit = Math.min(visibleLimit + 50, maxLibraryLimit)
  const normalizedQuery = queryText.toLowerCase()

  dbg('page/library:start', {
    userId: userId,
  })
  dbg('page/library:find-shelves', {
    userId: userId,
  })

  /**
   * 도서함 조회 조건을 붙입니다.
   *
   * @param {object} query 쿼리 빌더
   * @returns {object} 쿼리 빌더
   */
  function applyLibraryWhere(query) {
    query.where($dbx.exp('book_shelves.user_id = {:userId}', { userId: userId }))

    if (statusFilter !== 'all') {
      query.andWhere($dbx.exp('book_shelves.status = {:status}', { status: statusFilter }))
    }

    if (normalizedQuery) {
      query.andWhere(
        $dbx.exp("(instr(lower(coalesce(books.title, '')), {:query}) > 0 OR instr(lower(coalesce(books.author, '')), {:query}) > 0)", {
          query: normalizedQuery,
        })
      )
    }

    return query
  }

  /**
   * 도서함 이동 링크를 만듭니다.
   *
   * @param {{ q?: string, status?: string, sort?: string, limit?: number }} options 링크 옵션
   * @returns {string} 이동 링크
   */
  function buildLibraryHref(options) {
    const nextQuery = typeof options.q === 'string' ? options.q : queryText
    const nextStatus = typeof options.status === 'string' ? options.status : statusFilter
    const nextSort = typeof options.sort === 'string' ? options.sort : sortMode
    const nextVisibleLimit = typeof options.limit === 'number' ? options.limit : visibleLimit
    const pairs = []

    if (nextQuery) {
      pairs.push('q=' + encodeURIComponent(nextQuery))
    }

    if (nextStatus && nextStatus !== 'all') {
      pairs.push('status=' + encodeURIComponent(nextStatus))
    }

    if (nextSort && nextSort !== 'recent') {
      pairs.push('sort=' + encodeURIComponent(nextSort))
    }

    if (nextVisibleLimit > 50) {
      pairs.push('limit=' + encodeURIComponent(String(nextVisibleLimit)))
    }

    return pairs.length ? '/library?' + pairs.join('&') : '/library'
  }

  /**
   * 도서함 더 보기 조각 링크를 만듭니다.
   *
   * @param {number} offset 시작 위치
   * @returns {string} 더 보기 링크
   */
  function buildLibraryMoreHref(offset) {
    const pairs = ['offset=' + encodeURIComponent(String(offset)), 'limit=50']

    if (queryText) {
      pairs.push('q=' + encodeURIComponent(queryText))
    }

    if (statusFilter !== 'all') {
      pairs.push('status=' + encodeURIComponent(statusFilter))
    }

    if (sortMode !== 'recent') {
      pairs.push('sort=' + encodeURIComponent(sortMode))
    }

    return '/xapi/library-more?' + pairs.join('&')
  }

  const totalShelfResult = new DynamicModel({ total: 0 })
  const totalMatchedResult = new DynamicModel({ total: 0 })
  const libraryRows = arrayOf(
    new DynamicModel({
      bookId: '',
      title: '',
      author: '',
      coverUrl: '',
      status: '',
    })
  )

  $app
    .db()
    .select('count(*) as total')
    .from('book_shelves')
    .where($dbx.exp('book_shelves.user_id = {:userId}', { userId: userId }))
    .one(totalShelfResult)

  applyLibraryWhere($app.db().select('count(*) as total').from('book_shelves').innerJoin('books', $dbx.exp('books.id = book_shelves.book_id'))).one(totalMatchedResult)

  const libraryQuery = applyLibraryWhere(
    $app
      .db()
      .select('books.id as bookId', 'books.title as title', 'books.author as author', 'books.book_image_url as coverUrl', 'book_shelves.status as status')
      .from('book_shelves')
      .innerJoin('books', $dbx.exp('books.id = book_shelves.book_id'))
  )

  if (sortMode === 'title') {
    libraryQuery.orderBy("lower(coalesce(nullif(books.title_sort, ''), books.title, '')) ASC", "lower(coalesce(books.title, '')) ASC")
  } else {
    libraryQuery.orderBy('book_shelves.last_read_at DESC', 'book_shelves.updated DESC')
  }

  libraryQuery
    .limit(visibleLimit + 1)
    .offset(0)
    .all(libraryRows)

  const totalShelfCount = Number(totalShelfResult.total || 0)
  const totalMatchedBookCount = Number(totalMatchedResult.total || 0)
  const hasLibraryBooks = totalShelfCount > 0
  const hasMoreLibraryBooks = libraryRows.length > visibleLimit
  const visibleLibraryRowCount = Math.min(libraryRows.length, visibleLimit)

  for (let index = 0; index < visibleLibraryRowCount; index += 1) {
    const row = libraryRows[index]
    const status = String(row.status || 'queued').trim()
    libraryBooks.push({
      bookId: String(row.bookId || ''),
      title: String(row.title || '제목 없음'),
      author: String(row.author || '').trim(),
      coverUrl: String(row.coverUrl || '').trim(),
      status: status,
      statusLabel: shelfStatusLabels[status] || '보관 중',
      statusBadgeLabel: status === 'reading' || status === 'finished' ? shelfStatusLabels[status] : '',
      statusBadgeClass: status === 'finished' ? 'bg-[#9e6125]/88 text-white shadow-[0_8px_18px_rgba(165,103,38,0.14)]' : 'bg-stone-900/84 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]',
    })
  }
</script>

<section class="space-y-7">
  <div class="space-y-4">
    <a
      href="/"
      class="bg-white/78 inline-flex items-center gap-2 rounded-full border-none px-3 py-2 text-sm font-medium text-stone-700 no-underline shadow-[0_10px_22px_rgba(70,52,31,0.08)] outline-none ring-0">
      <span
        class="i-lucide-arrow-left h-4 w-4"
        aria-hidden="true"></span>
      메인으로
    </a>

    <div>
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-semibold tracking-tight text-stone-950 sm:text-3xl">도서함</h1>
        <p class="bg-white/78 inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium text-stone-600 shadow-[inset_0_0_0_1px_rgba(120,93,63,0.08)]"><%= totalMatchedBookCount %>권</p>
      </div>
    </div>
  </div>

  <% if (flashMessage) { %>
  <section class="rounded-[1.6rem] border border-stone-200 bg-white/85 px-5 py-4 text-sm text-stone-700 shadow-sm backdrop-blur-sm">
    <%= flashMessage %>
  </section>
  <% } %>

  <section class="rounded-[2rem] border border-stone-200/80 bg-white/80 p-4 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm sm:p-5">
    <% if (hasLibraryBooks) { %>
    <div class="mb-5 space-y-3">
      <form
        action="/library"
        method="get"
        class="space-y-3">
        <input
          type="hidden"
          name="status"
          value="<%= statusFilter %>" />
        <div class="flex gap-2">
          <label class="relative block min-w-0 flex-1">
            <span class="sr-only">도서함 검색</span>
            <span
              class="i-lucide-search pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-stone-400"
              aria-hidden="true"></span>
            <input
              name="q"
              value="<%= queryText %>"
              type="search"
              placeholder="제목이나 저자 검색"
              class="bg-white/88 box-border h-11 w-full rounded-full border-0 pl-9 pr-4 text-sm font-medium text-stone-900 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)] outline-none placeholder:text-stone-400" />
          </label>
          <button
            type="submit"
            class="inline-flex h-11 shrink-0 items-center justify-center rounded-full border-0 bg-stone-900 px-4 text-sm font-semibold text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)] outline-none ring-0">
            검색
          </button>
        </div>

        <div class="-mx-1 overflow-x-auto px-1 pb-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          <div class="flex w-max min-w-full items-center gap-2">
            <a
              href="<%= buildLibraryHref({ status: 'all', limit: 50 }) %>"
              aria-pressed="<%= statusFilter === 'all' ? 'true' : 'false' %>"
              class="<%= statusFilter === 'all' ? 'bg-stone-900 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]' : 'bg-white/86 text-stone-600 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)]' %> inline-flex h-10 shrink-0 items-center justify-center rounded-full border-0 px-4 text-sm font-semibold no-underline outline-none ring-0">
              전체
            </a>
            <a
              href="<%= buildLibraryHref({ status: 'queued', limit: 50 }) %>"
              aria-pressed="<%= statusFilter === 'queued' ? 'true' : 'false' %>"
              class="<%= statusFilter === 'queued' ? 'bg-stone-900 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]' : 'bg-white/86 text-stone-600 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)]' %> inline-flex h-10 shrink-0 items-center justify-center rounded-full border-0 px-4 text-sm font-semibold no-underline outline-none ring-0">
              읽을 예정
            </a>
            <a
              href="<%= buildLibraryHref({ status: 'reading', limit: 50 }) %>"
              aria-pressed="<%= statusFilter === 'reading' ? 'true' : 'false' %>"
              class="<%= statusFilter === 'reading' ? 'bg-stone-900 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]' : 'bg-white/86 text-stone-600 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)]' %> inline-flex h-10 shrink-0 items-center justify-center rounded-full border-0 px-4 text-sm font-semibold no-underline outline-none ring-0">
              읽는 중
            </a>
            <a
              href="<%= buildLibraryHref({ status: 'finished', limit: 50 }) %>"
              aria-pressed="<%= statusFilter === 'finished' ? 'true' : 'false' %>"
              class="<%= statusFilter === 'finished' ? 'bg-stone-900 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]' : 'bg-white/86 text-stone-600 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)]' %> inline-flex h-10 shrink-0 items-center justify-center rounded-full border-0 px-4 text-sm font-semibold no-underline outline-none ring-0">
              완독
            </a>
            <label class="relative ml-auto shrink-0">
              <span class="sr-only">도서함 정렬</span>
              <select
                name="sort"
                x-on:change="$el.form.requestSubmit()"
                class="bg-white/88 h-10 appearance-none rounded-full border-0 pl-4 pr-9 text-sm font-semibold text-stone-700 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)] outline-none">
                <option
                  value="recent"
                  <% if (sortMode === 'recent') { %>selected<% } %>>
                  최근 읽은 순
                </option>
                <option
                  value="title"
                  <% if (sortMode === 'title') { %>selected<% } %>>
                  제목순
                </option>
              </select>
              <span
                class="i-lucide-chevron-down pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-stone-400"
                aria-hidden="true"></span>
            </label>
            <% if (queryText) { %>
            <a
              href="<%= buildLibraryHref({ q: '', limit: 50 }) %>"
              aria-label="검색어 지우기"
              class="bg-white/88 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-stone-600 no-underline shadow-[0_8px_18px_rgba(70,52,31,0.08)]">
              <span
                class="i-lucide-x h-4 w-4"
                aria-hidden="true"></span>
            </a>
            <% } %>
          </div>
        </div>
      </form>
    </div>

    <% if (libraryBooks.length > 0) { %>
    <div class="grid grid-cols-2 gap-x-4 gap-y-6 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      <% for (let index = 0; index < libraryBooks.length; index += 1) { const book = libraryBooks[index] %>
      <a
        href="/books/<%= book.bookId %>?from=/library"
        class="group block min-w-0 text-stone-900 no-underline">
        <div
          class="relative aspect-[5/7] overflow-hidden rounded-[1.3rem] bg-gradient-to-b from-[#d8c3a5] to-[#b08968] shadow-[0_16px_26px_rgba(74,50,28,0.12)] transition group-hover:translate-y-[-1px]">
          <% if (book.statusBadgeLabel) { %>
          <span class="<%= book.statusBadgeClass %> absolute right-2 top-2 z-10 inline-flex items-center rounded-full px-2 py-1 text-[10px] font-semibold tracking-[0.08em] backdrop-blur-sm">
            <%= book.statusBadgeLabel %>
          </span>
          <% } %>
          <% if (book.coverUrl) { %>
          <div class="box-border flex h-full w-full items-center justify-center bg-white px-1.5 py-1.5">
            <img
              src="<%= book.coverUrl %>"
              alt="<%= book.title %> 표지"
              loading="lazy"
              decoding="async"
              class="block h-full w-full object-contain" />
          </div>
          <% } else { %>
          <div class="absolute inset-0 box-border px-3 py-4 text-white">
            <div class="absolute left-1/2 top-[34%] w-[78%] -translate-x-1/2 -translate-y-1/2 text-center">
              <h2 class="m-0 break-keep text-base font-semibold leading-5"><%= book.title %></h2>
            </div>
          </div>
          <% } %>
        </div>
        <div class="mt-3 min-w-0 space-y-1">
          <h2 class="m-0 min-w-0 break-words text-sm font-semibold leading-5 text-stone-950"><%= book.title %></h2>
          <p class="m-0 text-[12px] font-medium leading-5 text-stone-500"><%= book.author ? book.author + ' · ' : '' %><%= book.statusLabel %></p>
        </div>
      </a>
      <% } %>
      <% if (hasMoreLibraryBooks) { %>
      <div
        id="library-more-control"
        class="col-span-full flex justify-center">
        <a
          href="<%= buildLibraryHref({ limit: nextLimit }) %>"
          hx-get="<%= buildLibraryMoreHref(visibleLimit) %>"
          hx-target="#library-more-control"
          hx-push-url="<%= buildLibraryHref({ limit: nextLimit }) %>"
          hx-swap="outerHTML"
          class="inline-flex items-center rounded-full bg-stone-900 px-5 py-3 text-sm font-semibold text-white no-underline shadow-[0_10px_22px_rgba(24,19,16,0.12)]">
          더 보기
        </a>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <div
      class="flex flex-col gap-3 rounded-[1.4rem] bg-[#fbf7ef] px-4 py-4 text-sm leading-6 text-stone-500 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)] sm:flex-row sm:items-center sm:justify-between">
      <span>조건에 맞는 책이 없습니다.</span>
      <a
        href="/library"
        class="bg-white/88 inline-flex w-max items-center rounded-full border-0 px-3 py-2 text-sm font-semibold text-stone-700 no-underline shadow-[0_8px_18px_rgba(70,52,31,0.08)] outline-none ring-0">
        필터 초기화
      </a>
    </div>
    <% } %>
    <% } else { %>
    <div class="rounded-[1.4rem] bg-[#fbf7ef] px-4 py-4 text-sm leading-6 text-stone-500 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
      아직 도서함에 담긴 책이 없습니다. 메인에서 EPUB를 올리면 이곳에 책이 쌓입니다.
    </div>
    <% } %>
  </section>
</section>
