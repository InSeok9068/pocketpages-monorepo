<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= meta('title') %></title>
    <meta name="description" content="<%= meta('description') %>" />
    <meta property="og:title" content="<%= meta('title') %>" />
    <meta property="og:description" content="<%= meta('description') %>" />
    <meta property="og:image" content="<%= meta('image') || '/android-chrome-512x512.png' %>" />
    <meta property="og:url" content="<%= meta('path') ? meta('path') : meta('url') || request.url %>" />
    <link rel="stylesheet" href="<%= asset('/assets/style.css') %>" />
    <style>
      [un-cloak] {
        display: none !important;
      }
    </style>
    <script>
      window.__assetFallback = function (element) {
        element.onerror = null;
        element.src = element.dataset.fallbackSrc;
      };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.3/dist/htmx.min.js" data-fallback-src="<%= asset('/assets/vendor/htmx-2.0.3.min.js') %>" onerror="window.__assetFallback(this)"></script>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
      data-fallback-src="<%= asset('/assets/vendor/alpine-3.x.x-cdn.min.js') %>"
      onerror="window.__assetFallback(this)"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/pocketbase-htmx-ext-sse@latest"
      data-fallback-src="<%= asset('/assets/vendor/pocketbase-htmx-ext-sse-latest.js') %>"
      onerror="window.__assetFallback(this)"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/@unocss/runtime/uno.global.js"
      data-fallback-src="<%= asset('/assets/vendor/unocss-runtime-attributify.global.js') %>"
      onerror="window.__assetFallback(this)"
    ></script>
    <script>
      window.__unocss = {
        presets: [() => window.__unocss_runtime.presets.presetUno()],
        ready: () => {
          document.body.removeAttribute('un-cloak');
        },
      };
    </script>
    <%- slots.head %>
  </head>

  <body un-cloak class="min-h-screen bg-stone-100 text-stone-900 antialiased">
    <main class="mx-auto max-w-5xl px-6 py-10 md:px-8 md:py-14"><%- slots.body || slot %></main>
  </body>
</html>
