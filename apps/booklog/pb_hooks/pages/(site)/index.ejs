  </div>

  <div
    x-show="filterOpen"
    x-cloak
    x-transition.opacity
    class="bg-stone-950/42 fixed inset-0 z-[80] flex items-end justify-center px-0 pt-0 sm:items-center sm:px-6 sm:py-6">
    <div
      x-on:click.outside="filterOpen = false"
      class="ios-safe-sheet w-full max-w-md overflow-y-auto rounded-t-[2rem] border-none bg-[linear-gradient(180deg,#fffdf8,#f8f0e4)] px-5 pb-[max(1.25rem,env(safe-area-inset-bottom))] pt-4 shadow-[0_-18px_50px_rgba(41,28,17,0.18)] sm:rounded-[2.1rem] sm:px-6 sm:pb-6 sm:pt-5 sm:shadow-[0_30px_90px_rgba(41,28,17,0.2)]">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h3 class="text-2xl font-semibold tracking-tight text-stone-950">도서함 필터</h3>
        </div>
        <button
          type="button"
          x-on:click="filterOpen = false"
          class="bg-white/78 inline-flex h-10 w-10 items-center justify-center rounded-full border-none text-stone-600 shadow-[0_8px_20px_rgba(70,52,31,0.08)] outline-none ring-0 transition hover:bg-white/90"
