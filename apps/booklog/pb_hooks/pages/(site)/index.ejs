        </button>
      </div>

      <div class="mt-6 space-y-2.5">
        <label class="bg-white/78 flex items-center justify-between gap-4 rounded-[1.35rem] px-4 py-3.5 shadow-[inset_0_0_0_1px_rgba(117,84,49,0.08)]">
          <span class="text-sm font-medium text-stone-800">읽는 중</span>
          <input
            type="checkbox"
            class="sr-only"
            x-bind:checked="isShelfFilterEnabled('reading')"
            x-on:change="setShelfFilter('reading', $event.target.checked)" />
          <span
            class="relative inline-flex h-7 w-12 items-center rounded-full transition"
            x-bind:class="isShelfFilterEnabled('reading') ? 'bg-stone-900' : 'bg-stone-200'">
            <span
              class="absolute left-1 h-5 w-5 rounded-full bg-white shadow-[0_4px_10px_rgba(24,19,16,0.18)] transition"
              x-bind:class="isShelfFilterEnabled('reading') ? 'translate-x-5' : 'translate-x-0'"></span>
          </span>
        </label>

        <label class="bg-white/78 flex items-center justify-between gap-4 rounded-[1.35rem] px-4 py-3.5 shadow-[inset_0_0_0_1px_rgba(117,84,49,0.08)]">
          <span class="text-sm font-medium text-stone-800">읽을 예정</span>
          <input
            type="checkbox"
            class="sr-only"
            x-bind:checked="isShelfFilterEnabled('queued')"
            x-on:change="setShelfFilter('queued', $event.target.checked)" />
          <span
            class="relative inline-flex h-7 w-12 items-center rounded-full transition"
            x-bind:class="isShelfFilterEnabled('queued') ? 'bg-stone-900' : 'bg-stone-200'">
            <span
              class="absolute left-1 h-5 w-5 rounded-full bg-white shadow-[0_4px_10px_rgba(24,19,16,0.18)] transition"
              x-bind:class="isShelfFilterEnabled('queued') ? 'translate-x-5' : 'translate-x-0'"></span>
          </span>
        </label>

        <label class="bg-white/78 flex items-center justify-between gap-4 rounded-[1.35rem] px-4 py-3.5 shadow-[inset_0_0_0_1px_rgba(117,84,49,0.08)]">
          <span class="text-sm font-medium text-stone-800">완독</span>
          <input
            type="checkbox"
            class="sr-only"
            x-bind:checked="isShelfFilterEnabled('finished')"
            x-on:change="setShelfFilter('finished', $event.target.checked)" />
          <span
            class="relative inline-flex h-7 w-12 items-center rounded-full transition"
            x-bind:class="isShelfFilterEnabled('finished') ? 'bg-stone-900' : 'bg-stone-200'">
            <span
              class="absolute left-1 h-5 w-5 rounded-full bg-white shadow-[0_4px_10px_rgba(24,19,16,0.18)] transition"
              x-bind:class="isShelfFilterEnabled('finished') ? 'translate-x-5' : 'translate-x-0'"></span>
          </span>
        </label>
      </div>
    </div>
  </div>

  <div
    x-show="uploadOpen"
    x-cloak
    x-transition.opacity
    class="bg-stone-950/42 fixed inset-0 z-[80] flex items-end justify-center px-0 pt-0 sm:items-center sm:px-6 sm:py-6">
    <div
      x-on:click.outside="if (!uploading) { uploadOpen = false }"
      class="ios-safe-sheet w-full max-w-lg overflow-y-auto rounded-t-[2rem] border-none bg-[linear-gradient(180deg,#fffdf8,#f8f0e4)] px-5 pb-[max(1.25rem,env(safe-area-inset-bottom))] pt-4 shadow-[0_-18px_50px_rgba(41,28,17,0.18)] sm:rounded-[2.1rem] sm:px-6 sm:pb-6 sm:pt-5 sm:shadow-[0_30px_90px_rgba(41,28,17,0.2)]">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h3 class="text-2xl font-semibold tracking-tight text-stone-950">도서함에 책 넣기</h3>
        </div>
        <button
          type="button"
          x-bind:disabled="uploading"
          x-on:click="if (!uploading) { uploadOpen = false }"
          class="bg-white/78 inline-flex h-10 w-10 items-center justify-center rounded-full border-none text-stone-600 shadow-[0_8px_20px_rgba(70,52,31,0.08)] outline-none ring-0 transition hover:bg-white/90"
          aria-label="업로드 팝업 닫기">
          <span
            class="i-lucide-x h-4 w-4"
            aria-hidden="true"></span>
        </button>
      </div>

      <form
        class="mt-6 space-y-5"
        method="post"
        action="/xapi/epub/upload"
        enctype="multipart/form-data"
        x-on:submit.prevent="submitUpload($event)">
        <label class="block space-y-2">
          <span class="text-sm font-medium text-stone-700">EPUB 파일</span>
          <div class="rounded-[1.35rem] border border-stone-200 bg-white/90 px-3 py-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
            <input
              class="box-border block w-full text-sm text-stone-900 file:mr-3 file:rounded-full file:border-0 file:bg-stone-100 file:px-3 file:py-2 file:text-sm file:font-medium file:text-stone-700"
              type="file"
              name="epubFile"
              accept=".epub,application/epub+zip"
              x-on:change="selectUploadFile($event)"
              required />
            <p
              x-show="uploadFileName"
              x-cloak
              x-text="uploadFileName"
              class="mt-3 break-all text-[13px] leading-5 text-stone-500"></p>
          </div>
        </label>

        <div class="rounded-[1.5rem] border border-[#dcc5a3] bg-[#fff8ec] px-4 py-4 text-sm leading-6 text-stone-700">
          <p class="font-medium text-stone-900">업로드 후 메타데이터 조회까지 이어서 처리합니다.</p>
          <p class="mt-1 text-stone-600">대용량 파일이거나 외부 도서 정보 조회가 길어지면 잠시 시간이 걸릴 수 있습니다.</p>
        </div>

        <div class="flex gap-3 pt-1">
          <button
            x-bind:disabled="uploading"
            class="min-h-13 inline-flex flex-1 items-center justify-center rounded-full border-none bg-stone-900 px-4 py-3.5 text-sm font-medium text-white shadow-[0_10px_22px_rgba(24,19,16,0.12)] outline-none ring-0 transition hover:bg-stone-700 disabled:opacity-100"
            type="submit">
            <span
              x-show="!uploading"
              x-cloak
              >업로드</span
            >
            <span
              x-show="uploading"
              x-cloak
              >업로드 중...</span
            >
          </button>
          <button
            type="button"
            x-bind:disabled="uploading"
            x-on:click="if (!uploading) { uploadOpen = false }"
            class="min-h-13 bg-white/88 inline-flex items-center justify-center rounded-full border-none px-5 py-3.5 text-sm font-medium text-stone-700 shadow-[0_10px_22px_rgba(70,52,31,0.08)] outline-none ring-0 transition hover:bg-stone-100/80">
            닫기
          </button>
        </div>
      </form>
    </div>
  </div>

  <div
    x-show="uploading"
    x-cloak
    x-transition.opacity
    class="fixed inset-0 z-[90] overflow-y-auto bg-[linear-gradient(180deg,#fffdf8,#f5ead7)] text-stone-950">
    <section
      class="ios-safe-sheet mx-auto box-border flex min-h-[100dvh] w-full max-w-xl flex-col px-5 pb-[max(1.5rem,env(safe-area-inset-bottom))] pt-[max(1.25rem,env(safe-area-inset-top))] sm:px-6 sm:py-8">
      <div class="flex justify-end">
        <div class="bg-white/72 rounded-full px-3 py-1.5 shadow-[inset_0_0_0_1px_rgba(117,84,49,0.08)]">
          <p
            x-text="uploadElapsedLabel"
            class="text-[13px] font-semibold text-stone-700"></p>
        </div>
      </div>

      <div class="flex flex-1 flex-col justify-center py-8">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-[#f7f2e8] text-stone-700 shadow-[inset_0_0_0_1px_rgba(117,84,49,0.08),0_10px_24px_rgba(73,54,31,0.08)]">
          <span
            class="i-lucide-loader-circle h-7 w-7 animate-spin"
            aria-hidden="true"></span>
        </div>

        <div class="mt-5 text-center">
          <h3 class="text-2xl font-semibold tracking-tight text-stone-950">업로드 중입니다</h3>
          <p class="mx-auto mt-2 max-w-sm text-sm leading-6 text-stone-600">EPUB를 읽고 도서 정보를 찾고 있어요. 완료되면 자동으로 이동합니다.</p>
        </div>

        <div class="bg-white/76 mt-7 rounded-[1.6rem] px-5 py-5 shadow-[inset_0_0_0_1px_rgba(117,84,49,0.08),0_10px_26px_rgba(73,54,31,0.05)]">
          <div class="flex items-center justify-between gap-3">
            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-stone-500">현재 단계</p>
            <p
              x-text="'단계 ' + String(uploadStageIndex + 1) + '/' + String(uploadStages.length)"
              class="text-[12px] font-semibold text-stone-500"></p>
          </div>

          <p
            x-text="activeUploadStage.label"
            class="mt-3 text-xl font-semibold tracking-tight text-stone-950"></p>
          <p
            x-text="activeUploadStage.detail"
            class="mt-2 text-sm leading-6 text-stone-600"></p>

          <div class="mt-5 h-1.5 w-full overflow-hidden rounded-full bg-stone-200/80">
            <div
              class="h-full rounded-full bg-stone-900 transition-all duration-700"
              x-bind:style="'width: ' + String(Math.round(((uploadStageIndex + 1) / uploadStages.length) * 100)) + '%'"></div>
          </div>

          <div class="mt-5 grid grid-cols-4 gap-2">
            <template
              x-for="(stage, index) in uploadStages"
              :key="stage.label">
              <span
                class="h-2.5 rounded-full transition"
                x-bind:class="index <= uploadStageIndex ? 'bg-stone-900' : 'bg-stone-200'"
                x-bind:aria-label="stage.label"></span>
            </template>
          </div>

          <p
            x-text="uploadFileName || 'EPUB 파일'"
            class="mt-5 break-all text-[13px] font-medium leading-5 text-stone-500"></p>
        </div>

        <p class="mx-auto mt-5 max-w-sm text-center text-[13px] leading-6 text-stone-500">브라우저를 새로고침하거나 닫지 마세요.</p>
      </div>
    </section>
  </div>
</section>
<% } %>
