<script server>
  meta('title', 'Booklog')
  meta('description', '책을 읽고 남긴 문장과 감상이 한 권씩 쌓여, 나만의 작은 도서관이 되어가는 곳.')
  meta('url', 'https://booklog.development-support.o-r.kr/')
  meta('image', 'https://booklog.development-support.o-r.kr/assets/og/booklog-home.png')

  const { dateutil } = require('@pocketpages/utils')
  const flashMessage = params.__flash ? String(params.__flash) : ''
  const isSignedIn = !!request.auth
  const shelfStatusLabels = {
    queued: '읽을 예정',
    reading: '읽는 중',
    finished: '완독',
    dropped: '중단함',
  }
  const emptyShelfBooks = [
    {
      bookId: '',
      title: '아직 책이 없습니다',
      author: '첫 EPUB를 올리면 여기에 꽂힙니다',
      tone: 'from-[#d8c3a5] to-[#b08968]',
      coverUrl: '',
      isReading: false,
      statusBadgeLabel: '',
      statusBadgeClass: '',
      statusLabel: 'Shelf 1',
    },
    {
      bookId: '',
      title: '읽는 중인 책',
      author: '진행 중인 책이 가로로 쌓입니다',
      tone: 'from-[#9c6644] to-[#7f5539]',
      coverUrl: '',
      isReading: false,
      statusBadgeLabel: '',
      statusBadgeClass: '',
      statusLabel: 'Shelf 2',
    },
    {
      bookId: '',
      title: '읽은 책',
      author: '완독한 책도 같은 도서함에 정리됩니다',
      tone: 'from-[#7f4f24] to-[#582f0e]',
      coverUrl: '',
      isReading: false,
      statusBadgeLabel: '',
      statusBadgeClass: '',
      statusLabel: 'Shelf 3',
    },
  ]
  let shelfBooks = emptyShelfBooks
  let randomHighlights = []

  if (isSignedIn) {
    const shelfRecords = $app.findRecordsByFilter('book_shelves', 'user_id = {:userId}', '-status,-updated,-last_read_at', 50, 0, { userId: request.auth.get('id') })
    const loadedShelfBooks = []

    for (let index = 0; index < shelfRecords.length; index += 1) {
      const shelfRecord = shelfRecords[index]
      const bookId = shelfRecord.get('book_id')
      const status = String(shelfRecord.get('status') || 'queued')
      let bookRecord = null

      try {
        bookRecord = $app.findFirstRecordByFilter('books', 'id = {:id}', { id: bookId })
      } catch (exception) {
        bookRecord = null
      }

      if (!bookRecord) {
        continue
      }

      const author = String(bookRecord.get('author') || '').trim()
      loadedShelfBooks.push({
        bookId: String(bookRecord.get('id') || ''),
        title: String(bookRecord.get('title') || '제목 없음'),
        author: author || '저자 정보 없음',
        tone: 'from-[#d8c3a5] to-[#b08968]',
        coverUrl: String(bookRecord.get('book_image_url') || '').trim(),
        statusBadgeLabel: status === 'reading' || status === 'finished' ? shelfStatusLabels[status] : '',
        statusBadgeClass: status === 'finished' ? 'bg-[#9e6125]/88 text-white shadow-[0_8px_18px_rgba(165,103,38,0.14)]' : 'bg-stone-900/84 text-white shadow-[0_8px_18px_rgba(24,19,16,0.12)]',
        statusLabel: shelfStatusLabels[status] || '보관 중',
      })
    }

    if (loadedShelfBooks.length > 0) {
      shelfBooks = loadedShelfBooks
    }

    try {
      const highlightRecords = $app.findRecordsByFilter('book_highlights', 'user_id = {:userId}', '-updated', 50, 0, { userId: request.auth.get('id') })
      const shuffledHighlights = highlightRecords.slice()

      for (let index = shuffledHighlights.length - 1; index > 0; index -= 1) {
        const swapIndex = Math.floor(Math.random() * (index + 1))
        const currentValue = shuffledHighlights[index]

        shuffledHighlights[index] = shuffledHighlights[swapIndex]
        shuffledHighlights[swapIndex] = currentValue
      }

      randomHighlights = shuffledHighlights
        .slice(0, 3)
        .map((highlightRecord) => {
          const highlightBookId = String(highlightRecord.get('book_id') || '').trim()
          const quoteText = String(highlightRecord.get('quote_text') || '').trim()
          const highlightedAtValue = String(highlightRecord.get('highlighted_at') || '').trim()
          const highlightedAt = highlightedAtValue ? dateutil.formatDate(highlightedAtValue, dateutil.FORMATS.DATE) : ''
          let highlightBookRecord = null

          try {
            highlightBookRecord = $app.findFirstRecordByFilter('books', 'id = {:id}', { id: highlightBookId })
          } catch (exception) {
            highlightBookRecord = null
          }

          return {
            bookId: highlightBookId,
            bookTitle: highlightBookRecord ? String(highlightBookRecord.get('title') || '제목 없음') : '제목 없음',
            quoteText: quoteText,
            highlightedAt: highlightedAt,
          }
        })
        .filter((item) => item.quoteText)
    } catch (exception) {
      randomHighlights = []
    }
  }
</script>

<section class="space-y-5">
  <h1 class="text-4xl font-semibold tracking-tight text-stone-950">Booklog</h1>
  <p class="max-w-[18.5rem] text-sm leading-6 text-stone-600 sm:max-w-none sm:text-[15px] sm:leading-7">책을 읽고 남긴 문장과 감상이 한 권씩 쌓여,<br />나만의 작은 도서관이 되어가는 곳.</p>
</section>

<% if (flashMessage) { %>
<section class="mt-6 rounded-[1.6rem] border border-stone-200 bg-white/85 px-5 py-4 text-sm text-stone-700 shadow-sm backdrop-blur-sm">
  <%= flashMessage %>
</section>
<% } %>

<% if (!isSignedIn) { %>
<section class="mt-8 rounded-[2rem] border border-stone-200/80 bg-white/75 p-6 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm">
  <div class="space-y-3">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-stone-500">Welcome</p>
    <h2 class="text-3xl font-semibold tracking-tight text-stone-950">내 서재를 시작해보세요</h2>
    <p class="max-w-xl text-sm leading-7 text-stone-600">로그인하면 EPUB 업로드, 도서함 정리, 읽는 중 상태와 감상 기록을 이어서 관리할 수 있습니다.</p>
  </div>

  <div class="mt-6">
    <a
      class="inline-flex items-center rounded-full bg-stone-900 px-5 py-3 text-sm font-medium text-white no-underline transition hover:bg-stone-700"
      href="/auth">
      로그인 / 회원가입
    </a>
  </div>
</section>
<% } else { %>
<script>
  window.booklogHomeUpload = {
    stages: [
      { label: '파일 전송 중', detail: '선택한 EPUB 파일을 서버로 안전하게 올리고 있습니다.' },
      { label: 'EPUB 구조 확인 중', detail: '본문과 메타데이터, 식별자 정보를 읽고 있습니다.' },
      { label: '도서 정보 찾는 중', detail: '제목, 저자, ISBN을 기준으로 도서 메타데이터를 확인하고 있습니다.' },
      { label: '서재에 저장 중', detail: '책 정보와 업로드 파일을 도서함에 정리하고 있습니다.' },
    ],
    getActiveUploadStage: function (component) {
      return this.stages[component.uploadStageIndex] || this.stages[0]
    },
    getUploadElapsedLabel: function (seconds) {
      if (seconds < 60) {
        return seconds + '초'
      }

      return Math.floor(seconds / 60) + '분 ' + (seconds % 60) + '초'
    },
    selectUploadFile: function (component, event) {
      component.uploadFileName = event.target.files && event.target.files[0] ? event.target.files[0].name : ''
    },
    stopUploadTimers: function (component) {
      if (component.uploadTickTimerId) {
        window.clearInterval(component.uploadTickTimerId)
        component.uploadTickTimerId = null
      }

      if (component.uploadStageTimerId) {
        window.clearInterval(component.uploadStageTimerId)
        component.uploadStageTimerId = null
      }
    },
    beginUpload: function (component) {
      if (component.uploading) {
        return
      }

      component.uploading = true
      component.uploadOpen = false
      component.uploadElapsedSeconds = 0
      component.uploadStageIndex = 0
      this.stopUploadTimers(component)

      component.uploadTickTimerId = window.setInterval(function () {
        component.uploadElapsedSeconds += 1
      }, 1000)

      component.uploadStageTimerId = window.setInterval(function () {
        if (component.uploadStageIndex < component.uploadStages.length - 1) {
          component.uploadStageIndex += 1
        }
      }, 2600)
    },
  }
</script>
<section
  x-data="{
    uploadOpen: false,
    uploading: false,
    uploadFileName: '',
    uploadElapsedSeconds: 0,
    uploadStageIndex: 0,
    uploadTickTimerId: null,
    uploadStageTimerId: null,
    uploadStages: window.booklogHomeUpload.stages,
    get activeUploadStage() {
      return window.booklogHomeUpload.getActiveUploadStage(this)
    },
    get uploadElapsedLabel() {
      return window.booklogHomeUpload.getUploadElapsedLabel(this.uploadElapsedSeconds)
    },
    selectUploadFile(event) {
      window.booklogHomeUpload.selectUploadFile(this, event)
    },
    stopUploadTimers() {
      window.booklogHomeUpload.stopUploadTimers(this)
    },
    beginUpload() {
      window.booklogHomeUpload.beginUpload(this)
    },
  }"
  class="mt-6">
  <div class="space-y-6">
    <div class="flex items-center justify-between gap-4">
      <div class="space-y-1">
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-stone-500">My Shelf</p>
        <h2 class="text-2xl font-semibold tracking-tight text-stone-950">도서함</h2>
      </div>

      <button
        type="button"
        x-on:click="uploadOpen = true"
        class="inline-flex items-center rounded-full border-none bg-stone-900 px-4 py-2.5 text-sm font-medium text-white shadow-[0_10px_22px_rgba(24,19,16,0.12)] outline-none ring-0 transition hover:bg-stone-700">
        책 추가
      </button>
    </div>

    <section
      class="rounded-[2rem] border border-stone-200/80 bg-[linear-gradient(180deg,rgba(255,252,245,0.92),rgba(245,236,222,0.95))] p-4 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm sm:p-5">
      <div class="overflow-x-auto overflow-y-hidden [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <div class="flex min-w-max gap-3">
          <% for (let index = 0; index < shelfBooks.length; index += 1) { const book = shelfBooks[index] %>
          <article class="w-[7.35rem] flex-none sm:w-[7.8rem]">
            <% if (book.bookId) { %>
            <a
              href="/books/<%= book.bookId %>"
              class="block no-underline transition hover:translate-y-[-1px]">
              <div
                class="<%= book.tone %> <%= book.coverUrl ? 'shadow-[0_16px_24px_rgba(74,50,28,0.1)]' : 'shadow-[0_18px_28px_rgba(74,50,28,0.18)]' %> relative h-[10.4rem] overflow-hidden rounded-[1.3rem] bg-gradient-to-b sm:h-[11rem]">
                <% if (book.statusBadgeLabel) { %>
                <span class="<%= book.statusBadgeClass %> absolute right-2 top-2 z-10 inline-flex items-center rounded-full px-1.5 py-0.5 text-[10px] font-semibold tracking-[0.08em] backdrop-blur-sm">
                  <%= book.statusBadgeLabel %>
                </span>
                <% } %>
                <% if (book.coverUrl) { %>
                <img
                  src="<%= book.coverUrl %>"
                  alt="<%= book.title %> 표지"
                  class="h-full w-full object-cover" />
                <% } else { %>
                <div class="absolute inset-0 box-border px-3 py-4 text-white">
                  <div class="absolute left-1/2 top-[34%] w-[5.55rem] -translate-x-1/2 -translate-y-1/2 text-center">
                    <h3 class="m-0 break-keep text-base font-semibold leading-5 tracking-[-0.03em]"><%= book.title %></h3>
                  </div>
                  <p class="text-white/78 absolute bottom-4 left-3 right-3 m-0 break-keep text-right text-[11px] leading-4"><%= book.author %></p>
                </div>
                <% } %>
              </div>
            </a>
            <% } else { %>
            <div
              class="<%= book.tone %> <%= book.coverUrl ? 'shadow-[0_16px_24px_rgba(74,50,28,0.1)]' : 'shadow-[0_18px_28px_rgba(74,50,28,0.18)]' %> relative h-[10.4rem] overflow-hidden rounded-[1.3rem] bg-gradient-to-b sm:h-[11rem]">
              <% if (book.statusBadgeLabel) { %>
              <span class="<%= book.statusBadgeClass %> absolute right-2 top-2 z-10 inline-flex items-center rounded-full px-1.5 py-0.5 text-[10px] font-semibold tracking-[0.08em] backdrop-blur-sm">
                <%= book.statusBadgeLabel %>
              </span>
              <% } %>
              <% if (book.coverUrl) { %>
              <img
                src="<%= book.coverUrl %>"
                alt="<%= book.title %> 표지"
                class="h-full w-full object-cover" />
              <% } else { %>
              <div class="absolute inset-0 box-border px-3 py-4 text-white">
                <div class="absolute left-1/2 top-[34%] w-[5.55rem] -translate-x-1/2 -translate-y-1/2 text-center">
                  <h3 class="m-0 break-keep text-base font-semibold leading-5 tracking-[-0.03em]"><%= book.title %></h3>
                </div>
                <p class="text-white/78 absolute bottom-4 left-3 right-3 m-0 break-keep text-right text-[11px] leading-4"><%= book.author %></p>
              </div>
              <% } %>
            </div>
            <% } %>
          </article>
          <% } %>
        </div>
      </div>
    </section>

    <section class="bg-white/78 rounded-[2rem] border border-stone-200/80 p-4 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm sm:p-[1.2rem]">
      <div class="space-y-1.5">
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-stone-500">Highlights</p>
        <h3 class="text-xl font-semibold tracking-tight text-stone-950">인상 깊은 문구</h3>
      </div>

      <% if (randomHighlights.length > 0) { %>
      <div class="mt-4 space-y-2.5">
        <% for (let index = 0; index < randomHighlights.length; index += 1) { const highlight = randomHighlights[index] %>
        <a
          href="/books/<%= highlight.bookId %>"
          class="block rounded-[1.4rem] bg-[#fbf7ef] px-4 py-3.5 text-stone-900 no-underline shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)] transition hover:bg-[#f7f0e3]">
          <p class="text-[15px] font-semibold leading-[1.65] tracking-[-0.02em] text-stone-900 sm:text-base">"<%= highlight.quoteText %>"</p>
          <p class="mt-2.5 text-[12px] leading-5 text-stone-500"><%= highlight.bookTitle %></p>
          <% if (highlight.highlightedAt) { %>
          <p class="mt-1.5 text-[12px] font-medium text-stone-400"><%= highlight.highlightedAt %></p>
          <% } %>
        </a>
        <% } %>
      </div>
      <% } else { %>
      <div class="mt-4 rounded-[1.4rem] bg-[#fbf7ef] px-3.5 py-3.5 text-sm leading-6 text-stone-500 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">저장된 인상 깊은 문구가 아직 없습니다.</div>
      <% } %>

      <div class="mt-4 grid grid-cols-2 gap-2">
        <a
          href="/reviews"
          class="bg-white/88 inline-flex items-center justify-center rounded-full border-none px-4 py-3 text-sm font-medium text-stone-700 no-underline shadow-[0_10px_22px_rgba(70,52,31,0.08)] outline-none ring-0 transition hover:bg-stone-100/80">
