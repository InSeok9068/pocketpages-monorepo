<% } else if (!canUseBooklog) { %>
<section class="mt-8 rounded-[2rem] border border-stone-200/80 bg-white/75 p-6 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm">
  <div class="space-y-3">
    <h2 class="text-3xl font-semibold tracking-tight text-stone-950">아직 사용할 수 없는 계정입니다</h2>
    <p class="max-w-xl text-sm leading-7 text-stone-600">Booklog는 초대한 사람만 사용할 수 있습니다. 사용하려면 관리자에게 알려주세요.</p>
  </div>

  <form
    class="mt-6"
    method="post"
    action="/xapi/auth/sign-out">
    <button
      class="inline-flex items-center rounded-full border-none bg-stone-900 px-5 py-3 text-sm font-medium text-white no-underline transition hover:bg-stone-700"
      type="submit">
      로그아웃
    </button>
  </form>
</section>
<% } else { %>
<script>
  window.booklogHomeUpload = {
    stages: [
      { label: '파일 전송 중', detail: '선택한 EPUB 파일을 서버로 안전하게 올리고 있습니다.' },
      { label: 'EPUB 구조 확인 중', detail: '본문과 메타데이터, 식별자 정보를 읽고 있습니다.' },
      { label: '도서 정보 찾는 중', detail: '제목, 저자, ISBN을 기준으로 도서 메타데이터를 확인하고 있습니다.' },
      { label: '서재에 저장 중', detail: '책 정보와 업로드 파일을 도서함에 정리하고 있습니다.' },
    ],
    getActiveUploadStage: function (component) {
      return this.stages[component.uploadStageIndex] || this.stages[0]
    },
    getUploadElapsedLabel: function (seconds) {
      if (seconds < 60) {
        return seconds + '초'
      }

      return Math.floor(seconds / 60) + '분 ' + (seconds % 60) + '초'
    },
    selectUploadFile: function (component, event) {
      component.uploadFileName = event.target.files && event.target.files[0] ? event.target.files[0].name : ''
    },
    requestUploadPaint: function (callback) {
      const runCallback = function () {
        if (typeof callback === 'function') {
          callback()
        }
      }

      if (typeof window.requestAnimationFrame === 'function') {
        window.requestAnimationFrame(function () {
          window.requestAnimationFrame(runCallback)
        })
        return
      }

      window.setTimeout(runCallback, 34)
    },
    stopUploadTimers: function (component) {
      if (component.uploadTickTimerId) {
        window.clearInterval(component.uploadTickTimerId)
        component.uploadTickTimerId = null
      }

      if (component.uploadStageTimerId) {
        window.clearInterval(component.uploadStageTimerId)
        component.uploadStageTimerId = null
      }
    },
    beginUpload: function (component) {
      if (component.uploading) {
        return
      }

      component.uploading = true
      component.uploadOpen = false
      component.uploadElapsedSeconds = 0
      component.uploadStageIndex = 0
      this.stopUploadTimers(component)

      component.uploadTickTimerId = window.setInterval(function () {
        component.uploadElapsedSeconds += 1
      }, 1000)

      component.uploadStageTimerId = window.setInterval(function () {
        if (component.uploadStageIndex < component.uploadStages.length - 1) {
          component.uploadStageIndex += 1
        }
      }, 2600)
    },
    submitUpload: function (component, form) {
      const uploadForm = form && form.tagName === 'FORM' ? form : null

      if (!uploadForm || component.uploading || component.uploadSubmitQueued) {
        return
      }

      if (typeof uploadForm.reportValidity === 'function' && !uploadForm.reportValidity()) {
        return
      }

      component.uploadSubmitQueued = true
      this.beginUpload(component)

      this.requestUploadPaint(function () {
        window.setTimeout(function () {
          HTMLFormElement.prototype.submit.call(uploadForm)
        }, 150)
      })
    },
  }
</script>
<section
  x-data="{
    filterOpen: false,
    uploadOpen: false,
    uploading: false,
    uploadSubmitQueued: false,
    uploadFileName: '',
    uploadElapsedSeconds: 0,
    uploadStageIndex: 0,
    uploadTickTimerId: null,
    uploadStageTimerId: null,
    shelfFilters: $persist({ queued: true, reading: true, finished: true }).as('booklog.home.shelfFilters'),
    shelfStatusCounts: {
      queued: <%= shelfStatusCounts.queued %>,
      reading: <%= shelfStatusCounts.reading %>,
      finished: <%= shelfStatusCounts.finished %>,
    },
    uploadStages: window.booklogHomeUpload.stages,
    get activeUploadStage() {
      return window.booklogHomeUpload.getActiveUploadStage(this)
    },
    get uploadElapsedLabel() {
      return window.booklogHomeUpload.getUploadElapsedLabel(this.uploadElapsedSeconds)
    },
    selectUploadFile(event) {
      window.booklogHomeUpload.selectUploadFile(this, event)
    },
    stopUploadTimers() {
      window.booklogHomeUpload.stopUploadTimers(this)
    },
    isShelfFilterEnabled(status) {
      return this.shelfFilters[status] !== false
    },
    setShelfFilter(status, enabled) {
      const nextFilters = {
        queued: this.shelfFilters.queued !== false,
        reading: this.shelfFilters.reading !== false,
        finished: this.shelfFilters.finished !== false,
      }

      nextFilters[status] = enabled
      this.shelfFilters = nextFilters
    },
    isShelfCardVisible(status) {
      if (!status || typeof this.shelfFilters[status] === 'undefined') {
        return true
      }

      return this.isShelfFilterEnabled(status)
    },
    hasVisibleShelfBooks() {
      const statuses = ['queued', 'reading', 'finished']
      let totalCount = 0
      let visibleCount = 0

      for (let index = 0; index < statuses.length; index += 1) {
        const status = statuses[index]
        const count = Number(this.shelfStatusCounts[status] || 0)

        totalCount += count

        if (this.isShelfFilterEnabled(status)) {
          visibleCount += count
        }
      }

      return totalCount === 0 || visibleCount > 0
    },
    beginUpload() {
      window.booklogHomeUpload.beginUpload(this)
    },
    submitUpload(event) {
      window.booklogHomeUpload.submitUpload(this, event.currentTarget)
    },
  }"
  class="mt-6">
  <div class="space-y-6">
    <div class="flex items-center justify-between gap-4">
      <div>
        <a
          href="/library"
          class="inline-flex items-center gap-2 text-stone-950 no-underline transition hover:text-stone-700">
          <h2 class="m-0 text-2xl font-semibold tracking-tight">도서함</h2>
          <span
            class="i-lucide-arrow-right h-5 w-5"
            aria-hidden="true"></span>
        </a>
      </div>

      <div class="flex items-center gap-2">
        <button
          type="button"
          x-on:click="filterOpen = true"
          class="inline-flex h-11 w-11 items-center justify-center border-none bg-transparent p-0 text-stone-700 outline-none ring-0 transition hover:text-stone-950"
          aria-label="도서함 필터 열기">
          <span
            class="i-lucide-filter h-5 w-5"
            aria-hidden="true"></span>
        </button>
        <button
          type="button"
          x-on:click="uploadOpen = true"
          class="inline-flex items-center rounded-full border-none bg-stone-900 px-4 py-2.5 text-sm font-medium text-white shadow-[0_10px_22px_rgba(24,19,16,0.12)] outline-none ring-0 transition hover:bg-stone-700">
          책 추가
        </button>
      </div>
    </div>

    <section
      class="rounded-[2rem] border border-stone-200/80 bg-[linear-gradient(180deg,rgba(255,252,245,0.92),rgba(245,236,222,0.95))] p-4 shadow-[0_12px_30px_rgba(73,54,31,0.05)] backdrop-blur-sm sm:p-5">
      <div class="overflow-x-auto overflow-y-hidden [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <div class="flex min-w-max gap-3">
          <% for (let index = 0; index < shelfBooks.length; index += 1) { const book = shelfBooks[index] %>
          <article
            class="w-[7.35rem] flex-none sm:w-[7.8rem]"
            data-shelf-status="<%= book.status || '' %>"
            x-show="isShelfCardVisible($el.dataset.shelfStatus)">
            <% if (book.bookId) { %>
            <a
              href="/books/<%= book.bookId %>?from=/"
              class="group block no-underline transition hover:translate-y-[-1px]">
              <div
                class="<%= book.tone %> <%= book.coverUrl ? 'transition group-hover:shadow-[0_6px_14px_rgba(24,19,16,0.1)]' : 'shadow-[0_18px_28px_rgba(74,50,28,0.18)]' %> relative aspect-[2/3] overflow-hidden rounded-[0.35rem] bg-gradient-to-b">
                <% if (book.statusBadgeLabel) { %>
                <span class="<%= book.statusBadgeClass %> absolute right-2 top-2 z-10 inline-flex items-center rounded-full px-1.5 py-0.5 text-[10px] font-semibold tracking-[0.08em] backdrop-blur-sm">
                  <%= book.statusBadgeLabel %>
                </span>
                <% } %>
                <% if (book.coverUrl) { %>
                <img
                  src="<%= book.coverUrl %>"
                  alt="<%= book.title %> 표지"
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover" />
                <% } else { %>
                <div class="absolute inset-0 box-border px-3 py-4 text-white">
                  <div class="absolute left-1/2 top-[34%] w-[5.55rem] -translate-x-1/2 -translate-y-1/2 text-center">
                    <h3 class="m-0 break-keep text-base font-semibold leading-5 tracking-[-0.03em]"><%= book.title %></h3>
                  </div>
                  <p class="text-white/78 absolute bottom-4 left-3 right-3 m-0 break-keep text-right text-[11px] leading-4"><%= book.author %></p>
                </div>
                <% } %>
              </div>
            </a>
            <% } else { %>
            <div
              class="<%= book.tone %> <%= book.coverUrl ? '' : 'shadow-[0_18px_28px_rgba(74,50,28,0.18)]' %> relative aspect-[2/3] overflow-hidden rounded-[0.35rem] bg-gradient-to-b">
              <% if (book.statusBadgeLabel) { %>
              <span class="<%= book.statusBadgeClass %> absolute right-2 top-2 z-10 inline-flex items-center rounded-full px-1.5 py-0.5 text-[10px] font-semibold tracking-[0.08em] backdrop-blur-sm">
                <%= book.statusBadgeLabel %>
              </span>
              <% } %>
              <% if (book.coverUrl) { %>
              <img
                src="<%= book.coverUrl %>"
                alt="<%= book.title %> 표지"
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover" />
              <% } else { %>
              <div class="absolute inset-0 box-border px-3 py-4 text-white">
                <div class="absolute left-1/2 top-[34%] w-[5.55rem] -translate-x-1/2 -translate-y-1/2 text-center">
                  <h3 class="m-0 break-keep text-base font-semibold leading-5 tracking-[-0.03em]"><%= book.title %></h3>
                </div>
                <p class="text-white/78 absolute bottom-4 left-3 right-3 m-0 break-keep text-right text-[11px] leading-4"><%= book.author %></p>
              </div>
              <% } %>
            </div>
            <% } %>
          </article>
          <% } %>
          <div
            x-show="!hasVisibleShelfBooks()"
            x-cloak
            class="bg-white/72 w-[15rem] flex-none rounded-[1.4rem] px-4 py-4 text-sm leading-6 text-stone-500 shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)]">
            선택한 상태의 책이 없습니다.
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white/78 rounded-[2rem] border border-stone-200/80 p-4 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm sm:p-[1.2rem]">
      <div>
        <h3 class="text-xl font-semibold tracking-tight text-stone-950">인상 깊은 문구</h3>
      </div>

      <% if (randomHighlights.length > 0) { %>
