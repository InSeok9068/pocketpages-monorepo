<script server>
  meta('title', 'Booklog 독서 기록')
  meta('description', '주차별 독서 시간을 확인하는 페이지')

  if (!request.auth) {
    dbg('page/reading-records:redirect', {
      status: 303,
      redirectTo: '/auth',
      flash: '로그인이 필요합니다.',
    })
    redirect('/auth', {
      status: 303,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const userId = String(request.auth.get('id') || '')
  const now = new Date()
  const KOREA_TIME_OFFSET_MS = 9 * 60 * 60 * 1000
  const weekItems = []
  const requestedWeekValue = String(request.url.query.week || '').trim()
  const sessionRecords = $app.findRecordsByFilter('reading_sessions', 'user_id = {:userId}', '-ended_at', 500, 0, { userId: userId })

  /**
   * 날짜를 한국시간 기준 해당 주 월요일로 맞춥니다.
   *
   * @param {Date} date 기준 날짜
   * @returns {Date} 주 시작 날짜
   */
  function getWeekStart(date) {
    const koreanDate = new Date(date.getTime() + KOREA_TIME_OFFSET_MS)
    const target = new Date(Date.UTC(koreanDate.getUTCFullYear(), koreanDate.getUTCMonth(), koreanDate.getUTCDate(), 0, 0, 0, 0))
    const day = target.getUTCDay()
    const diff = day === 0 ? -6 : 1 - day

    target.setUTCDate(target.getUTCDate() + diff)

    return target
  }

  /**
   * 숫자를 두 자리 문자열로 맞춥니다.
   *
   * @param {number} value 숫자
   * @returns {string} 두 자리 문자열
   */
  function padTwo(value) {
    const text = String(value)

    return text.length < 2 ? '0' + text : text
  }

  /**
   * 날짜를 YYYY-MM-DD로 표시합니다.
   *
   * @param {Date} date 표시할 날짜
   * @returns {string} 날짜 문자열
   */
  function formatDateLabel(date) {
    const year = String(date.getUTCFullYear())
    const month = padTwo(date.getUTCMonth() + 1)
    const day = padTwo(date.getUTCDate())

    return year + '-' + month + '-' + day
  }

  /**
   * 날짜를 YYYY.MM.DD로 표시합니다.
   *
   * @param {Date} date 표시할 날짜
   * @returns {string} 날짜 문자열
   */
  function formatDateDotLabel(date) {
    const year = String(date.getUTCFullYear())
    const month = padTwo(date.getUTCMonth() + 1)
    const day = padTwo(date.getUTCDate())

    return year + '.' + month + '.' + day
  }

  /**
   * YYYY-MM-DD 값을 날짜로 바꿉니다.
   *
   * @param {string} value 날짜 값
   * @returns {Date|null} 날짜
   */
  function parseDateValue(value) {
    const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(value)

    if (!match) {
      return null
    }

    const year = Number(match[1])
    const month = Number(match[2])
    const day = Number(match[3])
    const date = new Date(Date.UTC(year, month - 1, day, 0, 0, 0, 0))

    if (date.getUTCFullYear() !== year || date.getUTCMonth() !== month - 1 || date.getUTCDate() !== day) {
      return null
    }

    return date
  }

  /**
   * 주차 이동 링크를 만듭니다.
   *
   * @param {Date} weekStart 주 시작 날짜
   * @returns {string} 이동 링크
   */
  function buildWeekHref(weekStart) {
    return '/reading-records?week=' + encodeURIComponent(formatDateLabel(weekStart))
  }

  /**
   * 시간을 짧은 한국어 문구로 표시합니다.
   *
   * @param {number} minutes 분
   * @returns {string} 표시 문구
   */
  function formatMinutesLabel(minutes) {
    const safeMinutes = Math.max(0, Math.round(minutes))
    const hours = Math.floor(safeMinutes / 60)
    const restMinutes = safeMinutes % 60

    if (hours > 0 && restMinutes > 0) {
      return hours + '시간 ' + restMinutes + '분'
    }

    if (hours > 0) {
      return hours + '시간'
    }

    return safeMinutes + '분'
  }

  /**
   * 누적 시간을 짧게 표시합니다.
   *
   * @param {number} minutes 분
   * @returns {string} 표시 문구
   */
  function formatTotalMinutesLabel(minutes) {
    const safeMinutes = Math.max(0, Math.round(minutes))
    const hours = Math.floor(safeMinutes / 60)

    if (hours >= 100) {
      return hours.toLocaleString('ko-KR') + '시간'
    }

    return formatMinutesLabel(safeMinutes)
  }

  const currentWeekStart = getWeekStart(now)
  const currentWeekKey = formatDateLabel(currentWeekStart)
  const requestedDate = parseDateValue(requestedWeekValue)
  let selectedWeekStart = requestedDate ? getWeekStart(requestedDate) : new Date(currentWeekStart.getTime())

  if (selectedWeekStart.getTime() > currentWeekStart.getTime()) {
    selectedWeekStart = new Date(currentWeekStart.getTime())
  }

  const previousWeekStart = new Date(selectedWeekStart.getTime())
  const nextWeekStart = new Date(selectedWeekStart.getTime())
  const periodStart = new Date(selectedWeekStart.getTime())
  const periodEnd = new Date(selectedWeekStart.getTime())

  previousWeekStart.setUTCDate(selectedWeekStart.getUTCDate() - 28)
  nextWeekStart.setUTCDate(selectedWeekStart.getUTCDate() + 28)
  periodStart.setUTCDate(selectedWeekStart.getUTCDate() - 21)
  periodEnd.setUTCDate(selectedWeekStart.getUTCDate() + 6)

  if (nextWeekStart.getTime() > currentWeekStart.getTime()) {
    nextWeekStart.setTime(currentWeekStart.getTime())
  }

  const isCurrentPeriod = selectedWeekStart.getTime() === currentWeekStart.getTime()
  const previousWeekHref = buildWeekHref(previousWeekStart)
  const nextWeekHref = buildWeekHref(nextWeekStart)
  const periodLabel = formatDateDotLabel(periodStart) + ' ~ ' + formatDateDotLabel(periodEnd)
  const weeklySecondsByKey = {}
  let totalSeconds = 0
  let currentWeekSeconds = 0
  let finishedBookCount = 0

  try {
    finishedBookCount = $app.countRecords(
      'book_shelves',
      $dbx.hashExp({
        user_id: userId,
        status: 'finished',
      })
    )
  } catch (exception) {
    finishedBookCount = 0
  }

  for (let weekIndex = 3; weekIndex >= 0; weekIndex -= 1) {
    const weekStart = new Date(selectedWeekStart.getTime())

    weekStart.setUTCDate(selectedWeekStart.getUTCDate() - weekIndex * 7)
    const weekEnd = new Date(weekStart.getTime())

    weekEnd.setUTCDate(weekStart.getUTCDate() + 6)

    const weekKey = formatDateLabel(weekStart)
    weeklySecondsByKey[weekKey] = 0
    weekItems.push({
      key: weekKey,
      label: formatDateLabel(weekStart).slice(5) + ' ~ ' + formatDateLabel(weekEnd).slice(5),
      minutes: 0,
      minutesLabel: '0분',
    })
  }

  for (let index = 0; index < sessionRecords.length; index += 1) {
    const sessionRecord = sessionRecords[index]
    const endedAtValue = String(sessionRecord.get('ended_at') || '').trim()
    const durationSeconds = Number(sessionRecord.get('duration_seconds') || 0)
    const endedAt = endedAtValue ? new Date(endedAtValue) : null

    if (!endedAt || isNaN(endedAt.getTime()) || isNaN(durationSeconds) || durationSeconds < 1) {
      continue
    }

    const weekKey = formatDateLabel(getWeekStart(endedAt))

    if (typeof weeklySecondsByKey[weekKey] === 'number') {
      weeklySecondsByKey[weekKey] += durationSeconds
    }

    if (weekKey === currentWeekKey) {
      currentWeekSeconds += durationSeconds
    }

    totalSeconds += durationSeconds
  }

  for (let index = 0; index < weekItems.length; index += 1) {
    const seconds = weeklySecondsByKey[weekItems[index].key] || 0
    const minutes = Math.round(seconds / 60)

    weekItems[index].minutes = minutes
    weekItems[index].minutesLabel = formatMinutesLabel(minutes)
  }

  const totalMinutes = Math.round(totalSeconds / 60)
  const totalMinutesLabel = formatTotalMinutesLabel(totalMinutes)
  const currentWeekMinutes = Math.round(currentWeekSeconds / 60)
</script>

<section class="space-y-6">
  <div class="space-y-3">
    <a
      href="/"
      class="bg-white/78 inline-flex items-center gap-2 rounded-full border-none px-3 py-2 text-sm font-medium text-stone-700 no-underline shadow-[0_10px_22px_rgba(70,52,31,0.08)] outline-none ring-0">
      <span
        class="i-lucide-arrow-left h-4 w-4"
        aria-hidden="true"></span>
      메인으로
    </a>
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-stone-950 sm:text-3xl">독서 기록</h1>
    </div>
  </div>

  <section class="bg-white/82 grid grid-cols-3 overflow-hidden rounded-[1.35rem] shadow-[inset_0_0_0_1px_rgba(120,93,63,0.08)] sm:gap-3 sm:overflow-visible sm:bg-transparent sm:shadow-none">
    <div class="min-w-0 px-3 py-3 sm:rounded-[1.5rem] sm:bg-white/80 sm:px-4 sm:py-4 sm:shadow-[inset_0_0_0_1px_rgba(120,93,63,0.08)]">
      <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-stone-500 sm:text-[11px] sm:tracking-[0.2em]">이번 주</p>
      <p class="mt-1 break-keep text-lg font-semibold tracking-tight text-stone-950 sm:mt-2 sm:text-2xl"><%= formatMinutesLabel(currentWeekMinutes) %></p>
    </div>
    <div class="min-w-0 border-x border-stone-200/70 px-3 py-3 sm:rounded-[1.5rem] sm:border-x-0 sm:bg-white/80 sm:px-4 sm:py-4 sm:shadow-[inset_0_0_0_1px_rgba(120,93,63,0.08)]">
      <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-stone-500 sm:text-[11px] sm:tracking-[0.2em]">누적</p>
      <p class="mt-1 break-keep text-lg font-semibold tracking-tight text-stone-950 sm:mt-2 sm:text-2xl"><%= totalMinutesLabel %></p>
    </div>
    <div class="min-w-0 px-3 py-3 sm:rounded-[1.5rem] sm:bg-white/80 sm:px-4 sm:py-4 sm:shadow-[inset_0_0_0_1px_rgba(120,93,63,0.08)]">
      <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-stone-500 sm:text-[11px] sm:tracking-[0.2em]">완독</p>
      <p class="mt-1 break-keep text-lg font-semibold tracking-tight text-stone-950 sm:mt-2 sm:text-2xl"><%= finishedBookCount %>권</p>
    </div>
  </section>

  <section class="rounded-[1.6rem] border border-stone-200/80 bg-white/80 p-4 shadow-[0_18px_45px_rgba(73,54,31,0.08)] backdrop-blur-sm sm:rounded-[2rem] sm:p-5">
    <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-lg font-semibold tracking-tight text-stone-950 sm:text-xl">주차별 독서 시간</h2>
      </div>
      <div class="flex w-full flex-col gap-2 sm:w-auto sm:items-end">
        <div class="flex min-w-0 items-center justify-between gap-2 sm:justify-end">
          <a
            href="<%= previousWeekHref %>"
            aria-label="이전 4주"
            class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#f5efe4] text-stone-700 no-underline shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)] outline-none ring-0">
            <span
              class="i-lucide-chevron-left h-4 w-4"
              aria-hidden="true"></span>
          </a>
          <p class="min-w-0 flex-1 text-center text-sm font-semibold tracking-tight text-stone-900 sm:min-w-[13.5rem]">
            <%= periodLabel %>
          </p>
          <% if (isCurrentPeriod) { %>
          <span
            aria-disabled="true"
            aria-label="다음 4주"
            class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-stone-100 text-stone-300 shadow-[inset_0_0_0_1px_rgba(120,113,108,0.12)]">
            <span
              class="i-lucide-chevron-right h-4 w-4"
              aria-hidden="true"></span>
          </span>
          <% } else { %>
          <a
            href="<%= nextWeekHref %>"
            aria-label="다음 4주"
            class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#f5efe4] text-stone-700 no-underline shadow-[inset_0_0_0_1px_rgba(118,87,52,0.1)] outline-none ring-0">
            <span
              class="i-lucide-chevron-right h-4 w-4"
              aria-hidden="true"></span>
          </a>
          <% } %>
        </div>
        <% if (!isCurrentPeriod) { %>
        <a
          href="/reading-records"
          class="self-center text-xs font-semibold text-stone-500 no-underline sm:self-auto">
          이번 주로 돌아가기
        </a>
        <% } %>
      </div>
    </div>

    <div class="space-y-2">
      <% for (let index = 0; index < weekItems.length; index += 1) { const item = weekItems[index] %>
      <div class="flex items-center justify-between gap-3 rounded-[1rem] bg-[#fbf7ef] px-3 py-2 text-sm shadow-[inset_0_0_0_1px_rgba(118,87,52,0.08)] sm:rounded-[1.1rem] sm:px-4 sm:py-3">
        <span class="font-medium text-stone-700"><%= item.label %></span>
        <span class="font-semibold text-stone-950"><%= item.minutesLabel %></span>
      </div>
      <% } %>
    </div>
  </section>
</section>
