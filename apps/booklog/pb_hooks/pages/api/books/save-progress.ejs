<script server>
  if (request.method !== 'POST') {
    response.json(405, {
      ok: false,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    response.json(401, {
      ok: false,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const form = body()
  const userId = String(request.auth.get('id') || '')
  const bookId = String(form.bookId || '').trim()
  const locator = String(form.locator || '').trim()
  const href = String(form.href || '').trim()
  const chapterLabel = String(form.chapterLabel || '').trim()
  const pageNumberRaw = String(form.pageNumber || '').trim()
  const progressPercentRaw = String(form.progressPercent || '').trim()
  const pageNumber = pageNumberRaw ? Number(pageNumberRaw) : null
  const progressPercent = progressPercentRaw ? Number(progressPercentRaw) : null

  dbg('api/books/save-progress:start', {
    userId: userId,
    bookId: bookId,
    hasLocator: !!locator,
    hasHref: !!href,
  })

  try {
    if (!bookId) throw new Error('책 정보가 필요합니다.')
    if (!locator && !href) throw new Error('저장할 읽기 위치가 없습니다.')

    const bookRecord = $app.findFirstRecordByFilter('books', 'id = {:bookId}', { bookId: bookId })
    let existingShelfRecord = null
    let bookFileRecord = null

    try {
      existingShelfRecord = $app.findFirstRecordByFilter('book_shelves', 'user_id = {:userId} && book_id = {:bookId}', {
        userId: userId,
        bookId: bookId,
      })
    } catch (exception) {
      existingShelfRecord = null
    }

    if (existingShelfRecord) {
      const shelfStatus = String(existingShelfRecord.get('status') || '').trim()

      if (shelfStatus !== 'finished' && shelfStatus !== 'reading') {
        existingShelfRecord.set('status', 'reading')
      }

      if (!String(existingShelfRecord.get('started_at') || '').trim()) {
        existingShelfRecord.set('started_at', new Date().toISOString().slice(0, 10))
      }

      existingShelfRecord.set('current_locator', locator)
      existingShelfRecord.set('current_href', href)
      existingShelfRecord.set('current_label', chapterLabel)
      existingShelfRecord.set('last_read_at', new Date().toISOString().slice(0, 10))

      if (pageNumber !== null && !isNaN(pageNumber)) {
        existingShelfRecord.set('current_page', pageNumber)
      }

      if (progressPercent !== null && !isNaN(progressPercent)) {
        existingShelfRecord.set('progress_percent', progressPercent)
      }

      $app.save(existingShelfRecord)

      info('api/books/save-progress:done', {
        userId: userId,
        bookId: bookId,
        shelfId: String(existingShelfRecord.get('id') || ''),
        hasLocator: !!locator,
      })

      response.json(200, {
        ok: true,
        message: '읽던 위치를 저장했습니다.',
        id: String(existingShelfRecord.get('id') || ''),
      })
      return
    } else {
      const shelfCollection = $app.findCollectionByNameOrId('book_shelves')
      const newShelfRecord = new Record(shelfCollection)

      newShelfRecord.set('user_id', userId)
      newShelfRecord.set('book_id', String(bookRecord.get('id') || ''))
      newShelfRecord.set('status', 'reading')

      try {
        bookFileRecord = $app.findFirstRecordByFilter('book_files', 'book_id = {:bookId}', { bookId: bookId })
      } catch (exception) {
        bookFileRecord = null
      }

      if (bookFileRecord) {
        newShelfRecord.set('book_file_id', String(bookFileRecord.get('id') || ''))
      }

      newShelfRecord.set('started_at', new Date().toISOString().slice(0, 10))
      newShelfRecord.set('current_locator', locator)
      newShelfRecord.set('current_href', href)
      newShelfRecord.set('current_label', chapterLabel)
      newShelfRecord.set('last_read_at', new Date().toISOString().slice(0, 10))

      if (pageNumber !== null && !isNaN(pageNumber)) {
        newShelfRecord.set('current_page', pageNumber)
      }

      if (progressPercent !== null && !isNaN(progressPercent)) {
        newShelfRecord.set('progress_percent', progressPercent)
      }

      $app.save(newShelfRecord)

      info('api/books/save-progress:done', {
        userId: userId,
        bookId: bookId,
        shelfId: String(newShelfRecord.get('id') || ''),
        hasLocator: !!locator,
      })

      response.json(200, {
        ok: true,
        message: '읽던 위치를 저장했습니다.',
        id: String(newShelfRecord.get('id') || ''),
      })
      return
    }
  } catch (exception) {
    const errorMessage = String(exception.message || exception)

    error('api/books/save-progress:failed', {
      userId: userId,
      bookId: bookId,
      error: errorMessage,
    })

    response.json(400, {
      ok: false,
      message: errorMessage || '읽던 위치 저장에 실패했습니다.',
    })
  }
</script>
