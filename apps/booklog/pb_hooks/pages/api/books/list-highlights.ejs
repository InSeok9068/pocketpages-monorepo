<script server>
  if (request.method !== 'POST') {
    response.json(405, {
      ok: false,
      message: '잘못된 요청입니다.',
    })
    return
  }

  if (!request.auth) {
    response.json(401, {
      ok: false,
      message: '로그인이 필요합니다.',
    })
    return
  }

  const form = body()
  const userId = String(request.auth.get('id') || '')
  const bookId = String(form.bookId || '').trim()
  const bookFileId = String(form.bookFileId || '').trim()

  dbg('api/books/list-highlights:start', {
    userId: userId,
    bookId: bookId,
    bookFileId: bookFileId,
  })

  /**
   * 레코드 값을 문자열로 정리합니다.
   *
   * @param {Record} record 원본 레코드
   * @param {string} fieldName 필드명
   * @returns {string} 표시 값
   */
  function readString(record, fieldName) {
    return String(record.get(fieldName) || '').trim()
  }

  try {
    if (!bookId) throw new Error('책 정보가 필요합니다.')

    const highlights = []

    $app.findFirstRecordByFilter('books', 'id = {:bookId}', { bookId: bookId })

    if (bookFileId) {
      const highlightRecords = $app.findRecordsByFilter('book_highlights', 'user_id = {:userId} && book_id = {:bookId} && file_id = {:bookFileId}', '-highlighted_at,-created', 100, 0, {
        userId: userId,
        bookId: bookId,
        bookFileId: bookFileId,
      })

      for (let index = 0; index < highlightRecords.length; index += 1) {
        const highlightRecord = highlightRecords[index]
        const pageValue = highlightRecord.get('page_number')

        highlights.push({
          id: readString(highlightRecord, 'id'),
          locator: readString(highlightRecord, 'locator'),
          href: readString(highlightRecord, 'href'),
          chapterLabel: readString(highlightRecord, 'chapter_label'),
          pageNumber: pageValue === null || typeof pageValue === 'undefined' ? '' : String(pageValue),
          quoteText: readString(highlightRecord, 'quote_text'),
          noteText: readString(highlightRecord, 'note_text'),
          highlightedAt: readString(highlightRecord, 'highlighted_at'),
        })
      }
    }

    info('api/books/list-highlights:done', {
      userId: userId,
      bookId: bookId,
      count: highlights.length,
    })

    response.json(200, {
      ok: true,
      highlights: highlights,
    })
  } catch (exception) {
    const errorMessage = String(exception.message || exception)

    error('api/books/list-highlights:failed', {
      userId: userId,
      bookId: bookId,
      error: errorMessage,
    })

    response.json(400, {
      ok: false,
      message: errorMessage || '문구를 불러오지 못했습니다.',
    })
  }
</script>
