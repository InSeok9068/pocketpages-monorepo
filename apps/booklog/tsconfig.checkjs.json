{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "target": "es6",
    "module": "commonjs",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "maxNodeModuleJsDepth": 0,
    "skipLibCheck": true
  },
  "include": ["pb_data/types.d.ts", "pocketpages-globals.d.ts", "types.d.ts", "pb_hooks/**/*.js"],
  "exclude": ["node_modules/**", "pb_hooks/pages/assets/**", "pb_hooks/pages/**/vendor/**"]
}
