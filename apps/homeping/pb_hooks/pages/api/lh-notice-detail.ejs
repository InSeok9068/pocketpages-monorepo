<script server>
  const applyhomeService = resolve('applyhome-service')

  if (request.method !== 'GET') {
    response.json(405, {
      ok: false,
      message: '잘못된 요청입니다.',
    })
    return
  }

  const apiKey = String(env('DATAGOKR_APIKEY') || '').trim()

  if (!apiKey) {
    response.json(500, {
      ok: false,
      message: 'DATAGOKR_APIKEY 환경변수가 필요합니다.',
    })
    return
  }

  const query = request.url.query
  const input = {
    panId: String(query.panId || '').trim(),
    splInfTpCd: String(query.splInfTpCd || '').trim(),
    ccrCnntSysDsCd: String(query.ccrCnntSysDsCd || '').trim(),
    uppAisTpCd: String(query.uppAisTpCd || '').trim(),
    aisTpCd: String(query.aisTpCd || '').trim(),
  }

  info('api/lh-notice-detail:start', {
    panId: input.panId,
    uppAisTpCd: input.uppAisTpCd,
    aisTpCd: input.aisTpCd,
  })

  try {
    const detail = applyhomeService.getLhNoticeDetail(
      {
        apiKey: apiKey,
      },
      input
    )

    response.header('Cache-Control', 'no-store')
    response.json(200, {
      ok: true,
      detail: detail,
    })
    return
  } catch (exception) {
    const message = String(exception && exception.message ? exception.message : exception)

    warn('api/lh-notice-detail:failed', {
      panId: input.panId,
      error: message,
    })

    response.json(400, {
      ok: false,
      message: message || 'LH 상세정보를 불러오지 못했습니다.',
    })
  }
</script>
