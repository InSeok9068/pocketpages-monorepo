<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1" />
    <title><%= meta('title') %></title>
    <meta
      name="description"
      content="<%= meta('description') %>" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="<%= asset('/assets/favicon.svg') %>" />
    <link
      rel="manifest"
      href="<%= asset('/assets/manifest.json') %>" />
    <meta
      name="theme-color"
      content="#f5f6f2" />
    <link
      rel="stylesheet"
      href="<%= asset('/assets/style.css') %>" />
    <script
      src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js"
      defer></script>
    <script>
      window.OneSignalDeferred = window.OneSignalDeferred || []
      OneSignalDeferred.push(async function (OneSignal) {
        await OneSignal.init({
          appId: '5bb6b0ff-fe97-4753-9ce8-508e6048a518',
        })
      })
    </script>
    <%- slots.head %>
  </head>

  <body>
    <main class="hp-shell"><%- slots.body || slot %></main>
    <script src="<%= asset('/assets/onesignal.js') %>"></script>
  </body>
</html>
